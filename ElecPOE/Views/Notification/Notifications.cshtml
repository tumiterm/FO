@model IReadOnlyList<ForekOnline.Domain.ViewModels.NotificationEventSummaryViewModel>
@{
    ViewData["Title"] = "Notifications";
    var total = Model?.Count ?? 0;
    var active = Model?.Count(n => n.IsActive) ?? 0;
    var inactive = total - active;
}

<style>
:root{
  --nt-dr:#320606;--nt-red:#b31217;--nt-orange:#ff7a18;
  --nt-grad:linear-gradient(95deg,#320606,#b31217 55%,#ff7a18);
  --nt-soft:#fff5f3;--nt-bg:#ffffff;--nt-bg-alt:#f6f8fa;
  --nt-border:#e1e4e8;--nt-border-alt:#d0d4d9;--nt-muted:#6b7280;
  --nt-radius:22px;
}
.page-shell{max-width:1400px;margin:0 auto;padding:1.4rem 1.1rem 3rem;}
.header-band{background:var(--nt-bg);border:1px solid var(--nt-border);border-radius:38px;padding:1.25rem 1.4rem 1.15rem;display:flex;flex-wrap:wrap;gap:1.2rem;align-items:center;position:relative;overflow:hidden;}
.header-band:before{content:'';position:absolute;inset:0;background:linear-gradient(130deg,#32060610,#b3121712,#ff7a1816);pointer-events:none;}
.h-icon{width:74px;height:74px;border-radius:26px;background:var(--nt-grad);display:flex;align-items:center;justify-content:center;font-size:2rem;color:#fff;box-shadow:0 12px 34px -14px rgba(179,18,23,.45);}
.header-band h1{margin:0;font-size:1.55rem;font-weight:600;letter-spacing:.6px;display:flex;align-items:center;gap:.65rem;}
.h-tag{font-size:.55rem;letter-spacing:.22rem;font-weight:700;text-transform:uppercase;background:var(--nt-soft);color:var(--nt-red);padding:.45rem .8rem;border-radius:40px;display:inline-flex;gap:.4rem;align-items:center;margin-top:.3rem;}
.actions{display:flex;gap:.55rem;margin-left:auto;flex-wrap:wrap;}
.btn-nt{font-size:.58rem;letter-spacing:.14rem;font-weight:600;text-transform:uppercase;padding:.55rem .9rem;border-radius:14px;border:1px solid var(--nt-border);background:#fff;color:var(--nt-red);display:inline-flex;align-items:center;gap:.45rem;text-decoration:none;transition:.3s;}
.btn-nt:hover{background:var(--nt-grad);color:#fff;border-color:var(--nt-red);box-shadow:0 6px 18px -10px rgba(179,18,23,.45);}
.btn-primary-nt{background:var(--nt-grad);color:#fff;border:1px solid var(--nt-red);}
.btn-primary-nt:hover{filter:brightness(.94);}
.metrics{margin-top:1.4rem;display:grid;gap:.9rem;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));}
.metric{background:var(--nt-bg);border:1px solid var(--nt-border);border-radius:28px;padding:.85rem .95rem .8rem;display:flex;flex-direction:column;gap:.4rem;position:relative;overflow:hidden;transition:.3s;}
.metric:before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 78% 18%,rgba(255,122,24,.2),transparent 62%);}
.metric:hover{border-color:var(--nt-border-alt);box-shadow:0 10px 24px -12px rgba(50,6,6,.25);transform:translateY(-4px);}
.metric small{font-size:.55rem;text-transform:uppercase;letter-spacing:.16rem;font-weight:700;color:var(--nt-muted);display:flex;align-items:center;gap:.4rem;}
.metric .value{font-size:1.5rem;font-weight:600;background:var(--nt-grad);-webkit-background-clip:text;color:transparent;line-height:1;}
.surface{margin-top:1.8rem;background:var(--nt-bg);border:1px solid var(--nt-border);border-radius:34px;padding:1.1rem 1rem 1.2rem;}
.surface h2{font-size:.75rem;text-transform:uppercase;letter-spacing:.22rem;font-weight:700;color:var(--nt-red);margin:0 0 1rem;display:flex;align-items:center;gap:.5rem;}
.table-modern{width:100%;border-collapse:separate;border-spacing:0;font-size:.68rem;}
.table-modern thead th{background:var(--nt-grad);color:#fff;font-size:.5rem;text-transform:uppercase;letter-spacing:.14rem;font-weight:700;padding:.5rem .6rem;position:sticky;top:0;z-index:4;}
.table-modern tbody td{padding:.5rem .65rem;border-top:1px solid var(--nt-border);background:#fff;vertical-align:middle;}
.table-modern tbody tr:nth-child(even){background:#fffdfd;}
.table-modern tbody tr:hover{background:#fff3ef;}
.order-input{width:70px;}
.status-chip{font-size:.5rem;font-weight:700;letter-spacing:.12rem;padding:.35rem .55rem;border-radius:30px;display:inline-flex;align-items:center;gap:.35rem;}
.status-active{background:#16a34a20;color:#15803d;}
.status-inactive{background:#64748b26;color:#475569;}
.reorder-bar{display:flex;align-items:center;gap:.6rem;margin-top:.85rem;flex-wrap:wrap;}
.helper{font-size:.55rem;color:var(--nt-muted);letter-spacing:.08rem;font-weight:600;}
.card-grid{margin-top:2rem;display:grid;gap:1rem;grid-template-columns:repeat(auto-fit,minmax(270px,1fr));}
.summary-card{background:#fff;border:1px solid var(--nt-border);border-radius:26px;padding:.9rem .85rem .8rem;display:flex;flex-direction:column;gap:.5rem;position:relative;overflow:hidden;transition:.35s;}
.summary-card:before{content:'';position:absolute;inset:0;background:linear-gradient(120deg,#32060608,#b312170a,#ff7a180d);}
.summary-card:hover{border-color:var(--nt-border-alt);box-shadow:0 8px 26px -10px rgba(50,6,6,.3);transform:translateY(-5px);}
.summary-title{font-size:.74rem;font-weight:700;letter-spacing:.4px;margin:0;display:flex;align-items:center;gap:.45rem;}
.summary-meta{font-size:.55rem;letter-spacing:.08rem;color:var(--nt-muted);display:flex;flex-wrap:wrap;gap:.4rem;}
.summary-actions{display:flex;gap:.45rem;margin-top:auto;flex-wrap:wrap;}
.badge-window{background:#fff;box-shadow:0 0 0 1px var(--nt-border) inset;font-size:.5rem;font-weight:600;letter-spacing:.1rem;padding:.32rem .6rem;border-radius:16px;color:var(--nt-red);}
.drag-handle{cursor:grab;font-size:.6rem;color:#b31217;padding:.2rem .35rem;border-radius:6px;background:#fff5f3;border:1px solid var(--nt-border);}
@@media (max-width:820px){.surface{overflow:auto;} .actions{margin-left:0;}}
</style>

<div class="page-shell">
    <div class="header-band">
        <div class="h-icon"><i class="fa fa-bell"></i></div>
        <div>
            <h1>Notifications</h1>
            <div class="h-tag"><i class="fa fa-layer-group"></i> EVENT STREAM</div>
        </div>
        <div class="actions">
            <a asp-action="Create" class="btn-primary-nt"><i class="fa fa-plus"></i> Create</a>
            <button type="button" class="btn-nt" id="btnScrollCards"><i class="fa fa-grid-2"></i> Cards</button>
        </div>
    </div>

    <div class="metrics">
        <div class="metric">
            <small>Total</small>
            <div class="value">@total</div>
            <span class="desc">items</span>
        </div>
        <div class="metric">
            <small>Active</small>
            <div class="value">@active</div>
            <span class="desc">enabled</span>
        </div>
        <div class="metric">
            <small>Inactive</small>
            <div class="value">@inactive</div>
            <span class="desc">disabled</span>
        </div>
        <div class="metric">
            <small>Reorder</small>
            <div class="value">@Model.Sum(m => m.DisplayOrder)</div>
            <span class="desc">order sum</span>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="surface">
            <h2><i class="fa fa-circle-info"></i> Status</h2>
            <div class="alert alert-info mb-0">No notifications found.</div>
        </div>
    }
    else
    {
        <div class="surface" id="listSurface">
            <h2><i class="fa fa-table"></i> Manage</h2>
            <form asp-action="Reorder" method="post" id="reorderForm">
                @Html.AntiForgeryToken()
                <div class="table-responsive">
                    <table class="table-modern">
                        <thead>
                        <tr>
                            <th style="width:60px;">Drag</th>
                            <th style="width:80px;">Order</th>
                            <th>Title</th>
                            <th>Status</th>
                            <th>Window</th>
                            <th style="width:230px;"></th>
                        </tr>
                        </thead>
                        <tbody id="notifyRows">
                        @foreach (var n in Model.OrderBy(m=>m.DisplayOrder))
                        {
                            <tr data-id="@n.Id">
                                <td class="text-center"><span class="drag-handle"><i class="fa fa-grip-lines"></i></span></td>
                                <td><input class="form-control form-control-sm order-input" name="orderMap[@n.Id]" value="@n.DisplayOrder" /></td>
                                <td>@n.Title</td>
                                <td>
                                    <span class="status-chip @(n.IsActive ? "status-active" : "status-inactive")">
                                        <i class="fa @(n.IsActive?"fa-check-circle":"fa-pause-circle")"></i>
                                        @(n.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td><small>@n.StartUtc.ToShortDateString() - @n.EndUtc.ToShortDateString()</small></td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@n.Id" class="btn btn-sm btn-outline-info"><i class="fa fa-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@n.Id" class="btn btn-sm btn-outline-primary"><i class="fa fa-pen"></i></a>
                                    @if (n.IsActive)
                                    {
                                        <form asp-action="Deactivate" asp-route-id="@n.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-warning"><i class="fa fa-ban"></i></button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Activate" asp-route-id="@n.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-success"><i class="fa fa-play"></i></button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
                <div class="reorder-bar">
                    <button type="submit" class="btn-nt"><i class="fa fa-arrows-rotate"></i> Apply Reorder</button>
                    <span class="helper"><i class="fa fa-info-circle"></i> You can drag rows; order inputs remain editable.</span>
                </div>
            </form>
        </div>

        <div class="card-grid" id="cardGrid">
            @foreach (var n in Model.OrderBy(m => m.DisplayOrder))
            {
                @await Html.PartialAsync("_SummaryCard", n)
            }
        </div>
    }
</div>

@section Scripts {
    <script>
    (function(){
        // Soft scroll to cards
        document.getElementById('btnScrollCards')?.addEventListener('click',()=> {
            document.getElementById('cardGrid')?.scrollIntoView({behavior:'smooth'});
        });

        // Drag & drop reorder (lightweight)
        const tbody = document.getElementById('notifyRows');
        if(tbody){
            let dragRow=null;
            tbody.querySelectorAll('.drag-handle').forEach(h=>{
                h.addEventListener('mousedown', e=>{
                    dragRow = h.closest('tr');
                    dragRow.style.opacity='.55';
                });
            });
            document.addEventListener('mouseup',()=>{
                if(dragRow){ dragRow.style.opacity='1'; dragRow=null; }
            });
            tbody.addEventListener('mousemove', e=>{
                if(!dragRow) return;
                const rows=[...tbody.querySelectorAll('tr')];
                const y=e.clientY;
                let nextRow=rows.find(r=>{
                    const rect=r.getBoundingClientRect();
                    return y<rect.bottom && y>rect.top && r!==dragRow;
                });
                if(nextRow){
                    const rect=nextRow.getBoundingClientRect();
                    const midpoint=rect.top + rect.height/2;
                    if(y<midpoint) tbody.insertBefore(dragRow,nextRow);
                    else tbody.insertBefore(dragRow,nextRow.nextSibling);
                }
            });
        }
    })();
    </script>
    <partial name="_ScriptsBlocks" />
}