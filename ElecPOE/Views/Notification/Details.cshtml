@model ForekOnline.Domain.ViewModels.NotificationEventSummaryViewModel
@{
    ViewData["Title"] = "Notification Details";
}
<style>
.detail-shell{max-width:1100px;margin:1.5rem auto 3rem;padding:1.1rem .95rem;}
.head-card{background:#fff;border:1px solid #e1e4e8;border-radius:30px;padding:1.1rem 1.2rem 1rem;display:flex;gap:1.1rem;align-items:flex-start;position:relative;overflow:hidden;}
.head-card:before{content:'';position:absolute;inset:0;background:linear-gradient(130deg,#32060610,#b3121710,#ff7a1815);pointer-events:none;}
.hc-icon{width:70px;height:70px;border-radius:24px;background:linear-gradient(95deg,#320606,#b31217 55%,#ff7a18);display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.8rem;box-shadow:0 10px 26px -12px rgba(179,18,23,.45);}
.head-card h2{margin:0;font-size:1.35rem;font-weight:600;letter-spacing:.5px;display:flex;align-items:center;gap:.6rem;}
.status-chip{font-size:.55rem;font-weight:700;letter-spacing:.12rem;padding:.4rem .7rem;border-radius:30px;display:inline-flex;align-items:center;gap:.35rem;margin-top:.4rem;color:#fff;}
.status-active{background:#15803d;}
.status-inactive{background:#64748b;}
.meta-line{font-size:.58rem;letter-spacing:.12rem;font-weight:600;color:#555;margin-top:.35rem;}
.img-wrap{margin:1.2rem 0;}
.block-surface{margin-top:1.2rem;background:#fff;border:1px solid #e1e4e8;border-radius:26px;padding:1rem .95rem .9rem;}
.block-surface h5{margin:0 0 .85rem;font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.18rem;color:#b31217;}
.actions{display:flex;gap:.55rem;margin-top:1.2rem;}
.btn-nt{font-size:.58rem;letter-spacing:.14rem;font-weight:600;text-transform:uppercase;padding:.55rem .9rem;border-radius:14px;border:1px solid #e1e4e8;background:#fff;color:#b31217;text-decoration:none;display:inline-flex;align-items:center;gap:.45rem;transition:.3s;}
.btn-nt:hover{background:linear-gradient(95deg,#320606,#b31217 55%,#ff7a18);color:#fff;border-color:#b31217;}
</style>

<div class="detail-shell">
    <div class="head-card">
        <div class="hc-icon"><i class="fa fa-bell"></i></div>
        <div style="flex:1;">
            <h2>
                @if(!string.IsNullOrEmpty(Model.HeaderIconCss)){<i class="@Model.HeaderIconCss"></i>}
                @Model.Title
            </h2>
            <span class="status-chip @(Model.IsActive ? "status-active" : "status-inactive")">
                <i class="fa @(Model.IsActive?"fa-check-circle":"fa-pause-circle")"></i>
                @(Model.IsActive ? "Active" : "Inactive")
            </span>
            <div class="meta-line">
                <i class="fa fa-clock"></i> Window: @Model.StartUtc:u → @Model.EndUtc:u
            </div>
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="img-wrap">
                    <img src="@Model.ImageUrl" alt="@Model.Title" class="img-fluid rounded shadow-sm" style="max-height:280px;object-fit:cover;" />
                </div>
            }
        </div>
    </div>

    <div class="block-surface">
        <h5><i class="fa fa-layer-group"></i> Content Blocks</h5>
        @if (!Model.Blocks.Any())
        {
            <div class="alert alert-info mb-0">No content blocks.</div>
        }
        else
        {
            @await Html.PartialAsync("_BlockList", Model.Blocks)
        }
    </div>

    <div class="actions">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-nt"><i class="fa fa-pen"></i> Edit</a>
        <a asp-action="Index" class="btn-nt"><i class="fa fa-arrow-left"></i> Back</a>
    </div>
</div>
