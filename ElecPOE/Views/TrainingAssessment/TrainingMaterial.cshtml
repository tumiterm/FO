@model dynamic
@using ForekOnline.Domain.Entities
@using static ForekOnline.Domain.Enums.EnumRegistry
@{
    ViewData["Title"] = "Training Material";
    string course = (string?)ViewData["course"] ?? "Course";
    string studentName = (string?)ViewData["name"] ?? "Student";
    var studentNumber = ViewData["StudentNumber"];
    var studentId = ViewData["StudentId"];
    var list = (IEnumerable<Training>?)Model?.MaterialList ?? Enumerable.Empty<Training>();

    int total = list.Count();
    int active = list.Count(m => m.IsActive);
    int inactive = total - active;
    int types = list.Select(m => m.Type).Distinct().Count();
    var last = list.OrderByDescending(m => m.CreatedOn).FirstOrDefault();
    bool canManage = User.IsInRole("Admin") || User.IsInRole("Facilitator");
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css"/>

<style>
:root{
  --tm-bg:#ffffff;--tm-bg-alt:#f6f8fa;--tm-border:#e2e6ea;--tm-border-strong:#c9d0d7;
  --tm-accent:#7d0e11;--tm-accent-grad:linear-gradient(120deg,#7d0e11,#b31217 55%,#ff7a18);
  --tm-soft:#fff5f3;--tm-text:#1f252c;--tm-green:#147a40;--tm-red:#b31217;
  --tm-radius-xl:34px;--tm-radius:22px;--tm-radius-sm:14px;
  --tm-focus:0 0 0 .15rem #b3121725;--tm-shadow:0 18px 48px -20px rgba(125,14,17,.28),0 8px 26px -14px rgba(125,14,17,.16);
  font-family:'Segoe UI',system-ui,sans-serif;
}
.page-shell{max-width:1450px;margin:0 auto;padding:1.9rem 1.15rem 3.1rem;}
.header-band{background:var(--tm-bg);border:1px solid var(--tm-border);border-radius:var(--tm-radius-xl);
  padding:1.35rem 1.6rem 1.25rem;display:flex;flex-wrap:wrap;gap:1.35rem;align-items:center;position:relative;overflow:hidden;}
.header-band:before{content:"";position:absolute;inset:0;background:linear-gradient(140deg,#7d0e1116,#b3121717,#ff7a1819);pointer-events:none;}
.icon-pill{width:86px;height:86px;border-radius:30px;background:var(--tm-accent-grad);display:flex;align-items:center;
  justify-content:center;font-size:2.2rem;color:#fff;box-shadow:0 14px 42px -18px rgba(179,18,23,.55);}
.header-band h1{margin:0;font-size:1.7rem;font-weight:600;letter-spacing:.55px;color:#222;display:flex;align-items:center;gap:.6rem;}
.tagline{font-size:.6rem;letter-spacing:.2rem;font-weight:700;background:var(--tm-soft);color:var(--tm-accent);padding:.55rem .9rem;border-radius:50px;text-transform:uppercase;display:inline-flex;gap:.5rem;align-items:center;}
.toolbar{margin-left:auto;display:flex;gap:.65rem;flex-wrap:wrap;}

.btn-base,.btn-accent,.btn-outline,.btn-danger-soft{
  font-size:.6rem;letter-spacing:.12rem;font-weight:600;text-transform:uppercase;
  padding:.66rem 1.15rem;border-radius:18px;border:1px solid var(--tm-border);
  background:#fff;color:var(--tm-accent);display:inline-flex;align-items:center;gap:.55rem;
  cursor:pointer;text-decoration:none;transition:.35s;
}
.btn-base:hover,.btn-outline:hover{background:var(--tm-accent-grad);color:#fff;border-color:var(--tm-accent);box-shadow:var(--tm-shadow);}
.btn-accent{background:var(--tm-accent-grad);color:#fff;border:1px solid var(--tm-accent);}
.btn-accent:hover{filter:brightness(.94);}
.btn-danger-soft{background:#ffe8ea;color:var(--tm-red);border:1px solid #f3c2c6;}
.btn-danger-soft:hover{background:var(--tm-accent-grad);color:#fff;border-color:var(--tm-accent);}

.layout{margin-top:1.55rem;display:grid;gap:1.55rem;grid-template-columns:350px 1fr;}
@@media (max-width:1150px){.layout{grid-template-columns:1fr;}}

.side-col{display:flex;flex-direction:column;gap:1.15rem;}
.panel-card{background:var(--tm-bg);border:1px solid var(--tm-border);border-radius:28px;padding:1.1rem 1.1rem .95rem;display:flex;flex-direction:column;gap:.85rem;position:relative;overflow:hidden;}
.panel-card:before{content:"";position:absolute;inset:0;background:linear-gradient(140deg,#7d0e110b,#b312170d,#ff7a180d);pointer-events:none;}
.panel-head{margin:0;font-size:.72rem;letter-spacing:.2rem;font-weight:700;color:var(--tm-accent);text-transform:uppercase;display:flex;align-items:center;gap:.45rem;}

.metrics-grid{display:grid;gap:.55rem;}
.metric-chip{background:#f6f8fa;border:1px solid var(--tm-border);border-radius:18px;padding:.55rem .65rem;display:flex;justify-content:space-between;align-items:center;gap:.8rem;font-size:.55rem;font-weight:600;letter-spacing:.08rem;color:#444;}
.metric-chip strong{font-size:.7rem;background:var(--tm-accent-grad);-webkit-background-clip:text;color:transparent;}

.progress-ring{--p:0;--size:72px;width:var(--size);height:var(--size);border-radius:50%;background:
  conic-gradient(var(--tm-accent) calc(var(--p)*1%),#e5e9ed 0);display:flex;align-items:center;justify-content:center;
  font-size:.65rem;font-weight:700;color:#222;position:relative;margin:.4rem auto 0;}
.progress-ring:after{content:"";position:absolute;inset:7px;background:#fff;border-radius:50%;}

.filter-box{display:flex;flex-wrap:wrap;gap:.55rem;}
.filter-box select,.filter-box input[type="text"]{
  flex:1 1 120px;min-width:120px;padding:.5rem .65rem;border:1px solid var(--tm-border);border-radius:14px;
  font-size:.65rem;background:#fff;transition:.25s;
}
.filter-box input:focus,.filter-box select:focus{outline:none;border-color:var(--tm-accent);box-shadow:var(--tm-focus);}

.main-card{background:var(--tm-bg);border:1px solid var(--tm-border);border-radius:32px;padding:1.25rem 1.25rem 1.1rem;display:flex;flex-direction:column;gap:1rem;position:relative;overflow:hidden;}
.main-card:before{content:"";position:absolute;inset:0;background:linear-gradient(145deg,#7d0e110c,#b312170d,#ff7a180e);pointer-events:none;}

.tabs{display:flex;gap:.55rem;flex-wrap:wrap;margin-bottom:.5rem;}
.tab-btn{background:#fff;border:1px solid var(--tm-border);color:var(--tm-accent);padding:.55rem 1rem;font-size:.55rem;font-weight:700;letter-spacing:.14rem;border-radius:16px;cursor:pointer;text-transform:uppercase;transition:.3s;}
.tab-btn.active,.tab-btn:hover{background:var(--tm-accent-grad);color:#fff;border-color:var(--tm-accent);box-shadow:0 6px 18px -8px rgba(179,18,23,.4);}

.form-grid{display:grid;gap:1rem;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));margin-top:.4rem;}
.field{display:flex;flex-direction:column;gap:.45rem;}
.field label{font-size:.5rem;letter-spacing:.15rem;text-transform:uppercase;font-weight:700;color:#4d5660;display:flex;align-items:center;gap:.4rem;}
.required:after{content:"*";color:var(--tm-red);margin-left:.25rem;font-weight:800;}
.input-wrap{display:flex;align-items:center;gap:.5rem;background:#fff;border:1px solid var(--tm-border);padding:.55rem .65rem;border-radius:14px;transition:.25s;}
.input-wrap:focus-within{border-color:var(--tm-accent);box-shadow:var(--tm-focus);}
.input-wrap i{font-size:.75rem;color:#888;}
.field select,.field input[type='text'],.field input[type='file']{border:none;background:transparent;width:100%;font-size:.68rem;outline:none;color:#222;}
small.note{font-size:.48rem;color:#777;font-weight:600;}

.table-meta{display:flex;flex-wrap:wrap;gap:.6rem;align-items:center;justify-content:space-between;font-size:.5rem;letter-spacing:.14rem;font-weight:700;color:#666;margin-bottom:.4rem;}
.action-line{display:flex;flex-wrap:wrap;gap:.5rem;}
.action-chip{font-size:.48rem;font-weight:600;letter-spacing:.08rem;padding:.4rem .6rem;border:1px solid var(--tm-border);border-radius:12px;background:#fff;cursor:pointer;display:inline-flex;align-items:center;gap:.3rem;color:var(--tm-accent);transition:.3s;text-decoration:none;}
.action-chip:hover{background:var(--tm-accent-grad);color:#fff;border-color:var(--tm-accent);box-shadow:0 4px 12px -6px rgba(179,18,23,.45);}

.material-table{width:100%;border-collapse:separate;border-spacing:0;font-size:.64rem;}
.material-table thead th{background:var(--tm-accent-grad);color:#fff;font-size:.52rem;letter-spacing:.16rem;padding:.55rem .55rem;text-transform:uppercase;font-weight:700;position:sticky;top:0;z-index:3;}
.material-table tbody tr{transition:.2s;}
.material-table tbody tr:nth-child(even){background:#fff;}
.material-table tbody tr:nth-child(odd){background:#fffdfd;}
.material-table tbody tr:hover{background:#fff4ef;}
.material-table td{padding:.5rem .55rem;border-bottom:1px solid var(--tm-border);vertical-align:middle;color:#333;}

.inline-badge{background:#eef3f7;color:#173a51;border:1px solid #d3dde4;padding:.3rem .55rem;border-radius:30px;font-size:.46rem;font-weight:700;letter-spacing:.08rem;display:inline-flex;align-items:center;gap:.3rem;}
.badge-state{font-size:.46rem;font-weight:700;letter-spacing:.08rem;padding:.28rem .55rem;border-radius:24px;display:inline-flex;align-items:center;gap:.3rem;}
.state-active{background:#e6f9ed;color:var(--tm-green);border:1px solid #b8e7c8;}
.state-inactive{background:#ffe9ed;color:var(--tm-red);border:1px solid #f3b4ba;}
.no-file{opacity:.45;cursor:not-allowed;}
.hidden-row{display:none!important;}
.empty-row{font-style:italic;color:#777;text-align:center;}

.remove-link{color:var(--tm-red);text-decoration:none;}
.remove-link:hover{text-decoration:underline;}
.download-link{text-decoration:none;}
.download-link:hover{text-decoration:underline;}

.select2-container .select2-selection--single{
  min-height:42px;border:1px solid var(--tm-border)!important;border-radius:14px!important;
}
.select2-selection__rendered{line-height:40px!important;font-size:.68rem!important;padding-left:.55rem!important;}
.select2-selection__arrow{height:42px!important;}

.fade-in{animation:fade .55s ease;}
@@keyframes fade{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
@@media (max-width:780px){
 .material-table thead th:nth-child(3),.material-table td:nth-child(3){display:none;}
}
@@media (max-width:620px){
 .material-table thead th:nth-child(4),.material-table td:nth-child(4){display:none;}
}
</style>

<div class="page-shell fade-in">
  <div class="header-band">
    <div class="icon-pill"><i class="fa fa-file-lines"></i></div>
    <div>
      <h1>Training Material</h1>
      <div class="tagline"><i class="fa fa-graduation-cap"></i> @studentName • @course</div>
    </div>
    <div class="toolbar">
      <a asp-action="StudentDetail" asp-controller="Student" asp-route-StudentNumber="@studentNumber" class="btn-base"><i class="fa fa-arrow-left"></i> Back</a>
      <button id="btnExport" type="button" class="btn-outline"><i class="fa fa-file-export"></i> Export</button>
      <button id="btnRefresh" type="button" class="btn-outline"><i class="fa fa-rotate"></i> Refresh</button>
    </div>
  </div>

  <div class="layout">
    <div class="side-col">
      <div class="panel-card">
        <h2 class="panel-head"><i class="fa fa-chart-simple"></i> Overview</h2>
        <div class="metrics-grid">
          <div class="metric-chip"><span>Total</span><strong>@total</strong></div>
            <div class="metric-chip"><span>Active</span><strong>@active</strong></div>
            <div class="metric-chip"><span>Inactive</span><strong>@inactive</strong></div>
            <div class="metric-chip"><span>Types</span><strong>@types</strong></div>
            <div class="metric-chip"><span>Last</span><strong>@(last?.CreatedOn?.ToString() ?? "-")</strong></div>
        </div>
        @{
           double activePct = total==0 ? 0 : (double)active/total*100;
        }
        <div class="progress-ring" style="--p:@activePct">@activePct.ToString("0")%</div>
        <small style="font-size:.48rem;color:#666;text-align:center;">Ring = % Active</small>
      </div>

      <div class="panel-card">
        <h2 class="panel-head"><i class="fa fa-filter"></i> Filters</h2>
        <div class="filter-box">
          <input type="text" id="searchBox" placeholder="Search type / user..." aria-label="Search"/>
          <select id="typeFilter" aria-label="Type Filter">
            <option value="">Type</option>
            @foreach(var t in Enum.GetValues(typeof(eTrainingAdministration)).Cast<eTrainingAdministration>()) {
              <option value="@t">@t</option>
            }
          </select>
          <select id="activeFilter" aria-label="Active Filter">
            <option value="">Status</option>
            <option value="1">Active</option>
            <option value="0">Inactive</option>
          </select>
          <select id="sortFilter" aria-label="Sort Filter">
            <option value="new">Newest</option>
            <option value="old">Oldest</option>
            <option value="type">Type</option>
            <option value="by">By</option>
            <option value="state">Status</option>
          </select>
        </div>
        <small style="font-size:.48rem;color:#666;margin-top:.4rem;display:block;">Export respects current filters.</small>
      </div>

      @if (canManage)
      {
        <div class="panel-card">
          <h2 class="panel-head"><i class="fa fa-lightbulb"></i> Tips</h2>
          <small style="font-size:.5rem;line-height:1.3;color:#555;">
            1. Only PDF uploads (1MB limit).<br/>
            2. Mark inactive by replacing file with new revision & toggle on backend if needed.<br/>
            3. Remove cautiously – permanent.<br/>
            4. Use filters to locate duplicates before deletion.
          </small>
        </div>
      }
    </div>

    <div class="main-card">
      <div class="tabs">
        @if (canManage)
        {
          <button class="tab-btn active" data-tab="uploadTab"><i class="fa fa-upload"></i> Upload</button>
        }
        <button class="tab-btn @(canManage? "" : "active")" data-tab="listTab"><i class="fa fa-table"></i> List</button>
      </div>

      @if (canManage)
      {
        <div id="uploadTab" class="tab-pane" style="display:block;">
          <form asp-action="TrainingMaterial" method="post" enctype="multipart/form-data" novalidate autocomplete="off">
            @Html.AntiForgeryToken()
            <input type="hidden" name="StudentNumber" value="@studentNumber"/>
            <input type="hidden" name="StudentId" value="@studentId"/>

            <div class="form-grid">
              <div class="field">
                <label class="required">Document Type</label>
                <div class="input-wrap">
                  <i class="fa fa-file-alt"></i>
                  <select name="Type" required asp-items="Html.GetEnumSelectList<eTrainingAdministration>()">
                    <option value="">Select type...</option>
                  </select>
                </div>
              </div>

              <div class="field">
                <label class="required">Document (PDF)</label>
                <div class="input-wrap">
                  <i class="fa fa-file-pdf"></i>
                  <input id="documentFileInput" name="DocumentFile" type="file" required accept="application/pdf"/>
                </div>
                <small id="fileInfo" class="note">Max 1MB • PDF only</small>
              </div>
            </div>

            <div class="action-line" style="margin-top:.6rem;">
              <button type="submit" class="btn-accent"><i class="fa fa-save"></i> Save</button>
              <button type="reset" class="btn-outline" id="resetUpload"><i class="fa fa-undo"></i> Reset</button>
            </div>
          </form>
        </div>
      }

      <div id="listTab" class="tab-pane" style="display:@(canManage? "none":"block")">
        <div class="table-meta">
          <span id="rowsInfo" class="inline-badge"><i class="fa fa-database"></i> Loading...</span>
          <span id="perfInfo" class="inline-badge" style="background:#fff7f6;"></span>
        </div>
        <div style="overflow:auto;">
          <table class="material-table" id="materialTable">
            <thead>
              <tr>
                <th style="min-width:110px;">Actions</th>
                <th>Type</th>
                <th>By</th>
                <th>Date</th>
                <th>Status</th>
                <th>File</th>
              </tr>
            </thead>
            <tbody id="materialBody">
            @if(!list.Any())
            {
              <tr><td colspan="6" class="empty-row">No training material uploaded.</td></tr>
            }
            else
            {
              foreach(var m in list)
              {
                var isActive = m.IsActive;
                <tr data-type="@m.Type"
                    data-by="@m.CreatedBy"
                    data-active="@(isActive ? "1":"0")"
                    data-date="@m.CreatedOn"
                    data-text="@($"{m.Type} {m.CreatedBy} {m.CreatedOn} {(isActive?"active":"inactive")}".ToLower())">
                  <td style="white-space:nowrap;">
                    @if (canManage)
                    {
                      <a class="action-chip remove-link act-remove" data-id="@m.TrainingId" title="Remove"><i class="fa fa-trash"></i></a>
                    }
                    else
                    {
                      <span class="action-chip" style="opacity:.4;cursor:not-allowed;"><i class="fa fa-ban"></i> N/A</span>
                    }
                  </td>
                  <td><span class="inline-badge"><i class="fa fa-file-pdf"></i> @m.Type</span></td>
                  <td>@m.CreatedBy</td>
                  <td>@m.CreatedOn</td>
                  <td>
                    <span class="badge-state @(isActive?"state-active":"state-inactive")">
                      <i class="fa @(isActive?"fa-check-circle":"fa-times-circle")"></i> @(isActive?"ACTIVE":"INACTIVE")
                    </span>
                  </td>
                  <td>
                    @if (string.IsNullOrEmpty(m.Document))
                    {
                      <span class="action-chip no-file"><i class="fa fa-ban"></i></span>
                    }
                    else
                    {
                      <a class="action-chip download-link" href="@Url.Action("AttachmentDownload","TrainingAssessment", new { fileId = m.Document })" title="Download">
                        <i class="fa fa-download"></i>
                      </a>
                    }
                  </td>
                </tr>
              }
            }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
(function($){
  $('.tab-btn').on('click', function(){
     const tab=$(this).data('tab');
     $('.tab-btn').removeClass('active');
     $(this).addClass('active');
     $('.tab-pane').hide();
     $('#'+tab).show();
  });

  const fileInput=document.getElementById('documentFileInput');
  const fileInfo=document.getElementById('fileInfo');
  const MAX=1*1024*1024;
  fileInput?.addEventListener('change', function(){
     const f=this.files[0];
     if(!f){ fileInfo.textContent='Max 1MB • PDF only'; return; }
     if(f.type!=='application/pdf'){ alert('Only PDF allowed'); this.value=''; fileInfo.textContent='Max 1MB • PDF only'; return; }
     if(f.size>MAX){ alert('File exceeds 1MB limit'); this.value=''; fileInfo.textContent='Max 1MB • PDF only'; return; }
     fileInfo.textContent=f.name+' ('+(f.size/1024).toFixed(0)+' KB)';
  });
  $('#resetUpload').on('click', ()=> setTimeout(()=> fileInfo.textContent='Max 1MB • PDF only',0));

  const body=document.getElementById('materialBody');
  const rowsInfo=document.getElementById('rowsInfo');
  const perfInfo=document.getElementById('perfInfo');
  const searchBox=document.getElementById('searchBox');
  const typeFilter=document.getElementById('typeFilter');
  const activeFilter=document.getElementById('activeFilter');
  const sortFilter=document.getElementById('sortFilter');

  function norm(v){return (v||'').toString().toLowerCase().trim();}

  function applyFilters(){
     if(!body)return;
     const t0=performance.now();
     const q=norm(searchBox.value);
     const tp=typeFilter.value;
     const aF=activeFilter.value;
     const sort=sortFilter.value;
     const rows=[...body.querySelectorAll('tr')];
     let visible=[];
     let total=0;
     rows.forEach(r=>{
        if(r.classList.contains('empty-row')) return;
        total++;
        const txt=r.getAttribute('data-text')||'';
        const dType=r.getAttribute('data-type')||'';
        const dActive=r.getAttribute('data-active')||'';
        let show=true;
        if(q && !txt.includes(q)) show=false;
        if(tp && dType!==tp) show=false;
        if(aF && dActive!==aF) show=false;
        r.classList.toggle('hidden-row', !show);
        if(show) visible.push(r);
     });
     const comp={
        'new':(a,b)=> b.rowIndex - a.rowIndex,
        'old':(a,b)=> a.rowIndex - b.rowIndex,
        'type':(a,b)=>(a.getAttribute('data-type')||'').localeCompare(b.getAttribute('data-type')||''),
        'by':(a,b)=>(a.getAttribute('data-text')||'').localeCompare(b.getAttribute('data-text')||''),
        'state':(a,b)=>(a.getAttribute('data-active')||'').localeCompare(b.getAttribute('data-active')||'')
     }[sort] || (()=>0);
     visible.sort(comp);
     visible.forEach(v=>body.appendChild(v));

     rowsInfo.innerHTML=`<i class="fa fa-database"></i> Showing ${visible.length} of ${total} item(s)` + ((q||tp||aF||sort!=='new')?' (filtered)':'');
     perfInfo.textContent='Render '+(performance.now()-t0).toFixed(1)+'ms';
  }
  [searchBox,typeFilter,activeFilter,sortFilter].forEach(el=>{
     el?.addEventListener(el.tagName==='INPUT'?'input':'change', applyFilters);
  });
  applyFilters();

  $('#btnExport').on('click', ()=>{
    if(!body)return;
    const visible=[...body.querySelectorAll('tr:not(.hidden-row)')].filter(r=>!r.classList.contains('empty-row'));
    if(!visible.length){ alert('No rows to export.'); return; }
    const lines=['Type,By,Date,Status,File'];
    visible.forEach(r=>{
       const c=r.querySelectorAll('td');
       const type=c[1].innerText.trim();
       const by=c[2].innerText.trim();
       const date=c[3].innerText.trim();
       const status=c[4].innerText.replace(/\s+/g,' ').trim();
       const file=c[5].innerText.trim();
       lines.push([type,by,date,status,file].map(v=>'"'+v.replace(/"/g,'""')+'"').join(','));
    });
    const blob=new Blob([lines.join('\r\n')],{type:'text/csv;charset=utf-8;'});
    const a=document.createElement('a'); a.href=URL.createObjectURL(blob);
    a.download='training-material-'+new Date().toISOString().slice(0,10)+'.csv';
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
  });

  $('#btnRefresh').on('click',()=>location.reload());

  $(document).on('click','.act-remove', function(e){
     e.preventDefault();
     const id=$(this).data('id');
     if(!confirm('Remove this training material? This cannot be undone.')) return;
     window.location.href='/TrainingAssessment/RemoveDocument?AttachmentId='+id;
  });

  document.addEventListener('keydown', e=>{
     if(e.key==='/' && document.activeElement.tagName!=='INPUT' && document.activeElement.tagName!=='TEXTAREA'){
        e.preventDefault();
        searchBox.focus();
     }
  });

  $('select[name="Type"]').select2({ width:'100%' });

})(jQuery);
</script>
