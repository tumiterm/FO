@using ForekOnline.Domain.Entities
@model ApplicationCycle

@{
    ViewData["Title"] = "Configure Application Cycle";

    var success = TempData["success"] as string;
    var error = TempData["error"] as string;

    var periodOptions = new[]
    {
        new { Value = "Intake", Icon = "fa-layer-group", Title = "Intake", Sub = "Short intake window" },
        new { Value = "Semester", Icon = "fa-calendar-alt", Title = "Semester", Sub = "Half-year period" },
        new { Value = "Trimester", Icon = "fa-calendar-week", Title = "Trimester", Sub = "Three terms / year" }
    };

    var activeOptions = new[]
    {
        new { Value = "true", Icon = "fa-bolt", Title = "Active", Sub = "Accept applications" },
        new { Value = "false", Icon = "fa-circle-pause", Title = "Inactive", Sub = "Draft / planned" }
    };
}

<style>
    :root {
        --ac-bg: #ffffff;
        --ac-bg-2: #f6f8fb;
        --ac-text: #1e2430;
        --ac-muted: #6b7484;
        --ac-border: #e4e8ef;
        --ac-card: #ffffff;
        --ac-shadow: 0 18px 45px -28px rgba(16,24,40,.35);
        --ac-shadow-soft: 0 10px 30px -22px rgba(16,24,40,.28);
        --ac-radius: 22px;
        --ac-accent: #b31217;
        --ac-accent-2: #ff7a18;
        --ac-grad: linear-gradient(95deg,#320606 0%,#b31217 55%,#ff7a18 105%);
        --ac-focus: 0 0 0 .22rem rgba(179,18,23,.18);
    }

    .ac-shell {
        max-width: 1180px;
        margin: 0 auto;
        padding: 2.2rem 1.2rem 3.5rem;
    }

    .ac-hero {
        position: relative;
        background: var(--ac-card);
        border: 1px solid var(--ac-border);
        border-radius: calc(var(--ac-radius) + 10px);
        box-shadow: var(--ac-shadow);
        padding: 1.6rem 1.7rem 1.35rem;
        overflow: hidden;
    }

        .ac-hero:before {
            content: "";
            position: absolute;
            inset: 0;
            background: var(--ac-grad);
            opacity: .12;
            pointer-events: none;
        }

    .ac-hero-grid {
        display: flex;
        gap: 1.15rem;
        align-items: flex-start;
        position: relative;
    }

    .ac-hero-icon {
        width: 62px;
        height: 62px;
        border-radius: 18px;
        background: var(--ac-grad);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.45rem;
        box-shadow: 0 14px 30px -18px rgba(179,18,23,.55);
        flex: 0 0 auto;
    }

    .ac-hero h1 {
        margin: 0;
        font-size: 1.25rem;
        font-weight: 800;
        letter-spacing: .06rem;
        color: var(--ac-text);
    }

    .ac-hero p {
        margin: .4rem 0 0;
        color: var(--ac-muted);
        font-weight: 600;
        font-size: .78rem;
        max-width: 820px;
        line-height: 1.25rem;
    }

    .ac-grid {
        display: grid;
        gap: 1.15rem;
        margin-top: 1.15rem;
        grid-template-columns: 1.2fr .8fr;
    }
    @@media (max-width: 980px) {
        .ac-grid

    {
        grid-template-columns: 1fr;
    }

    }

    .ac-card {
        background: var(--ac-card);
        border: 1px solid var(--ac-border);
        border-radius: var(--ac-radius);
        box-shadow: var(--ac-shadow-soft);
        padding: 1.1rem 1.15rem;
    }

    .ac-card-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .8rem;
        margin-bottom: .75rem;
    }

        .ac-card-title h2 {
            margin: 0;
            color: var(--ac-text);
            font-size: .85rem;
            font-weight: 900;
            letter-spacing: .14rem;
            text-transform: uppercase;
            display: flex;
            align-items: center;
            gap: .5rem;
        }

    .ac-chip {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        padding: .42rem .65rem;
        border-radius: 999px;
        border: 1px solid var(--ac-border);
        background: linear-gradient(135deg, rgba(179,18,23,.04), rgba(255,122,24,.06));
        color: var(--ac-accent);
        font-weight: 800;
        font-size: .58rem;
        letter-spacing: .12rem;
        text-transform: uppercase;
    }

    .ac-form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .ac-row {
        display: grid;
        gap: .9rem;
        grid-template-columns: repeat(2, minmax(0,1fr));
    }
    @@media (max-width: 720px) {
        .ac-row

    {
        grid-template-columns: 1fr;
    }

    }

    .ac-input {
        display: flex;
        flex-direction: column;
        gap: .45rem;
    }

    .ac-label {
        font-size: .6rem;
        letter-spacing: .16rem;
        text-transform: uppercase;
        font-weight: 900;
        color: #465062;
    }

    .ac-textbox {
        display: flex;
        align-items: center;
        gap: .55rem;
        border: 1px solid var(--ac-border);
        border-radius: 16px;
        background: #fff;
        padding: .7rem .8rem;
        transition: .2s;
    }

        .ac-textbox:focus-within {
            border-color: var(--ac-accent);
            box-shadow: var(--ac-focus);
        }

        .ac-textbox i {
            color: #97a0af;
            font-size: .85rem;
        }

        .ac-textbox input, .ac-textbox textarea {
            border: none;
            outline: none;
            background: transparent;
            width: 100%;
            font-size: .82rem;
            color: var(--ac-text);
        }

        .ac-textbox textarea {
            min-height: 84px;
            resize: vertical;
        }

    .ac-select-grid {
        display: grid;
        gap: .75rem;
        grid-template-columns: repeat(3, minmax(0,1fr));
    }
    @@media (max-width: 720px) {
        .ac-select-grid

    {
        grid-template-columns: 1fr;
    }

    }

    .ac-option {
        position: relative;
        border: 1px solid var(--ac-border);
        border-radius: 18px;
        background: var(--ac-bg);
        padding: .9rem .95rem;
        cursor: pointer;
        transition: .18s ease;
        display: flex;
        gap: .8rem;
        align-items: flex-start;
        user-select: none;
    }

        .ac-option:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 30px -24px rgba(16,24,40,.35);
        }

        .ac-option .ic {
            width: 38px;
            height: 38px;
            border-radius: 14px;
            background: linear-gradient(135deg, rgba(179,18,23,.09), rgba(255,122,24,.12));
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--ac-accent);
            font-size: 1rem;
            flex: 0 0 auto;
        }

        .ac-option strong {
            display: block;
            color: var(--ac-text);
            font-weight: 900;
            font-size: .78rem;
            letter-spacing: .04rem;
        }

        .ac-option span {
            display: block;
            color: var(--ac-muted);
            font-size: .68rem;
            font-weight: 600;
            margin-top: .18rem;
            line-height: 1.05rem;
        }

    .ac-check {
        position: absolute;
        top: .55rem;
        right: .55rem;
        width: 22px;
        height: 22px;
        border-radius: 999px;
        border: 1px solid var(--ac-border);
        display: flex;
        align-items: center;
        justify-content: center;
        color: transparent;
        background: #fff;
        transition: .18s ease;
    }

    .ac-option.selected {
        border-color: rgba(179,18,23,.55);
        box-shadow: 0 18px 38px -28px rgba(179,18,23,.42);
    }

        .ac-option.selected .ac-check {
            background: var(--ac-accent);
            border-color: var(--ac-accent);
            color: #fff;
        }

    .ac-actions {
        display: flex;
        gap: .6rem;
        flex-wrap: wrap;
        margin-top: .15rem;
    }

    .ac-btn {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        text-decoration: none;
        border-radius: 16px;
        padding: .65rem 1rem;
        border: 1px solid var(--ac-border);
        background: #fff;
        color: var(--ac-accent);
        font-weight: 900;
        font-size: .62rem;
        letter-spacing: .14rem;
        text-transform: uppercase;
        transition: .2s;
        cursor: pointer;
    }

        .ac-btn:hover {
            background: var(--ac-grad);
            color: #fff;
            border-color: var(--ac-accent);
        }

        .ac-btn.primary {
            background: var(--ac-grad);
            color: #fff;
            border-color: var(--ac-accent);
        }

            .ac-btn.primary:hover {
                filter: brightness(.97);
            }

    .ac-note {
        color: var(--ac-muted);
        font-weight: 600;
        font-size: .68rem;
        line-height: 1.05rem;
        margin: 0;
    }

    .ac-status {
        border: 1px solid var(--ac-border);
        border-radius: 18px;
        padding: .75rem .85rem;
        background: var(--ac-bg);
        display: flex;
        gap: .75rem;
        align-items: flex-start;
    }

        .ac-status .dot {
            width: 12px;
            height: 12px;
            border-radius: 999px;
            margin-top: .25rem;
            background: #c9d2df;
        }

        .ac-status.ok .dot {
            background: #22c55e;
        }

        .ac-status.err .dot {
            background: #ef4444;
        }

        .ac-status strong {
            display: block;
            font-size: .72rem;
            font-weight: 900;
            color: var(--ac-text);
            letter-spacing: .04rem;
        }

        .ac-status span {
            display: block;
            color: var(--ac-muted);
            font-size: .68rem;
            font-weight: 600;
            margin-top: .15rem;
            line-height: 1.05rem;
        }

    .ac-summary {
        display: flex;
        flex-direction: column;
        gap: .85rem;
    }

    .ac-kv {
        border: 1px dashed var(--ac-border);
        border-radius: 18px;
        padding: .85rem .9rem;
        background: linear-gradient(135deg, rgba(246,248,251,.9), rgba(255,255,255,.9));
    }

        .ac-kv .k {
            font-size: .58rem;
            letter-spacing: .16rem;
            text-transform: uppercase;
            font-weight: 900;
            color: #465062;
        }

        .ac-kv .v {
            margin-top: .35rem;
            font-weight: 900;
            color: var(--ac-text);
            font-size: .85rem;
        }

        .ac-kv .s {
            margin-top: .25rem;
            color: var(--ac-muted);
            font-weight: 600;
            font-size: .68rem;
            line-height: 1.05rem;
        }

    .ac-edit {
        border: none;
        background: transparent;
        color: var(--ac-accent);
        font-weight: 900;
        cursor: pointer;
        font-size: .72rem;
        padding: .25rem .35rem;
    }
</style>

<section class="ac-shell">

    <header class="ac-hero">
        <div class="ac-hero-grid">
            <div class="ac-hero-icon"><i class="fa fa-calendar-check"></i></div>
            <div style="flex:1;">
                <h1>Configure Application Cycle</h1>
                <p>
                    Create an application intake window using selection-based controls and minimal typing.
                    Cycles are validated for overlap and active-cycle uniqueness.
                </p>
            </div>
        </div>
    </header>

    <div class="ac-grid">
        <!-- LEFT: Capture -->
        <div class="ac-card">
            <div class="ac-card-title">
                <h2><i class="fa fa-sliders-h"></i> Cycle Setup</h2>
                <span class="ac-chip"><i class="fa fa-shield-check"></i> Validated</span>
            </div>

            @if (!string.IsNullOrWhiteSpace(error))
            {
                <div class="ac-status err" style="margin-bottom:.85rem;">
                    <div class="dot"></div>
                    <div>
                        <strong>Could not save</strong>
                        <span>@error</span>
                    </div>
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(success))
            {
                <div class="ac-status ok" style="margin-bottom:.85rem;">
                    <div class="dot"></div>
                    <div>
                        <strong>Saved</strong>
                        <span>@success</span>
                    </div>
                </div>
            }
            else
            {
                <div class="ac-status" style="margin-bottom:.85rem;">
                    <div class="dot"></div>
                    <div>
                        <strong>Draft</strong>
                        <span>Choose a period, set dates, and mark it active only when ready.</span>
                    </div>
                </div>
            }

            <form class="ac-form" asp-action="ConfigureApplicationCycle" asp-controller="OnlineApplications" method="post" autocomplete="off">
                @Html.AntiForgeryToken()

                <!-- Minimal typing section -->
                <div class="ac-row">
                    <div class="ac-input">
                        <div class="ac-label">Cycle Name</div>
                        <div class="ac-textbox">
                            <i class="fa fa-pen"></i>
                            <input asp-for="Name" placeholder="e.g., 2026 Intake 1" />
                        </div>
                        <p class="ac-note">Optional. If blank, a default name is generated from year + period.</p>
                    </div>

                    <div class="ac-input">
                        <div class="ac-label">Academic Year</div>
                        <div class="ac-textbox">
                            <i class="fa fa-hashtag"></i>
                            <input asp-for="AcademicYear" type="number" min="2000" max="2100" placeholder="e.g., 2026" required />
                        </div>
                    </div>
                </div>

                <div class="ac-input">
                    <div class="ac-label">Application Period</div>
                    <div class="ac-select-grid" id="periodOptions">
                        @foreach (var opt in periodOptions)
                        {
                            <div class="ac-option" data-target="ApplicationPeriod" data-value="@opt.Value" role="button" tabindex="0">
                                <div class="ic"><i class="fa @opt.Icon"></i></div>
                                <div>
                                    <strong>@opt.Title</strong>
                                    <span>@opt.Sub</span>
                                </div>
                                <div class="ac-check"><i class="fa fa-check"></i></div>
                            </div>
                        }
                    </div>
                    <input asp-for="ApplicationPeriod" type="hidden" />
                </div>

                <div class="ac-row">
                    <div class="ac-input">
                        <div class="ac-label">Opens At</div>
                        <div class="ac-textbox">
                            <i class="fa fa-door-open"></i>
                            <input asp-for="OpensAt" type="datetime-local" required />
                        </div>
                    </div>

                    <div class="ac-input">
                        <div class="ac-label">Closes</div>
                        <div class="ac-textbox">
                            <i class="fa fa-door-closed"></i>
                            <input asp-for="Closes" type="datetime-local" required />
                        </div>
                    </div>
                </div>

                <div class="ac-row">
                    <div class="ac-input">
                        <div class="ac-label">Turnaround Days (TAT)</div>
                        <div class="ac-textbox">
                            <i class="fa fa-hourglass-half"></i>
                            <input asp-for="TurnaroundDays" type="number" min="0" max="365" placeholder="e.g., 14" />
                        </div>
                        <p class="ac-note">How many days applications should take from submission before flagged overdue.</p>
                    </div>

                    <div class="ac-input">
                        <div class="ac-label">Status</div>
                        <div class="ac-select-grid" id="activeOptions" style="grid-template-columns: repeat(2, minmax(0,1fr));">
                            @foreach (var opt in activeOptions)
                            {
                                <div class="ac-option" data-target="IsActive" data-value="@opt.Value" role="button" tabindex="0">
                                    <div class="ic"><i class="fa @opt.Icon"></i></div>
                                    <div>
                                        <strong>@opt.Title</strong>
                                        <span>@opt.Sub</span>
                                    </div>
                                    <div class="ac-check"><i class="fa fa-check"></i></div>
                                </div>
                            }
                        </div>
                        <input asp-for="IsActive" type="hidden" />
                    </div>
                </div>

                <div class="ac-input">
                    <div class="ac-label">Description</div>
                    <div class="ac-textbox" style="align-items:flex-start;">
                        <i class="fa fa-align-left" style="margin-top:.3rem;"></i>
                        <textarea asp-for="Description" placeholder="Optional notes shown to admins..."></textarea>
                    </div>
                </div>

                <div class="ac-actions">
                    <button type="submit" class="ac-btn primary"><i class="fa fa-save"></i> Save Cycle</button>
                    <button type="reset" class="ac-btn"><i class="fa fa-rotate-left"></i> Reset</button>
                </div>
            </form>
        </div>

        <!-- RIGHT: Summary -->
        <aside class="ac-card">
            <div class="ac-card-title">
                <h2><i class="fa fa-id-badge"></i> Preview</h2>
                <span class="ac-chip"><i class="fa fa-eye"></i> Live</span>
            </div>

            <div class="ac-summary">
                <div class="ac-kv">
                    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:.75rem;">
                        <div>
                            <div class="k">Cycle Name</div>
                            <div class="v" id="pvName">@(Model?.Name ?? "—")</div>
                            <div class="s">Auto-generated if left blank.</div>
                        </div>
                        <button type="button" class="ac-edit" title="Edit name" data-scroll-to="Name"><i class="fa fa-pen"></i></button>
                    </div>
                </div>

                <div class="ac-kv">
                    <div class="k">Academic Year</div>
                    <div class="v" id="pvYear">@(Model?.AcademicYear > 0 ? Model.AcademicYear.ToString() : "—")</div>
                    <div class="s">Used for numbering and reporting.</div>
                </div>

                <div class="ac-kv">
                    <div class="k">Period</div>
                    <div class="v" id="pvPeriod">@(string.IsNullOrWhiteSpace(Model?.ApplicationPeriod) ? "—" : Model.ApplicationPeriod)</div>
                    <div class="s">Selection-driven (Intake/Semester/Trimester).</div>
                </div>

                <div class="ac-kv">
                    <div class="k">Open Window</div>
                    <div class="v" id="pvDates">—</div>
                    <div class="s">OpensAt must be before Closes (overlap checks apply).</div>
                </div>

                <div class="ac-kv">
                    <div class="k">TAT</div>
                    <div class="v" id="pvTat">@(Model?.TurnaroundDays >= 0 ? $"{Model.TurnaroundDays} days" : "—")</div>
                    <div class="s">Overdue apps are flagged after this threshold.</div>
                </div>

                <div class="ac-kv">
                    <div class="k">Status</div>
                    <div class="v" id="pvActive">@((Model?.IsActive ?? false) ? "Active" : "Inactive")</div>
                    <div class="s">Only one active cycle allowed per year + period.</div>
                </div>
            </div>
        </aside>
    </div>
</section>

<script>
    (function () {
        const form = document.querySelector("form.ac-form");
        if (!form) return;

        const inputName = form.querySelector('input[name="Name"]');
        const inputYear = form.querySelector('input[name="AcademicYear"]');
        const inputPeriod = form.querySelector('input[name="ApplicationPeriod"]');
        const inputOpens = form.querySelector('input[name="OpensAt"]');
        const inputCloses = form.querySelector('input[name="Closes"]');
        const inputTat = form.querySelector('input[name="TurnaroundDays"]');
        const inputActive = form.querySelector('input[name="IsActive"]');

        const pvName = document.getElementById("pvName");
        const pvYear = document.getElementById("pvYear");
        const pvPeriod = document.getElementById("pvPeriod");
        const pvDates = document.getElementById("pvDates");
        const pvTat = document.getElementById("pvTat");
        const pvActive = document.getElementById("pvActive");

        function fmtLocal(dtValue) {
            if (!dtValue) return "—";
            const d = new Date(dtValue);
            if (Number.isNaN(d.getTime())) return "—";
            return d.toLocaleString(undefined, { year: "numeric", month: "short", day: "2-digit", hour: "2-digit", minute: "2-digit" });
        }

        function updatePreview() {
            pvName.textContent = (inputName?.value || "—").trim() || "—";
            pvYear.textContent = (inputYear?.value || "—").trim() || "—";
            pvPeriod.textContent = (inputPeriod?.value || "—").trim() || "—";

            const opens = inputOpens?.value;
            const closes = inputCloses?.value;
            pvDates.textContent = `${fmtLocal(opens)} → ${fmtLocal(closes)}`;

            const tat = (inputTat?.value || "").trim();
            pvTat.textContent = tat ? `${tat} days` : "—";

            const active = (inputActive?.value || "").toLowerCase();
            pvActive.textContent = active === "true" ? "Active" : (active === "false" ? "Inactive" : "—");
        }

        function setSelected(targetName, value) {
            const hidden = form.querySelector(`input[name="${targetName}"]`);
            if (hidden) hidden.value = value;

            const options = document.querySelectorAll(`.ac-option[data-target="${targetName}"]`);
            options.forEach(o => o.classList.toggle("selected", o.getAttribute("data-value") === value));
            updatePreview();
        }

        function wireOptionCards(containerId) {
            const container = document.getElementById(containerId);
            if (!container) return;

            container.querySelectorAll(".ac-option").forEach(card => {
                const target = card.getAttribute("data-target");
                const value = card.getAttribute("data-value");

                function choose() {
                    if (!target || value == null) return;
                    setSelected(target, value);
                }

                card.addEventListener("click", choose);
                card.addEventListener("keydown", function (e) {
                    if (e.key === "Enter" || e.key === " ") {
                        e.preventDefault();
                        choose();
                    }
                });
            });
        }

        // Initialize selection states from model-bound hidden values (if any)
        wireOptionCards("periodOptions");
        wireOptionCards("activeOptions");

        if (inputPeriod?.value) setSelected("ApplicationPeriod", inputPeriod.value);
        if (inputActive?.value) setSelected("IsActive", inputActive.value.toLowerCase());

        // Default active selection if empty
        if (inputActive && !inputActive.value) setSelected("IsActive", "false");

        // Keep preview live as user types
        [inputName, inputYear, inputOpens, inputCloses, inputTat].forEach(i => {
            i?.addEventListener("input", updatePreview);
            i?.addEventListener("change", updatePreview);
        });

        // "Edit" buttons scroll to related input
        document.querySelectorAll("[data-scroll-to]").forEach(btn => {
            btn.addEventListener("click", function () {
                const name = btn.getAttribute("data-scroll-to");
                if (!name) return;
                const el = form.querySelector(`[name="${name}"]`);
                el?.scrollIntoView({ behavior: "smooth", block: "center" });
                el?.focus?.();
            });
        });

        updatePreview();
    })();
</script>