@{
    Layout = null;
    ViewData["Title"] = "Forek Online Applications";
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@500;600;700;800&display=swap" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

    <style>
        :root {
            --forek-orange: #ff6a00;
            --forek-red: #d7263d;
            --forek-ink: #0f172a;
            --forek-muted: #475569;
            --forek-surface: rgba(255, 255, 255, 0.85);
            --forek-border: rgba(15, 23, 42, 0.10);
            --forek-focus-border: rgba(255, 106, 0, 0.75);
            --forek-focus-ring: rgba(255, 106, 0, 0.22);
            --forek-invalid: rgba(215, 38, 61, 0.85);
            --forek-invalid-ring: rgba(215, 38, 61, 0.18);
            --forek-valid: rgba(22, 163, 74, 0.85);
            --forek-valid-ring: rgba(22, 163, 74, 0.16);
        }

        .was-validated .form-control:valid,
        .form-control.is-valid,
        .was-validated .form-select:valid,
        .form-select.is-valid {
            border-color: var(--forek-valid) !important;
        }

            .was-validated .form-control:valid:focus,
            .form-control.is-valid:focus,
            .was-validated .form-select:valid:focus,
            .form-select.is-valid:focus {
                box-shadow: 0 0 0 .25rem var(--forek-valid-ring) !important;
            }

        .input-group .btn:focus,
        .input-group .btn:active:focus {
            border-color: var(--forek-focus-border) !important;
            box-shadow: 0 0 0 .25rem var(--forek-focus-ring) !important;
        }

        .was-validated .form-control:invalid,
        .form-control.is-invalid,
        .was-validated .form-select:invalid,
        .form-select.is-invalid {
            border-color: var(--forek-invalid) !important;
        }

            .was-validated .form-control:invalid:focus,
            .form-control.is-invalid:focus,
            .was-validated .form-select:invalid:focus,
            .form-select.is-invalid:focus {
                box-shadow: 0 0 0 .25rem var(--forek-invalid-ring) !important;
            }

        .form-control:focus,
        .form-select:focus,
        .form-check-input:focus {
            border-color: var(--forek-focus-border) !important;
            box-shadow: 0 0 0 .25rem var(--forek-focus-ring) !important;
        }

        .input-group .form-control:focus,
        .input-group .form-select:focus {
            z-index: 3; 
        }

        .input-group:focus-within .input-group-text {
            border-color: var(--forek-focus-border) !important;
            box-shadow: 0 0 0 .25rem var(--forek-focus-ring) !important;
        }

        body {
            font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
            color: var(--forek-ink);
            background: radial-gradient(1200px 600px at 15% 10%, rgba(255, 106, 0, 0.18), transparent 55%), radial-gradient(900px 500px at 85% 0%, rgba(215, 38, 61, 0.18), transparent 55%), radial-gradient(900px 700px at 60% 90%, rgba(255, 106, 0, 0.12), transparent 60%), linear-gradient(180deg, #fff 0%, #fff7f3 35%, #fff 100%);
            min-height: 100vh;
        }

        .navbar-glass {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--forek-border);
        }

        .logo-pill {
            background: rgba(255, 255, 255, 0.80);
            border: 1px solid var(--forek-border);
            border-radius: 16px;
            padding: .4rem .7rem;
            box-shadow: 0 14px 30px rgba(15, 23, 42, 0.10);
        }

        .brand-logo {
            height: 56px;
            width: auto;
            object-fit: contain;
            filter: drop-shadow(0 10px 18px rgba(15, 23, 42, 0.12));
        }

        @@media (min-width: 992px) {
            .brand-logo {
                height: 64px;
            }
        }

        .admin-avatar {
            width: 44px;
            height: 44px;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, rgba(255, 106, 0, 0.22), rgba(215, 38, 61, 0.22));
            border: 1px solid rgba(255, 106, 0, 0.35);
            box-shadow: 0 14px 30px rgba(15, 23, 42, 0.10);
            color: var(--forek-ink);
            text-decoration: none;
            transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease, background 160ms ease;
        }

            .admin-avatar:hover,
            .admin-avatar:focus {
                transform: translateY(-1px);
                border-color: rgba(215, 38, 61, 0.55);
                box-shadow: 0 18px 44px rgba(15, 23, 42, 0.14);
                color: var(--forek-ink);
            }

            .admin-avatar i {
                font-size: 1.05rem;
            }

        @@media (max-width: 360px) {
            .admin-avatar {
                width: 40px;
                height: 40px;
            }
        }

        .hero {
            padding-top: 2.5rem;
            padding-bottom: 2.5rem;
        }

        @@media (min-width: 992px) {
            .hero {
                padding-top: 3.5rem;
                padding-bottom: 3.0rem;
            }
        }

        .hero-title {
            font-family: Poppins, Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
            letter-spacing: -0.025em;
            line-height: 1.05;
        }

        .hero-lead {
            color: var(--forek-muted);
            max-width: 56ch;
        }

        .badge-soft {
            border: 1px solid var(--forek-border);
            background: rgba(255, 255, 255, 0.70);
            color: var(--forek-ink);
        }

        .hero-card {
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(255, 255, 255, 0.78));
            border: 1px solid var(--forek-border);
            border-radius: 22px;
            box-shadow: 0 20px 60px rgba(15, 23, 42, 0.10);
            overflow: hidden;
        }

        .accent-line {
            height: 6px;
            background: linear-gradient(90deg, var(--forek-orange), var(--forek-red));
        }

        .cta-grid .card {
            border: 1px solid var(--forek-border);
            border-radius: 18px;
            transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
            background: var(--forek-surface);
        }

            .cta-grid .card:hover {
                transform: translateY(-3px);
                box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12);
                border-color: rgba(255, 106, 0, 0.35);
            }

        .icon-pill {
            width: 48px;
            height: 48px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 14px;
            background: linear-gradient(135deg, rgba(255, 106, 0, 0.18), rgba(215, 38, 61, 0.18));
            border: 1px solid rgba(255, 106, 0, 0.25);
            color: var(--forek-ink);
        }

        .btn-forek {
            border: 0;
            color: #fff;
            background: linear-gradient(135deg, var(--forek-orange), var(--forek-red));
            box-shadow: 0 14px 30px rgba(255, 106, 0, 0.25);
        }

            .btn-forek:hover {
                filter: brightness(0.98);
            }

        .btn-outline-forek {
            border: 1px solid rgba(215, 38, 61, 0.35);
            color: var(--forek-ink);
            background: rgba(255, 255, 255, 0.70);
        }

            .btn-outline-forek:hover {
                border-color: rgba(255, 106, 0, 0.55);
                background: rgba(255, 255, 255, 0.90);
            }

        .footer-note {
            color: #64748b;
        }

        .small-muted {
            color: #64748b;
        }

        .modal-glass .modal-content {
            border-radius: 18px;
            border: 1px solid var(--forek-border);
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(10px);
            box-shadow: 0 30px 90px rgba(15, 23, 42, 0.18);
        }

        .course-list {
            max-height: min(52vh, 560px);
            overflow: auto;
        }

        .course-item {
            border: 1px solid var(--forek-border);
            border-radius: 14px;
            background: rgba(255, 255, 255, 0.75);
        }

        .course-chip {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            padding: .25rem .55rem;
            border-radius: 999px;
            border: 1px solid var(--forek-border);
            background: rgba(255, 255, 255, 0.65);
            color: var(--forek-ink);
            font-size: .8rem;
            white-space: nowrap;
        }

        .step-chip {
            display: inline-flex;
            align-items: center;
            gap: .5rem;
            padding: .35rem .65rem;
            border-radius: 999px;
            border: 1px solid var(--forek-border);
            background: rgba(255, 255, 255, 0.75);
            color: var(--forek-ink);
            font-size: .85rem;
        }

        .step-dot {
            width: 10px;
            height: 10px;
            border-radius: 999px;
            background: rgba(15, 23, 42, 0.20);
        }

            .step-dot.active {
                background: linear-gradient(135deg, var(--forek-orange), var(--forek-red));
            }

        .privacy-note {
            border: 1px dashed rgba(15, 23, 42, 0.18);
            background: rgba(255, 255, 255, 0.75);
            border-radius: 14px;
            padding: .65rem .75rem;
        }

        .btn-icon {
            border: 1px solid var(--forek-border);
            background: rgba(255, 255, 255, 0.75);
        }
    </style>
</head>
<body>
    <header class="navbar navbar-expand-lg navbar-glass py-3">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-3 text-decoration-none" href="#">
                <span class="logo-pill d-inline-flex align-items-center gap-3">
                    <img class="brand-logo" src="~/Theme/images/logob-removebg-preview.png" alt="Forek" />
                    <span class="fw-semibold d-none d-md-inline">Forek Online</span>
                </span>
            </a>

            <div class="ms-auto d-flex align-items-center gap-2">
                <span class="badge badge-soft rounded-pill px-3 py-2">
                    <i class="fa-solid fa-shield-halved me-2" aria-hidden="true"></i>
                    Secure Student Portal
                </span>

                <a class="admin-avatar" href="/Admin/Login" title="Admin Login" aria-label="Admin Login">
                    <i class="fa-solid fa-user-shield" aria-hidden="true"></i>
                </a>
            </div>
        </div>
    </header>

    <main class="container hero">
        <div class="row align-items-center g-4 g-lg-5">
            <div class="col-lg-7">
                <div class="d-inline-flex align-items-center gap-2 badge badge-soft rounded-pill px-3 py-2 mb-3">
                    <i class="fa-solid fa-sparkles" aria-hidden="true"></i>
                    <span class="small fw-semibold">Start your application journey</span>
                </div>

                <h1 class="display-5 display-md-4 fw-bold hero-title mb-3">
                    Welcome to <span style="background: linear-gradient(90deg, var(--forek-orange), var(--forek-red)); -webkit-background-clip: text; background-clip: text; color: transparent;">Forek</span>
                    <br class="d-none d-md-block" />Online Applications
                </h1>

                <p class="fs-5 hero-lead mb-4">
                    Apply, register, and manage your student profile in one place. Choose an option below to continue.
                </p>

                <div class="d-grid d-sm-flex flex-wrap gap-2">
                    <button type="button" class="btn btn-forek btn-lg px-4" data-bs-toggle="modal" data-bs-target="#registerModal">
                        <i class="fa-solid fa-id-card-clip me-2" aria-hidden="true"></i>
                        Register (No Student Number)
                    </button>

                    <button type="button" class="btn btn-outline-forek btn-lg px-4" data-bs-toggle="modal" data-bs-target="#continueModal">
                        <i class="fa-solid fa-right-to-bracket me-2" aria-hidden="true"></i>
                        Continue
                    </button>

                    <button type="button" class="btn btn-light btn-lg px-4 border" data-bs-toggle="modal" data-bs-target="#coursesModal">
                        <i class="fa-solid fa-graduation-cap me-2" aria-hidden="true"></i>
                        View Courses
                    </button>
                </div>

                <div class="mt-4 small-muted">
                    <i class="fa-regular fa-circle-check me-2" aria-hidden="true"></i>
                    Tip: If you’re new, start with registration to receive your student number.
                </div>
            </div>

            <div class="col-lg-5">
                <div class="hero-card">
                    <div class="accent-line"></div>

                    <div class="p-4 pb-3">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <div class="fw-semibold">Quick Actions</div>
                                <div class="small-muted">Everything you need to get started.</div>
                            </div>
                            <div class="icon-pill" aria-hidden="true">
                                <i class="fa-solid fa-bolt"></i>
                            </div>
                        </div>
                    </div>

                    <div class="px-4 pb-4">
                        <div class="row g-3 cta-grid">
                            <div class="col-12">
                                <div class="card p-3">
                                    <div class="d-flex gap-3">
                                        <div class="icon-pill flex-shrink-0">
                                            <i class="fa-solid fa-user-plus" aria-hidden="true"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="fw-semibold">Create your profile</div>
                                            <div class="small-muted">
                                                Register to generate your student number and begin your application.
                                            </div>
                                            <div class="mt-2">
                                                <a class="btn btn-sm btn-forek" href="/Account/Register">
                                                    Get started
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="card p-3">
                                    <div class="d-flex gap-3">
                                        <div class="icon-pill flex-shrink-0">
                                            <i class="fa-solid fa-lock" aria-hidden="true"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="fw-semibold">Continue your journey</div>
                                            <div class="small-muted">
                                                Enter your student number, confirm your identity, and continue.
                                            </div>
                                            <div class="mt-2">
                                                <button type="button" class="btn btn-sm btn-outline-forek" data-bs-toggle="modal" data-bs-target="#continueModal">
                                                    Continue
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex align-items-start gap-3">
                            <div class="icon-pill flex-shrink-0">
                                <i class="fa-solid fa-headset" aria-hidden="true"></i>
                            </div>
                            <div>
                                <div class="fw-semibold">Need help?</div>
                                <div class="small-muted">
                                    Contact support if you’re unsure where to start.
                                </div>
                                <div class="mt-2">
                                    <a class="text-decoration-none fw-semibold" href="/Support">
                                        Go to support <i class="fa-solid fa-arrow-right ms-1" aria-hidden="true"></i>
                                    </a>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="mt-3 footer-note small">
                    <i class="fa-regular fa-clock me-2" aria-hidden="true"></i>
                    Fast • Secure • Mobile-friendly
                </div>
            </div>
        </div>
    </main>

    <!-- Continue Modal (Student Number -> + DOB) -->
    <div class="modal fade modal-glass" id="continueModal" tabindex="-1" aria-labelledby="continueModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header border-0 pb-0">
                    <div>
                        <h5 class="modal-title fw-bold" id="continueModalLabel">
                            <i class="fa-solid fa-lock me-2" aria-hidden="true"></i>
                            Continue your application
                        </h5>
                        <div class="small-muted">Confirm your identity to proceed.</div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body pt-3">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                        <span class="step-chip">
                            <span id="stepDot1" class="step-dot active" aria-hidden="true"></span>
                            Student Number
                        </span>
                        <span class="step-chip">
                            <span id="stepDot2" class="step-dot" aria-hidden="true"></span>
                            Date of Birth
                        </span>
                    </div>

                    <form id="continueForm" class="needs-validation" novalidate>
                        <div id="continueStep1">
                            <label for="forekStudentNumber" class="form-label fw-semibold">Forek Student Number</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border">
                                    <i class="fa-solid fa-id-badge" aria-hidden="true"></i>
                                </span>
                                <input id="forekStudentNumber"
                                       name="forekStudentNumber"
                                       class="form-control border"
                                       inputmode="numeric"
                                       autocomplete="off"
                                       placeholder="e.g., 2025001234"
                                       required />
                            </div>
                            <div class="invalid-feedback">Student Number is required.</div>

                            <div class="mt-3 small-muted">
                                <i class="fa-regular fa-circle-info me-1" aria-hidden="true"></i>
                                We’ll use this to find your profile.
                            </div>
                        </div>

                        <div id="continueLoading" class="d-none text-center py-4">
                            <div class="spinner-border" role="status" aria-hidden="true"></div>
                            <div class="mt-3 fw-semibold">Checking your student number...</div>
                            <div class="small-muted">Please wait a moment.</div>
                        </div>

                        <div id="continueStep2" class="d-none">
                            <div class="mb-2">
                                <div class="small-muted">Student Number</div>
                                <div class="fw-semibold" id="confirmedStudentNumber">-</div>
                            </div>

                            <label for="dateOfBirth" class="form-label fw-semibold mt-2">Date of Birth</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border">
                                    <i class="fa-solid fa-cake-candles" aria-hidden="true"></i>
                                </span>
                                <input id="dateOfBirth"
                                       name="dateOfBirth"
                                       type="date"
                                       class="form-control border"
                                       required />
                            </div>
                            <div class="invalid-feedback">Date of Birth is required.</div>

                            <div class="mt-3 small-muted">
                                <i class="fa-solid fa-shield-halved me-1" aria-hidden="true"></i>
                                This helps us verify it’s really you.
                            </div>
                        </div>
                    </form>
                </div>

                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-forek" data-bs-dismiss="modal">Cancel</button>

                    <button id="continueBackBtn" type="button" class="btn btn-outline-forek d-none">
                        Back
                    </button>

                    <button id="continueNextBtn" type="button" class="btn btn-forek">
                        Next
                        <i class="fa-solid fa-arrow-right ms-2" aria-hidden="true"></i>
                    </button>

                    <button id="continueSubmitBtn" type="button" class="btn btn-forek d-none">
                        Submit
                        <i class="fa-solid fa-paper-plane ms-2" aria-hidden="true"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Courses Modal -->
    <div class="modal fade modal-glass" id="coursesModal" tabindex="-1" aria-labelledby="coursesModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
            <div class="modal-content">
                <div class="modal-header border-0 pb-0">
                    <div>
                        <h5 class="modal-title fw-bold" id="coursesModalLabel">
                            <i class="fa-solid fa-graduation-cap me-2" aria-hidden="true"></i>
                            Courses We Offer
                        </h5>
                        <div class="small-muted">Search and preview courses (name/type/NQF).</div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body pt-3">
                    <div class="row g-2 align-items-center mb-3">
                        <div class="col-12 col-md-8">
                            <div class="input-group">
                                <span class="input-group-text bg-white border">
                                    <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                                </span>
                                <input id="courseSearch" type="search" class="form-control border" placeholder="Search courses (e.g., ICT, NQF 4, Welding)..." />
                            </div>
                        </div>
                        <div class="col-12 col-md-4 text-md-end">
                            <span class="badge badge-soft rounded-pill px-3 py-2">
                                <span id="courseCount">0</span> results
                            </span>
                        </div>
                    </div>

                    <div id="courseList" class="course-list d-grid gap-2"></div>
                </div>

                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-forek" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade modal-glass" id="registerModal" tabindex="-1" aria-labelledby="registerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <div>
                    <h5 class="modal-title fw-bold" id="registerModalLabel">
                        <i class="fa-solid fa-user-plus me-2" aria-hidden="true"></i>
                        Create your Forek profile
                    </h5>
                    <div class="small-muted">Register to get started. You’ll receive a student number after registration.</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body pt-3">
                <div class="privacy-note small mb-3">
                    <i class="fa-solid fa-shield-heart me-2" aria-hidden="true"></i>
                    <strong>Privacy:</strong> Your ID/Passport is used for verification only. <strong>We do not store it</strong> in plain text.
                </div>

                    <form id="registerForm" asp-action="SignUp" asp-controller="OnlineApplicationsAuth" method="post" class="needs-validation" novalidate>
                        @Html.AntiForgeryToken()

                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label class="form-label fw-semibold" for="regName">Name</label>
                                <input id="regName" name="FirstName" class="form-control" autocomplete="given-name" required />
                                <div class="invalid-feedback">Name is required.</div>
                            </div>

                            <div class="col-12 col-md-6">
                                <label class="form-label fw-semibold" for="regSurname">Surname</label>
                                <input id="regSurname" name="LastName" class="form-control" autocomplete="family-name" required />
                                <div class="invalid-feedback">Surname is required.</div>
                            </div>

                            <div class="col-12">
                                <label class="form-label fw-semibold" for="regIdOrPassport">
                                    ID Number / Passport
                                    <span class="small-muted fw-normal">(verification only)</span>
                                </label>

                                <input id="regIdOrPassport"
                                       name="IdOrPassport"
                                       class="form-control"
                                       autocomplete="off"
                                       placeholder="South African ID number or Passport number"
                                       required />
                                <div class="invalid-feedback">ID Number / Passport is required.</div>
                            </div>

                            <div class="col-12 col-md-6">
                                <label class="form-label fw-semibold" for="regCell">Cellphone</label>
                                <input id="regCell"
                                       name="Cellphone"
                                       class="form-control"
                                       inputmode="tel"
                                       autocomplete="tel"
                                       placeholder="e.g., 0712345678"
                                       required />
                                <div class="invalid-feedback">Cellphone is required.</div>
                            </div>

                            <div class="col-12 col-md-6">
                                <label class="form-label fw-semibold" for="regEmail">Email</label>
                                <input id="regEmail"
                                       name="Username"
                                       type="email"
                                       class="form-control"
                                       autocomplete="email"
                                       placeholder="name@example.com"
                                       required />
                                <div class="invalid-feedback">Valid email is required.</div>
                            </div>

                            <div class="col-12 col-md-6">
                                <label class="form-label fw-semibold" for="regPassword">Password</label>
                                <div class="input-group">
                                    <input id="regPassword" name="Password" type="password" class="form-control" autocomplete="new-password" minlength="8" required />
                                    <button type="button" class="btn btn-icon" id="toggleRegPassword" aria-label="Show/Hide password">
                                        <i class="fa-solid fa-eye" aria-hidden="true"></i>
                                    </button>
                                </div>
                                <div class="form-text small-muted">Minimum 8 characters.</div>
                                <div class="invalid-feedback">Password is required (min 8 characters).</div>
                            </div>

                            <div class="col-12 col-md-6">
                                <label class="form-label fw-semibold" for="regConfirmPassword">Confirm Password</label>
                                <div class="input-group">
                                    <input id="regConfirmPassword" type="password" class="form-control" autocomplete="new-password" minlength="8" required />
                                    <button type="button" class="btn btn-icon" id="toggleRegConfirmPassword" aria-label="Show/Hide confirm password">
                                        <i class="fa-solid fa-eye" aria-hidden="true"></i>
                                    </button>
                                </div>
                                <div class="invalid-feedback">Confirm Password is required.</div>
                            </div>

                            <div class="col-12 d-none" id="regPasswordMismatch">
                                <div class="alert alert-danger mb-0">
                                    <i class="fa-solid fa-triangle-exclamation me-2" aria-hidden="true"></i>
                                    Password and Confirm Password do not match.
                                </div>
                            </div>
                        </div>

                        <div class="modal-footer border-0 pt-0">
                            <button type="button" class="btn btn-outline-forek" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-forek" id="registerSubmitBtn">
                                Create profile
                                <i class="fa-solid fa-arrow-right ms-2" aria-hidden="true"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        (function () {
            "use strict";

            const coursesListEl = document.getElementById("courseList");
            const coursesSearchEl = document.getElementById("courseSearch");
            const coursesCountEl = document.getElementById("courseCount");

            let coursesLastController = null;
            let coursesDebounceTimer = null;

            function esc(s) {
                return (s ?? "").toString()
                    .replaceAll("&", "&amp;")
                    .replaceAll("<", "&lt;")
                    .replaceAll(">", "&gt;")
                    .replaceAll("\"", "&quot;")
                    .replaceAll("'", "&#39;");
            }

            function coursesSetLoading() {
                coursesListEl.innerHTML = `
                    <div class="course-item p-3">
                        <div class="d-flex align-items-center gap-2">
                            <div class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></div>
                            <div class="small-muted">Loading courses...</div>
                        </div>
                    </div>`;
            }

            function coursesSetError(message) {
                coursesListEl.innerHTML = `
                    <div class="course-item p-3">
                        <div class="fw-semibold">Unable to load courses</div>
                        <div class="small-muted">${esc(message)}</div>
                    </div>`;
            }

            function coursesRender(items) {
                coursesListEl.innerHTML = "";

                for (const c of items) {
                    const nqf = c.nqfLevel ? `NQF ${c.nqfLevel}` : "NQF -";
                    const type = c.type || "Type -";

                    const el = document.createElement("div");
                    el.className = "course-item p-3";
                    el.innerHTML = `
                        <div class="d-flex flex-column flex-sm-row gap-2 align-items-start align-items-sm-center justify-content-between">
                            <div class="pe-sm-3">
                                <div class="fw-semibold">${esc(c.name)}</div>
                                <div class="small-muted">Modules: ${esc(c.moduleCount)} • Credits: ${esc(c.credit)}</div>
                            </div>
                            <div class="d-flex flex-wrap gap-2 justify-content-sm-end">
                                <span class="course-chip"><i class="fa-solid fa-layer-group" aria-hidden="true"></i> ${esc(type)}</span>
                                <span class="course-chip"><i class="fa-solid fa-stairs" aria-hidden="true"></i> ${esc(nqf)}</span>
                            </div>
                        </div>`;
                    coursesListEl.appendChild(el);
                }
            }

            async function coursesLoad(q) {
                if (coursesLastController) {
                    coursesLastController.abort();
                }

                coursesLastController = new AbortController();
                coursesSetLoading();

                try {
                    const url = new URL("/api/courses", window.location.origin);
                    if (q && q.trim().length > 0) {
                        url.searchParams.set("q", q.trim());
                    }
                    url.searchParams.set("page", "1");
                    url.searchParams.set("pageSize", "50");

                    const res = await fetch(url.toString(), { signal: coursesLastController.signal });
                    if (!res.ok) {
                        throw new Error(`HTTP ${res.status}`);
                    }

                    const data = await res.json();
                    const items = (data.items || []).map(x => ({
                        courseId: x.courseId,
                        name: x.name,
                        type: x.type,
                        nqfLevel: x.nqfLevel,
                        credit: x.credit,
                        moduleCount: x.moduleCount
                    }));

                    coursesCountEl.textContent = (data.totalCount ?? items.length).toString();
                    coursesRender(items);
                } catch (e) {
                    if (e && e.name === "AbortError") {
                        return;
                    }
                    coursesCountEl.textContent = "0";
                    coursesSetError(e.message || "Unknown error");
                }
            }

            function coursesScheduleLoad() {
                window.clearTimeout(coursesDebounceTimer);
                coursesDebounceTimer = window.setTimeout(() => coursesLoad(coursesSearchEl.value), 250);
            }

            coursesSearchEl.addEventListener("input", coursesScheduleLoad);

            const coursesModalEl = document.getElementById("coursesModal");
            coursesModalEl.addEventListener("shown.bs.modal", function () {
                coursesSearchEl.focus();
                coursesSearchEl.select();
                coursesLoad(coursesSearchEl.value);
            });

            // -----------------------------------------------------------------
            // Continue modal (Student Number -> + DOB)
            // -----------------------------------------------------------------
            const continueModalEl = document.getElementById("continueModal");
            const continueForm = document.getElementById("continueForm");

            const stepDot1 = document.getElementById("stepDot1");
            const stepDot2 = document.getElementById("stepDot2");

            const step1 = document.getElementById("continueStep1");
            const loading = document.getElementById("continueLoading");
            const step2 = document.getElementById("continueStep2");

            const studentNumberInput = document.getElementById("forekStudentNumber");
            const dobInput = document.getElementById("dateOfBirth");
            const confirmedStudentNumber = document.getElementById("confirmedStudentNumber");

            const backBtn = document.getElementById("continueBackBtn");
            const nextBtn = document.getElementById("continueNextBtn");
            const submitBtn = document.getElementById("continueSubmitBtn");

            let fakeLoadingTimer = null;

            function setStep(stepIndex) {
                const isStep1 = stepIndex === 1;
                const isLoading = stepIndex === 0;
                const isStep2 = stepIndex === 2;

                step1.classList.toggle("d-none", !isStep1);
                loading.classList.toggle("d-none", !isLoading);
                step2.classList.toggle("d-none", !isStep2);

                stepDot1.classList.toggle("active", isStep1 || isLoading);
                stepDot2.classList.toggle("active", isStep2);

                backBtn.classList.toggle("d-none", !isStep2);
                nextBtn.classList.toggle("d-none", !(isStep1));
                submitBtn.classList.toggle("d-none", !isStep2);
            }

            function resetContinueModal() {
                window.clearTimeout(fakeLoadingTimer);
                continueForm.classList.remove("was-validated");
                continueForm.reset();

                confirmedStudentNumber.textContent = "-";
                setStep(1);
            }

            function validateCurrentStep(stepIndex) {
                continueForm.classList.add("was-validated");

                if (stepIndex === 1) {
                    return studentNumberInput.checkValidity();
                }

                if (stepIndex === 2) {
                    return dobInput.checkValidity();
                }

                return true;
            }

            nextBtn.addEventListener("click", function () {
                if (!validateCurrentStep(1)) {
                    return;
                }

                confirmedStudentNumber.textContent = studentNumberInput.value.trim();
                setStep(0);

                window.clearTimeout(fakeLoadingTimer);
                fakeLoadingTimer = window.setTimeout(function () {
                    continueForm.classList.remove("was-validated");
                    setStep(2);
                    dobInput.focus();
                }, 900);
            });

            backBtn.addEventListener("click", function () {
                continueForm.classList.remove("was-validated");
                setStep(1);
                studentNumberInput.focus();
                studentNumberInput.select();
            });

            submitBtn.addEventListener("click", function () {
                if (!validateCurrentStep(2)) {
                    return;
                }

                // No backend yet: wire later.
                const modal = bootstrap.Modal.getInstance(continueModalEl);
                modal.hide();
            });

            continueModalEl.addEventListener("shown.bs.modal", function () {
                resetContinueModal();
                studentNumberInput.focus();
            });

            continueModalEl.addEventListener("hidden.bs.modal", function () {
                resetContinueModal();
            });

         // -----------------------------------------------------------------
        // Register modal (client-side validation only for now)
        // -----------------------------------------------------------------
        const registerModalEl = document.getElementById("registerModal");
        const registerForm = document.getElementById("registerForm");
        const registerSubmitBtn = document.getElementById("registerSubmitBtn");

        const regPassword = document.getElementById("regPassword");
        const regConfirmPassword = document.getElementById("regConfirmPassword");
        const regPasswordMismatch = document.getElementById("regPasswordMismatch");

        const toggleRegPassword = document.getElementById("toggleRegPassword");
        const toggleRegConfirmPassword = document.getElementById("toggleRegConfirmPassword");

        function togglePassword(input, iconBtn) {
            const isPassword = input.type === "password";
            input.type = isPassword ? "text" : "password";

            const icon = iconBtn.querySelector("i");
            if (icon) {
                icon.classList.toggle("fa-eye", !isPassword);
                icon.classList.toggle("fa-eye-slash", isPassword);
            }
        }

        function setMismatchVisible(show) {
            regPasswordMismatch.classList.toggle("d-none", !show);
        }

        function passwordsMatch() {
            return (regPassword.value || "") === (regConfirmPassword.value || "");
        }

        toggleRegPassword.addEventListener("click", function () {
            togglePassword(regPassword, toggleRegPassword);
        });

        toggleRegConfirmPassword.addEventListener("click", function () {
            togglePassword(regConfirmPassword, toggleRegConfirmPassword);
        });

        regPassword.addEventListener("input", function () {
            setMismatchVisible(false);
        });

        regConfirmPassword.addEventListener("input", function () {
            setMismatchVisible(false);
        });

         registerForm.addEventListener("submit", function (e) {
                registerForm.classList.add("was-validated");

                if (!registerForm.checkValidity()) {
                    e.preventDefault();
                    e.stopPropagation();
                    return;
                }

                if (!passwordsMatch()) {
                    e.preventDefault();
                    e.stopPropagation();
                    setMismatchVisible(true);
                    return;
                }

                // Let the form POST normally to OnlineApplicationsAuthController.SignUp
            });

        registerModalEl.addEventListener("hidden.bs.modal", function () {
            registerForm.classList.remove("was-validated");
            registerForm.reset();
            setMismatchVisible(false);

            regPassword.type = "password";
            regConfirmPassword.type = "password";

            const icon1 = toggleRegPassword.querySelector("i");
            const icon2 = toggleRegConfirmPassword.querySelector("i");
            if (icon1) { icon1.className = "fa-solid fa-eye"; }
            if (icon2) { icon2.className = "fa-solid fa-eye"; }
        });

        })();
    </script>
</body>
</html>