@model IReadOnlyList<ForekOnline.Domain.Entities.VenueReservation>
@{
    ViewData["Title"] = "Pending Venue Reservations";
}

@section Styles {
    <style>
        :root {
            --pr-red: #b31217;
            --pr-orange: #ff7a18;
            --pr-bg: #f7f8fb;
            --pr-panel: #fff;
            --pr-border: #e6e9f0;
            --pr-muted: #64748b;
            --pr-text: #0f172a;
            --pr-grad: linear-gradient(135deg,#320606,#b31217 55%,#ff7a18);
            --pr-shadow: 0 14px 42px -18px rgba(50,6,6,.28);
            --pr-r-lg: 26px;
            --pr-r-md: 18px;
            --pr-t: 250ms cubic-bezier(.2,.75,.2,1);
            --pr-focus: 0 0 0 4px rgba(179,18,23,.14);
        }

        .pr-shell {
            max-width: 1440px;
            margin: 0 auto;
            padding: 1.25rem 1rem 3.5rem;
        }

        .pr-hero {
            position: relative;
            border-radius: var(--pr-r-lg);
            background: var(--pr-grad);
            color: #fff;
            padding: 1.5rem 1.5rem 1.25rem;
            overflow: hidden;
            box-shadow: var(--pr-shadow);
        }

            .pr-hero::before {
                content: "";
                position: absolute;
                inset: -140px -140px auto auto;
                width: 400px;
                height: 400px;
                background: radial-gradient(circle,rgba(255,255,255,.18),transparent 60%);
                transform: rotate(20deg);
                pointer-events: none;
            }

        .pr-hero-row {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .pr-hero-left {
            display: flex;
            align-items: center;
            gap: .95rem;
        }

        .pr-hero-icon {
            width: 56px;
            height: 56px;
            border-radius: 18px;
            background: rgba(255,255,255,.16);
            border: 1px solid rgba(255,255,255,.22);
            backdrop-filter: blur(10px);
            display: grid;
            place-items: center;
            box-shadow: 0 10px 24px rgba(0,0,0,.18);
            font-size: 1.25rem;
        }

        .pr-hero h1 {
            font-size: 1.35rem;
            font-weight: 900;
            margin: 0;
        }

        .pr-hero p {
            margin: .25rem 0 0;
            opacity: .92;
            font-size: .85rem;
            font-weight: 500;
        }

        .pr-card {
            background: rgba(255,255,255,.88);
            border: 1px solid var(--pr-border);
            border-radius: var(--pr-r-lg);
            box-shadow: 0 10px 30px rgba(15,23,42,.06);
            overflow: hidden;
            margin-top: 1.15rem;
        }

        .pr-card-head {
            padding: 1.1rem 1.25rem .95rem;
            display: flex;
            align-items: end;
            justify-content: space-between;
            gap: 1rem;
            background: linear-gradient(180deg,rgba(255,255,255,.95),rgba(255,255,255,.7));
        }

            .pr-card-head h2 {
                margin: 0;
                font-size: .82rem;
                font-weight: 900;
                letter-spacing: .16rem;
                text-transform: uppercase;
                color: var(--pr-red);
                display: flex;
                gap: .5rem;
                align-items: center;
            }

            .pr-card-head p {
                margin: .2rem 0 0;
                color: var(--pr-muted);
                font-size: .78rem;
                font-weight: 600;
            }

        .pr-card-body {
            padding: 1.15rem 1.25rem 1.35rem;
        }

        .pr-pill {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            padding: .32rem .6rem;
            border-radius: 50px;
            font-size: .58rem;
            font-weight: 800;
            border: 1px solid var(--pr-border);
            background: #fff;
            color: var(--pr-muted);
        }

        .pr-pill-warn {
            background: rgba(245,158,11,.1);
            border-color: rgba(245,158,11,.28);
            color: #92400e;
        }

        .pr-btn {
            font-size: .56rem;
            letter-spacing: .12rem;
            font-weight: 800;
            text-transform: uppercase;
            padding: .55rem .9rem;
            border-radius: 14px;
            border: 1px solid var(--pr-border);
            background: #fff;
            color: var(--pr-red);
            display: inline-flex;
            align-items: center;
            gap: .45rem;
            cursor: pointer;
            transition: var(--pr-t);
            text-decoration: none;
        }

            .pr-btn:hover {
                transform: translateY(-1px);
                box-shadow: 0 6px 18px rgba(15,23,42,.1);
            }

            .pr-btn.approve {
                background: linear-gradient(135deg,#059669,#047857);
                color: #fff;
                border-color: #059669;
            }

                .pr-btn.approve:hover {
                    filter: brightness(.95);
                }

            .pr-btn.reject {
                background: linear-gradient(135deg,#dc2626,#b91c1c);
                color: #fff;
                border-color: #dc2626;
            }

                .pr-btn.reject:hover {
                    filter: brightness(.95);
                }

        .pr-queue {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .pr-reservation {
            background: #fff;
            border: 1px solid var(--pr-border);
            border-radius: var(--pr-r-md);
            padding: 1.05rem 1.15rem;
            display: grid;
            gap: .7rem;
            transition: var(--pr-t);
        }

            .pr-reservation:hover {
                box-shadow: 0 8px 28px -10px rgba(179,18,23,.15);
            }

        .pr-res-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: .8rem;
            flex-wrap: wrap;
        }

            .pr-res-top h3 {
                margin: 0;
                font-size: .85rem;
                font-weight: 900;
                color: var(--pr-text);
            }

        .pr-res-meta {
            display: grid;
            grid-template-columns: repeat(auto-fit,minmax(170px,1fr));
            gap: .55rem;
        }

        .pr-meta-item {
            background: rgba(179,18,23,.03);
            border: 1px solid var(--pr-border);
            border-radius: 12px;
            padding: .55rem .7rem;
        }

            .pr-meta-item .lbl {
                font-size: .46rem;
                letter-spacing: .14rem;
                text-transform: uppercase;
                font-weight: 800;
                color: var(--pr-muted);
                margin-bottom: .15rem;
                display: flex;
                gap: .35rem;
                align-items: center;
            }

            .pr-meta-item .val {
                font-size: .78rem;
                font-weight: 800;
                color: var(--pr-text);
            }

        .pr-res-actions {
            display: flex;
            flex-wrap: wrap;
            gap: .5rem;
            align-items: center;
        }

        .pr-empty {
            border: 2px dashed rgba(100,116,139,.3);
            border-radius: var(--pr-r-md);
            padding: 2rem;
            text-align: center;
            color: var(--pr-muted);
            font-weight: 700;
            font-size: .82rem;
        }

        /* Reject modal */
        .pr-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(15,23,42,.45);
            backdrop-filter: blur(4px);
            z-index: 1060;
            place-items: center;
        }

            .pr-overlay.show {
                display: grid;
            }

        .pr-modal {
            background: #fff;
            border-radius: var(--pr-r-lg);
            box-shadow: 0 24px 60px rgba(15,23,42,.2);
            width: 95%;
            max-width: 480px;
            padding: 1.4rem 1.4rem 1.2rem;
            animation: pr-pop .35s ease;
        }

        @@keyframes pr-pop {
            from {
                opacity: 0;
                transform: scale(.95) translateY(10px);
            }

            to {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }

        .pr-modal h3 {
            margin: 0 0 .7rem;
            font-size: .95rem;
            font-weight: 900;
            color: var(--pr-red);
        }

        .pr-modal textarea {
            width: 100%;
            border: 1px solid var(--pr-border);
            border-radius: 12px;
            padding: .7rem .85rem;
            font-size: .78rem;
            font-weight: 650;
            resize: vertical;
            min-height: 90px;
            outline: none;
            transition: var(--pr-t);
        }

            .pr-modal textarea:focus {
                border-color: var(--pr-red);
                box-shadow: var(--pr-focus);
            }

        .pr-modal-actions {
            display: flex;
            gap: .5rem;
            margin-top: .85rem;
        }
    </style>
}

<section class="pr-shell">

    <header class="pr-hero">
        <div class="pr-hero-row">
            <div class="pr-hero-left">
                <div class="pr-hero-icon"><i class="fa fa-clipboard-check"></i></div>
                <div>
                    <h1>Pending Venue Reservations</h1>
                    <p>Review, approve or reject facilitator venue requests. One-click governance.</p>
                </div>
            </div>
            <span class="pr-pill pr-pill-warn" style="font-size:.65rem;">
                <i class="fa fa-clock"></i> @Model.Count pending
            </span>
        </div>
    </header>

    <div class="pr-card">
        <div class="pr-card-head">
            <div>
                <h2><i class="fa fa-inbox"></i> Approval Queue</h2>
                <p>Reservations expire automatically after the soft-hold window. Act before the timer runs out.</p>
            </div>
        </div>
        <div class="pr-card-body">
            @if (Model.Count == 0)
            {
                <div class="pr-empty">
                    <i class="fa fa-check-circle" style="font-size:1.6rem;display:block;margin-bottom:.5rem;color:#059669;"></i>
                    All clear — no pending reservations at this time.
                </div>
            }
            else
            {
                <div class="pr-queue">
                    @foreach (var r in Model)
                    {
                        var timeLeft = r.ExpiresOnUtc - DateTime.UtcNow;
                        var hoursLeft = Math.Max(0, (int)timeLeft.TotalHours);
                        <div class="pr-reservation">
                            <div class="pr-res-top">
                                <h3><i class="fa fa-map-pin" style="color:var(--pr-red);margin-right:.35rem;"></i> @r.Venue?.Name</h3>
                                <span class="pr-pill pr-pill-warn"><i class="fa fa-hourglass-half"></i> ~@hoursLeft hrs left</span>
                            </div>

                            <div class="pr-res-meta">
                                <div class="pr-meta-item">
                                    <div class="lbl"><i class="fa fa-user"></i> Facilitator</div>
                                    <div class="val">@r.FacilitatorName</div>
                                </div>
                                <div class="pr-meta-item">
                                    <div class="lbl"><i class="fa fa-building-columns"></i> Campus</div>
                                    <div class="val">@r.Campus</div>
                                </div>
                                <div class="pr-meta-item">
                                    <div class="lbl"><i class="fa fa-users"></i> Students</div>
                                    <div class="val">@r.ExpectedStudents</div>
                                </div>
                                <div class="pr-meta-item">
                                    <div class="lbl"><i class="fa fa-calendar"></i> Date</div>
                                    <div class="val">@r.ReservedDate.ToString("dd MMM yyyy")</div>
                                </div>
                                <div class="pr-meta-item">
                                    <div class="lbl"><i class="fa fa-clock"></i> Time</div>
                                    <div class="val">@r.StartTimeUtc.ToString("HH:mm") – @r.EndTimeUtc.ToString("HH:mm")</div>
                                </div>
                            </div>

                            <div class="pr-res-actions">
                                <form method="post" asp-action="ApproveReservation" asp-controller="VenueBooking" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="reservationId" value="@r.Id" />
                                    <button type="submit" class="pr-btn approve"><i class="fa fa-check"></i> Approve</button>
                                </form>
                                <button type="button" class="pr-btn reject" data-reject-id="@r.Id" data-reject-venue="@r.Venue?.Name">
                                    <i class="fa fa-times"></i> Reject
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</section>

<div class="pr-overlay" id="rejectOverlay">
    <div class="pr-modal">
        <h3><i class="fa fa-ban"></i> Reject Reservation</h3>
        <p style="font-size:.75rem;color:var(--pr-muted);font-weight:600;margin:0 0 .7rem;">
            Rejecting <strong id="rejectVenueName"></strong>. A reason is mandatory and will be stored in the audit log.
        </p>
        <form method="post" asp-action="RejectReservation" asp-controller="VenueBooking" id="rejectForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="reservationId" id="rejectResId" />
            <textarea name="reason" placeholder="Reason for rejection (mandatory)..." required></textarea>
            <div class="pr-modal-actions">
                <button type="submit" class="pr-btn reject"><i class="fa fa-ban"></i> Confirm Reject</button>
                <button type="button" class="pr-btn" id="btnCancelReject"><i class="fa fa-arrow-left"></i> Cancel</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            const overlay = document.getElementById('rejectOverlay');
            const nameEl  = document.getElementById('rejectVenueName');
            const idEl    = document.getElementById('rejectResId');

            document.querySelectorAll('[data-reject-id]').forEach(btn => {
                btn.addEventListener('click', () => {
                    idEl.value   = btn.dataset.rejectId;
                    nameEl.textContent = btn.dataset.rejectVenue || 'this venue';
                    overlay.classList.add('show');
                });
            });

            document.getElementById('btnCancelReject')?.addEventListener('click', () => overlay.classList.remove('show'));
            overlay.addEventListener('click', e => { if (e.target === overlay) overlay.classList.remove('show'); });
        })();
    </script>
}