@{
    ViewData["Title"] = "Reserve Venue";
    bool isAdmin = User.IsInRole("Admin") || User.IsInRole("SuperAdmin");
    bool isFacilitator = User.IsInRole("Facilitator");
    string displayName = User?.Identity?.Name ?? "Facilitator";
}

@section Styles {
    <style>
        :root {
            --vb-red: #b31217;
            --vb-red-alt: #9d1117;
            --vb-orange: #ff7a18;
            --vb-bg: #f7f8fb;
            --vb-panel: #ffffff;
            --vb-border: #e6e9f0;
            --vb-border-alt: #d0d4d9;
            --vb-muted: #64748b;
            --vb-text: #0f172a;
            --vb-focus: 0 0 0 4px rgba(179,18,23,.14);
            --vb-grad: linear-gradient(135deg,#320606,#b31217 55%,#ff7a18);
            --vb-shadow-1: 0 14px 42px -18px rgba(50,6,6,.28);
            --vb-shadow-2: 0 8px 24px rgba(15,23,42,.08);
            --vb-r-lg: 26px;
            --vb-r-md: 18px;
            --vb-r-sm: 12px;
            --vb-t: 250ms cubic-bezier(.2,.75,.2,1);
        }

        .vb-shell { max-width:1440px; margin:0 auto; padding:1.25rem 1rem 3.5rem; }

        .vb-hero {
            position:relative; border-radius:var(--vb-r-lg);
            background:var(--vb-grad); color:#fff;
            padding:1.5rem 1.5rem 1.25rem; overflow:hidden;
            box-shadow:var(--vb-shadow-1);
        }
        .vb-hero::before {
            content:""; position:absolute; inset:-140px -140px auto auto;
            width:400px; height:400px;
            background:radial-gradient(circle,rgba(255,255,255,.18),transparent 60%);
            transform:rotate(20deg); pointer-events:none;
        }
        .vb-hero-row { position:relative; display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap; }
        .vb-hero-left { display:flex; align-items:center; gap:.95rem; }
        .vb-hero-icon {
            width:56px; height:56px; border-radius:18px;
            background:rgba(255,255,255,.16); border:1px solid rgba(255,255,255,.22);
            backdrop-filter:blur(10px); display:grid; place-items:center;
            box-shadow:0 10px 24px rgba(0,0,0,.18); flex:0 0 auto; font-size:1.25rem;
        }
        .vb-hero h1 { font-size:1.35rem; font-weight:900; margin:0; letter-spacing:.3px; }
        .vb-hero p  { margin:.25rem 0 0; opacity:.92; font-size:.85rem; font-weight:500; }

        .vb-stepper {
            display:flex; gap:.5rem; flex-wrap:wrap;
            margin-top:1.25rem; padding:.6rem .7rem;
            background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.12);
            border-radius:50px; backdrop-filter:blur(6px);
        }
        .vb-step {
            display:inline-flex; align-items:center; gap:.45rem;
            padding:.45rem .8rem; border-radius:50px;
            font-size:.6rem; font-weight:800; letter-spacing:.18rem;
            text-transform:uppercase; color:rgba(255,255,255,.55);
            border:1px solid transparent; transition:var(--vb-t);
        }
        .vb-step.active {
            background:rgba(255,255,255,.18); border-color:rgba(255,255,255,.28);
            color:#fff; box-shadow:0 4px 14px rgba(0,0,0,.15);
        }
        .vb-step .num {
            width:22px; height:22px; border-radius:50%; display:grid; place-items:center;
            font-size:.55rem; font-weight:900; background:rgba(255,255,255,.12);
        }
        .vb-step.active .num { background:rgba(255,255,255,.3); }

        .vb-card {
            background:rgba(255,255,255,.88); border:1px solid var(--vb-border);
            border-radius:var(--vb-r-lg); box-shadow:0 10px 30px rgba(15,23,42,.06);
            overflow:hidden; margin-top:1.15rem;
        }
        .vb-card-head {
            padding:1.1rem 1.25rem .95rem;
            display:flex; align-items:end; justify-content:space-between; gap:1rem;
            background:linear-gradient(180deg,rgba(255,255,255,.95),rgba(255,255,255,.7));
        }
        .vb-card-head h2 {
            margin:0; font-size:.82rem; font-weight:900;
            letter-spacing:.16rem; text-transform:uppercase; color:var(--vb-red);
            display:flex; gap:.5rem; align-items:center;
        }
        .vb-card-head p { margin:.2rem 0 0; color:var(--vb-muted); font-size:.78rem; font-weight:600; }
        .vb-card-body { padding:1.15rem 1.25rem 1.35rem; background:var(--vb-panel); }

        .vb-field-grid {
            display:grid; gap:.9rem;
            grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
        }
        .vb-field { display:grid; gap:.3rem; }
        .vb-field label {
            font-size:.6rem; font-weight:800; letter-spacing:.14rem;
            text-transform:uppercase; color:var(--vb-muted);
            display:inline-flex; gap:.4rem; align-items:center;
        }
        .vb-field label.required::after { content:'*'; color:var(--vb-red); font-weight:900; }
        .vb-input-wrap {
            display:flex; align-items:center; gap:.55rem;
            background:#fff; border:1px solid var(--vb-border);
            padding:.65rem .8rem; border-radius:14px; transition:var(--vb-t);
        }
        .vb-input-wrap:focus-within { border-color:var(--vb-red); box-shadow:var(--vb-focus); }
        .vb-input-wrap i { font-size:.72rem; color:#94a3b8; flex:0 0 auto; }
        .vb-input-wrap input, .vb-input-wrap select {
            border:none; outline:none; background:transparent;
            font-size:.78rem; font-weight:650; color:var(--vb-text); width:100%;
        }

        .vb-btn {
            font-size:.58rem; letter-spacing:.14rem; font-weight:800;
            text-transform:uppercase; padding:.6rem 1rem; border-radius:14px;
            border:1px solid var(--vb-border); background:#fff; color:var(--vb-red);
            display:inline-flex; align-items:center; gap:.5rem;
            cursor:pointer; transition:var(--vb-t); text-decoration:none;
        }
        .vb-btn:hover { background:var(--vb-grad); color:#fff; border-color:var(--vb-red); transform:translateY(-1px); box-shadow:var(--vb-shadow-2); }
        .vb-btn:active { transform:translateY(0); }
        .vb-btn:disabled { opacity:.45; pointer-events:none; }
        .vb-btn.primary { background:var(--vb-grad); color:#fff; border-color:var(--vb-red); }
        .vb-btn.primary:hover { filter:brightness(.96); }

        .vb-actions { display:flex; flex-wrap:wrap; gap:.6rem; margin-top:.85rem; }

        .vb-venue-grid {
            display:grid; gap:1rem;
            grid-template-columns:repeat(auto-fill,minmax(290px,1fr));
            margin-top:.85rem;
        }
        .vb-venue-card {
            background:#fff; border:1px solid var(--vb-border);
            border-radius:var(--vb-r-md); padding:1rem 1.05rem;
            display:flex; flex-direction:column; gap:.6rem;
            transition:var(--vb-t); position:relative; cursor:pointer;
        }
        .vb-venue-card:hover { box-shadow:0 10px 36px -14px rgba(179,18,23,.22); transform:translateY(-3px); }
        .vb-venue-card.selected { border-color:var(--vb-red); box-shadow:0 0 0 3px rgba(179,18,23,.15), 0 10px 36px -14px rgba(179,18,23,.22); }
        .vb-venue-card.unavailable { opacity:.55; pointer-events:none; }
        .vb-venue-card.suggested::before {
            content:'★ SUGGESTED'; position:absolute; top:.65rem; right:.65rem;
            font-size:.42rem; letter-spacing:.18rem; font-weight:900;
            text-transform:uppercase; background:var(--vb-grad); color:#fff;
            padding:.3rem .6rem; border-radius:50px;
        }
        .vb-venue-card h3 {
            margin:0; font-size:.78rem; font-weight:900;
            letter-spacing:.08rem; color:var(--vb-text);
        }
        .vb-venue-meta {
            display:flex; flex-wrap:wrap; gap:.4rem;
        }
        .vb-pill {
            display:inline-flex; align-items:center; gap:.35rem;
            padding:.3rem .55rem; border-radius:50px; font-size:.55rem;
            font-weight:800; border:1px solid var(--vb-border); background:#fff; color:var(--vb-muted);
        }
        .vb-pill-ok { background:rgba(16,185,129,.1); border-color:rgba(16,185,129,.25); color:#065f46; }
        .vb-pill-no { background:rgba(239,68,68,.08); border-color:rgba(239,68,68,.22); color:#7f1d1d; }
        .vb-venue-card .vb-tooltip {
            display:none; font-size:.58rem; color:#7f1d1d; font-weight:700;
            background:rgba(239,68,68,.06); padding:.4rem .6rem; border-radius:10px;
            border:1px solid rgba(239,68,68,.15);
        }
        .vb-venue-card.unavailable .vb-tooltip { display:block; }

        .vb-empty {
            border:2px dashed var(--vb-border-alt); border-radius:var(--vb-r-md);
            padding:1.25rem; text-align:center; font-size:.68rem;
            font-weight:700; color:var(--vb-muted);
        }
        .vb-loader { display:none; align-items:center; gap:.5rem; color:var(--vb-red); font-weight:900; font-size:.65rem; letter-spacing:.1rem; text-transform:uppercase; }
        .vb-loader.show { display:inline-flex; }
        .vb-spin { width:16px; height:16px; border-radius:50%; border:3px solid rgba(179,18,23,.25); border-top-color:var(--vb-red); animation:vb-rot .75s linear infinite; }
        @@keyframes vb-rot { to { transform:rotate(360deg); } }
        @@keyframes vb-fade { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
        .vb-fade-in { animation:vb-fade .4s ease; }
    </style>
}

<section class="vb-shell">

    <header class="vb-hero">
        <div class="vb-hero-row">
            <div class="vb-hero-left">
                <div class="vb-hero-icon"><i class="fa fa-map-pin"></i></div>
                <div>
                    <h1>Reserve a Venue</h1>
                    <p>Stage 1 — Secure a slot, then await HOD approval before booking your assessment.</p>
                </div>
            </div>
            <a class="vb-btn" href="@Url.Action("BookAssessment", "VenueBooking")" style="background:rgba(255,255,255,.14);border-color:rgba(255,255,255,.22);color:#fff;">
                <i class="fa fa-calendar-check"></i> Go to Stage 2
            </a>
        </div>

        <div class="vb-stepper">
            <div class="vb-step active" id="step1"><span class="num">1</span> Filter &amp; Select</div>
            <div class="vb-step" id="step2"><span class="num">2</span> Confirm Reservation</div>
            <div class="vb-step" id="step3"><span class="num">3</span> Awaiting HOD</div>
        </div>
    </header>

    <div class="vb-card">
        <div class="vb-card-head">
            <div>
                <h2><i class="fa fa-filter"></i> Search Available Venues</h2>
                <p>Select campus, date &amp; time, and expected students. The system returns only eligible venues in real time.</p>
            </div>
        </div>
        <div class="vb-card-body">
            <form id="venueFilterForm" autocomplete="off">
                @Html.AntiForgeryToken()
                <div class="vb-field-grid">
                    <div class="vb-field">
                        <label class="required"><i class="fa fa-building"></i> Campus</label>
                        <div class="vb-input-wrap">
                            <i class="fa fa-building-columns"></i>
                            <select name="campus" required>
                                <option value="">— Select Campus —</option>
                                <option value="Kabokweni">Kabokweni</option>
                                <option value="Malelane">Malelane</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                    </div>
                    <div class="vb-field">
                        <label class="required"><i class="fa fa-users"></i> Expected Students</label>
                        <div class="vb-input-wrap">
                            <i class="fa fa-hashtag"></i>
                            <input type="number" name="expectedStudents" min="1" max="2000" placeholder="e.g. 45" required />
                        </div>
                    </div>
                    <div class="vb-field">
                        <label class="required"><i class="fa fa-calendar"></i> Date</label>
                        <div class="vb-input-wrap">
                            <i class="fa fa-calendar-day"></i>
                            <input type="date" name="date" required />
                        </div>
                    </div>
                    <div class="vb-field">
                        <label class="required"><i class="fa fa-clock"></i> Start Time</label>
                        <div class="vb-input-wrap">
                            <i class="fa fa-hourglass-start"></i>
                            <input type="time" name="startTime" required />
                        </div>
                    </div>
                    <div class="vb-field">
                        <label class="required"><i class="fa fa-clock"></i> End Time</label>
                        <div class="vb-input-wrap">
                            <i class="fa fa-hourglass-end"></i>
                            <input type="time" name="endTime" required />
                        </div>
                    </div>
                </div>
                <div class="vb-actions">
                    <button type="submit" class="vb-btn primary"><i class="fa fa-search"></i> Search Venues</button>
                    <button type="reset" class="vb-btn"><i class="fa fa-undo"></i> Reset</button>
                    <span class="vb-loader" id="searchLoader"><span class="vb-spin"></span> Searching</span>
                </div>
            </form>
        </div>
    </div>

    <div class="vb-card" id="resultsCard" style="display:none;">
        <div class="vb-card-head">
            <div>
                <h2><i class="fa fa-th-large"></i> Available Venues</h2>
                <p>Select one venue below. Greyed-out venues show why they're unavailable.</p>
            </div>
            <span class="vb-pill" id="venueCount" style="font-size:.6rem;"></span>
        </div>
        <div class="vb-card-body">
            <div id="venueResults" class="vb-venue-grid">
                <div class="vb-empty"><i class="fa fa-building"></i> No venues loaded.</div>
            </div>
        </div>
    </div>

    <div class="vb-card" id="confirmCard" style="display:none;">
        <div class="vb-card-head">
            <div>
                <h2><i class="fa fa-check-double"></i> Confirm Reservation</h2>
                <p>Review the details below and submit to create a 24-hour soft hold.</p>
            </div>
        </div>
        <div class="vb-card-body">
            <div id="confirmSummary" style="display:grid;gap:.6rem;"></div>
            <div class="vb-actions" style="margin-top:1rem;">
                <button type="button" class="vb-btn primary" id="btnConfirmReserve"><i class="fa fa-paper-plane"></i> Reserve Venue</button>
                <button type="button" class="vb-btn" id="btnCancelReserve"><i class="fa fa-times"></i> Cancel</button>
                <span class="vb-loader" id="reserveLoader"><span class="vb-spin"></span> Reserving</span>
            </div>
        </div>
    </div>

    <div class="vb-card vb-fade-in" id="successCard" style="display:none;">
        <div class="vb-card-body" style="text-align:center;padding:2.5rem 1.5rem;">
            <div style="width:64px;height:64px;border-radius:50%;background:rgba(16,185,129,.12);display:grid;place-items:center;margin:0 auto .85rem;font-size:1.6rem;color:#059669;">
                <i class="fa fa-circle-check"></i>
            </div>
            <h2 style="margin:0 0 .4rem;font-size:1.1rem;font-weight:900;color:var(--vb-text);">Venue Reserved!</h2>
            <p style="color:var(--vb-muted);font-size:.82rem;font-weight:600;max-width:520px;margin:0 auto;">
                Your reservation is now pending HOD approval. You'll be notified once it's approved,
                after which you can proceed to <strong>Stage 2 — Book Assessment</strong>.
            </p>
            <div class="vb-actions" style="justify-content:center;margin-top:1.2rem;">
                <a class="vb-btn primary" href="@Url.Action("BookAssessment", "VenueBooking")"><i class="fa fa-calendar-check"></i> Stage 2: Book Assessment</a>
                <a class="vb-btn" href="@Url.Action("ReserveVenue", "VenueBooking")"><i class="fa fa-plus"></i> New Reservation</a>
            </div>
        </div>
    </div>

</section>

@section Scripts {
    <script>
        (function() {
            const esc = s => (s??'').toString().replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
            const form       = document.getElementById('venueFilterForm');
            const resultsCard= document.getElementById('resultsCard');
            const venueHost  = document.getElementById('venueResults');
            const countBadge = document.getElementById('venueCount');
            const confirmCard= document.getElementById('confirmCard');
            const confirmSum = document.getElementById('confirmSummary');
            const successCard= document.getElementById('successCard');
            const searchLoad = document.getElementById('searchLoader');
            const reserveLoad= document.getElementById('reserveLoader');
            const steps      = [document.getElementById('step1'),document.getElementById('step2'),document.getElementById('step3')];

            let venues = [];
            let selectedVenue = null;
            let filterSnapshot = {};

            function setStep(n) { steps.forEach((s,i)=> s.classList.toggle('active', i<n)); }
            function show(el)  { el.style.display=''; }
            function hide(el)  { el.style.display='none'; }

            function buildDateUtc(dateStr, timeStr) {
                return new Date(`${dateStr}T${timeStr}:00`).toISOString();
            }

            function pill(text, cls) { return `<span class="vb-pill ${cls||''}"><i class="fa fa-circle-info"></i> ${esc(text)}</span>`; }

            function renderVenues(data) {
                venues = data || [];
                countBadge.textContent = `${venues.length} venue(s)`;
                show(resultsCard);
                setStep(1);

                if (!venues.length) {
                    venueHost.innerHTML = '<div class="vb-empty"><i class="fa fa-ban"></i> No venues match your criteria. Try different filters.</div>';
                    return;
                }

                venueHost.innerHTML = venues.map(v => {
                    const cls = [];
                    if (!v.isAvailable) cls.push('unavailable');
                    if (v.isSuggested) cls.push('suggested');
                    return `
                    <div class="vb-venue-card ${cls.join(' ')}" data-vid="${v.venueId}">
                        <h3>${esc(v.venueName)}</h3>
                        <div class="vb-venue-meta">
                            ${pill(v.campus)} ${pill('Cap: '+v.maxCapacity)}
                            ${pill(v.venueType)}
                            ${v.isAvailable ? pill('Available','vb-pill-ok') : pill('Unavailable','vb-pill-no')}
                        </div>
                        ${v.equipmentChecklist ? `<div style="font-size:.58rem;color:var(--vb-muted);font-weight:600;"><i class="fa fa-toolbox"></i> ${esc(v.equipmentChecklist)}</div>` : ''}
                        <div class="vb-tooltip"><i class="fa fa-triangle-exclamation"></i> ${esc(v.unavailableReason||'Not available')}</div>
                    </div>`;
                }).join('');

                venueHost.querySelectorAll('.vb-venue-card:not(.unavailable)').forEach(card => {
                    card.addEventListener('click', () => selectVenue(card.dataset.vid));
                });
            }

            function selectVenue(vid) {
                selectedVenue = venues.find(v => v.venueId === vid);
                if (!selectedVenue) return;

                venueHost.querySelectorAll('.vb-venue-card').forEach(c => c.classList.remove('selected'));
                venueHost.querySelector(`[data-vid="${vid}"]`)?.classList.add('selected');

                show(confirmCard);
                setStep(2);

                confirmSum.innerHTML = `
                <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:.7rem;">
                    ${summaryItem('fa-building', 'Venue', selectedVenue.venueName)}
                    ${summaryItem('fa-building-columns', 'Campus', filterSnapshot.campus)}
                    ${summaryItem('fa-users', 'Students', filterSnapshot.expectedStudents)}
                    ${summaryItem('fa-calendar', 'Date', filterSnapshot.date)}
                    ${summaryItem('fa-clock', 'Time', filterSnapshot.startTime + ' – ' + filterSnapshot.endTime)}
                </div>`;

                confirmCard.scrollIntoView({ behavior:'smooth', block:'start' });
            }

            function summaryItem(icon, label, value) {
                return `<div style="background:rgba(179,18,23,.04);border:1px solid var(--vb-border);border-radius:14px;padding:.7rem .85rem;">
                    <div style="font-size:.5rem;letter-spacing:.14rem;text-transform:uppercase;font-weight:800;color:var(--vb-muted);margin-bottom:.2rem;">
                        <i class="fa ${icon}"></i> ${esc(label)}
                    </div>
                    <div style="font-size:.82rem;font-weight:800;color:var(--vb-text);">${esc(value)}</div>
                </div>`;
            }

            form.addEventListener('submit', async function(e) {
                e.preventDefault();
                const fd = new FormData(form);
                filterSnapshot = { campus: fd.get('campus'), expectedStudents: fd.get('expectedStudents'), date: fd.get('date'), startTime: fd.get('startTime'), endTime: fd.get('endTime') };

                if (!filterSnapshot.campus || !filterSnapshot.expectedStudents || !filterSnapshot.date || !filterSnapshot.startTime || !filterSnapshot.endTime) return;

                searchLoad.classList.add('show');
                hide(confirmCard); hide(successCard); selectedVenue = null;

                try {
                    const qs = new URLSearchParams({
                        campus: filterSnapshot.campus,
                        expectedStudents: filterSnapshot.expectedStudents,
                        date: filterSnapshot.date,
                        startUtc: buildDateUtc(filterSnapshot.date, filterSnapshot.startTime),
                        endUtc: buildDateUtc(filterSnapshot.date, filterSnapshot.endTime)
                    });
                    const res = await fetch(`@Url.Action("AvailableVenues", "VenueBooking")?${qs}`, { headers:{'Accept':'application/json'} });
                    if (!res.ok) throw new Error('HTTP ' + res.status);
                    renderVenues(await res.json());
                } catch(ex) {
                    venueHost.innerHTML = `<div class="vb-empty"><i class="fa fa-triangle-exclamation"></i> ${esc(ex.message)}</div>`;
                    show(resultsCard);
                } finally {
                    searchLoad.classList.remove('show');
                }
            });

            document.getElementById('btnConfirmReserve').addEventListener('click', async function() {
                if (!selectedVenue) return;
                reserveLoad.classList.add('show');
                this.disabled = true;

                const token = form.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const payload = {
                    venueId: selectedVenue.venueId,
                    campus: filterSnapshot.campus,
                    expectedStudents: parseInt(filterSnapshot.expectedStudents),
                    reservedDate: filterSnapshot.date,
                    startTimeUtc: buildDateUtc(filterSnapshot.date, filterSnapshot.startTime),
                    endTimeUtc: buildDateUtc(filterSnapshot.date, filterSnapshot.endTime)
                };

                try {
                    const res = await fetch('@Url.Action("ReserveVenue", "VenueBooking")', {
                        method:'POST',
                        headers:{ 'Content-Type':'application/json', 'Accept':'application/json', ...(token ? {'RequestVerificationToken':token}:{}) },
                        body: JSON.stringify(payload)
                    });
                    const data = await res.json();
                    if (!res.ok) throw new Error(data.message || 'Reservation failed');

                    hide(resultsCard); hide(confirmCard);
                    show(successCard);
                    setStep(3);
                    successCard.scrollIntoView({ behavior:'smooth', block:'center' });
                } catch(ex) {
                    alert(ex.message);
                } finally {
                    reserveLoad.classList.remove('show');
                    this.disabled = false;
                }
            });

            document.getElementById('btnCancelReserve').addEventListener('click', () => {
                hide(confirmCard); selectedVenue = null; setStep(1);
                venueHost.querySelectorAll('.vb-venue-card').forEach(c => c.classList.remove('selected'));
            });
        })();
    </script>
}