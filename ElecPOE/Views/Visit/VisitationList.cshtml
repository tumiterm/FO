@model IEnumerable<ForekOnline.Domain.ViewModels.VisitationViewModel>
@{
    ViewData["Title"] = "Visitations";
    var visits       = (Model ?? Enumerable.Empty<ForekOnline.Domain.ViewModels.VisitationViewModel>()).ToList();
    string companyName = (string?)ViewData["result"] ?? "Company";
    var mentors   = visits.Select(v => v.Mentor).Where(m => !string.IsNullOrWhiteSpace(m)).Distinct().OrderBy(m => m).ToList();
    var visitors  = visits.Select(v => v.VisitBy).Where(m => !string.IsNullOrWhiteSpace(m)).Distinct().OrderBy(m => m).ToList();
    var companyId = ViewData["CompanyId"];
}

<link rel="stylesheet" href="~/css/Enrollment.css" />

<style>
.vl-shell {
    max-width: 1320px;
    margin: 0 auto;
    padding: 2.1rem 1.35rem 4rem;
}

.vl-hero {
    position: relative;
    overflow: hidden;
    background: var(--es-bg);
    border: 1px solid var(--es-border);
    border-radius: var(--es-radius-xl);
    box-shadow: var(--es-shadow-lg);
    padding: 1.6rem 1.75rem;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.25rem;
    align-items: center;
}
.vl-hero::before {
    content: "";
    position: absolute; inset: 0;
    background: var(--es-grad-soft);
    pointer-events: none;
}
.vl-hero__icon {
    width: 82px; height: 82px;
    border-radius: 26px;
    background: var(--es-grad);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 2.35rem;
    box-shadow: 0 16px 32px -16px rgba(179,18,23,.45);
    position: relative; z-index: 1;
    animation: vl-pop .65s cubic-bezier(.34,1.56,.64,1) both;
}
@@keyframes vl-pop {
    from { transform: scale(.5) rotate(-8deg); opacity: 0; }
    to   { transform: scale(1) rotate(0);      opacity: 1; }
}
.vl-hero__body { position: relative; z-index: 1; }
.vl-hero__actions {
    position: relative; z-index: 1;
    display: flex; flex-wrap: wrap; gap: .55rem; justify-content: flex-end;
}

.vl-stats {
    margin-top: 1.4rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: .75rem;
}
.vl-stat {
    background: rgba(255,255,255,.82);
    border: 1px solid rgba(179,18,23,.08);
    border-radius: 18px;
    padding: .85rem 1rem;
    box-shadow: var(--es-shadow-sm);
    position: relative; overflow: hidden;
    transition: transform .28s, box-shadow .28s;
}
.vl-stat:hover { transform: translateY(-3px); box-shadow: var(--es-shadow-md); }
.vl-stat::after {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0;
    height: 3px; background: var(--es-grad);
    border-radius: 0 0 18px 18px; opacity: .55;
}
.vl-stat__label {
    color: var(--es-muted); font-size: .62rem; font-weight: 800;
    letter-spacing: .14rem; text-transform: uppercase; margin-bottom: .3rem;
}
.vl-stat__value {
    font-size: 1.32rem; font-weight: 800; line-height: 1.1;
    background: var(--es-grad);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}

/* ── Content grid (mirrors enroll-grid) ── */
.vl-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 1.5rem;
    margin-top: 1.8rem;
}
@@media (max-width: 900px) { .vl-grid { grid-template-columns: 1fr; } }

.vl-filter-card {
    display: flex; flex-direction: column; gap: 1.1rem;
}
.vl-filter-group {
    display: flex; flex-direction: column; gap: .38rem;
}
.vl-filter-group label {
    font-size: .58rem; letter-spacing: .16rem; font-weight: 800;
    text-transform: uppercase; color: var(--es-muted);
    display: flex; align-items: center; gap: .38rem;
}
.vl-filter-group label i { color: var(--es-red); }
.vl-filter-input {
    background: var(--es-bg);
    border: 1.5px solid var(--es-border);
    border-radius: var(--es-radius-md);
    font-size: .72rem; font-family: inherit;
    color: var(--es-text);
    padding: .58rem .75rem;
    transition: border-color var(--es-speed), box-shadow var(--es-speed);
    width: 100%;
}
.vl-filter-input:focus {
    outline: none;
    border-color: var(--es-red);
    box-shadow: 0 0 0 .18rem rgba(179,18,23,.14);
}
.vl-search-wrap { position: relative; }
.vl-search-wrap i {
    position: absolute; top: 50%; left: .75rem;
    transform: translateY(-50%);
    color: #aab; font-size: .72rem; pointer-events: none;
}
.vl-search-wrap .vl-filter-input { padding-left: 2.2rem; }

.vl-filter-actions {
    display: flex; flex-direction: column; gap: .5rem; margin-top: .3rem;
}

.vl-main { min-width: 0; display: flex; flex-direction: column; gap: 1.1rem; }

.vl-doc-grid { display: flex; flex-direction: column; gap: .65rem; }
.vl-visit-row {
    display: flex; align-items: center; flex-wrap: wrap; gap: .9rem;
    background: var(--es-bg);
    border: 1px solid var(--es-border);
    border-radius: var(--es-radius-md);
    padding: .9rem 1.05rem;
    transition: transform .25s, box-shadow .25s, border-color .25s;
    animation: vl-rise .4s cubic-bezier(.22,1,.36,1) both;
}
.vl-visit-row:hover {
    transform: translateY(-2px);
    box-shadow: var(--es-shadow-md);
    border-color: var(--es-border-strong);
    background: #fff;
}
@@keyframes vl-rise {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
}
.vl-row-icon {
    width: 46px; height: 46px; border-radius: 14px; flex-shrink: 0;
    background: var(--es-grad);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.15rem; color: #fff;
    box-shadow: 0 6px 18px -6px rgba(179,18,23,.42);
}
.vl-row-info { flex: 1; min-width: 120px; }
.vl-row-title { font-size: .76rem; font-weight: 700; color: var(--es-text); }
.vl-row-meta {
    font-size: .6rem; color: var(--es-muted);
    margin-top: .18rem; display: flex; align-items: center; gap: .55rem; flex-wrap: wrap;
}
.vl-row-meta i { font-size: .56rem; }
.vl-row-actions { display: flex; gap: .42rem; flex-shrink: 0; flex-wrap: wrap; }

.vl-chip {
    display: inline-flex; align-items: center; gap: .3rem;
    font-size: .5rem; letter-spacing: .1rem; font-weight: 700; text-transform: uppercase;
    padding: .28rem .55rem; border-radius: 30px;
    background: #f0f1f3; color: #555; border: 1px solid #e0e4ea;
}
.vl-chip-yes { background: #e8f9ef; color: #137a44; border-color: #b7e6c8; }
.vl-chip-no  { background: #ffe6ea; color: #b31217; border-color: #f3b4ba; }

.vl-empty {
    text-align: center; padding: 3.5rem 1rem;
    display: flex; flex-direction: column; align-items: center; gap: .75rem;
    color: var(--es-muted); font-size: .8rem;
}
.vl-empty i { font-size: 2.6rem; opacity: .25; }

.vl-filtered-chip {
    display: none;
    font-size: .5rem; font-weight: 700; letter-spacing: .12rem; text-transform: uppercase;
    padding: .38rem .7rem; border-radius: 30px;
    background: var(--es-rose); color: var(--es-red); border: 1px solid rgba(179,18,23,.18);
    align-items: center; gap: .35rem;
}
.vl-filtered-chip.show { display: inline-flex; }

@@media (max-width: 860px) {
    .vl-hero { grid-template-columns: auto 1fr; }
    .vl-hero__actions { grid-column: 1/-1; justify-content: flex-start; }
}
@@media (max-width: 580px) {
    .vl-hero { padding: 1.25rem 1.1rem 1rem; }
    .vl-hero__icon { width: 64px; height: 64px; font-size: 1.65rem; border-radius: 18px; }
}
</style>

<div class="vl-shell fade-up">

    <div class="vl-hero">
        <div class="vl-hero__icon"><i class="fa fa-archway"></i></div>
        <div class="vl-hero__body">
            <div class="enroll-kicker">
                <i class="fa fa-building"></i>
                Company Visitation Suite
            </div>
            <h1 class="enroll-title">Visitations</h1>
            <p class="enroll-subtitle" style="margin-top:.4rem;">
                Track, audit and manage all workplace visits for
                <strong>@companyName</strong>.
                Filter records, open a visit detail or log a new visitation below.
            </p>
        </div>
        <div class="vl-hero__actions">
            <a asp-action="Visitation"
               asp-route-CompanyId="@companyId"
               class="btn-premium btn-premium--primary">
                <i class="fa fa-plus-circle me-2"></i>New Visitation
            </a>
            <a asp-action="HostCompanies" class="btn-premium btn-premium--ghost">
                <i class="fa fa-arrow-left me-2"></i>Back
            </a>
        </div>
    </div>

    <div class="vl-stats">
        <div class="vl-stat">
            <div class="vl-stat__label">Company</div>
            <div class="vl-stat__value" style="font-size:.95rem;-webkit-text-fill-color:var(--es-dark);">@companyName</div>
        </div>
        <div class="vl-stat">
            <div class="vl-stat__label">Total Visits</div>
            <div class="vl-stat__value" id="statTotal">@visits.Count</div>
        </div>
        <div class="vl-stat">
            <div class="vl-stat__label">With Report</div>
            <div class="vl-stat__value" id="statReports">@visits.Count(v => v.HasReport)</div>
        </div>
        <div class="vl-stat">
            <div class="vl-stat__label">Visible</div>
            <div class="vl-stat__value" id="statVisible">@visits.Count</div>
        </div>
    </div>

    <div class="vl-grid">
        <aside>
            <div class="glass-card progress-card fade-up">
                <h5 class="progress-title">
                    <i class="fa fa-filter"></i>
                    Filter Visitations
                </h5>

                <div class="vl-filter-card">
                    <div class="vl-filter-group">
                        <label><i class="fa fa-magnifying-glass"></i> Search</label>
                        <div class="vl-search-wrap">
                            <i class="fa fa-search"></i>
                            <input id="searchBox" class="vl-filter-input"
                                   type="text"
                                   placeholder="Mentor / visitor / notes…"
                                   autocomplete="off" />
                        </div>
                    </div>

                    <div class="vl-filter-group">
                        <label><i class="fa fa-chalkboard-user"></i> Mentor</label>
                        <select id="mentorFilter" class="vl-filter-input">
                            <option value="">Any</option>
                            @foreach (var m in mentors) { <option value="@m">@m</option> }
                        </select>
                    </div>

                    <div class="vl-filter-group">
                        <label><i class="fa fa-user-tie"></i> Visited By</label>
                        <select id="visitorFilter" class="vl-filter-input">
                            <option value="">Any</option>
                            @foreach (var vb in visitors) { <option value="@vb">@vb</option> }
                        </select>
                    </div>

                    <div class="vl-filter-group">
                        <label><i class="fa fa-file-circle-check"></i> Report</label>
                        <select id="reportFilter" class="vl-filter-input">
                            <option value="">Any</option>
                            <option value="yes">Has Report</option>
                            <option value="no">No Report</option>
                        </select>
                    </div>

                    <div class="vl-filter-group">
                        <label><i class="fa fa-calendar-day"></i> Date From</label>
                        <input type="date" id="fromDate" class="vl-filter-input" />
                    </div>

                    <div class="vl-filter-group">
                        <label><i class="fa fa-calendar-day"></i> Date To</label>
                        <input type="date" id="toDate" class="vl-filter-input" />
                    </div>

                    <div class="vl-filter-actions">
                        <button id="btnClearFilters" type="button" class="btn-premium btn-premium--ghost" style="justify-content:center;">
                            <i class="fa fa-filter-circle-xmark me-2"></i>Clear Filters
                        </button>
                        <button id="btnExport" type="button" class="btn-premium" style="justify-content:center;">
                            <i class="fa fa-file-export me-2"></i>Export CSV
                        </button>
                    </div>

                    <div class="lookup-badge-row">
                        <span class="vl-filtered-chip" id="filteredChip">
                            <i class="fa fa-filter"></i> Filters active
                        </span>
                        <span class="smart-badge smart-badge--soft" id="perfBadge"></span>
                    </div>
                </div>
            </div>
        </aside>
        <main class="vl-main">
            <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem;">
                <span class="smart-badge smart-badge--soft" id="rowsInfo">
                    <i class="fa fa-database"></i> @visits.Count visit(s)
                </span>
                <button id="btnRefresh" type="button" class="btn-premium btn-premium--ghost btn-sm"
                        style="font-size:.55rem;padding:.46rem .85rem;">
                    <i class="fa fa-rotate me-1"></i>Refresh
                </button>
            </div>
            <div class="vl-doc-grid" id="visitGrid">
                @if (!visits.Any())
                {
                    <div class="vl-empty" id="emptyState">
                        <i class="fa fa-folder-open"></i>
                        <span>No visitations recorded for <strong>@companyName</strong> yet.<br />
                              Use the <em>New Visitation</em> button above to add the first one.</span>
                    </div>
                }
                else
                {
                    foreach (var v in visits)
                    {
                        var dateTxt = v.Date.ToString("yyyy-MM-dd");
                        var has     = v.HasReport;
                        <div class="vl-visit-row"
                             data-text="@($"{v.Mentor} {v.VisitBy} {(has ? "yes" : "no")} {dateTxt}".ToLower())"
                             data-mentor="@v.Mentor"
                             data-visitor="@v.VisitBy"
                             data-report="@(has ? "yes" : "no")"
                             data-date="@dateTxt">

                            <div class="vl-row-icon"><i class="fa fa-building-user"></i></div>

                            <div class="vl-row-info">
                                <div class="vl-row-title">@(string.IsNullOrWhiteSpace(v.Mentor) ? "—" : v.Mentor)</div>
                                <div class="vl-row-meta">
                                    <i class="fa fa-user-tie"></i> @v.VisitBy
                                    &nbsp;·&nbsp;
                                    <i class="fa fa-calendar"></i> @dateTxt
                                    @if (!string.IsNullOrWhiteSpace(v.VisitPurpose))
                                    {
                                        <text>&nbsp;·&nbsp;<i class="fa fa-bullseye"></i> @v.VisitPurpose</text>
                                    }
                                    &nbsp;·&nbsp;
                                    <span class="vl-chip @(has ? "vl-chip-yes" : "vl-chip-no")">
                                        <i class="fa @(has ? "fa-check-circle" : "fa-times-circle")"></i>
                                        @(has ? "Report" : "No Report")
                                    </span>
                                </div>
                            </div>

                            <div class="vl-row-actions">
                                <a class="btn-premium btn-premium--primary btn-sm"
                                   asp-action="OnModifyVisitation"
                                   asp-route-VisitId="@v.VisitId"
                                   style="font-size:.55rem;padding:.46rem .85rem;">
                                    <i class="fa fa-folder-open me-1"></i>Open
                                </a>
                                @if (has && !string.IsNullOrWhiteSpace(v.Report))
                                {
                                    <a class="btn-premium btn-sm"
                                       asp-action="AttachmentDownload"
                                       asp-route-filename="@v.Report"
                                       style="font-size:.55rem;padding:.46rem .85rem;">
                                        <i class="fa fa-download me-1"></i>Report
                                    </a>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
            <div class="vl-empty" id="noResults" style="display:none;">
                <i class="fa fa-magnifying-glass"></i>
                <span>No visitations match your current filter criteria.</span>
            </div>

        </main>
    </div>
</div>

<script>
(function () {
    'use strict';

    const grid         = document.getElementById('visitGrid');
    const noResults    = document.getElementById('noResults');
    const emptyState   = document.getElementById('emptyState');
    const rowsInfo     = document.getElementById('rowsInfo');
    const statVisible  = document.getElementById('statVisible');
    const perfBadge    = document.getElementById('perfBadge');
    const filteredChip = document.getElementById('filteredChip');

    const searchBox     = document.getElementById('searchBox');
    const mentorFilter  = document.getElementById('mentorFilter');
    const visitorFilter = document.getElementById('visitorFilter');
    const reportFilter  = document.getElementById('reportFilter');
    const fromDate      = document.getElementById('fromDate');
    const toDate        = document.getElementById('toDate');

    function norm(v)  { return (v || '').toString().toLowerCase().trim(); }
    function pd(d)    { if (!d) return null; const dt = new Date(d); return isNaN(dt) ? null : dt; }

    function apply() {
        const t0 = performance.now();
        const q  = norm(searchBox.value);
        const m  = mentorFilter.value;
        const vb = visitorFilter.value;
        const rp = reportFilter.value;
        const f  = fromDate.value ? pd(fromDate.value) : null;
        const t  = toDate.value   ? pd(toDate.value)   : null;

        const rows  = Array.from(grid.querySelectorAll('.vl-visit-row'));
        let shown   = 0;

        rows.forEach(r => {
            const txt  = norm(r.getAttribute('data-text'));
            const dm   = r.getAttribute('data-mentor')  || '';
            const dv   = r.getAttribute('data-visitor') || '';
            const dr   = r.getAttribute('data-report')  || '';
            const dObj = pd(r.getAttribute('data-date'));

            let ok = true;
            if (q  && !txt.includes(q))            ok = false;
            if (m  && dm !== m)                    ok = false;
            if (vb && dv !== vb)                   ok = false;
            if (rp && dr !== rp)                   ok = false;
            if (f  && (!dObj || dObj < f))         ok = false;
            if (t  && (!dObj || dObj > t))         ok = false;

            r.style.display = ok ? '' : 'none';
            if (ok) shown++;
        });

        const total     = rows.length;
        const filtering = !!(q || m || vb || rp || f || t);

        rowsInfo.innerHTML = `<i class="fa fa-database"></i> Showing ${shown} of ${total} visit(s)${filtering ? ' (filtered)' : ''}`;
        if (statVisible) statVisible.textContent = shown;
        filteredChip.classList.toggle('show', filtering);
        noResults.style.display    = (total > 0 && shown === 0) ? 'flex' : 'none';
        if (emptyState) emptyState.style.display = total === 0 ? 'flex' : 'none';
        perfBadge.innerHTML = `<i class="fa fa-bolt"></i> ${(performance.now() - t0).toFixed(1)} ms`;
    }

    [searchBox, mentorFilter, visitorFilter, reportFilter].forEach(el =>
        el?.addEventListener('input', apply));
    [mentorFilter, visitorFilter, reportFilter, fromDate, toDate].forEach(el =>
        el?.addEventListener('change', apply));

    document.getElementById('btnClearFilters')?.addEventListener('click', () => {
        searchBox.value = mentorFilter.value = visitorFilter.value = reportFilter.value = '';
        fromDate.value  = toDate.value = '';
        apply();
    });

    document.getElementById('btnRefresh')?.addEventListener('click', () => location.reload());

    document.getElementById('btnExport')?.addEventListener('click', () => {
        const visible = Array.from(grid.querySelectorAll('.vl-visit-row')).filter(r => r.style.display !== 'none');
        if (!visible.length) { alert('No rows to export.'); return; }

        const lines = ['"Mentor","Visited By","Date","Has Report","Purpose"'];
        visible.forEach(r => {
            const cells = [
                r.getAttribute('data-mentor')  ?? '',
                r.getAttribute('data-visitor') ?? '',
                r.getAttribute('data-date')    ?? '',
                r.getAttribute('data-report')  ?? '',
                r.querySelector('.vl-row-meta')?.innerText?.replace(/\s+/g,' ').trim() ?? ''
            ].map(v => '"' + v.replace(/"/g, '""') + '"');
            lines.push(cells.join(','));
        });

        const blob = new Blob([lines.join('\r\n')], { type: 'text/csv;charset=utf-8;' });
        const a    = Object.assign(document.createElement('a'), {
            href:     URL.createObjectURL(blob),
            download: `visitations-${new Date().toISOString().slice(0, 10)}.csv`
        });
        document.body.appendChild(a); a.click(); document.body.removeChild(a);
    });

    apply();
})();
</script>
