@model ForekOnline.Domain.ViewModels.VisitViewModel
@{
    ViewData["Title"] = "New Visitation";
    var compId = ViewData["CompId"];
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css"/>

<style>
:root{
    --vi-bg:#ffffff;--vi-bg-alt:#f6f8fa;--vi-border:#e2e6ea;--vi-border-strong:#cbd2d8;
    --vi-accent:#7d0e11;--vi-accent-grad:linear-gradient(120deg,#7d0e11,#b31217 55%,#ff7a18);
    --vi-soft:#fff5f3;--vi-text:#1f262e;
    --vi-radius-xl:34px;--vi-radius:22px;--vi-radius:14px;
    --vi-focus:0 0 0 .15rem #b3121725;--vi-shadow:0 14px 42px -18px rgba(125,14,17,.3),0 6px 20px -10px rgba(125,14,17,.14);
    font-family:'Segoe UI',system-ui,sans-serif;
}
.page-shell{max-width:1250px;margin:0 auto;padding:1.85rem 1.15rem 3rem;}
.header-band{
    background:var(--vi-bg);border:1px solid var(--vi-border);border-radius:var(--vi-radius-xl);
    padding:1.25rem 1.55rem 1.15rem;display:flex;gap:1.25rem;flex-wrap:wrap;align-items:center;position:relative;overflow:hidden;
}
.header-band:before{content:"";position:absolute;inset:0;background:linear-gradient(140deg,#7d0e1114,#b3121714,#ff7a1818);pointer-events:none;}
.icon-pill{width:78px;height:78px;border-radius:26px;background:var(--vi-accent-grad);display:flex;align-items:center;justify-content:center;font-size:2.05rem;color:#fff;box-shadow:0 12px 30px -12px rgba(179,18,23,.55);}
.header-band h1{margin:0;font-size:1.55rem;font-weight:600;letter-spacing:.55px;color:#222;display:flex;align-items:center;gap:.6rem;}
.tagline{font-size:.58rem;letter-spacing:.18rem;font-weight:700;background:var(--vi-soft);color:var(--vi-accent);padding:.5rem .9rem;border-radius:40px;text-transform:uppercase;display:inline-flex;gap:.45rem;align-items:center;}
.toolbar{margin-left:auto;display:flex;gap:.6rem;flex-wrap:wrap;}

.btn-base,.btn-accent,.btn-outline{
    font-size:.58rem;letter-spacing:.12rem;font-weight:600;text-transform:uppercase;
    padding:.6rem 1.05rem;border-radius:16px;border:1px solid var(--vi-border);
    background:#fff;color:var(--vi-accent);display:inline-flex;align-items:center;gap:.5rem;
    cursor:pointer;text-decoration:none;transition:.35s;
}
.btn-base:hover,.btn-outline:hover{background:var(--vi-accent-grad);color:#fff;border-color:var(--vi-accent);box-shadow:var(--vi-shadow);}
.btn-accent{background:var(--vi-accent-grad);color:#fff;border:1px solid var(--vi-accent);}
.btn-accent:hover{filter:brightness(.94);}

.layout-grid{margin-top:1.6rem;display:grid;gap:1.5rem;grid-template-columns:repeat(auto-fit,minmax(520px,1fr));align-items:start;}
.section-card{
    background:var(--vi-bg);border:1px solid var(--vi-border);border-radius:28px;
    padding:1.2rem 1.2rem 1.15rem;display:flex;flex-direction:column;gap:1.15rem;position:relative;overflow:hidden;
}
.section-card:before{content:"";position:absolute;inset:0;background:linear-gradient(140deg,#7d0e110e,#b312170e,#ff7a1810);pointer-events:none;}
.section-head{display:flex;align-items:center;gap:.65rem;flex-wrap:wrap;}
.section-head h2{margin:.1rem 0;font-size:.82rem;letter-spacing:.22rem;font-weight:700;text-transform:uppercase;color:var(--vi-accent);display:flex;gap:.5rem;align-items:center;}

.field-grid{display:grid;gap:1rem;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));}
.field{display:flex;flex-direction:column;gap:.45rem;}
.field label{font-size:.52rem;letter-spacing:.16rem;text-transform:uppercase;font-weight:700;color:#4d5660;display:flex;align-items:center;gap:.4rem;}
.required:after{content:"*";color:#b31217;margin-left:.25rem;font-weight:800;}
.input-wrap{
    display:flex;align-items:center;gap:.5rem;background:#fff;border:1px solid var(--vi-border);
    padding:.55rem .65rem;border-radius:14px;transition:.25s;
}
.input-wrap:focus-within{border-color:var(--vi-accent);box-shadow:var(--vi-focus);}
.input-wrap i{font-size:.75rem;color:#888;}
.field input[type='text'],.field input[type='datetime-local'],.field input[type='file'],.field select,.field textarea{
    width:100%;border:none;outline:none;background:transparent;font-size:.7rem;color:#222;resize:vertical;
}
.field textarea{min-height:110px;}
.badge-inline{
    background:#eef3f7;color:#17394f;border:1px solid #d3dde4;
    padding:.34rem .6rem;border-radius:30px;font-size:.48rem;font-weight:700;letter-spacing:.08rem;display:inline-flex;gap:.35rem;align-items:center;
}
.toggle-line{display:flex;align-items:center;gap:.55rem;font-size:.58rem;font-weight:600;margin-top:.3rem;}
.toggle-line input{transform:scale(1.15);cursor:pointer;}
.actions-row{display:flex;flex-wrap:wrap;gap:.7rem;margin-top:.3rem;}
.note{font-size:.5rem;letter-spacing:.14rem;color:#666;font-weight:600;margin-top:.45rem;}

.preview-box{
    background:#f6f8fa;border:1px solid var(--vi-border);border-radius:26px;
    min-height:340px;display:flex;align-items:center;justify-content:center;overflow:hidden;
}
.preview-box img{width:100%;height:100%;object-fit:cover;opacity:.95;transition:.5s;}
.preview-box img:hover{transform:scale(1.03);}

.helper-line{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:.65rem;}
.rep-field{display:none;}
.fade-in{animation:fade .55s ease;}
@@keyframes fade{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}
.select2-container .select2-selection--single{height:42px!important;border:1px solid var(--vi-border)!important;border-radius:14px!important;}
.select2-selection__rendered{line-height:40px!important;font-size:.7rem!important;padding-left:.55rem!important;}
.select2-selection__arrow{height:40px!important;}
.select2-container--default .select2-selection--multiple{
    border:1px solid var(--vi-border)!important;border-radius:14px!important;min-height:42px;
}
.select2-container--default .select2-selection--multiple .select2-selection__rendered li{
    font-size:.58rem;
}
@@media (max-width:640px){
    .header-band{padding:1.1rem 1.15rem 1rem;}
    .icon-pill{width:62px;height:62px;font-size:1.65rem;}
    .header-band h1{font-size:1.35rem;}
}
</style>

<div class="page-shell fade-in">
    <div class="header-band">
        <div class="icon-pill"><i class="fa fa-archway"></i></div>
        <div>
            <h1>New Visitation</h1>
            <div class="tagline"><i class="fa fa-building"></i> Workplace Check</div>
        </div>
        <div class="toolbar">
            <a asp-action="VisitationList" asp-route-CompanyId="@compId" class="btn-base"><i class="fa fa-list"></i> List</a>
            <a asp-action="HostCompanies" class="btn-outline"><i class="fa fa-arrow-left"></i> Companies</a>
        </div>
    </div>

    <form asp-action="Visitation" method="post" enctype="multipart/form-data" autocomplete="off" novalidate>
        @Html.AntiForgeryToken()
        <input asp-for="CompanyId" type="hidden" value="@compId"/>
        <input asp-for="PlacementId" type="hidden"/>

        <div class="layout-grid">
            <!-- Form -->
            <div class="section-card">
                <div class="section-head">
                    <h2><i class="fa fa-info-circle"></i> Details</h2>
                    <span class="badge-inline"><i class="fa fa-building"></i>@Model.Company</span>
                </div>

                <div class="field-grid">
                    <div class="field">
                        <label>Company</label>
                        <div class="input-wrap" style="background:#fff9ed;">
                            <i class="fa fa-industry"></i>
                            <input asp-for="Company" readonly />
                        </div>
                    </div>

                    <div class="field">
                        <label class="required">Visitor</label>
                        <div class="input-wrap">
                            <i class="fa fa-user-tie"></i>
                            <select asp-for="VisitBy" asp-items="ViewBag.userList">
                                <option value="">Select visitor...</option>
                            </select>
                        </div>
                        <span asp-validation-for="VisitBy" class="text-danger" style="font-size:.55rem;"></span>
                    </div>

                    <div class="field" style="grid-column:1/-1;">
                        <label class="required">Student(s)</label>
                        <div class="input-wrap" style="flex-wrap:wrap;">
                            <i class="fa fa-users"></i>
                            <select asp-for="SelectedIDArray" multiple class="studs" asp-items="ViewBag.StudentId" style="width:100%;">
                            </select>
                        </div>
                        <small style="font-size:.48rem;color:#666;">Hold CTRL / Cmd or use multi-select UI to choose learners.</small>
                        <span asp-validation-for="SelectedIDArray" class="text-danger" style="font-size:.55rem;"></span>
                    </div>

                    <div class="field">
                        <label class="required">Visit Date/Time</label>
                        <div class="input-wrap">
                            <i class="fa fa-calendar-day"></i>
                            <input asp-for="Date" type="datetime-local" />
                        </div>
                        <span asp-validation-for="Date" class="text-danger" style="font-size:.55rem;"></span>
                    </div>

                    <div class="field">
                        <label>Duration (minutes)</label>
                        <div class="input-wrap">
                            <i class="fa fa-hourglass-half"></i>
                            <input asp-for="DurationMinutes" type="number" min="1" placeholder="60" />
                        </div>
                    </div>

                    <div class="field">
                        <label class="required">Mentor</label>
                        <div class="input-wrap">
                            <i class="fa fa-user"></i>
                            <input asp-for="Mentor" placeholder="Workplace mentor name" />
                        </div>
                        <span asp-validation-for="Mentor" class="text-danger" style="font-size:.55rem;"></span>
                    </div>

                    <div class="field" style="grid-column:1/-1;">
                        <label class="required">Purpose of Visit</label>
                        <div class="input-wrap" style="align-items:flex-start;">
                            <i class="fa fa-clipboard-list" style="margin-top:.15rem;"></i>
                            <textarea asp-for="VisitPurpose" placeholder="Describe objectives / agenda..."></textarea>
                        </div>
                        <span asp-validation-for="VisitPurpose" class="text-danger" style="font-size:.55rem;"></span>
                    </div>

                    <div class="field" style="grid-column:1/-1;">
                        <label>Learner Feedback</label>
                        <div class="input-wrap" style="align-items:flex-start;">
                            <i class="fa fa-comments" style="margin-top:.15rem;"></i>
                            <textarea asp-for="LearnerFeedback" placeholder="Notes on learner performance, engagement, issues..."></textarea>
                        </div>
                        <span asp-validation-for="LearnerFeedback" class="text-danger" style="font-size:.55rem;"></span>
                    </div>


                    <div class="field" style="grid-column:1/-1;">
                        <label>Observation Checklist</label>
                        <div class="input-wrap" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));align-items:center;">
                            <label><input asp-for="AttendanceObserved" type="checkbox" /> Attendance</label>
                            <label><input asp-for="EngagementObserved" type="checkbox" /> Engagement</label>
                            <label><input asp-for="WorkplaceConditionsObserved" type="checkbox" /> Workplace conditions</label>
                            <label><input asp-for="SafetyObserved" type="checkbox" /> Safety</label>
                            <label><input asp-for="SkillApplicationObserved" type="checkbox" /> Skill application</label>
                        </div>
                    </div>

                    <div class="field" style="grid-column:1/-1;">
                        <label>Observation Notes / Feedback</label>
                        <div class="input-wrap" style="align-items:flex-start;">
                            <i class="fa fa-note-sticky" style="margin-top:.15rem;"></i>
                            <textarea asp-for="ObservationNotes" placeholder="Attendance, engagement, workplace conditions, safety and skills feedback..."></textarea>
                        </div>
                    </div>

                    <div class="field" style="grid-column:1/-1;">
                        <label>Action Items</label>
                        <div class="input-wrap" style="align-items:flex-start;">
                            <i class="fa fa-list-check" style="margin-top:.15rem;"></i>
                            <textarea asp-for="ActionItems" placeholder="Actions agreed during the visit..."></textarea>
                        </div>
                    </div>

                    <div class="field">
                        <label>Action Due Date</label>
                        <div class="input-wrap"><i class="fa fa-calendar-check"></i><input asp-for="ActionItemDueDate" type="date" /></div>
                    </div>

                    <div class="field">
                        <label>Assignee</label>
                        <div class="input-wrap"><i class="fa fa-user-check"></i><input asp-for="ActionItemAssignee" placeholder="Responsible person" /></div>
                    </div>
                    <div class="field">
                        <label>Report Available?</label>
                        <div class="toggle-line">
                            <input asp-for="HasReport" type="checkbox" id="chkReport"/>
                            <span class="status-pill" id="repState">NO REPORT</span>
                        </div>
                    </div>

                    <div class="field rep-field" id="repField">
                        <label class="required">Upload Report (PDF)</label>
                        <div class="input-wrap">
                            <i class="fa fa-file-pdf"></i>
                            <input asp-for="ReportFile" type="file" accept="application/pdf" id="reportInput"/>
                        </div>
                        <small id="fileInfo" style="font-size:.48rem;color:#666;">Max 3MB • PDF only</small>
                        <span asp-validation-for="ReportFile" class="text-danger" style="font-size:.55rem;"></span>
                    </div>
                </div>

                <div class="actions-row">
                    <button type="submit" class="btn-accent"><i class="fa fa-save"></i> Save</button>
                    <a asp-action="VisitationList" asp-route-CompanyId="@compId" class="btn-outline"><i class="fa fa-list"></i> List</a>
                    <a asp-action="HostCompanies" class="btn-base"><i class="fa fa-arrow-left"></i> Companies</a>
                </div>
                <div class="note"><strong>Note:</strong> Multi-select captures all learners covered by this visit.</div>
            </div>

            <!-- Visual -->
            <div class="section-card">
                <div class="section-head">
                    <h2><i class="fa fa-image"></i> Preview</h2>
                </div>
                <div class="preview-box">
                    <img src="~/Theme/images/Work.jpg" alt="Workplace preview"/>
                </div>
                <div class="helper-line" id="helperState">
                    <span class="badge-inline"><i class="fa fa-info-circle"></i> Fill required fields to enable a complete record</span>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts{
<script src="https://code.jquery.com/jquery-3.6.0.min.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script>
(function($){
    $('.studs').select2({ width:'100%' });

    const chkReport=document.getElementById('chkReport');
    const repField=document.getElementById('repField');
    const repState=document.getElementById('repState');
    const reportInput=document.getElementById('reportInput');
    const fileInfo=document.getElementById('fileInfo');
    const MAX=3*1024*1024;

    function syncReport(){
        if(chkReport.checked){
            repField.style.display='';
            repState.textContent='HAS REPORT';
            repState.style.background='#e8f9ef';
            repState.style.color='#157a41';
        }else{
            repField.style.display='none';
            repState.textContent='NO REPORT';
            repState.style.background='#ffe8ea';
            repState.style.color='#b31217';
            if(reportInput) reportInput.value='';
            fileInfo.textContent='Max 3MB • PDF only';
        }
    }
    chkReport.addEventListener('change',syncReport);
    syncReport();

    reportInput?.addEventListener('change',function(){
        const f=this.files[0];
        if(!f){ fileInfo.textContent='Max 3MB • PDF only'; return; }
        if(f.type!=='application/pdf'){ alert('Only PDF allowed.'); this.value=''; fileInfo.textContent='Max 3MB • PDF only'; return; }
        if(f.size>MAX){ alert('File exceeds 3MB.'); this.value=''; fileInfo.textContent='Max 3MB • PDF only'; return; }
        fileInfo.textContent = f.name+' ('+ (f.size/1024).toFixed(0)+' KB)';
    });

})(jQuery);
</script>
}