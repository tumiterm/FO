@model ForekOnline.Domain.ViewModels.PlacementViewModel
@using static ForekOnline.Domain.Enums.EnumRegistry
@using ForekOnline.Domain.Entities
@{
    ViewData["Title"] = "Learner Placement";
    var timesheets = ViewBag.Timesheets as IReadOnlyCollection<WeeklyTimesheet> ?? new List<WeeklyTimesheet>();
    var visits = ViewBag.VisitHistory as IReadOnlyCollection<Visit> ?? new List<Visit>();
    Guid? focusTimesheetId = null;
    if (ViewBag.FocusTimesheetId is Guid selectedTimesheetId)
    {
        focusTimesheetId = selectedTimesheetId;
    }
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css"/>

<style>
:root{
    --pl-ink:#171114;
    --pl-muted:#73666c;
    --pl-bg:#fffaf7;
    --pl-card:rgba(255,255,255,.9);
    --pl-glass:rgba(255,255,255,.74);
    --pl-border:rgba(125,14,17,.13);
    --pl-border-strong:rgba(125,14,17,.25);
    --pl-accent:#7d0e11;
    --pl-red:#b31217;
    --pl-orange:#ff7a18;
    --pl-gold:#f7c873;
    --pl-accent-grad:linear-gradient(135deg,#250306 0%,#7d0e11 45%,#ff7a18 100%);
    --pl-soft:#fff1eb;
    --pl-radius-xl:34px;
    --pl-radius-lg:28px;
    --pl-radius-md:16px;
    --pl-focus:0 0 0 .2rem rgba(179,18,23,.13);
    --pl-shadow:0 28px 76px -42px rgba(37,3,6,.55),0 16px 38px -30px rgba(179,18,23,.42);
    --pl-shadow-soft:0 18px 42px -34px rgba(37,3,6,.35);
    font-family:Inter,'Segoe UI',system-ui,sans-serif;
}
body{
    color:var(--pl-ink);
    background:
        radial-gradient(circle at 8% 0%,rgba(255,122,24,.18),transparent 34rem),
        radial-gradient(circle at 92% 12%,rgba(179,18,23,.14),transparent 30rem),
        linear-gradient(180deg,#fffaf7 0%,#f7f4f2 100%);
}
.page-shell{max-width:1280px;margin:0 auto;padding:2rem 1.15rem 3.25rem;}
.header-band{
    background:linear-gradient(135deg,rgba(255,255,255,.95),rgba(255,247,243,.82));
    border:1px solid var(--pl-border);
    border-radius:var(--pl-radius-xl);
    padding:1.35rem 1.55rem;
    display:flex;
    flex-wrap:wrap;
    gap:1.25rem;
    align-items:center;
    position:relative;
    overflow:hidden;
    box-shadow:var(--pl-shadow);
    backdrop-filter:blur(18px);
}
.header-band:before{content:"";position:absolute;inset:0;background:linear-gradient(140deg,rgba(125,14,17,.10),rgba(179,18,23,.08),rgba(255,122,24,.16));pointer-events:none;}
.header-band:after{content:"";position:absolute;width:300px;height:300px;right:-95px;top:-145px;background:radial-gradient(circle,rgba(247,200,115,.55),transparent 68%);pointer-events:none;}
.header-band > *{position:relative;z-index:1;}
.icon-pill{width:82px;height:82px;border-radius:28px;background:var(--pl-accent-grad);display:flex;align-items:center;justify-content:center;font-size:2.1rem;color:#fff;box-shadow:0 24px 44px -24px rgba(125,14,17,.78);position:relative;overflow:hidden;}
.icon-pill:after{content:"";position:absolute;inset:1px;border-radius:27px;background:linear-gradient(115deg,rgba(255,255,255,.46),rgba(255,255,255,.04) 42%,rgba(247,200,115,.25));opacity:.75;}
.icon-pill i{position:relative;z-index:1;}
.header-band h1{margin:0;font-size:clamp(1.55rem,2vw,2.1rem);font-weight:850;letter-spacing:-.035em;color:#1d1214;display:flex;align-items:center;gap:.6rem;}
.tagline{font-size:.58rem;letter-spacing:.23rem;font-weight:850;background:rgba(255,255,255,.78);color:var(--pl-accent);padding:.62rem 1rem;border:1px solid var(--pl-border);border-radius:999px;text-transform:uppercase;display:inline-flex;gap:.45rem;align-items:center;box-shadow:inset 0 1px 0 rgba(255,255,255,.9);}
.toolbar{margin-left:auto;display:flex;gap:.65rem;flex-wrap:wrap;}
.btn-base,.btn-accent,.btn-outline{
    font-size:.6rem;letter-spacing:.13rem;font-weight:850;text-transform:uppercase;
    padding:.72rem 1.08rem;border-radius:16px;border:1px solid var(--pl-border);
    background:rgba(255,255,255,.88);color:var(--pl-accent);display:inline-flex;align-items:center;gap:.5rem;
    cursor:pointer;text-decoration:none;transition:.26s ease;box-shadow:0 11px 24px -20px rgba(37,3,6,.5);
}
.btn-base:hover,.btn-outline:hover{transform:translateY(-2px);background:#fff;color:var(--pl-accent);border-color:var(--pl-border-strong);box-shadow:0 18px 30px -24px rgba(37,3,6,.54);}
.btn-accent{background:var(--pl-accent-grad);color:#fff;border-color:rgba(255,255,255,.24);box-shadow:0 20px 36px -22px rgba(125,14,17,.75);}
.btn-accent:hover{color:#fff;transform:translateY(-2px);filter:saturate(1.08) brightness(.98);}
.layout-grid{margin-top:1.55rem;display:grid;gap:1.35rem;grid-template-columns:repeat(auto-fit,minmax(480px,1fr));align-items:start;}
.section-card{
    background:var(--pl-card);border:1px solid var(--pl-border);border-radius:30px;
    padding:1.25rem;display:flex;flex-direction:column;gap:1.15rem;position:relative;overflow:hidden;
    box-shadow:var(--pl-shadow);backdrop-filter:blur(18px);
}
.section-card:before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 95% 0%,rgba(255,122,24,.18),transparent 42%),linear-gradient(140deg,rgba(125,14,17,.07),rgba(255,255,255,.18));pointer-events:none;}
.section-card:after{content:"";position:absolute;left:1.25rem;top:0;width:74px;height:4px;border-radius:0 0 999px 999px;background:var(--pl-accent-grad);}
.section-card > *{position:relative;z-index:1;}
.section-head{display:flex;align-items:center;gap:.7rem;flex-wrap:wrap;justify-content:space-between;}
.section-head h2{margin:.1rem 0;font-size:.78rem;letter-spacing:.22rem;font-weight:850;text-transform:uppercase;color:var(--pl-accent);display:flex;gap:.55rem;align-items:center;}
.field-grid{display:grid;gap:1rem;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));}
.field{display:flex;flex-direction:column;gap:.46rem;}
.field label{font-size:.52rem;letter-spacing:.16rem;text-transform:uppercase;font-weight:850;color:#5f5359;display:flex;align-items:center;gap:.4rem;}
.required:after{content:"*";color:var(--pl-red);margin-left:.25rem;font-weight:900;}
.input-wrap{display:flex;align-items:center;gap:.55rem;background:rgba(255,255,255,.9);border:1px solid var(--pl-border);padding:.64rem .72rem;border-radius:16px;transition:.23s ease;box-shadow:inset 0 1px 0 rgba(255,255,255,.92);}
.input-wrap:focus-within{border-color:rgba(179,18,23,.45);box-shadow:var(--pl-focus);background:#fff;}
.input-wrap i{font-size:.78rem;color:#a09096;}
.field select,.field input[type='text'],.field input[type='email'],.field input[type='file'],.field input[type='date'],.field input[type='number']{width:100%;border:none;background:transparent;font-size:.74rem;color:#21181b;outline:none;}
.badge-inline{background:rgba(255,241,235,.9);color:var(--pl-accent);border:1px solid rgba(179,18,23,.15);padding:.42rem .7rem;border-radius:999px;font-size:.5rem;font-weight:850;letter-spacing:.09rem;display:inline-flex;gap:.35rem;align-items:center;}
.status-pill{font-size:.5rem;font-weight:850;letter-spacing:.12rem;padding:.38rem .68rem;border-radius:999px;display:inline-flex;align-items:center;gap:.35rem;background:#f1f3f4;color:#555;border:1px solid #dde1e4;}
.actions-row{display:flex;flex-wrap:wrap;gap:.72rem;margin-top:.15rem;}
.note{font-size:.52rem;letter-spacing:.13rem;color:var(--pl-muted);font-weight:750;margin-top:.25rem;text-transform:uppercase;}
.divider{height:1px;background:linear-gradient(to right,transparent,rgba(125,14,17,.2),transparent);margin:.4rem 0;}
.preview-box{background:#f6f8fa;border:1px solid var(--pl-border);border-radius:24px;min-height:320px;display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative;}
.preview-box img{width:100%;height:100%;object-fit:cover;opacity:.95;transition:.5s;}
.preview-box img:hover{transform:scale(1.03);}
.inline-toggle{display:flex;align-items:center;gap:.6rem;font-size:.6rem;font-weight:800;margin-top:.3rem;}
.inline-toggle input{transform:scale(1.15);cursor:pointer;accent-color:var(--pl-red);}
.modal-content{border:1px solid var(--pl-border);border-radius:28px;overflow:hidden;box-shadow:var(--pl-shadow);}
.modal-header-modern{background:var(--pl-accent-grad);color:#fff;border-bottom:0;}
.modal-footer-modern{background:#fff5f4;border-top:1px solid var(--pl-border);}
.helper-inline{display:flex;flex-wrap:wrap;gap:.48rem;}
.modal.show .select2-container{z-index:2000;}
.select2-container--open .select2-dropdown{z-index:2100;}
.calc-pill{background:rgba(255,241,235,.92);color:var(--pl-red);border:1px solid rgba(179,18,23,.15);font-size:.5rem;font-weight:850;letter-spacing:.08rem;padding:.38rem .62rem;border-radius:999px;display:inline-flex;align-items:center;gap:.34rem;}
.select2-container .select2-selection--single{height:44px!important;border:0!important;border-radius:14px!important;background:transparent!important;}
.select2-selection__rendered{line-height:42px!important;font-size:.74rem!important;padding-left:.2rem!important;color:#21181b!important;}
.select2-selection__arrow{height:42px!important;}
.select2-dropdown{border:1px solid var(--pl-border)!important;border-radius:16px!important;overflow:hidden;box-shadow:var(--pl-shadow-soft);}
.monitor-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(118px,1fr));gap:.85rem;}
.monitor-card{background:rgba(255,255,255,.78);border:1px solid var(--pl-border);border-radius:22px;padding:.9rem;position:relative;overflow:hidden;box-shadow:var(--pl-shadow-soft);}
.monitor-card:before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 86% 10%,rgba(255,122,24,.22),transparent 58%);pointer-events:none;}
.monitor-label{position:relative;font-size:.5rem;letter-spacing:.16rem;text-transform:uppercase;font-weight:850;color:var(--pl-muted);}
.monitor-value{position:relative;margin-top:.35rem;font-size:1.35rem;font-weight:900;letter-spacing:-.05em;background:var(--pl-accent-grad);-webkit-background-clip:text;background-clip:text;color:transparent;}
.progress-track{height:10px;background:#efe7e5;border:1px solid rgba(125,14,17,.10);border-radius:999px;overflow:hidden;box-shadow:inset 0 1px 3px rgba(37,3,6,.08);}
.progress-fill{height:100%;background:var(--pl-accent-grad);border-radius:999px;box-shadow:0 0 18px rgba(255,122,24,.35);}
.wbl-tabs{display:flex;flex-wrap:wrap;gap:.55rem;margin-top:.15rem;}
.wbl-tab{border:1px solid var(--pl-border);background:rgba(255,255,255,.76);color:var(--pl-accent);border-radius:999px;padding:.55rem .8rem;font-size:.54rem;font-weight:850;letter-spacing:.11rem;text-transform:uppercase;transition:.22s ease;}
.wbl-tab:hover,.wbl-tab.active{background:var(--pl-accent-grad);color:#fff;border-color:transparent;box-shadow:0 14px 26px -20px rgba(125,14,17,.8);transform:translateY(-1px);}
.tab-pane{display:none;}
.tab-pane.active{display:block;animation:fade .45s ease;}
.timeline{display:flex;flex-direction:column;gap:.85rem;padding:.15rem 0;}
.timeline-item{display:grid;grid-template-columns:auto 1fr;gap:.75rem;align-items:start;}
.timeline-dot{width:14px;height:14px;margin-top:.2rem;border-radius:50%;background:var(--pl-accent-grad);box-shadow:0 0 0 6px rgba(179,18,23,.10);}
.timeline-body,.empty-state{background:rgba(255,255,255,.7);border:1px solid var(--pl-border);border-radius:20px;padding:.85rem;color:#4f4449;font-size:.72rem;line-height:1.55;box-shadow:var(--pl-shadow-soft);}
.timeline-body.focused-review{border-color:rgba(179,18,23,.42);box-shadow:0 20px 44px -30px rgba(179,18,23,.55),0 0 0 4px rgba(255,122,24,.10);background:linear-gradient(135deg,rgba(255,255,255,.95),rgba(255,242,235,.88));}
.timesheet-status{display:inline-flex;align-items:center;gap:.35rem;border:1px solid var(--pl-border);border-radius:999px;padding:.28rem .55rem;font-size:.54rem;letter-spacing:.09rem;text-transform:uppercase;font-weight:850;color:var(--pl-accent);background:#fff;margin:.3rem 0 .4rem;}
.timesheet-copy{margin:.35rem 0 .55rem;color:#5a4d52;}
.decision-note{margin-top:.6rem;font-size:.62rem;color:var(--pl-muted);font-weight:750;}
.empty-state{display:flex;align-items:center;gap:.65rem;}
.empty-state i{color:var(--pl-red);font-size:1rem;}
.risk-good{background:#e8f9ef!important;color:#137345!important;border-color:#aee4c4!important;}
.risk-attention{background:#fff4dd!important;color:#9a5a00!important;border-color:#f1c982!important;}
.risk-risk{background:#ffe7eb!important;color:#a90f16!important;border-color:#f1b0b8!important;}
.fade-in{animation:fade .55s ease;}
@@keyframes fade{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}
@@media (max-width:640px){
    .page-shell{padding:1.35rem .85rem 2.5rem;}
    .header-band{padding:1.1rem;}
    .icon-pill{width:64px;height:64px;font-size:1.7rem;}
    .header-band h1{font-size:1.35rem;}
    .toolbar{margin-left:0;}
    .layout-grid{grid-template-columns:1fr;}
    .field-grid{grid-template-columns:1fr;}
}
</style>

<div class="page-shell fade-in">
    <div class="header-band">
        <div class="icon-pill"><i class="fa fa-briefcase"></i></div>
        <div>
            <h1>Learner Placement</h1>
            <div class="tagline"><i class="fa fa-user-graduate"></i> Manage Assignment</div>
        </div>
        <div class="toolbar">
            <a asp-action="PlacedLearners" asp-controller="LearnerPlacement" class="btn-base"><i class="fa fa-list"></i> Placement List</a>
        </div>
    </div>

    <div class="layout-grid">
        <!-- Placement Form -->
        <form asp-action="OnPlaceLearner" method="post" enctype="multipart/form-data" autocomplete="off" novalidate class="section-card">
            @Html.AntiForgeryToken()
            <input asp-for="PlacementId" type="hidden"/>
            <input asp-for="PlacementAgreement" type="hidden"/>
            <div class="section-head">
                    <h2><i class="fa fa-user-check"></i> Details</h2>
                    <span class="badge-inline"><i class="fa fa-hashtag"></i>@Model.PlacementId</span>
                </div>

                <div class="field-grid">
                    <div class="field" style="grid-column:1/-1;">
                        <label>Learner</label>
                        <div class="input-wrap" style="background:#fff9ed;">
                            <i class="fa fa-graduation-cap"></i>
                            <input asp-for="Student" readonly />
                        </div>
                    </div>

                    <div class="field">
                        <label class="required">Host Company</label>
                        <div class="input-wrap">
                            <i class="fa fa-building"></i>
                            <select asp-for="CompanyId" class="company" asp-items="ViewBag.CompanyId">
                                <option value="">Select company...</option>
                            </select>
                        </div>
                        <span asp-validation-for="CompanyId" class="text-danger" style="font-size:.55rem;"></span>
                    </div>

                    <div class="field">
                        <label class="required">Status</label>
                        <div class="input-wrap">
                            <i class="fa fa-spinner"></i>
                            <select asp-for="Status" asp-items="Html.GetEnumSelectList<eStatus>()">
                                <option value="">Select status...</option>
                            </select>
                        </div>
                        <span asp-validation-for="Status" class="text-danger" style="font-size:.55rem;"></span>
                    </div>

                    <div class="field">
                        <label class="required">Campus Mentor</label>
                        <div class="input-wrap">
                            <i class="fa fa-users"></i>
                            <select asp-for="PlacedBy" asp-items="ViewBag.UserId">
                                <option value="">Select mentor...</option>
                            </select>
                        </div>
                        <span asp-validation-for="PlacedBy" class="text-danger" style="font-size:.55rem;"></span>
                    </div>



                    <div class="field">
                        <label class="required">Workplace Mentor Name</label>
                        <div class="input-wrap">
                            <i class="fa fa-id-badge"></i>
                            <input asp-for="WorkplaceMentorName" required placeholder="Full name" />
                        </div>
                    </div>

                    <div class="field">
                        <label class="required">Workplace Mentor Email</label>
                        <div class="input-wrap">
                            <i class="fa fa-at"></i>
                            <input asp-for="WorkplaceMentorEmail" type="email" required placeholder="mentor@company.co.za" />
                        </div>
                    </div>

                    <div class="field">
                        <label class="required">Workplace Mentor Phone</label>
                        <div class="input-wrap">
                            <i class="fa fa-phone"></i>
                            <input asp-for="WorkplaceMentorPhone" required placeholder="Contact number" />
                        </div>
                    </div>

                    <div class="field">
                        <label>Placement Agreement PDF</label>
                        <div class="input-wrap">
                            <i class="fa fa-file-pdf"></i>
                            <input type="file" name="PlacementAgreementFile" accept="application/pdf" />
                        </div>
                        <small style="font-size:.5rem;color:#666;">Current: @(string.IsNullOrWhiteSpace(Model.PlacementAgreement) ? "No agreement uploaded" : Model.PlacementAgreement)</small>
                    </div>

                    <div class="field" style="grid-column:1/-1;">
                        <label>Digital Signature / Confirmation</label>
                        <div class="input-wrap">
                            <i class="fa fa-signature"></i>
                            <input asp-for="DigitalSignature" placeholder="Signer name, e-signature reference, or confirmation" />
                        </div>
                    </div>

                    <div class="field">
                        <label class="required">Start Date</label>
                        <div class="input-wrap">
                            <i class="fa fa-calendar-plus"></i>
                            <input asp-for="StartDate" type="date" id="startDate" />
                        </div>
                        <span asp-validation-for="StartDate" class="text-danger" style="font-size:.55rem;"></span>
                    </div>

                    <div class="field">
                        <label class="required">End Date</label>
                        <div class="input-wrap">
                            <i class="fa fa-calendar-xmark"></i>
                            <input asp-for="EndDate" type="date" id="endDate" />
                        </div>
                        <span asp-validation-for="EndDate" class="text-danger" style="font-size:.55rem;"></span>
                    </div>

                    <div class="field">
                        <label>Duration (Days)</label>
                        <div class="input-wrap">
                            <i class="fa fa-clock"></i>
                            <input type="number" id="durationDays" min="1" placeholder="Auto" />
                        </div>
                        <small style="font-size:.5rem;color:#666;">Auto recalculates from dates (editable).</small>
                    </div>

                    <div class="field">
                        <label>Active</label>
                        <div class="inline-toggle">
                            <input asp-for="IsActive" type="checkbox" />
                            <span class="status-pill" id="activeLabel">@((Model.IsActive)?"ACTIVE":"INACTIVE")</span>
                        </div>
                    </div>
                </div>

                <div class="actions-row">
                    <button type="submit" class="btn-accent"><i class="fa fa-save"></i> Save</button>
                    <a asp-action="WorkplaceModules" asp-controller="WorplaceModules" asp-route-PlacementId="@Model.PlacementId" class="btn-outline">
                        <i class="fa fa-eye"></i> Workplace Modules
                    </a>
                    <button type="button" class="btn-base" data-bs-toggle="modal" data-bs-target="#modulesModal">
                        <i class="fa fa-plus-circle"></i> Add Workplace Modules
                    </button>
                </div>
            <div class="note"><strong>Note:</strong> Dates drive duration. Adjust duration directly to shift end date.</div>
        </form>

        <!-- WBL / WIL Journey -->
        <div class="section-card" style="min-height:100%;">
                <div class="section-head">
                    <h2><i class="fa fa-chart-line"></i> WBL Journey Hub</h2>
                    @{
                        var riskClass = Model.RiskLevel == "Good" ? "risk-good" : Model.RiskLevel == "At Risk" ? "risk-risk" : "risk-attention";
                    }
                    <span class="badge-inline @riskClass"><i class="fa fa-shield-heart"></i> @Model.RiskLevel</span>
                </div>

                <div class="monitor-grid">
                    <div class="monitor-card"><div class="monitor-label">Progress</div><div class="monitor-value">@Model.ProgressPercentage%</div></div>
                    <div class="monitor-card"><div class="monitor-label">Weekly Logs</div><div class="monitor-value">@timesheets.Count</div></div>
                    <div class="monitor-card"><div class="monitor-label">Visits</div><div class="monitor-value">@visits.Count</div></div>
                    <div class="monitor-card"><div class="monitor-label">Documents</div><div class="monitor-value">@(string.IsNullOrWhiteSpace(Model.PlacementAgreement) ? 0 : 1)</div></div>
                </div>
                <div class="progress-track" aria-label="Placement progress"><div class="progress-fill" style="width:@Model.ProgressPercentage%"></div></div>
                <div class="helper-inline">
                    <span class="calc-pill" id="calcInfo"><i class="fa fa-circle-info"></i> @Model.LastActivity</span>
                    <span class="calc-pill"><i class="fa fa-building"></i> @(ViewData["CompanyName"] ?? "Host company")</span>
                    <span class="calc-pill"><i class="fa fa-user-tie"></i> @(ViewData["CampusMentorName"] ?? "Campus mentor")</span>
                </div>

                <div class="wbl-tabs" role="tablist" aria-label="Placement detail sections">
                    <button type="button" class="wbl-tab active" data-tab="overview">Overview</button>
                    <button type="button" class="wbl-tab" data-tab="logs">Activity Logs</button>
                    <button type="button" class="wbl-tab" data-tab="visits">Visits</button>
                    <button type="button" class="wbl-tab" data-tab="documents">Documents</button>
                    <button type="button" class="wbl-tab" data-tab="issues">Issues</button>
                </div>

                <div class="tab-pane active" id="tab-overview">
                    <div class="timeline">
                        <div class="timeline-item"><span class="timeline-dot"></span><div class="timeline-body"><strong>Placement created.</strong><br/>Single learner placement record now anchors mentor contacts, documents, visits, logs, progress and risk monitoring.</div></div>
                        <div class="timeline-item"><span class="timeline-dot"></span><div class="timeline-body"><strong>Next action:</strong> Student submits first weekly activity log; workplace mentor approves; campus mentor acknowledges.</div></div>
                    </div>
                </div>
                <div class="tab-pane" id="tab-logs">
                    @if (!timesheets.Any())
                    {
                        <div class="empty-state"><i class="fa fa-clock"></i> No weekly timesheets submitted yet.</div>
                    }
                    else
                    {
                        <div class="timeline-list">
                            @foreach (var sheet in timesheets)
                            {
                                var isFocused = focusTimesheetId.HasValue && focusTimesheetId.Value == sheet.WeeklyTimesheetId;
                                var isPendingWorkplace = sheet.Status == "Pending Workplace Approval";
                                var isPendingCampus = sheet.Status == "Approved - Pending Campus Acknowledgement";
                                var reviewBodyClass = isFocused ? "focused-review" : string.Empty;
                                <div class="timeline-item" data-timesheet-id="@sheet.WeeklyTimesheetId">
                                    <span class="timeline-dot"></span>
                                    <div class="timeline-body @reviewBodyClass">
                                        <strong>@sheet.WeekStartDate.ToString("yyyy-MM-dd") – @sheet.WeekEndDate.ToString("yyyy-MM-dd") (@sheet.TotalHours hours)</strong><br />
                                        <span class="timesheet-status"><i class="fa fa-circle"></i> @sheet.Status</span>
                                        <div class="timesheet-copy">@sheet.ActivityDescription</div>
                                        @if (isPendingWorkplace)
                                        {
                                            <form asp-controller="LearnerPlacement" asp-action="WorkplaceTimesheetDecision" method="post" style="margin-top:.75rem;display:flex;gap:.5rem;flex-wrap:wrap;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="weeklyTimesheetId" value="@sheet.WeeklyTimesheetId" />
                                                <input name="comments" placeholder="Workplace mentor comments" style="flex:1;min-width:220px;border:1px solid var(--pl-border);border-radius:12px;padding:.55rem .7rem;" />
                                                <button name="approve" value="true" class="btn-accent" type="submit">Approve</button>
                                                <button name="approve" value="false" class="btn-outline" type="submit">Reject</button>
                                            </form>
                                        }
                                        else if (isPendingCampus)
                                        {
                                            <form asp-controller="LearnerPlacement" asp-action="AcknowledgeTimesheet" method="post" style="margin-top:.5rem;display:flex;gap:.5rem;flex-wrap:wrap;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="weeklyTimesheetId" value="@sheet.WeeklyTimesheetId" />
                                                <input name="comments" placeholder="Campus mentor acknowledgement note" style="flex:1;min-width:220px;border:1px solid var(--pl-border);border-radius:12px;padding:.55rem .7rem;" />
                                                <button class="btn-accent" type="submit">Acknowledge</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <div class="decision-note"><i class="fa fa-lock"></i> Review actions are closed for this timesheet.</div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="tab-pane" id="tab-visits">
                    <div style="margin-bottom:1rem;">
                        <a class="btn-accent" asp-controller="Visit" asp-action="Visitation" asp-route-CompanyId="@Model.CompanyId" asp-route-PlacementId="@Model.PlacementId"><i class="fa fa-plus"></i> Capture Campus Visit</a>
                    </div>
                    @if (!visits.Any())
                    {
                        <div class="empty-state"><i class="fa fa-clipboard-check"></i> No campus visits linked to this placement yet.</div>
                    }
                    else
                    {
                        <div class="timeline-list">
                            @foreach (var visit in visits)
                            {
                                <div class="timeline-item"><span class="timeline-dot"></span><div class="timeline-body"><strong>@visit.Date.ToString("yyyy-MM-dd HH:mm") • @visit.DurationMinutes min</strong><br />Checklist: attendance @visit.AttendanceObserved, engagement @visit.EngagementObserved, conditions @visit.WorkplaceConditionsObserved, safety @visit.SafetyObserved, skills @visit.SkillApplicationObserved<br />@visit.ObservationNotes<br /><strong>Actions:</strong> @visit.ActionItems @if (visit.ActionItemDueDate.HasValue) { <span>(due @visit.ActionItemDueDate.Value.ToString("yyyy-MM-dd"))</span> }</div></div>
                            }
                        </div>
                    }
                </div>
                <div class="tab-pane" id="tab-documents"><div class="empty-state"><i class="fa fa-folder-open"></i> Agreement: @(string.IsNullOrWhiteSpace(Model.PlacementAgreement) ? "Not uploaded yet." : Model.PlacementAgreement) Evidence uploads and final certificates will be listed here.</div></div>
                <div class="tab-pane" id="tab-issues"><div class="empty-state"><i class="fa fa-life-ring"></i> Support tickets, at-risk alerts and overdue actions will be managed from this section.</div></div>
        </div>
    </div>
</div>

<!-- Modal: Add Workplace Modules -->
<div class="modal fade" id="modulesModal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header modal-header-modern">
                <h5 class="modal-title"><i class="fa fa-layer-group"></i> Add Workplace Modules</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="RegisterModule"
                  asp-controller="WorplaceModules"
                  asp-route-PlacementId="@ViewData["PlacementId"]"
                  asp-route-CompanyId="@ViewData["CompanyId"]"
                  method="post" autocomplete="off" novalidate>
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="PlacementId" value="@ViewData["PlacementId"]" />
                    <input type="hidden" name="CompanyId" value="@ViewData["CompanyId"]" />

                    <div class="section-card" style="box-shadow:none;border:none;padding:0;background:transparent;">
                        <div class="section-head" style="margin-bottom:.8rem;">
                            <h2 style="font-size:.7rem;"><i class="fa fa-cogs"></i> Module Allocation</h2>
                        </div>

                        <div class="field-grid">
                            <div class="field">
                                <label class="required">Course</label>
                                <div class="input-wrap">
                                    <i class="fa fa-book"></i>
                                    <select name="CourseId" class="course" asp-items="ViewBag.CourseId">
                                        <option value="">Select course...</option>
                                    </select>
                                </div>
                            </div>

                            <div class="field">
                                <label class="required">Module</label>
                                <div class="input-wrap">
                                    <i class="fa fa-book-open"></i>
                                    <select name="ModuleId" class="module" asp-items="ViewBag.ModuleId">
                                        <option value="">Select module...</option>
                                    </select>
                                </div>
                            </div>

                            <div class="field">
                                <label class="required">Start Day</label>
                                <div class="input-wrap">
                                    <i class="fa fa-calendar-plus"></i>
                                    <input type="date" name="StartDate" id="mStart" required />
                                </div>
                            </div>

                            <div class="field">
                                <label class="required">End Day</label>
                                <div class="input-wrap">
                                    <i class="fa fa-calendar-xmark"></i>
                                    <input type="date" name="EndDate" id="mEnd" required />
                                </div>
                            </div>

                            <div class="field">
                                <label class="required">Duration (Days)</label>
                                <div class="input-wrap">
                                    <i class="fa fa-clock"></i>
                                    <input type="number" name="Days" id="mDays" min="1" required />
                                </div>
                            </div>

                            <div class="field">
                                <label class="required">Progress</label>
                                <div class="input-wrap">
                                    <i class="fa fa-spinner"></i>
                                    <select name="Progress" asp-items="Html.GetEnumSelectList<eStatus>()">
                                        <option value="">Select progress...</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="note" id="modCalcInfo"><i class="fa fa-info-circle"></i> Fill start/end to auto-calc days.</div>
                    </div>
                </div>
                <div class="modal-footer modal-footer-modern">
                    <button type="button" class="btn-outline btn-base" data-bs-dismiss="modal"><i class="fa fa-xmark"></i> Close</button>
                    <button type="submit" class="btn-accent"><i class="fa fa-save"></i> Save Module</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function($){
        // Select2 init
        $('.company,.course,.module').select2({ width:'100%' });

            function initModalSelects() {
                const $modal = $('#modulesModal');
                const opts = { width: '100%', dropdownParent: $modal };

                // Destroy previous instances if any (prevents duplicate containers)
                $modal.find('.course.select2-hidden-accessible').select2('destroy');
                $modal.find('.module.select2-hidden-accessible').select2('destroy');

                $modal.find('.course').select2(opts);
                $modal.find('.module').select2(opts);
            }

            // Initialize when modal becomes visible (ensures correct stacking)
            $('#modulesModal').on('shown.bs.modal', function () {
                initModalSelects();
                // Force repaint (rare Safari quirks)
                window.requestAnimationFrame(()=> $('.course').trigger('blur').trigger('focus'));
            });

            // If modal opened programmatically before this code runs
            if ($('#modulesModal').hasClass('show')) {
                initModalSelects();
            }

            // Dependent module load
            function loadModules() {
                const courseId = $('#modulesModal .course').val();
                if (!courseId) {
                    $('#modulesModal .module').empty().append('<option value="">Select module...</option>').trigger('change');
                    return;
                }
                $.get('@Url.Action("GetCourseModuleId", "LearnerPlacement")', { CourseId: courseId })
                    .done(data => {
                        const $m = $('#modulesModal .module');
                        $m.empty().append('<option value="">Select module...</option>');
                        (data || []).forEach(x => $m.append(`<option value="${x.moduleId}">${x.moduleName}</option>`));
                        $m.trigger('change');
                    })
                    .fail(() => console.warn('Module load failed'));
            }

            // Delegate change (reliable after re-init)
            $(document).on('change', '#modulesModal .course', loadModules);

            // Active label toggle
            const activeCb = document.querySelector('input[name="IsActive"]');
            const activeLabel = document.getElementById('activeLabel');
            activeCb?.addEventListener('change', () => {
                activeLabel.textContent = activeCb.checked ? 'ACTIVE' : 'INACTIVE';
            });

            // Duration calc (main form)
            const startDate = document.getElementById('startDate');
            const endDate = document.getElementById('endDate');
            const durationDays = document.getElementById('durationDays');
            const calcInfo = document.getElementById('calcInfo');

            function parse(d) { return d ? new Date(d + 'T00:00:00') : null; }
            function daysDiff(a, b) { return Math.round((b - a) / 86400000) + 1; }

            function updateFromDates() {
                const s = parse(startDate.value), e = parse(endDate.value);
                if (s && e && e >= s) {
                    const diff = daysDiff(s, e);
                    durationDays.value = diff;
                    calcInfo.innerHTML = '<i class="fa fa-clock"></i> ' + diff + ' day(s)';
                } else {
                    calcInfo.innerHTML = (startDate.value || endDate.value)
                        ? '<i class="fa fa-warning"></i> Invalid range'
                        : '<i class="fa fa-circle-info"></i> Awaiting date selection';
                }
            }
            function updateFromDuration() {
                const s = parse(startDate.value);
                const days = parseInt(durationDays.value, 10);
                if (s && days > 0) {
                    const e = new Date(s);
                    e.setDate(e.getDate() + days - 1);
                    endDate.value = e.toISOString().slice(0, 10);
                    updateFromDates();
                }
            }
            startDate?.addEventListener('change', updateFromDates);
            endDate?.addEventListener('change', updateFromDates);
            durationDays?.addEventListener('input', updateFromDuration);

            // Modal module duration
            const mStart = document.getElementById('mStart');
            const mEnd = document.getElementById('mEnd');
            const mDays = document.getElementById('mDays');
            const modCalcInfo = document.getElementById('modCalcInfo');

            function modFromDates() {
                const s = parse(mStart.value), e = parse(mEnd.value);
                if (s && e && e >= s) {
                    const diff = daysDiff(s, e);
                    mDays.value = diff;
                    modCalcInfo.innerHTML = '<i class="fa fa-clock"></i> ' + diff + ' day(s)';
                } else {
                    modCalcInfo.innerHTML = '<i class="fa fa-info-circle"></i> Fill dates to calculate duration.';
                }
            }
            function modFromDays() {
                const s = parse(mStart.value); const d = parseInt(mDays.value, 10);
                if (s && d > 0) {
                    const e = new Date(s); e.setDate(e.getDate() + d - 1);
                    mEnd.value = e.toISOString().slice(0, 10);
                    modFromDates();
                }
            }
            mStart?.addEventListener('change', modFromDates);
            mEnd?.addEventListener('change', modFromDates);
            mDays?.addEventListener('input', modFromDays);

            function activatePlacementTab(key){
                $('.wbl-tab').removeClass('active');
                $('.wbl-tab[data-tab="' + key + '"]').addClass('active');
                $('.tab-pane').removeClass('active');
                $('#tab-' + key).addClass('active');
            }

            $('.wbl-tab').on('click', function(){
                activatePlacementTab($(this).data('tab'));
            });

            const focusTimesheetId = '@(focusTimesheetId?.ToString() ?? string.Empty)';
            if (focusTimesheetId) {
                activatePlacementTab('logs');
                const target = $('[data-timesheet-id="' + focusTimesheetId + '"]');
                if (target.length) {
                    setTimeout(() => target[0].scrollIntoView({ behavior: 'smooth', block: 'center' }), 120);
                }
            }

        })(jQuery);

    </script>
}


