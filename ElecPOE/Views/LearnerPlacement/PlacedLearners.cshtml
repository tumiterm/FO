@model IEnumerable<ForekOnline.Domain.ViewModels.PlacementViewModel>
@using static ForekOnline.Domain.Enums.EnumRegistry
@using ForekOnline.Application.Common.Utility
@{
    var placements = Model?.ToList() ?? new List<ForekOnline.Domain.ViewModels.PlacementViewModel>();
    var statusGroups = placements.GroupBy(p => p.Status).ToDictionary(g => g.Key, g => g.Count());
    int total = placements.Count;
    int atRisk = placements.Count(p => p.IsAtRisk);
    int pendingTimesheets = ViewBag.PendingTimesheets ?? 0;
    int pendingCampusAcknowledgements = ViewBag.PendingCampusAcknowledgements ?? 0;
    int totalVisits = ViewBag.TotalVisits ?? 0;
}

<style>
:root {
    --pl-ink:#151016;
    --pl-muted:#6f6470;
    --pl-dr:#250306;
    --pl-red:#8f0d13;
    --pl-red-strong:#b31217;
    --pl-orange:#ff7a18;
    --pl-gold:#f7c873;
    --pl-bg:#fffaf7;
    --pl-card:rgba(255,255,255,.88);
    --pl-glass:rgba(255,255,255,.72);
    --pl-soft:#fff1eb;
    --pl-border:rgba(143,13,19,.12);
    --pl-border-strong:rgba(143,13,19,.22);
    --pl-grad:linear-gradient(135deg,#250306 0%,#8f0d13 48%,#ff7a18 100%);
    --pl-grad-soft:linear-gradient(135deg,rgba(37,3,6,.10),rgba(179,18,23,.10),rgba(255,122,24,.16));
    --pl-sheen:linear-gradient(115deg,rgba(255,255,255,.45),rgba(255,255,255,.04) 42%,rgba(247,200,115,.25));
    --pl-radius-xl:34px;
    --pl-radius-lg:26px;
    --pl-radius-md:18px;
    --pl-shadow:0 24px 70px -35px rgba(37,3,6,.45),0 14px 34px -28px rgba(179,18,23,.38);
    --pl-shadow-soft:0 18px 44px -34px rgba(37,3,6,.35);
    font-family:Inter,'Segoe UI',system-ui,sans-serif;
}
body {
    color:var(--pl-ink);
    background:
        radial-gradient(circle at top left,rgba(255,122,24,.18),transparent 34rem),
        radial-gradient(circle at 88% 8%,rgba(179,18,23,.14),transparent 28rem),
        linear-gradient(180deg,#fffaf7 0%,#f7f4f2 100%);
}
.placement-shell { max-width:1440px; margin:0 auto; padding:2rem 1.25rem 3.5rem; }

/* Header */
.header-band {
    background:linear-gradient(135deg,rgba(255,255,255,.94),rgba(255,248,244,.82));
    border:1px solid var(--pl-border);
    border-radius:var(--pl-radius-xl);
    padding:1.35rem 1.55rem;
    display:flex;
    flex-wrap:wrap;
    gap:1.25rem;
    align-items:center;
    position:relative;
    overflow:hidden;
    box-shadow:var(--pl-shadow);
    backdrop-filter:blur(18px);
}
.header-band:before { content:""; position:absolute; inset:0; background:var(--pl-grad-soft); pointer-events:none; }
.header-band:after { content:""; position:absolute; width:260px; height:260px; right:-80px; top:-120px; background:radial-gradient(circle,rgba(247,200,115,.55),transparent 68%); pointer-events:none; }
.header-band > * { position:relative; z-index:1; }
.icon-pill { width:82px;height:82px;border-radius:28px;background:var(--pl-grad);display:flex;align-items:center;justify-content:center;color:#fff;font-size:2.05rem;box-shadow:0 22px 42px -22px rgba(143,13,19,.72); position:relative; overflow:hidden; }
.icon-pill:after{content:"";position:absolute;inset:1px;border-radius:27px;background:var(--pl-sheen);opacity:.7;}
.icon-pill i{position:relative;z-index:1;}
.header-band h1 { margin:0;font-size:clamp(1.55rem,2vw,2.05rem);font-weight:800;letter-spacing:-.03em;color:#1d1214;display:flex;align-items:center;gap:.65rem; }
.tagline { font-size:.58rem; letter-spacing:.26rem; font-weight:800; background:rgba(255,255,255,.76); color:var(--pl-red-strong); padding:.62rem 1rem; border:1px solid var(--pl-border); border-radius:999px; text-transform:uppercase; display:inline-flex; gap:.5rem; align-items:center; margin-top:.55rem; box-shadow:inset 0 1px 0 rgba(255,255,255,.85); }
.toolbar { margin-left:auto; display:flex; gap:.65rem; flex-wrap:wrap; }
.btn-act,.btn-accent { font-size:.62rem; letter-spacing:.14rem; font-weight:800; text-transform:uppercase; padding:.72rem 1.12rem; border-radius:16px; border:1px solid var(--pl-border); background:rgba(255,255,255,.86); color:var(--pl-red-strong); display:inline-flex; align-items:center; gap:.5rem; cursor:pointer; text-decoration:none; transition:.28s ease; box-shadow:0 10px 22px -18px rgba(37,3,6,.45); }
.btn-act:hover { transform:translateY(-2px); background:#fff; color:var(--pl-red); border-color:var(--pl-border-strong); box-shadow:0 16px 28px -20px rgba(37,3,6,.5); }
.btn-accent { background:var(--pl-grad); color:#fff; border-color:rgba(255,255,255,.26); box-shadow:0 18px 34px -20px rgba(143,13,19,.75); }
.btn-accent:hover { color:#fff; transform:translateY(-2px); filter:saturate(1.08) brightness(.98); }
.btn-disabled { opacity:.5; pointer-events:none; }

/* Status summary cards */
.status-grid { margin-top:1.4rem; display:grid; gap:1rem; grid-template-columns:repeat(auto-fit,minmax(175px,1fr)); }
.stat-card { position:relative; background:var(--pl-card); border:1px solid var(--pl-border); border-radius:24px; padding:1.05rem 1rem; display:flex; flex-direction:column; gap:.45rem; overflow:hidden; transition:.3s ease; box-shadow:var(--pl-shadow-soft); backdrop-filter:blur(14px); }
.stat-card:before { content:""; position:absolute; inset:0; background:radial-gradient(circle at 88% 8%,rgba(255,122,24,.24),transparent 55%),linear-gradient(135deg,rgba(255,255,255,.7),transparent); opacity:.85; pointer-events:none; }
.stat-card:after { content:""; position:absolute; width:44px; height:4px; left:1rem; top:0; background:var(--pl-grad); border-radius:0 0 999px 999px; }
.stat-card > * { position:relative; z-index:1; }
.stat-card:hover { transform:translateY(-5px); border-color:var(--pl-border-strong); box-shadow:0 26px 48px -34px rgba(37,3,6,.5); }
.stat-label { font-size:.52rem; letter-spacing:.18rem; text-transform:uppercase; font-weight:800; color:var(--pl-muted); }
.stat-value { font-size:1.55rem; font-weight:850; background:var(--pl-grad); -webkit-background-clip:text; background-clip:text; color:transparent; line-height:1; letter-spacing:-.04em; }
.stat-chip { font-size:.5rem; letter-spacing:.14rem; font-weight:800; background:rgba(255,241,235,.92); color:var(--pl-red-strong); padding:.36rem .62rem; border:1px solid rgba(179,18,23,.10); border-radius:999px; align-self:flex-start; }

/* Filters */
.filter-bar { margin-top:1.35rem; background:var(--pl-glass); border:1px solid var(--pl-border); border-radius:28px; padding:1rem; display:flex; gap:.9rem; flex-wrap:wrap; align-items:flex-end; box-shadow:var(--pl-shadow-soft); backdrop-filter:blur(16px); }
.filter-group { display:flex; flex-direction:column; gap:.4rem; }
.filter-group label { font-size:.52rem; letter-spacing:.16rem; text-transform:uppercase; font-weight:800; color:#685b63; }
.filter-bar input[type="text"], .filter-bar select, .filter-bar input[type="date"] { background:rgba(255,255,255,.9); border:1px solid var(--pl-border); font-size:.74rem; padding:.67rem .75rem; border-radius:15px; min-width:180px; transition:.22s ease; color:var(--pl-ink); box-shadow:inset 0 1px 0 rgba(255,255,255,.9); }
.filter-bar input:focus, .filter-bar select:focus { outline:none; border-color:rgba(179,18,23,.45); box-shadow:0 0 0 .2rem rgba(179,18,23,.12); }
.search-wrap { position:relative; flex:1 1 320px; }
.search-wrap i { position:absolute; top:50%; left:.9rem; transform:translateY(-50%); font-size:.78rem; color:#9c8b92; z-index:1; }
.search-wrap input { width:100%; padding-left:2.35rem!important; }

/* Table */
.table-shell { margin-top:1.25rem; background:rgba(255,255,255,.88); border:1px solid var(--pl-border); border-radius:30px; padding:1.1rem; overflow:auto; box-shadow:var(--pl-shadow); backdrop-filter:blur(18px); }
.table-meta { display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:.65rem; margin-bottom:.75rem; font-size:.56rem; letter-spacing:.15rem; font-weight:800; color:var(--pl-muted); text-transform:uppercase; }
.table-meta span.badge { background:var(--pl-grad); color:#fff; padding:.45rem .7rem; border-radius:999px; font-size:.52rem; font-weight:800; letter-spacing:.12rem; box-shadow:0 12px 24px -18px rgba(143,13,19,.8); }
.placement-table { width:100%; border-collapse:separate; border-spacing:0 .42rem; font-size:.73rem; }
.placement-table thead th { background:#251316; color:#fff; font-size:.54rem; letter-spacing:.17rem; text-transform:uppercase; font-weight:800; padding:.78rem .72rem; position:sticky; top:0; z-index:3; border-top:1px solid rgba(255,255,255,.12); border-bottom:1px solid rgba(255,255,255,.10); }
.placement-table thead th:first-child{border-radius:16px 0 0 16px;}
.placement-table thead th:last-child{border-radius:0 16px 16px 0;}
.placement-table tbody tr { transition:.2s ease; background:rgba(255,255,255,.74); box-shadow:0 8px 20px -18px rgba(37,3,6,.45); }
.placement-table tbody tr:hover { transform:translateY(-2px); background:#fffaf7; box-shadow:0 18px 34px -28px rgba(37,3,6,.52); }
.placement-table td { padding:.72rem .7rem; border-top:1px solid rgba(143,13,19,.08); border-bottom:1px solid rgba(143,13,19,.08); vertical-align:middle; color:#33272c; }
.placement-table td:first-child{border-left:1px solid rgba(143,13,19,.08);border-radius:16px 0 0 16px;}
.placement-table td:last-child{border-right:1px solid rgba(143,13,19,.08);border-radius:0 16px 16px 0;}
.action-link { font-weight:800; font-size:.58rem; letter-spacing:.1rem; text-transform:uppercase; background:#fff; padding:.5rem .7rem; border:1px solid var(--pl-border); border-radius:13px; text-decoration:none; display:inline-flex; gap:.4rem; align-items:center; color:var(--pl-red-strong); transition:.24s ease; white-space:nowrap; }
.action-link:hover { transform:translateY(-2px); background:var(--pl-grad); color:#fff; border-color:transparent; box-shadow:0 12px 24px -18px rgba(143,13,19,.8); }
.badge-status { font-size:.55rem; padding:.42rem .66rem; border-radius:999px; font-weight:800; letter-spacing:.08rem; display:inline-flex; gap:.35rem; align-items:center; white-space:nowrap; }
.st-startingsoon { background:#fff4dd; color:#9a5a00; border:1px solid #f1c982; }
.st-started { background:#e8f9ef; color:#137345; border:1px solid #aee4c4; }
.st-droppedout { background:#ffe7eb; color:#a90f16; border:1px solid #f1b0b8; }
.st-transferred { background:#e9f3ff; color:#195a96; border:1px solid #accfec; }
.st-completed { background:#e1f7ff; color:#0e688e; border:1px solid #9dd9ee; }
.st-default { background:#f0f1f3; color:#555; border:1px solid #dadde0; }
.risk-good { background:#e8f9ef; color:#137345; border:1px solid #aee4c4; }
.risk-attention { background:#fff4dd; color:#9a5a00; border:1px solid #f1c982; }
.risk-at-risk { background:#ffe7eb; color:#a90f16; border:1px solid #f1b0b8; }
.progress-cell { min-width:128px; }
.progress-track { height:9px; background:#efe7e5; border-radius:999px; overflow:hidden; border:1px solid rgba(143,13,19,.10); box-shadow:inset 0 1px 3px rgba(37,3,6,.08); }
.progress-fill { height:100%; background:var(--pl-grad); border-radius:999px; box-shadow:0 0 16px rgba(255,122,24,.35); }
.progress-label { font-size:.54rem; font-weight:850; color:var(--pl-red-strong); margin-top:.28rem; }
.footer-bar { margin-top:.85rem; display:flex; gap:.75rem; flex-wrap:wrap; justify-content:space-between; align-items:center; font-size:.55rem; letter-spacing:.11rem; color:var(--pl-muted); text-transform:uppercase; }
.footer-bar .mini { display:flex; gap:.4rem; align-items:center; }
.hidden-row { display:none !important; }
@@media (max-width:950px){ .placement-table thead th:nth-child(5), .placement-table td:nth-child(5) { display:none; } }
@@media (max-width:720px){ .placement-table thead th:nth-child(3), .placement-table td:nth-child(3) { display:none; } .toolbar{margin-left:0;} .header-band{align-items:flex-start;} }
</style>

<div class="placement-shell">
    <div class="header-band">
        <div class="icon-pill"><i class="fa fa-people-carry-box"></i></div>
        <div>
            <h1>Learner Placements</h1>
            <div class="tagline"><i class="fa fa-layer-group"></i> OVERSIGHT</div>
        </div>
        <div class="toolbar">
            <button type="button" class="btn-act" onclick="location.reload()"><i class="fa fa-rotate"></i> Refresh</button>
            <button type="button" class="btn-accent" id="btnExportCsv"><i class="fa fa-file-export"></i> CSV</button>
        </div>
    </div>

    <div class="status-grid">
        <div class="stat-card">
            <div class="stat-label">TOTAL</div>
            <div class="stat-value">@total</div>
            <div class="stat-chip"><i class="fa fa-database"></i> RECORDS</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">AT RISK</div>
            <div class="stat-value">@atRisk</div>
            <div class="stat-chip"><i class="fa fa-triangle-exclamation"></i> INTERVENTION</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">PENDING TIMESHEETS</div>
            <div class="stat-value">@pendingTimesheets</div>
            <div class="stat-chip"><i class="fa fa-clock"></i> WORKPLACE APPROVAL</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">CAMPUS ACKS</div>
            <div class="stat-value">@pendingCampusAcknowledgements</div>
            <div class="stat-chip"><i class="fa fa-user-check"></i> ACKNOWLEDGEMENT</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">VISITS</div>
            <div class="stat-value">@totalVisits</div>
            <div class="stat-chip"><i class="fa fa-clipboard-check"></i> LINKED HISTORY</div>
        </div>
        @foreach (eStatus s in Enum.GetValues(typeof(eStatus)))
        {
            <div class="stat-card">
                <div class="stat-label">@s</div>
                <div class="stat-value">@(statusGroups.ContainsKey(s)? statusGroups[s] : 0)</div>
                <div class="stat-chip">@s.ToString().ToUpperInvariant()</div>
            </div>
        }
    </div>

    <div class="filter-bar">
        <div class="search-wrap">
            <i class="fa fa-search"></i>
            <input id="searchBox" type="text" placeholder="Search student / company / placed by..." autocomplete="off" />
        </div>
        <div class="filter-group">
            <label>Status</label>
            <select id="statusFilter">
                <option value="">All</option>
                @foreach (eStatus s in Enum.GetValues(typeof(eStatus)))
                {
                    <option value="@s">@s</option>
                }
            </select>
        </div>
        <div class="filter-group">
            <label>From Date</label>
            <input type="date" id="fromDate" />
        </div>
        <div class="filter-group">
            <label>To Date</label>
            <input type="date" id="toDate" />
        </div>
        <div class="filter-group" style="margin-left:auto;align-items:flex-end;">
            <span id="limitNote" class="stat-chip" style="display:none;">LIMITED</span>
        </div>
    </div>

    <div class="table-shell">
        <div class="table-meta">
            <span id="rowsInfo" class="badge">Showing @placements.Count record(s)</span>
            <span id="filterInfo"></span>
        </div>
        <table class="placement-table" id="placementsTable">
            <thead>
                <tr>
                    <th>Action</th>
                    <th>Student</th>
                    <th>Host Company</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Campus Mentor</th>
                    <th>Workplace Mentor</th>
                    <th>Progress</th>
                    <th>Status</th>
                    <th>Last Activity</th>
                    <th>Risk Level</th>
                </tr>
            </thead>
            <tbody id="placementsBody">
            @foreach (var p in placements)
            {
                var dateVal = p.StartDate;
                <tr data-status="@p.Status" data-date="@dateVal.ToString()">
                    <td>
                        <a class="action-link" asp-action="OnPlaceLearner" asp-controller="LearnerPlacement" asp-route-PlacementId="@p.PlacementId"><i class="fa fa-folder-open"></i> Open</a>
                    </td>
                    <td>@p.Student</td>
                    <td>@p.CompanyId</td>
                    <td>@dateVal.ToString()</td>
                    <td>@p.EndDate</td>
                    <td>@p.PlacedBy</td>
                    <td>@(string.IsNullOrWhiteSpace(p.WorkplaceMentorName) ? "Not captured" : p.WorkplaceMentorName)</td>
                    <td class="progress-cell">
                        <div class="progress-track"><div class="progress-fill" style="width:@p.ProgressPercentage%"></div></div>
                        <div class="progress-label">@p.ProgressPercentage%</div>
                    </td>
                    <td>
                        @{ string stClass = p.Status switch {
                                eStatus.StartingSoon => "st-startingsoon",
                                eStatus.Started => "st-started",
                                eStatus.DroppedOut => "st-droppedout",
                                eStatus.Transferred => "st-transferred",
                                eStatus.Completed => "st-completed",
                                _ => "st-default"
                            }; }
                        <span class="badge-status @stClass"><i class="fa fa-circle"></i> @p.Status</span>
                    </td>
                    <td>@p.LastActivity</td>
                    <td>
                        @{ var riskCss = p.RiskLevel == "Good" ? "risk-good" : p.RiskLevel == "At Risk" ? "risk-at-risk" : "risk-attention"; }
                        <span class="badge-status @riskCss"><i class="fa fa-shield-heart"></i> @p.RiskLevel</span>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        <div class="footer-bar">
            <div class="mini" id="performanceInfo"></div>
            <div class="mini">Use search / filters to refine results • <strong>Export</strong> exports current view.</div>
        </div>
    </div>
</div>

<script>
(function(){
    const DEFAULT_LIMIT = 200; // safety for huge datasets
    const bodyEl = document.getElementById('placementsBody');
    const searchBox = document.getElementById('searchBox');
    const statusFilter = document.getElementById('statusFilter');
    const fromDate = document.getElementById('fromDate');
    const toDate = document.getElementById('toDate');
    const rowsInfo = document.getElementById('rowsInfo');
    const filterInfo = document.getElementById('filterInfo');
    const performanceInfo = document.getElementById('performanceInfo');
    const btnExport = document.getElementById('btnExportCsv');
    const limitNote = document.getElementById('limitNote');

    let limitedMode = true;

    function norm(v){ return (v||'').toString().toLowerCase().trim(); }
    function parseDate(d){ return d? new Date(d): null; }

    function applyFilters(){
        const t0 = performance.now();
        const q = norm(searchBox.value);
        const st = statusFilter.value;
        const f = fromDate.value ? parseDate(fromDate.value) : null;
        const t = toDate.value ? parseDate(toDate.value) : null;
        const filtering = !!(q||st||f||t);
        const rows = Array.from(bodyEl.querySelectorAll('tr'));
        let shown=0, matched=0;
        rows.forEach((r,i)=>{
            const text = norm(r.innerText);
            const rs = r.getAttribute('data-status');
            const dAttr = r.getAttribute('data-date');
            const rd = dAttr? parseDate(dAttr): null;
            let show = true;
            if(q && !text.includes(q)) show=false;
            if(st && rs !== st) show=false;
            if(f && (!rd || rd < f)) show=false;
            if(t && (!rd || rd > t)) show=false;
            if(show){
                matched++;
                if(limitedMode && !filtering && shown >= DEFAULT_LIMIT) show=false;
            }
            r.classList.toggle('hidden-row', !show);
            if(show) shown++;
        });
        rowsInfo.textContent = 'Showing ' + shown + ' record(s)' + (filtering? ' (matched)':'' );
        filterInfo.textContent = filtering? 'FILTERED' : (limitedMode? 'LIMITED':'');
        limitNote.style.display = (!filtering && limitedMode && matched > DEFAULT_LIMIT)? '' : 'none';
        const t1 = performance.now();
        performanceInfo.textContent = 'Render: ' + (t1 - t0).toFixed(1) + 'ms';
    }

    // Auto disable limit when user searches or filters
    function onFilterChange(){
        if(searchBox.value || statusFilter.value || fromDate.value || toDate.value) limitedMode=false; else limitedMode=true; applyFilters();
    }

    searchBox.addEventListener('input', onFilterChange);
    statusFilter.addEventListener('change', onFilterChange);
    fromDate.addEventListener('change', onFilterChange);
    toDate.addEventListener('change', onFilterChange);

    // CSV Export (current view)
    btnExport.addEventListener('click', ()=>{
        const visible = Array.from(bodyEl.querySelectorAll('tr:not(.hidden-row)'));
        if(!visible.length){ alert('No rows to export.'); return; }
        const lines = [];
        lines.push('Student,HostCompany,StartDate,EndDate,CampusMentor,WorkplaceMentor,Progress,Status,LastActivity,RiskLevel');
        visible.forEach(r=>{
            const cells = r.querySelectorAll('td');
            const student = cells[1]?.innerText.trim() || '';
            const host = cells[2]?.innerText.trim() || '';
            const start = cells[3]?.innerText.trim() || '';
            const end = cells[4]?.innerText.trim() || '';
            const campus = cells[5]?.innerText.trim() || '';
            const workplace = cells[6]?.innerText.trim() || '';
            const progress = cells[7]?.innerText.trim() || '';
            const status = cells[8]?.innerText.trim() || '';
            const lastActivity = cells[9]?.innerText.trim() || '';
            const risk = cells[10]?.innerText.trim() || '';
            const row = [student,host,start,end,campus,workplace,progress,status,lastActivity,risk].map(v => '"'+v.replace(/"/g,'""')+'"').join(',');
            lines.push(row);
        });
        const blob = new Blob([lines.join('\r\n')],{type:'text/csv;charset=utf-8;'});
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob); a.download = 'placements-' + new Date().toISOString().slice(0,10) + '.csv';
        document.body.appendChild(a); a.click(); document.body.removeChild(a);
    });

    applyFilters();
})();
</script>










