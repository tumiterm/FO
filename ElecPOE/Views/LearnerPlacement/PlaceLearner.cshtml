@using ForekOnline.Domain.ViewModels
@model LearnerPlacementViewModel
@using static ForekOnline.Domain.Enums.EnumRegistry
@{
    ViewData["Title"] = "Place Learner";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" />

<style>
:root {
    --c-bg:          #f4f6f9;
    --c-surface:     #ffffff;
    --c-border:      #e3e7ef;
    --c-border-s:    #cbd2dc;
    --c-text:        #1a2130;
    --c-muted:       #6b7585;
    --c-accent:      #7d0e11;
    --c-accent-mid:  #b31217;
    --c-accent-warm: #ff7a18;
    --c-grad:        linear-gradient(128deg, #7d0e11 0%, #b31217 52%, #ff7a18 100%);
    --c-grad-soft:   linear-gradient(128deg, #7d0e1112 0%, #b3121718 52%, #ff7a181a 100%);
    --c-glow:        0 0 0 .18rem #b312172a;
    --c-shadow-sm:   0 2px 8px -2px rgba(30,10,10,.12);
    --c-shadow-md:   0 8px 28px -8px rgba(125,14,17,.22), 0 2px 10px -4px rgba(125,14,17,.10);
    --c-shadow-lg:   0 18px 52px -16px rgba(125,14,17,.32), 0 6px 24px -8px rgba(125,14,17,.14);
    --r-xl:          32px;
    --r-lg:          22px;
    --r-md:          14px;
    --r-sm:          10px;
    font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body { background: var(--c-bg); }

.pl-shell {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
}

.hero {
    position: relative;
    border-radius: var(--r-xl);
    overflow: hidden;
    padding: 2rem 2rem 1.75rem;
    display: flex;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1.5rem;
    border: 1px solid var(--c-border);
    background: var(--c-surface);
    box-shadow: var(--c-shadow-md);
}
.hero-mesh {
    position: absolute;
    inset: 0;
    background:
        radial-gradient(ellipse 72% 66% at 4% 12%, #7d0e1116 0%, transparent 60%),
        radial-gradient(ellipse 55% 50% at 95% 88%, #ff7a1818 0%, transparent 58%),
        radial-gradient(ellipse 45% 40% at 52% 50%, #b3121710 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
}
.hero > * { position: relative; z-index: 1; }

.hero-icon {
    width: 80px; height: 80px;
    border-radius: 24px;
    background: var(--c-grad);
    display: flex; align-items: center; justify-content: center;
    font-size: 2.1rem; color: #fff;
    box-shadow: 0 14px 36px -12px rgba(179,18,23,.58), 0 0 0 6px rgba(179,18,23,.08);
    flex-shrink: 0;
    animation: iconPop .65s cubic-bezier(.34,1.56,.64,1) both;
}
@@keyframes iconPop { from { transform: scale(.55) rotate(-8deg); opacity: 0; } to { transform: scale(1) rotate(0); opacity: 1; } }

.hero-copy { flex: 1; min-width: 200px; }
.hero-copy h1 {
    font-size: 1.62rem;
    font-weight: 700;
    letter-spacing: -.4px;
    color: var(--c-text);
    line-height: 1.2;
}
.hero-copy h1 span {
    background: var(--c-grad);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}
.hero-tagline {
    margin-top: .55rem;
    display: inline-flex; align-items: center; gap: .4rem;
    font-size: .58rem; letter-spacing: .2rem; font-weight: 700;
    text-transform: uppercase;
    background: #fff5f3; color: var(--c-accent-mid);
    border: 1px solid #f3c9cb;
    padding: .45rem .85rem; border-radius: 40px;
}

.hero-toolbar { margin-left: auto; display: flex; gap: .5rem; flex-wrap: wrap; align-items: flex-start; }

.step-rail {
    margin-top: 1.65rem;
    display: flex;
    gap: 0;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--r-lg);
    overflow: hidden;
    box-shadow: var(--c-shadow-sm);
}
.step-item {
    flex: 1;
    padding: .75rem 1rem;
    display: flex; align-items: center; gap: .65rem;
    position: relative;
    transition: background .3s;
    border-right: 1px solid var(--c-border);
}
.step-item:last-child { border-right: none; }
.step-item.active { background: var(--c-grad-soft); }
.step-item.done { background: #f0faf4; }
.step-num {
    width: 30px; height: 30px;
    border-radius: 50%;
    background: var(--c-border);
    display: flex; align-items: center; justify-content: center;
    font-size: .65rem; font-weight: 700; color: var(--c-muted);
    flex-shrink: 0;
    transition: .3s;
}
.step-item.active .step-num { background: var(--c-grad); color: #fff; box-shadow: 0 4px 12px -4px rgba(179,18,23,.5); }
.step-item.done .step-num { background: #18a85a; color: #fff; }
.step-text { display: flex; flex-direction: column; }
.step-label { font-size: .58rem; letter-spacing: .16rem; text-transform: uppercase; font-weight: 700; color: var(--c-muted); }
.step-item.active .step-label { color: var(--c-accent-mid); }
.step-item.done .step-label { color: #137a44; }
.step-desc { font-size: .6rem; color: #aaa; font-weight: 500; }

.btn {
    display: inline-flex; align-items: center; gap: .5rem;
    font-size: .58rem; letter-spacing: .13rem; font-weight: 700;
    text-transform: uppercase; text-decoration: none;
    padding: .62rem 1.1rem; border-radius: var(--r-md);
    border: 1px solid var(--c-border);
    background: var(--c-surface); color: var(--c-accent-mid);
    cursor: pointer; transition: .3s; white-space: nowrap;
    position: relative; overflow: hidden;
}
.btn::after {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(circle, rgba(255,255,255,.35) 0%, transparent 70%);
    opacity: 0; transition: opacity .3s;
    pointer-events: none;
}
.btn:hover::after { opacity: 1; }
.btn:hover { background: var(--c-grad); color: #fff; border-color: var(--c-accent); box-shadow: var(--c-shadow-md); }
.btn-primary { background: var(--c-grad); color: #fff; border-color: var(--c-accent); box-shadow: var(--c-shadow-sm); }
.btn-primary:hover { filter: brightness(.93); box-shadow: var(--c-shadow-lg); }
.btn-ghost { background: transparent; }
.btn-ghost:hover { background: var(--c-grad); }
.btn-sm { padding: .48rem .8rem; font-size: .54rem; border-radius: var(--r-sm); }
.btn:disabled { opacity: .55; pointer-events: none; }

.pl-grid {
    margin-top: 1.5rem;
    display: grid;
    gap: 1.4rem;
    grid-template-columns: 1fr 380px;
    align-items: start;
}
@@media (max-width: 960px) { .pl-grid { grid-template-columns: 1fr; } }

.card {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: 28px;
    padding: 1.45rem 1.4rem 1.35rem;
    display: flex; flex-direction: column; gap: 1.25rem;
    position: relative; overflow: hidden;
    box-shadow: var(--c-shadow-sm);
    animation: fadeUp .55s cubic-bezier(.22,1,.36,1) both;
}
@@keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
.card::before {
    content: ''; position: absolute; inset: 0;
    background: var(--c-grad-soft);
    pointer-events: none;
}
.card > * { position: relative; }

.card-head {
    display: flex; align-items: center; gap: .7rem; flex-wrap: wrap;
    padding-bottom: .9rem;
    border-bottom: 1px solid var(--c-border);
}
.card-head-icon {
    width: 38px; height: 38px;
    border-radius: 12px;
    background: var(--c-grad-soft);
    border: 1px solid #f3c9cb;
    display: flex; align-items: center; justify-content: center;
    font-size: .9rem; color: var(--c-accent-mid);
}
.card-title {
    font-size: .72rem; letter-spacing: .22rem; font-weight: 800;
    text-transform: uppercase; color: var(--c-accent-mid);
}
.card-badge {
    margin-left: auto;
    background: var(--c-grad-soft);
    color: var(--c-accent-mid);
    border: 1px solid #f3c9cb;
    font-size: .52rem; font-weight: 700; letter-spacing: .12rem;
    text-transform: uppercase;
    padding: .35rem .7rem; border-radius: 30px;
    display: inline-flex; align-items: center; gap: .35rem;
}

.lookup-band {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: 24px;
    padding: 1.1rem 1.35rem;
    margin-top: 1.5rem;
    display: flex; flex-wrap: wrap; gap: 1rem; align-items: flex-end;
    box-shadow: var(--c-shadow-sm);
    position: relative; overflow: hidden;
    animation: fadeUp .4s ease both;
}
.lookup-band::before {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(128deg, #b3121709 0%, #ff7a1810 100%);
    pointer-events: none;
}
.lookup-band > * { position: relative; }
.lookup-title {
    width: 100%;
    font-size: .58rem; letter-spacing: .2rem; font-weight: 800;
    text-transform: uppercase; color: var(--c-muted);
    display: flex; align-items: center; gap: .45rem;
}
.lookup-title i { color: var(--c-accent-mid); }
.lookup-input-wrap {
    flex: 1 1 280px;
    display: flex; align-items: center; gap: .55rem;
    background: #fff; border: 1px solid var(--c-border);
    border-radius: var(--r-md); padding: .58rem .75rem;
    transition: .25s;
}
.lookup-input-wrap:focus-within { border-color: var(--c-accent-mid); box-shadow: var(--c-glow); }
.lookup-input-wrap i { color: #aaa; font-size: .78rem; flex-shrink: 0; }
.lookup-input-wrap input {
    border: none; outline: none; background: transparent;
    font-size: .72rem; font-family: inherit; color: var(--c-text);
    width: 100%;
}
.lookup-result {
    width: 100%;
    display: none;
}
.lookup-card {
    display: flex; align-items: center; gap: .75rem;
    background: #f9fafc; border: 1px solid var(--c-border);
    border-radius: var(--r-md); padding: .75rem .9rem;
}
.lookup-avatar {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: var(--c-grad);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 1.05rem; flex-shrink: 0;
    box-shadow: 0 4px 12px -4px rgba(179,18,23,.38);
}
.lookup-info { flex: 1; }
.lookup-name { font-size: .78rem; font-weight: 600; color: var(--c-text); }
.lookup-meta { font-size: .58rem; color: var(--c-muted); margin-top: .2rem; }
.placement-status-badge {
    font-size: .52rem; font-weight: 700; letter-spacing: .1rem;
    padding: .38rem .65rem; border-radius: 30px;
    display: inline-flex; align-items: center; gap: .35rem;
}
.pst-clear { background: #e8f9ef; color: #137a44; border: 1px solid #b7e6c8; }
.pst-placed { background: #ffe6ea; color: #b31217; border: 1px solid #f3b4ba; }
.pst-checking { background: #fff3e0; color: #bc6b00; border: 1px solid #f0c48b; }

.field-grid { display: grid; gap: 1.05rem; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); }
.field { display: flex; flex-direction: column; gap: .42rem; }
.field label {
    font-size: .52rem; letter-spacing: .16rem; text-transform: uppercase;
    font-weight: 700; color: #505a68;
    display: flex; align-items: center; gap: .4rem;
}
.field label .req { color: var(--c-accent-mid); font-size: .65rem; line-height: 1; }
.input-wrap {
    display: flex; align-items: center; gap: .55rem;
    background: #fff; border: 1.5px solid var(--c-border);
    border-radius: var(--r-md); padding: .6rem .75rem;
    transition: .25s;
}
.input-wrap:focus-within { border-color: var(--c-accent-mid); box-shadow: var(--c-glow); }
.input-wrap:has(input[readonly]) { background: #f9f9fa; cursor: not-allowed; }
.input-wrap i { color: #bbb; font-size: .78rem; flex-shrink: 0; transition: color .25s; }
.input-wrap:focus-within i { color: var(--c-accent-mid); }
.input-wrap input,
.input-wrap select {
    border: none; outline: none; background: transparent;
    font-size: .72rem; font-family: inherit; color: var(--c-text); width: 100%;
}
.input-wrap select { cursor: pointer; }
.field .val-msg { font-size: .54rem; color: var(--c-accent-mid); display: none; }
.field .val-msg.show { display: block; }

.toggle-row { display: flex; align-items: center; gap: .65rem; }
.toggle-switch { position: relative; display: inline-block; width: 42px; height: 24px; }
.toggle-switch input { opacity: 0; width: 0; height: 0; }
.toggle-track {
    position: absolute; inset: 0; border-radius: 40px;
    background: #e0e4ea; cursor: pointer; transition: .35s;
}
.toggle-track::before {
    content: ''; position: absolute;
    width: 18px; height: 18px; left: 3px; top: 3px;
    background: #fff; border-radius: 50%;
    box-shadow: 0 2px 6px rgba(0,0,0,.18);
    transition: .35s cubic-bezier(.34,1.56,.64,1);
}
.toggle-switch input:checked + .toggle-track { background: var(--c-grad); }
.toggle-switch input:checked + .toggle-track::before { transform: translateX(18px); }
.toggle-label { font-size: .62rem; font-weight: 600; color: var(--c-text); }
.toggle-pill {
    font-size: .5rem; font-weight: 700; letter-spacing: .1rem;
    padding: .3rem .55rem; border-radius: 30px;
    background: #f0f1f3; color: #666; display: inline-flex; align-items: center; gap: .3rem;
    transition: .3s;
}
.toggle-pill.on { background: #e8f9ef; color: #137a44; border: 1px solid #b7e6c8; }

.summary-stack { display: flex; flex-direction: column; gap: 1.1rem; }

.summary-widget {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: 24px;
    padding: 1.1rem 1.15rem 1rem;
    display: flex; flex-direction: column; gap: .8rem;
    position: relative; overflow: hidden;
    box-shadow: var(--c-shadow-sm);
    animation: fadeUp .6s cubic-bezier(.22,1,.36,1) .1s both;
}
.summary-widget::before {
    content: ''; position: absolute; inset: 0;
    background: var(--c-grad-soft); pointer-events: none;
}
.summary-widget > * { position: relative; }
.sw-head {
    font-size: .58rem; letter-spacing: .2rem; font-weight: 800;
    text-transform: uppercase; color: var(--c-accent-mid);
    display: flex; align-items: center; gap: .45rem;
    padding-bottom: .75rem; border-bottom: 1px solid var(--c-border);
}
.sw-row { display: flex; justify-content: space-between; align-items: flex-start; gap: .5rem; }
.sw-key { font-size: .55rem; letter-spacing: .1rem; text-transform: uppercase; font-weight: 700; color: var(--c-muted); padding-top: .1rem; }
.sw-val { font-size: .68rem; font-weight: 600; color: var(--c-text); text-align: right; flex: 1; word-break: break-word; }
.sw-val.placeholder { color: #ccc; font-style: italic; font-weight: 400; }

.duration-pill {
    display: flex; align-items: center; justify-content: center;
    background: var(--c-grad);
    border-radius: var(--r-md); padding: .9rem 1rem;
    color: #fff; gap: .65rem;
    box-shadow: var(--c-shadow-md);
}
.duration-pill .dp-num {
    font-size: 2rem; font-weight: 800; letter-spacing: -.5px; line-height: 1;
}
.duration-pill .dp-label {
    font-size: .62rem; font-weight: 600; letter-spacing: .15rem;
    text-transform: uppercase; opacity: .88;
}

.preview-frame {
    border-radius: 20px; overflow: hidden; position: relative;
    border: 1px solid var(--c-border);
    box-shadow: var(--c-shadow-sm);
    min-height: 200px;
}
.preview-frame img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
    transition: transform .55s cubic-bezier(.22,1,.36,1);
}
.preview-frame:hover img { transform: scale(1.04); }
.preview-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(125,14,17,.55) 0%, transparent 55%);
    display: flex; align-items: flex-end; padding: 1rem;
}
.preview-overlay-text {
    font-size: .62rem; font-weight: 700; color: #fff;
    letter-spacing: .15rem; text-transform: uppercase;
    display: flex; align-items: center; gap: .4rem;
}

.form-actions {
    display: flex; flex-wrap: wrap; gap: .65rem; align-items: center;
    padding-top: 1rem; border-top: 1px solid var(--c-border);
}
.form-note {
    width: 100%;
    font-size: .54rem; letter-spacing: .1rem; color: var(--c-muted);
    display: flex; align-items: flex-start; gap: .4rem;
}
.form-note i { color: var(--c-accent-mid); margin-top: .1rem; flex-shrink: 0; }

.select2-container .select2-selection--single {
    height: 44px !important;
    border: 1.5px solid var(--c-border) !important;
    border-radius: var(--r-md) !important;
    background: transparent !important;
    transition: border .25s, box-shadow .25s;
}
.select2-container--default.select2-container--focus .select2-selection--single,
.select2-container--default.select2-container--open .select2-selection--single {
    border-color: var(--c-accent-mid) !important;
    box-shadow: var(--c-glow) !important;
}
.select2-selection__rendered { line-height: 42px !important; font-size: .72rem !important; padding-left: .75rem !important; color: var(--c-text) !important; }
.select2-selection__arrow { height: 42px !important; }
.select2-dropdown { border: 1.5px solid var(--c-border) !important; border-radius: var(--r-md) !important; box-shadow: var(--c-shadow-md) !important; }
.select2-results__option { font-size: .7rem !important; padding: .55rem .75rem !important; }
.select2-results__option--highlighted { background: var(--c-grad) !important; color: #fff !important; }

.spin { display: inline-block; width: 14px; height: 14px; border: 2px solid #f3c9cb; border-top-color: var(--c-accent-mid); border-radius: 50%; animation: spin .7s linear infinite; }
@@keyframes spin { to { transform: rotate(360deg); } }

@@media (max-width: 640px) {
    .hero { padding: 1.25rem 1.1rem 1rem; }
    .hero-icon { width: 64px; height: 64px; font-size: 1.65rem; }
    .hero-copy h1 { font-size: 1.35rem; }
    .step-desc { display: none; }
}
</style>

<div class="pl-shell">

    <div class="hero">
        <div class="hero-mesh"></div>
        <div class="hero-icon"><i class="fa fa-briefcase"></i></div>
        <div class="hero-copy">
            <h1>Place <span>Learner</span></h1>
            <div class="hero-tagline"><i class="fa fa-user-graduate"></i> New Workplace Placement</div>
        </div>
        <div class="hero-toolbar">
            <a asp-action="PlacedLearners" asp-controller="LearnerPlacement" class="btn btn-ghost btn-sm">
                <i class="fa fa-list-ul"></i> All Placements
            </a>
            <a asp-action="StudentList" asp-controller="Student" class="btn btn-sm">
                <i class="fa fa-users"></i> Students
            </a>
        </div>
    </div>

    <div class="step-rail">
        <div class="step-item done" id="step1">
            <div class="step-num"><i class="fa fa-check" style="font-size:.6rem;"></i></div>
            <div class="step-text">
                <div class="step-label">Verify</div>
                <div class="step-desc">Student confirmed</div>
            </div>
        </div>
        <div class="step-item active" id="step2">
            <div class="step-num">2</div>
            <div class="step-text">
                <div class="step-label">Configure</div>
                <div class="step-desc">Placement details</div>
            </div>
        </div>
        <div class="step-item" id="step3">
            <div class="step-num">3</div>
            <div class="step-text">
                <div class="step-label">Save</div>
                <div class="step-desc">Persist record</div>
            </div>
        </div>
    </div>

    <div class="lookup-band">
        <div class="lookup-title"><i class="fa fa-magnifying-glass"></i> Student Placement Check</div>
        <div class="lookup-input-wrap">
            <i class="fa fa-user-circle"></i>
            <input type="text" id="lookupInput" placeholder="Type a student name to check existing placement…" autocomplete="off" />
        </div>
        <button type="button" class="btn btn-sm" id="lookupBtn">
            <i class="fa fa-search"></i> Check
        </button>
        <div class="lookup-result" id="lookupResult">
            <div class="lookup-card" id="lookupCard">
                <div class="lookup-avatar" id="lookupAvatar"><i class="fa fa-user"></i></div>
                <div class="lookup-info">
                    <div class="lookup-name" id="lookupName">—</div>
                    <div class="lookup-meta" id="lookupMeta">—</div>
                </div>
                <span class="placement-status-badge" id="lookupBadge"></span>
            </div>
        </div>
    </div>

    <form asp-action="PlaceLearner" method="post" autocomplete="off" novalidate id="placementForm">
        @Html.AntiForgeryToken()
        <input asp-for="StudentId" type="hidden" />
        <input asp-for="StudentNumber" type="hidden" />

        <div class="pl-grid">

            <div class="card">
                <div class="card-head">
                    <div class="card-head-icon"><i class="fa fa-id-card"></i></div>
                    <span class="card-title">Placement Details</span>
                    <span class="card-badge" id="studentBadge"><i class="fa fa-user"></i> @Model.Student</span>
                </div>

                <div class="field-grid">
                    <div class="field" style="grid-column: 1 / -1;">
                        <label><i class="fa fa-graduation-cap"></i> Learner</label>
                        <div class="input-wrap" style="background:#f9f9fa;">
                            <i class="fa fa-user-tie"></i>
                            <input asp-for="Student" readonly tabindex="-1" />
                        </div>
                    </div>

                    <div class="field">
                        <label><i class="fa fa-building"></i> Host Company <span class="req">*</span></label>
                        <div class="input-wrap" style="padding: 0 .75rem 0 .75rem;">
                            <i class="fa fa-city"></i>
                            <select required asp-for="CompanyId" class="s2-company" asp-items="ViewBag.CompanyId" style="padding-left:.25rem;">
                                <option value="">Select company…</option>
                            </select>
                        </div>
                        <span asp-validation-for="CompanyId" class="val-msg show"></span>
                    </div>

                    <div class="field">
                        <label><i class="fa fa-circle-dot"></i> Status <span class="req">*</span></label>
                        <div class="input-wrap">
                            <i class="fa fa-spinner"></i>
                            <select required asp-for="Status" asp-items="Html.GetEnumSelectList<eStatus>()">
                                <option value="">Select status…</option>
                            </select>
                        </div>
                        <span asp-validation-for="Status" class="val-msg show"></span>
                    </div>

                    <div class="field">
                        <label><i class="fa fa-chalkboard-user"></i> Campus Mentor <span class="req">*</span></label>
                        <div class="input-wrap" style="padding: 0 .75rem 0 .75rem;">
                            <i class="fa fa-users"></i>
                            <select required asp-for="PlacedBy" class="s2-mentor" asp-items="ViewBag.UserId" style="padding-left:.25rem;">
                                <option value="">Select mentor…</option>
                            </select>
                        </div>
                        <span asp-validation-for="PlacedBy" class="val-msg show"></span>
                    </div>

                    <div class="field">
                        <label><i class="fa fa-book-open"></i> Course</label>
                        <div class="input-wrap" style="padding: 0 .75rem 0 .75rem;">
                            <i class="fa fa-graduation-cap"></i>
                            <select asp-for="CourseId" class="s2-course" asp-items="ViewBag.CourseId" id="courseSelect" style="padding-left:.25rem;">
                                <option value="">Select course…</option>
                            </select>
                        </div>
                    </div>

                    <div class="field">
                        <label><i class="fa fa-puzzle-piece"></i> Module</label>
                        <div class="input-wrap" style="padding: 0 .75rem 0 .75rem;">
                            <i class="fa fa-layer-group"></i>
                            <select asp-for="Module" class="s2-module" id="moduleSelect" style="padding-left:.25rem;">
                                <option value="">Select module…</option>
                            </select>
                        </div>
                    </div>

                    <div class="field">
                        <label><i class="fa fa-calendar-plus"></i> Start Date <span class="req">*</span></label>
                        <div class="input-wrap">
                            <i class="fa fa-calendar"></i>
                            <input required asp-for="StartDate" type="date" id="startDate" />
                        </div>
                        <span asp-validation-for="StartDate" class="val-msg show"></span>
                    </div>

                    <div class="field">
                        <label><i class="fa fa-calendar-xmark"></i> End Date <span class="req">*</span></label>
                        <div class="input-wrap">
                            <i class="fa fa-calendar"></i>
                            <input required asp-for="EndDate" type="date" id="endDate" />
                        </div>
                        <span asp-validation-for="EndDate" class="val-msg show"></span>
                    </div>

                    <div class="field">
                        <label><i class="fa fa-clock"></i> Duration (Days)</label>
                        <div class="input-wrap">
                            <i class="fa fa-hourglass-half"></i>
                            <input asp-for="Duration" type="number" min="1" id="durationDays" placeholder="Auto-calculated" />
                        </div>
                        <small style="font-size:.52rem;color:#aaa;margin-top:.15rem;">Derived from dates; editing adjusts End Date.</small>
                    </div>

                    <div class="field">
                        <label><i class="fa fa-bell"></i> SMS Notification</label>
                        <div class="toggle-row" style="margin-top:.2rem;">
                            <label class="toggle-switch">
                                <input asp-for="SendNotification" type="checkbox" id="notifyCheck" />
                                <span class="toggle-track"></span>
                            </label>
                            <span class="toggle-label">Notify learner via SMS</span>
                            <span class="toggle-pill" id="notifyPill">
                                <i class="fa fa-bell-slash"></i> No Notice
                            </span>
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary" id="saveBtn">
                        <i class="fa fa-floppy-disk"></i> Save Placement
                    </button>
                    <a asp-action="StudentList" asp-controller="Student" class="btn btn-ghost">
                        <i class="fa fa-xmark"></i> Discard
                    </a>
                    <div class="form-note">
                        <i class="fa fa-circle-info"></i>
                        Fields marked <strong style="color:var(--c-accent-mid);">*</strong> are required.
                        Enabling SMS notification triggers learner communication upon save.
                    </div>
                </div>
            </div>

            <div class="summary-stack">

                <div class="summary-widget">
                    <div class="sw-head"><i class="fa fa-calendar-days"></i> Placement Window</div>
                    <div class="duration-pill" id="durationPill">
                        <div>
                            <div class="dp-num" id="dpNum">—</div>
                            <div class="dp-label">Days</div>
                        </div>
                        <div style="opacity:.75;font-size:.65rem;line-height:1.6;font-weight:500;">
                            <div id="dpFrom">From: —</div>
                            <div id="dpTo">To: —</div>
                        </div>
                    </div>
                    <div id="dpWarning" style="display:none;font-size:.58rem;color:#bc6b00;display:flex;align-items:center;gap:.4rem;">
                        <i class="fa fa-triangle-exclamation"></i> End date must be after start date.
                    </div>
                </div>

                <div class="summary-widget">
                    <div class="sw-head"><i class="fa fa-clipboard-list"></i> Live Summary</div>
                    <div class="sw-row"><span class="sw-key">Student</span><span class="sw-val" id="smStudent">@Model.Student</span></div>
                    <div class="sw-row"><span class="sw-key">Company</span><span class="sw-val placeholder" id="smCompany">Not selected</span></div>
                    <div class="sw-row"><span class="sw-key">Mentor</span><span class="sw-val placeholder" id="smMentor">Not selected</span></div>
                    <div class="sw-row"><span class="sw-key">Course</span><span class="sw-val placeholder" id="smCourse">Not selected</span></div>
                    <div class="sw-row"><span class="sw-key">Status</span><span class="sw-val placeholder" id="smStatus">Not selected</span></div>
                    <div class="sw-row"><span class="sw-key">Notify</span><span class="sw-val" id="smNotify">No</span></div>
                </div>

                <div class="summary-widget" style="padding:0;overflow:hidden;">
                    <div class="preview-frame">
                        <img src="~/Images/6308.jpg" alt="Placement Illustration" />
                        <div class="preview-overlay">
                            <div class="preview-overlay-text">
                                <i class="fa fa-building"></i> Workplace Placement
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </form>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script>
(function ($) {
    'use strict';

    const s2opts = { width: '100%', dropdownParent: $('body') };
    $('.s2-company, .s2-mentor, .s2-course, .s2-module').select2(s2opts);

    const parseDate = d => d ? new Date(d + 'T00:00:00') : null;
    const fmtDate   = d => d ? d.toLocaleDateString('en-ZA', { day:'2-digit', month:'short', year:'numeric' }) : '—';
    const diffDays  = (a, b) => Math.round((b - a) / 86400000) + 1;
    const setText   = (id, val, placeholder) => {
        const el = document.getElementById(id);
        if (!el) return;
        el.textContent = val || '—';
        el.classList.toggle('placeholder', !val);
    };

    const notifyCb  = document.getElementById('notifyCheck');
    const notifyPill = document.getElementById('notifyPill');
    const smNotify  = document.getElementById('smNotify');
    notifyCb?.addEventListener('change', () => {
        const on = notifyCb.checked;
        notifyPill.innerHTML = on
            ? '<i class="fa fa-bell"></i> Will Notify'
            : '<i class="fa fa-bell-slash"></i> No Notice';
        notifyPill.classList.toggle('on', on);
        smNotify.textContent = on ? 'Yes — SMS will be sent' : 'No';
    });

    const startEl = document.getElementById('startDate');
    const endEl   = document.getElementById('endDate');
    const durEl   = document.getElementById('durationDays');
    const dpNum   = document.getElementById('dpNum');
    const dpFrom  = document.getElementById('dpFrom');
    const dpTo    = document.getElementById('dpTo');
    const dpWarn  = document.getElementById('dpWarning');

    function syncDates() {
        const s = parseDate(startEl.value);
        const e = parseDate(endEl.value);
        if (s && e && e >= s) {
            const d = diffDays(s, e);
            durEl.value  = d;
            dpNum.textContent  = d;
            dpFrom.textContent = 'From: ' + fmtDate(s);
            dpTo.textContent   = 'To: '   + fmtDate(e);
            dpWarn.style.display = 'none';
        } else {
            dpNum.textContent  = '—';
            dpFrom.textContent = 'From: —';
            dpTo.textContent   = 'To: —';
            dpWarn.style.display = (startEl.value || endEl.value) ? 'flex' : 'none';
        }
    }

    function durToEnd() {
        const s = parseDate(startEl.value);
        const d = parseInt(durEl.value, 10);
        if (s && d > 0) {
            const e = new Date(s);
            e.setDate(e.getDate() + d - 1);
            endEl.value = e.toISOString().slice(0, 10);
            syncDates();
        }
    }

    startEl?.addEventListener('change', syncDates);
    endEl?.addEventListener('change', syncDates);
    durEl?.addEventListener('input', durToEnd);

    const company2 = $('select.s2-company');
    const mentor2  = $('select.s2-mentor');
    const course2  = $('select.s2-course');
    const status2  = $('select[name="Status"]');

    company2.on('change', function () {
        setText('smCompany', $('option:selected', this).text() || null);
    });
    mentor2.on('change', function () {
        setText('smMentor', $('option:selected', this).text() || null);
    });
    course2.on('change', function () {
        const txt = $('option:selected', this).text();
        setText('smCourse', txt && txt !== 'Select course…' ? txt : null);
        loadModules($(this).val());
    });
    status2.on('change', function () {
        setText('smStatus', $('option:selected', this).text() || null);
    });

    function loadModules(courseId) {
        const modSel = $('#moduleSelect');
        modSel.empty().append('<option value="">Loading…</option>');
        modSel.trigger('change');
        if (!courseId) {
            modSel.empty().append('<option value="">Select module…</option>');
            return;
        }
        $.getJSON('@Url.Action("GetCourseModuleId", "LearnerPlacement")', { CourseId: courseId })
            .done(function (data) {
                modSel.empty().append('<option value="">Select module…</option>');
                $.each(data, function (_, m) {
                    modSel.append($('<option>', { value: m.moduleId, text: m.moduleName }));
                });
                modSel.trigger('change');
            })
            .fail(function () {
                modSel.empty().append('<option value="">Failed to load</option>');
            });
    }

    const lookupInput  = document.getElementById('lookupInput');
    const lookupBtn    = document.getElementById('lookupBtn');
    const lookupResult = document.getElementById('lookupResult');
    const lookupName   = document.getElementById('lookupName');
    const lookupMeta   = document.getElementById('lookupMeta');
    const lookupBadge  = document.getElementById('lookupBadge');
    const lookupAvatar = document.getElementById('lookupAvatar');

    function doLookup() {
        const q = lookupInput.value.trim();
        if (!q) return;

        lookupBadge.className = 'placement-status-badge pst-checking';
        lookupBadge.innerHTML = '<span class="spin"></span> Checking…';
        lookupName.textContent = q;
        lookupMeta.textContent = 'Searching placement records…';
        lookupResult.style.display = 'block';
        lookupAvatar.innerHTML = '<i class="fa fa-user"></i>';

        $.getJSON('@Url.Action("CheckStudentPlacement", "LearnerPlacement")', { studentName: q })
            .done(function (res) {
                lookupName.textContent = res.studentName || q;
                if (res.isPlaced) {
                    lookupMeta.innerHTML =
                        'Placed at <strong>' + (res.companyName || 'a company') + '</strong>' +
                        (res.startDate ? ' &bull; From ' + res.startDate : '');
                    lookupBadge.className = 'placement-status-badge pst-placed';
                    lookupBadge.innerHTML = '<i class="fa fa-circle-xmark"></i> Already Placed';
                    lookupAvatar.innerHTML = '<i class="fa fa-user-xmark"></i>';
                } else {
                    lookupMeta.innerHTML = res.found
                        ? 'Student found &bull; No active placement on record.'
                        : 'No placement record found for this name.';
                    lookupBadge.className = 'placement-status-badge pst-clear';
                    lookupBadge.innerHTML = '<i class="fa fa-circle-check"></i> Clear';
                    lookupAvatar.innerHTML = '<i class="fa fa-user-check"></i>';
                }
            })
            .fail(function () {
                lookupMeta.textContent = 'Could not reach lookup service.';
                lookupBadge.className = 'placement-status-badge pst-checking';
                lookupBadge.innerHTML = '<i class="fa fa-triangle-exclamation"></i> Error';
            });
    }

    lookupBtn?.addEventListener('click', doLookup);
    lookupInput?.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); doLookup(); } });

    document.getElementById('saveBtn')?.addEventListener('click', function () {
        this.innerHTML = '<i class="fa fa-circle-notch fa-spin"></i> Saving…';
        this.disabled = true;
        document.getElementById('step3')?.classList.add('active');
    });

})(jQuery);
</script>