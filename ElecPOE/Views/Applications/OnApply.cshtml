@using static ForekOnline.Domain.Enums.EnumRegistry
@model ForekOnline.Domain.ViewModels.ApplyViewModel

@{
    ViewData["Title"] = "Application Review";

    var status = Model.Status.ToString() ?? "N/A";
    var applicantName = $"{Model.ApplicantName} {Model.ApplicantSurname}".Trim();
    var applicantInitials = string.Join("", new[] { Model.ApplicantName, Model.ApplicantSurname }
        .Where(value => !string.IsNullOrWhiteSpace(value))
        .Select(value => value!.Trim()[0].ToString().ToUpperInvariant()));

    string StatusClass(string value) => value switch
    {
        "Approved" => "status-approved",
        "Pending" => "status-pending",
        "Submitted" => "status-submitted",
        "Rejected" => "status-rejected",
        "AptituteTest" => "status-assessment",
        _ => "status-neutral"
    };

    string StatusCopy(string value) => value switch
    {
        "Approved" => "The application has successfully completed review.",
        "Pending" => "The application is waiting for additional review or information.",
        "Submitted" => "The application is ready for an admissions decision.",
        "Rejected" => "The application has not met the current admission requirements.",
        "AptituteTest" => "The applicant is progressing to the aptitude assessment stage.",
        _ => "Review the application record and select the appropriate outcome."
    };
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

<style>
    :root {
        --review-bg: #0a0a10;
        --review-surface: rgba(18, 18, 28, .86);
        --review-surface-solid: #12121c;
        --review-surface-raised: #181824;
        --review-border: rgba(255, 255, 255, .08);
        --review-border-strong: rgba(255, 255, 255, .15);
        --review-text: #f4f3f7;
        --review-muted: rgba(244, 243, 247, .58);
        --review-faint: rgba(244, 243, 247, .35);
        --review-red: #b31217;
        --review-orange: #ff7a18;
        --review-gold: #f6bd60;
        --review-green: #55d896;
        --review-blue: #66b9ff;
        --review-gradient: linear-gradient(135deg, #6f090d 0%, #b31217 42%, #ff7a18 100%);
        --review-gradient-soft: linear-gradient(135deg, rgba(179, 18, 23, .17), rgba(255, 122, 24, .08));
        --review-radius-xl: 28px;
        --review-radius-lg: 20px;
        --review-radius-md: 14px;
        --review-shadow: 0 26px 70px rgba(0, 0, 0, .28);
        --review-ease: cubic-bezier(.4, 0, .2, 1);
    }

    body { background: var(--review-bg); }

    .review-page {
        position: relative;
        isolation: isolate;
        max-width: 1380px;
        width: calc(100% - 2rem);
        margin: 0 auto;
        padding: 2rem 0 4rem;
        color: var(--review-text);
    }

    .review-page::before,
    .review-page::after {
        content: "";
        position: fixed;
        z-index: -1;
        width: 34rem;
        height: 34rem;
        border-radius: 50%;
        filter: blur(110px);
        pointer-events: none;
        opacity: .15;
    }

    .review-page::before { top: 2rem; right: -14rem; background: var(--review-orange); }
    .review-page::after { bottom: -16rem; left: -12rem; background: var(--review-red); }

    .review-hero {
        position: relative;
        overflow: hidden;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 2rem;
        align-items: center;
        min-height: 245px;
        padding: clamp(1.5rem, 4vw, 3rem);
        border: 1px solid var(--review-border);
        border-radius: var(--review-radius-xl);
        background:
            radial-gradient(circle at 80% 15%, rgba(255, 122, 24, .2), transparent 33%),
            radial-gradient(circle at 10% 120%, rgba(179, 18, 23, .24), transparent 42%),
            linear-gradient(145deg, rgba(24, 24, 36, .98), rgba(12, 12, 19, .98));
        box-shadow: var(--review-shadow);
    }

    .review-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        opacity: .22;
        background-image:
            linear-gradient(rgba(255,255,255,.035) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,.035) 1px, transparent 1px);
        background-size: 30px 30px;
        mask-image: linear-gradient(90deg, #000, transparent 72%);
    }

    .hero-copy, .hero-actions { position: relative; z-index: 1; }

    .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: .55rem;
        margin-bottom: 1rem;
        color: #ffad6f;
        font-size: .7rem;
        font-weight: 800;
        letter-spacing: .17em;
        text-transform: uppercase;
    }

    .eyebrow::before { content: ""; width: 28px; height: 1px; background: currentColor; }

    .review-title {
        max-width: 830px;
        margin: 0;
        color: var(--review-text);
        font-family: 'Space Grotesk', 'Inter', sans-serif;
        font-size: clamp(2rem, 5vw, 4rem);
        font-weight: 800;
        letter-spacing: -.055em;
        line-height: .98;
    }

    .review-title span {
        background: linear-gradient(100deg, #fff 20%, #ffb478 82%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .hero-meta {
        display: flex;
        flex-wrap: wrap;
        gap: .65rem 1.25rem;
        margin-top: 1.35rem;
        color: var(--review-muted);
        font-size: .78rem;
    }

    .hero-meta span { display: inline-flex; align-items: center; gap: .5rem; }
    .hero-meta i { color: var(--review-orange); }

    .hero-actions { display: flex; flex-direction: column; min-width: 150px; gap: .7rem; }

    .review-button {
        min-height: 44px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .55rem;
        padding: .72rem 1rem;
        border: 1px solid var(--review-border-strong);
        border-radius: 12px;
        background: rgba(255,255,255,.045);
        color: var(--review-text);
        font-size: .72rem;
        font-weight: 750;
        letter-spacing: .04em;
        text-decoration: none;
        cursor: pointer;
        transition: transform .2s var(--review-ease), border-color .2s, background .2s, box-shadow .2s;
    }

    .review-button:hover {
        transform: translateY(-2px);
        border-color: rgba(255, 122, 24, .5);
        background: rgba(255, 122, 24, .1);
        color: #fff;
    }

    .review-button-primary {
        border-color: transparent;
        background: var(--review-gradient);
        box-shadow: 0 10px 28px rgba(179, 18, 23, .22);
    }

    .review-button-primary:hover { background: linear-gradient(135deg, #8a0c11, #d32820 48%, #ff8b34); }
    .review-button-danger { color: #ff9a9e; }

    .review-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.45fr) minmax(320px, .55fr);
        gap: 1.25rem;
        margin-top: 1.25rem;
        align-items: start;
    }

    .review-card {
        border: 1px solid var(--review-border);
        border-radius: var(--review-radius-lg);
        background: var(--review-surface);
        box-shadow: 0 16px 44px rgba(0,0,0,.14);
        backdrop-filter: blur(20px);
    }

    .decision-card { overflow: hidden; }

    .card-heading {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.35rem 1.4rem 1.15rem;
        border-bottom: 1px solid var(--review-border);
    }

    .card-kicker {
        display: block;
        margin-bottom: .35rem;
        color: var(--review-orange);
        font-size: .62rem;
        font-weight: 800;
        letter-spacing: .14em;
        text-transform: uppercase;
    }

    .card-heading h2, .section-heading h2 {
        margin: 0;
        color: var(--review-text);
        font-size: 1.05rem;
        font-weight: 750;
        letter-spacing: -.02em;
    }

    .card-heading p, .section-heading p {
        margin: .35rem 0 0;
        color: var(--review-muted);
        font-size: .75rem;
        line-height: 1.55;
    }

    .status-pill {
        flex: 0 0 auto;
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        padding: .5rem .7rem;
        border: 1px solid;
        border-radius: 999px;
        font-size: .63rem;
        font-weight: 800;
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    .status-pill i { font-size: .46rem; }
    .status-approved { color: #7ce3aa; background: rgba(31, 155, 89, .12); border-color: rgba(85, 216, 150, .25); }
    .status-pending { color: #7fc8ff; background: rgba(43, 142, 219, .12); border-color: rgba(102, 185, 255, .25); }
    .status-submitted { color: #ffc171; background: rgba(255, 139, 44, .11); border-color: rgba(255, 170, 91, .25); }
    .status-rejected { color: #ff858a; background: rgba(204, 48, 55, .12); border-color: rgba(255, 101, 107, .25); }
    .status-assessment { color: #d1adff; background: rgba(137, 76, 211, .12); border-color: rgba(190, 142, 247, .25); }
    .status-neutral { color: #c9c7d0; background: rgba(255,255,255,.05); border-color: var(--review-border-strong); }

    .decision-form { padding: 1.35rem 1.4rem 1.45rem; }

    .field-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
    .field-wide { grid-column: 1 / -1; }

    .field-label {
        display: flex;
        align-items: center;
        gap: .45rem;
        margin: 0 0 .5rem;
        color: rgba(244, 243, 247, .72);
        font-size: .64rem;
        font-weight: 800;
        letter-spacing: .09em;
        text-transform: uppercase;
    }

    .field-label i { color: var(--review-orange); }

    .review-control,
    .decision-form .form-control,
    .rejection-modal .form-control {
        width: 100%;
        min-height: 48px;
        padding: .75rem .85rem;
        border: 1px solid var(--review-border-strong);
        border-radius: 12px !important;
        outline: none;
        background-color: rgba(255,255,255,.045);
        color: var(--review-text);
        font-size: .78rem;
        transition: border-color .2s, background .2s, box-shadow .2s;
    }

    select.review-control,
    .decision-form select.form-control {
        appearance: auto;
        color-scheme: dark;
    }

    .review-control:focus,
    .decision-form .form-control:focus,
    .rejection-modal .form-control:focus {
        border-color: rgba(255, 122, 24, .72);
        background-color: rgba(255,255,255,.065);
        color: #fff;
        box-shadow: 0 0 0 3px rgba(255, 122, 24, .11);
    }

    .review-control[readonly] { color: rgba(244, 243, 247, .72); cursor: default; }
    .review-control option { background: #181824; color: #fff; }
    .field-help { margin-top: .42rem; color: var(--review-faint); font-size: .66rem; }
    .field-error { margin-top: .45rem; color: #ff858a; font-size: .68rem; }

    .pending-panel {
        margin-top: 1rem;
        padding: 1rem;
        border: 1px solid rgba(102, 185, 255, .2);
        border-radius: var(--review-radius-md);
        background: rgba(62, 147, 214, .06);
    }

    .decision-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-top: 1.2rem;
        padding-top: 1.15rem;
        border-top: 1px solid var(--review-border);
    }

    .decision-note { max-width: 470px; color: var(--review-muted); font-size: .69rem; line-height: 1.55; }
    .decision-note i { margin-right: .35rem; color: var(--review-gold); }
    .decision-actions { display: flex; flex-wrap: wrap; gap: .65rem; justify-content: flex-end; }

    .identity-card { overflow: hidden; }

    .identity-top {
        position: relative;
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.4rem;
        background: var(--review-gradient-soft);
        border-bottom: 1px solid var(--review-border);
    }

    .avatar {
        width: 62px;
        height: 62px;
        flex: 0 0 auto;
        display: grid;
        place-items: center;
        border: 1px solid rgba(255,255,255,.18);
        border-radius: 19px;
        background: var(--review-gradient);
        color: #fff;
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1.2rem;
        font-weight: 800;
        box-shadow: 0 12px 28px rgba(179,18,23,.24);
    }

    .identity-name { margin: 0; color: #fff; font-size: 1.05rem; font-weight: 750; }
    .identity-id { margin-top: .35rem; color: var(--review-muted); font-family: ui-monospace, monospace; font-size: .7rem; letter-spacing: .06em; }

    .identity-list { display: grid; gap: 0; margin: 0; padding: .4rem 1.4rem 1rem; }

    .identity-row {
        display: grid;
        grid-template-columns: 28px minmax(0, 1fr);
        gap: .7rem;
        padding: .85rem 0;
        border-bottom: 1px solid var(--review-border);
    }

    .identity-row:last-child { border-bottom: 0; }
    .identity-row > i { margin-top: .15rem; color: var(--review-orange); text-align: center; }
    .identity-row dt { margin: 0 0 .2rem; color: var(--review-faint); font-size: .59rem; font-weight: 800; letter-spacing: .09em; text-transform: uppercase; }
    .identity-row dd { margin: 0; color: rgba(244,243,247,.83); font-size: .73rem; line-height: 1.45; overflow-wrap: anywhere; }

    .content-section { margin-top: 1.25rem; padding: 1.4rem; }

    .section-heading {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .section-mark {
        width: 42px;
        height: 42px;
        display: grid;
        place-items: center;
        flex: 0 0 auto;
        border: 1px solid rgba(255, 122, 24, .24);
        border-radius: 13px;
        background: rgba(255, 122, 24, .08);
        color: #ff9c53;
    }

    .section-title-wrap { display: flex; align-items: center; gap: .85rem; }

    .detail-cards { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .85rem; }

    .detail-card {
        min-width: 0;
        padding: 1rem;
        border: 1px solid var(--review-border);
        border-radius: var(--review-radius-md);
        background: rgba(255,255,255,.025);
        transition: transform .2s var(--review-ease), border-color .2s, background .2s;
    }

    .detail-card:hover { transform: translateY(-2px); border-color: rgba(255,122,24,.23); background: rgba(255,255,255,.04); }
    .detail-card h3 { margin: 0 0 .85rem; color: #fff; font-size: .76rem; font-weight: 750; }
    .detail-card h3 i { width: 22px; color: var(--review-orange); }

    .detail-list { display: grid; gap: .72rem; margin: 0; }
    .detail-item dt { margin: 0 0 .16rem; color: var(--review-faint); font-size: .56rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
    .detail-item dd { margin: 0; color: rgba(244,243,247,.8); font-size: .7rem; line-height: 1.5; overflow-wrap: anywhere; }
    .detail-link { color: #ffac6e; text-decoration: none; }
    .detail-link:hover { color: #fff; }

    .document-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: .85rem; }

    .document-card {
        min-height: 126px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem;
        border: 1px solid var(--review-border);
        border-radius: var(--review-radius-md);
        background: rgba(255,255,255,.025);
        color: var(--review-text);
        text-decoration: none;
        transition: transform .22s var(--review-ease), border-color .22s, background .22s;
    }

    .document-card:hover { transform: translateY(-3px); border-color: rgba(255,122,24,.4); background: rgba(255,122,24,.065); color: #fff; }
    .document-icon { width: 38px; height: 38px; display: grid; place-items: center; border-radius: 11px; background: var(--review-gradient); color: #fff; box-shadow: 0 8px 20px rgba(179,18,23,.18); }
    .document-name { display: block; color: #fff; font-size: .72rem; font-weight: 750; }
    .document-action { display: block; margin-top: .22rem; color: var(--review-muted); font-size: .61rem; }

    .empty-documents {
        grid-column: 1 / -1;
        padding: 1.4rem;
        border: 1px dashed var(--review-border-strong);
        border-radius: var(--review-radius-md);
        color: var(--review-muted);
        font-size: .72rem;
        text-align: center;
    }

    .rejection-modal .modal-content {
        overflow: hidden;
        border: 1px solid var(--review-border-strong);
        border-radius: var(--review-radius-lg);
        background: #14141f;
        color: var(--review-text);
        box-shadow: 0 30px 90px rgba(0,0,0,.5);
    }

    .rejection-modal .modal-header { padding: 1.25rem 1.4rem; border-bottom: 1px solid var(--review-border); background: var(--review-gradient-soft); }
    .rejection-modal .modal-title { color: #fff; font-size: .95rem; font-weight: 750; }
    .rejection-modal .modal-body { padding: 1.4rem; }
    .rejection-modal .modal-footer { padding: 1rem 1.4rem; border-top: 1px solid var(--review-border); }
    .rejection-modal textarea.form-control { min-height: 120px; resize: vertical; }
    .rejection-modal .btn-close { filter: invert(1) grayscale(1); }

    @@media (max-width: 1080px) {
        .review-grid { grid-template-columns: 1fr; }
        .detail-cards { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .document-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    @@media (max-width: 720px) {
        .review-page { width: calc(100% - 1rem); padding-top: 1rem; }
        .review-hero { grid-template-columns: 1fr; min-height: auto; padding: 1.35rem; }
        .hero-actions { flex-direction: row; min-width: 0; flex-wrap: wrap; }
        .hero-actions .review-button { flex: 1 1 120px; }
        .field-grid, .detail-cards, .document-grid { grid-template-columns: 1fr; }
        .field-wide { grid-column: auto; }
        .card-heading, .section-heading, .decision-footer { align-items: stretch; flex-direction: column; }
        .decision-actions { justify-content: stretch; }
        .decision-actions .review-button { flex: 1 1 140px; }
        .content-section, .decision-form, .card-heading { padding-left: 1rem; padding-right: 1rem; }
    }

    @@media (prefers-reduced-motion: reduce) {
        .review-button, .detail-card, .document-card { transition: none; }
    }
</style>

<main class="review-page">
    <header class="review-hero">
        <div class="hero-copy">
            <div class="eyebrow">Admissions workspace</div>
            <h1 class="review-title">Review <span>@applicantName</span></h1>
            <div class="hero-meta">
                <span><i class="fa-solid fa-book-open"></i> @ViewData["Course"]</span>
                <span><i class="fa-regular fa-calendar"></i> Record viewed @DateTime.UtcNow.ToString("dd MMM yyyy")</span>
                <span><i class="fa-solid fa-shield-halved"></i> Secure application record</span>
            </div>
        </div>
        <nav class="hero-actions" aria-label="Application navigation">
            <button type="button" class="review-button" onclick="history.back()">
                <i class="fa-solid fa-arrow-left"></i> Back
            </button>
            <a asp-action="Applications" asp-controller="Applications" class="review-button">
                <i class="fa-solid fa-table-list"></i> All applications
            </a>
        </nav>
    </header>

    <div class="review-grid">
        <section class="review-card decision-card" aria-labelledby="decisionHeading">
            <div class="card-heading">
                <div>
                    <span class="card-kicker">Decision console</span>
                    <h2 id="decisionHeading">Application outcome</h2>
                    <p>@StatusCopy(status)</p>
                </div>
                <span class="status-pill @StatusClass(status)"><i class="fa-solid fa-circle"></i> @status</span>
            </div>

            <form asp-action="OnApply" method="post" enctype="multipart/form-data" class="decision-form">
                <input asp-for="ApplicantId" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="field-error"></div>

                <div class="field-grid">
                    <div>
                        <label class="field-label" asp-for="CourseId"><i class="fa-solid fa-book"></i> Course chosen</label>
                        <input class="review-control" asp-for="CourseId" value="@ViewData["Course"]" readonly />
                    </div>
                    <div>
                        <label class="field-label" asp-for="HighestQualification"><i class="fa-solid fa-graduation-cap"></i> Highest qualification</label>
                        <select asp-for="HighestQualification" class="form-control review-control" asp-items="Html.GetEnumSelectList<HighestQualification>()">
                            <option disabled value="">Select option</option>
                        </select>
                    </div>
                    <div class="field-wide">
                        <label class="field-label" asp-for="Status"><i class="fa-solid fa-flag-checkered"></i> Status / outcome</label>
                        <select asp-for="Status" class="form-control review-control status" asp-items="Html.GetEnumSelectList<ApplicationStatus>()">
                            <option disabled value="">Select option</option>
                        </select>
                        <div class="field-help">Changing the outcome may trigger the corresponding applicant communication and workflow.</div>
                    </div>
                </div>

                <div id="pendingFields" class="pending-panel d-none">
                    <div class="field-grid">
                        <div>
                            <label class="field-label" asp-for="PendingStatusReason"><i class="fa-regular fa-clock"></i> Pending reason</label>
                            <select asp-for="PendingStatusReason" class="form-control review-control" id="pendingReasonSelect">
                                <option value="">Select reason...</option>
                                <option value="Awaiting documents">Awaiting documents</option>
                                <option value="Under review">Under review</option>
                                <option value="Needs clarification">Needs clarification</option>
                                <option value="Background check in progress">Background check in progress</option>
                                <option value="Capacity / scheduling delay">Capacity / scheduling delay</option>
                            </select>
                            <div class="field-error d-none" id="pendingReasonError">
                                <i class="fa-solid fa-circle-exclamation"></i> Pending reason is required when status is Pending.
                            </div>
                        </div>
                        <div>
                            <label class="field-label" asp-for="PendingStatusMessage"><i class="fa-regular fa-message"></i> Applicant message</label>
                            <input asp-for="PendingStatusMessage" class="form-control review-control" maxlength="250" placeholder="Optional short message to the applicant" />
                            <div class="field-help">Optional · maximum 250 characters.</div>
                        </div>
                    </div>
                </div>

                <div class="decision-footer">
                    <div class="decision-note">
                        <i class="fa-solid fa-lock"></i> Your changes are recorded against this application when you save the review.
                    </div>
                    <div class="decision-actions">
                        <button type="button" id="btnReject" class="review-button review-button-danger" data-bs-toggle="modal" data-bs-target="#staticBackdrop">
                            <i class="fa-solid fa-ban"></i> Record rejection
                        </button>
                        <button type="submit" class="review-button review-button-primary">
                            <i class="fa-solid fa-check"></i> Save decision
                        </button>
                    </div>
                </div>
            </form>
        </section>

        <aside class="review-card identity-card" aria-labelledby="applicantHeading">
            <div class="identity-top">
                <div class="avatar" aria-hidden="true">@(string.IsNullOrWhiteSpace(applicantInitials) ? "FO" : applicantInitials)</div>
                <div>
                    <span class="card-kicker">Applicant profile</span>
                    <h2 class="identity-name" id="applicantHeading">@Model.ApplicantTitle @applicantName</h2>
                    <div class="identity-id">@Model.IDNumber</div>
                </div>
            </div>
            <dl class="identity-list">
                <div class="identity-row">
                    <i class="fa-solid fa-envelope"></i>
                    <div><dt>Email address</dt><dd>@Model.Email</dd></div>
                </div>
                <div class="identity-row">
                    <i class="fa-solid fa-phone"></i>
                    <div><dt>Cellphone</dt><dd>@Model.Cellphone</dd></div>
                </div>
                <div class="identity-row">
                    <i class="fa-solid fa-earth-africa"></i>
                    <div><dt>Citizenship</dt><dd>@Model.Selection</dd></div>
                </div>
                <div class="identity-row">
                    <i class="fa-solid fa-venus-mars"></i>
                    <div><dt>Gender</dt><dd>@Model.Gender</dd></div>
                </div>
                <div class="identity-row">
                    <i class="fa-solid fa-wallet"></i>
                    <div><dt>Funding type</dt><dd>@Model.FunderType</dd></div>
                </div>
            </dl>
        </aside>
    </div>

    <section class="review-card content-section" aria-labelledby="recordHeading">
        <div class="section-heading">
            <div class="section-title-wrap">
                <div class="section-mark"><i class="fa-solid fa-address-card"></i></div>
                <div>
                    <span class="card-kicker">Application record</span>
                    <h2 id="recordHeading">Applicant information</h2>
                    <p>The essential personal, study and guardian details submitted with this application.</p>
                </div>
            </div>
        </div>

        <div class="detail-cards">
            <article class="detail-card">
                <h3><i class="fa-solid fa-graduation-cap"></i> Study profile</h3>
                <dl class="detail-list">
                    <div class="detail-item"><dt>Course</dt><dd>@ViewData["Course"]</dd></div>
                    <div class="detail-item"><dt>Highest qualification</dt><dd>@Model.HighestQualification</dd></div>
                    <div class="detail-item"><dt>Current outcome</dt><dd>@Model.Status</dd></div>
                    <div class="detail-item"><dt>Funding type</dt><dd>@Model.FunderType</dd></div>
                </dl>
            </article>

            <article class="detail-card">
                <h3><i class="fa-solid fa-user"></i> Biographical</h3>
                <dl class="detail-list">
                    <div class="detail-item"><dt>Full name</dt><dd>@Model.ApplicantTitle @applicantName</dd></div>
                    <div class="detail-item"><dt>National ID</dt><dd>@Model.IDNumber</dd></div>
                    <div class="detail-item"><dt>Gender</dt><dd>@Model.Gender</dd></div>
                    <div class="detail-item"><dt>Citizenship</dt><dd>@Model.Selection</dd></div>
                </dl>
            </article>

            <article class="detail-card">
                <h3><i class="fa-solid fa-location-dot"></i> Contact & guardian</h3>
                <dl class="detail-list">
                    <div class="detail-item"><dt>Residential address</dt><dd>@Model.Line1, @Model.StreetName, @Model.Province</dd></div>
                    <div class="detail-item"><dt>Contact</dt><dd>@Model.Cellphone · @Model.Email</dd></div>
                    <div class="detail-item"><dt>Guardian</dt><dd>@Model.GuardianFirstName @Model.GuardianLastName · @Model.GuardianCellphone</dd></div>
                    <div class="detail-item">
                        <dt>Guardian ID document</dt>
                        <dd>
                            @if (!string.IsNullOrWhiteSpace(Model.GuardianIDDoc))
                            {
                                <a asp-action="FileDownload" asp-route-fileName="@Model.GuardianIDDoc" asp-route-destinationFolder="GuardianID" class="detail-link">
                                    <i class="fa-solid fa-download"></i> Download document
                                </a>
                            }
                            else
                            {
                                <span>Not provided</span>
                            }
                        </dd>
                    </div>
                </dl>
            </article>
        </div>
    </section>

    <section class="review-card content-section" aria-labelledby="documentsHeading">
        <div class="section-heading">
            <div class="section-title-wrap">
                <div class="section-mark"><i class="fa-solid fa-paperclip"></i></div>
                <div>
                    <span class="card-kicker">Supporting evidence</span>
                    <h2 id="documentsHeading">Application documents</h2>
                    <p>Open the submitted files to verify the applicant's supporting information.</p>
                </div>
            </div>
        </div>

        <div class="document-grid">
            @if (!string.IsNullOrWhiteSpace(Model.IDPassFileUrl))
            {
                <a asp-action="ApplicantAttachmentDownload" asp-controller="Applications" asp-route-fileId="@Model.IDPassFileUrl" class="document-card">
                    <span class="document-icon"><i class="fa-solid fa-id-card"></i></span>
                    <span><span class="document-name">Identity document</span><span class="document-action">Open secure file <i class="fa-solid fa-arrow-up-right-from-square"></i></span></span>
                </a>
            }
            @if (!string.IsNullOrWhiteSpace(Model.HighestQualFileUrl))
            {
                <a asp-action="ApplicantAttachmentDownload" asp-controller="Applications" asp-route-fileId="@Model.HighestQualFileUrl" class="document-card">
                    <span class="document-icon"><i class="fa-solid fa-certificate"></i></span>
                    <span><span class="document-name">Qualification</span><span class="document-action">Open secure file <i class="fa-solid fa-arrow-up-right-from-square"></i></span></span>
                </a>
            }
            @if (!string.IsNullOrWhiteSpace(Model.ResidenceFileUrl))
            {
                <a asp-action="ApplicantAttachmentDownload" asp-controller="Applications" asp-route-fileId="@Model.ResidenceFileUrl" class="document-card">
                    <span class="document-icon"><i class="fa-solid fa-house"></i></span>
                    <span><span class="document-name">Proof of residence</span><span class="document-action">Open secure file <i class="fa-solid fa-arrow-up-right-from-square"></i></span></span>
                </a>
            }
            @if (!string.IsNullOrWhiteSpace(Model.GuardianIDDoc))
            {
                <a asp-action="FileDownload" asp-route-fileName="@Model.GuardianIDDoc" asp-route-destinationFolder="GuardianID" class="document-card">
                    <span class="document-icon"><i class="fa-solid fa-user-shield"></i></span>
                    <span><span class="document-name">Guardian ID</span><span class="document-action">Download document <i class="fa-solid fa-download"></i></span></span>
                </a>
            }
            @if (string.IsNullOrWhiteSpace(Model.IDPassFileUrl) && string.IsNullOrWhiteSpace(Model.HighestQualFileUrl) && string.IsNullOrWhiteSpace(Model.ResidenceFileUrl) && string.IsNullOrWhiteSpace(Model.GuardianIDDoc))
            {
                <div class="empty-documents"><i class="fa-regular fa-folder-open"></i> No supporting documents were attached to this application.</div>
            }
        </div>
    </section>
</main>

<div class="modal fade rejection-modal" id="staticBackdrop" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="rejectionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="OnRejectApplication" asp-controller="Applications" method="post">
                <div class="modal-header">
                    <div>
                        <span class="card-kicker">Decision record</span>
                        <h5 class="modal-title" id="rejectionModalLabel"><i class="fa-solid fa-ban"></i> Rejection details</h5>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-4" style="color:var(--review-muted);font-size:.74rem;">Add a clear audit record and the next action the applicant should take.</p>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="field-label" for="rejectionReason"><i class="fa-solid fa-circle-exclamation"></i> Rejection reason</label>
                            <textarea id="rejectionReason" name="Reason" required rows="4" class="form-control" placeholder="Primary reason(s)..."></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="field-label" for="rejectionComments"><i class="fa-regular fa-message"></i> Additional comments</label>
                            <textarea id="rejectionComments" name="AdditionalComments" required rows="4" class="form-control" placeholder="Further clarification..."></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="field-label" for="nextSteps"><i class="fa-solid fa-route"></i> Next step</label>
                            <input id="nextSteps" name="NextSteps" required class="form-control" placeholder="For example: resubmit documents" />
                        </div>
                        <div class="col-md-6">
                            <label class="field-label" for="followUpDate"><i class="fa-regular fa-calendar"></i> Follow-up date</label>
                            <input id="followUpDate" name="FollowUpDate" required type="date" class="form-control" />
                        </div>
                        <input type="hidden" name="ApplicationId" value="@Model.ApplicantId" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="review-button" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i> Cancel</button>
                    <button type="submit" class="review-button review-button-primary"><i class="fa-solid fa-check"></i> Save rejection</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const statusSelect = document.querySelector('.status');
        const pendingFields = document.getElementById('pendingFields');
        const pendingReasonSelect = document.getElementById('pendingReasonSelect');
        const pendingReasonError = document.getElementById('pendingReasonError');

        if (!statusSelect || !pendingFields) {
            return;
        }

        function isPendingSelected() {
            const option = statusSelect.options[statusSelect.selectedIndex];
            return (option?.text || '').trim() === 'Pending';
        }

        function togglePendingFields() {
            const isPending = isPendingSelected();
            pendingFields.classList.toggle('d-none', !isPending);

            if (!isPending) {
                pendingReasonError?.classList.add('d-none');
            }
        }

        togglePendingFields();
        statusSelect.addEventListener('change', togglePendingFields);

        const form = statusSelect.closest('form');
        form?.addEventListener('submit', function (event) {
            if (!isPendingSelected()) {
                return;
            }

            const reason = (pendingReasonSelect?.value || '').trim();
            if (!reason) {
                event.preventDefault();
                pendingReasonError?.classList.remove('d-none');
                pendingReasonSelect?.focus();
            }
        });
    });
</script>
