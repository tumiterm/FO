@using static ForekOnline.Domain.Enums.EnumRegistry
@model ForekOnline.Domain.ViewModels.ApplyViewModel
@{
    ViewData["Title"] = "Application Review";

    var status = Model.Status.ToString() ?? "N/A";
    var applicantName = $"{Model.ApplicantName} {Model.ApplicantSurname}".Trim();
    var applicantInitials = string.Join("", new[] { Model.ApplicantName, Model.ApplicantSurname }
        .Where(v => !string.IsNullOrWhiteSpace(v))
        .Select(v => v!.Trim()[0].ToString().ToUpperInvariant()));

    // Map status → badge modifier + copy
    (string cls, string icon, string copy) StatusMeta(string s) => s switch
    {
        "Approved" => ("oa-badge-approved", "fa-circle-check", "Application successfully completed review."),
        "Pending" => ("oa-badge-pending", "fa-clock", "Awaiting additional review or information."),
        "Submitted" => ("oa-badge-submitted", "fa-paper-plane", "Ready for an admissions decision."),
        "Rejected" => ("oa-badge-rejected", "fa-circle-xmark", "Did not meet current admission requirements."),
        "AptituteTest" => ("oa-badge-assess", "fa-flask", "Progressing to the aptitude assessment stage."),
        _ => ("oa-badge-neutral", "fa-circle", "Review and select the appropriate outcome.")
    };
    var (statusCls, statusIcon, statusCopy) = StatusMeta(status);

    // Determine if any documents exist
    bool hasDocs = !string.IsNullOrWhiteSpace(Model.IDPassFileUrl)
                || !string.IsNullOrWhiteSpace(Model.HighestQualFileUrl)
                || !string.IsNullOrWhiteSpace(Model.ResidenceFileUrl)
                || !string.IsNullOrWhiteSpace(Model.GuardianIDDoc);
}

<link rel="stylesheet" href="~/css/Enrollment.css" />

<style>
    /* ── All scoped to oa- prefix ─────────────────────────────────── */

    .oa-shell {
        max-width: 1300px;
        margin: 0 auto;
        padding: 2.1rem 1.35rem 4rem;
    }

    /* ── Hero ── */
    .oa-hero {
        position: relative;
        overflow: hidden;
        background: var(--es-bg);
        border: 1px solid var(--es-border);
        border-radius: var(--es-radius-xl);
        box-shadow: var(--es-shadow-lg);
        padding: 1.6rem 1.75rem;
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 1.25rem;
        align-items: center;
    }

        .oa-hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background: var(--es-grad-soft);
            pointer-events: none;
        }

        .oa-hero > * {
            position: relative;
            z-index: 1;
        }

    .oa-hero__icon {
        width: 82px;
        height: 82px;
        flex-shrink: 0;
        border-radius: 26px;
        background: var(--es-grad);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 2.1rem;
        box-shadow: 0 16px 32px -16px rgba(179,18,23,.45);
        animation: oa-pop .65s cubic-bezier(.34,1.56,.64,1) both;
    }
    @@keyframes oa-pop {
        from {
            transform: scale(.5) rotate(-8deg);
            opacity: 0;
        }

        to {
            transform: scale(1) rotate(0);
            opacity: 1;
        }
    }

    .oa-hero__meta {
        display: grid;
        gap: .75rem;
        min-width: 210px;
    }

    /* ── Content grid ── */
    .oa-grid {
        display: grid;
        grid-template-columns: minmax(0,1fr) 300px;
        gap: 1.5rem;
        margin-top: 1.8rem;
        align-items: start;
    }

    /* ── Status badges ── */
    .oa-status {
        display: inline-flex;
        align-items: center;
        gap: .42rem;
        padding: .38rem .75rem;
        border-radius: 999px;
        font-size: .58rem;
        font-weight: 800;
        letter-spacing: .1rem;
        text-transform: uppercase;
        border: 1px solid;
        white-space: nowrap;
    }

    .oa-badge-approved {
        background: #e8f9ef;
        color: #137a44;
        border-color: #b7e6c8;
    }

    .oa-badge-pending {
        background: #e8f0ff;
        color: #1c5fbf;
        border-color: #b3ccf3;
    }

    .oa-badge-submitted {
        background: #fff3e0;
        color: #bc6b00;
        border-color: #f0c48b;
    }

    .oa-badge-rejected {
        background: #ffe6ea;
        color: #b31217;
        border-color: #f3b4ba;
    }

    .oa-badge-assess {
        background: #f3e8ff;
        color: #6d28d9;
        border-color: #d9b8f5;
    }

    .oa-badge-neutral {
        background: #f0f1f3;
        color: #555;
        border-color: #dadde0;
    }

    /* ── Compact form fields ── */
    .oa-field-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(200px,1fr));
        gap: .85rem;
    }

    .oa-field-wide {
        grid-column: 1 / -1;
    }

    .oa-field-label {
        display: flex;
        align-items: center;
        gap: .42rem;
        font-size: .54rem;
        letter-spacing: .15rem;
        font-weight: 800;
        text-transform: uppercase;
        color: var(--es-muted);
        margin-bottom: .42rem;
    }

        .oa-field-label i {
            color: var(--es-red);
        }

    .oa-control {
        width: 100%;
        height: 44px;
        border-radius: var(--es-radius-md);
        border: 1.5px solid var(--es-border);
        background: var(--es-bg);
        color: var(--es-text);
        font-size: .72rem;
        font-family: inherit;
        padding: 0 .78rem;
        outline: none;
        transition: border-color var(--es-speed), box-shadow var(--es-speed);
    }

        .oa-control:focus {
            border-color: var(--es-red);
            box-shadow: 0 0 0 .18rem rgba(179,18,23,.13);
            background: #fff;
        }

        .oa-control[readonly] {
            background: #f9f9fa;
            color: var(--es-muted);
            cursor: default;
        }

    .oa-control-help {
        font-size: .55rem;
        color: var(--es-muted);
        margin-top: .3rem;
    }

    /* ── Pending panel ── */
    .oa-pending-panel {
        margin-top: .85rem;
        padding: 1rem;
        border: 1.5px solid rgba(28,95,191,.2);
        border-radius: var(--es-radius-md);
        background: rgba(28,95,191,.04);
    }

    /* ── Form footer ── */
    .oa-form-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: .75rem;
        margin-top: 1.1rem;
        padding-top: 1rem;
        border-top: 1px solid var(--es-border);
    }

    .oa-form-note {
        font-size: .58rem;
        color: var(--es-muted);
        display: flex;
        align-items: flex-start;
        gap: .4rem;
        max-width: 420px;
        line-height: 1.55;
    }

        .oa-form-note i {
            color: var(--es-red);
            margin-top: .1rem;
            flex-shrink: 0;
        }

    .oa-form-actions {
        display: flex;
        gap: .55rem;
        flex-wrap: wrap;
    }

    /* ── Identity sidebar ── */
    .oa-identity-top {
        display: flex;
        align-items: center;
        gap: .95rem;
        padding-bottom: .9rem;
        margin-bottom: .9rem;
        border-bottom: 1px solid var(--es-border);
    }

    .oa-avatar {
        width: 54px;
        height: 54px;
        flex-shrink: 0;
        border-radius: 18px;
        background: var(--es-grad);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.15rem;
        font-weight: 800;
        box-shadow: 0 10px 24px -8px rgba(179,18,23,.42);
    }

    .oa-identity-name {
        font-size: .88rem;
        font-weight: 800;
        color: var(--es-dark);
    }

    .oa-identity-id {
        font-size: .64rem;
        color: var(--es-muted);
        font-family: ui-monospace,monospace;
        margin-top: .18rem;
    }

    .oa-identity-list {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .oa-identity-row {
        display: grid;
        grid-template-columns: 22px 1fr;
        gap: .65rem;
        padding: .65rem 0;
        border-bottom: 1px solid var(--es-border);
    }

        .oa-identity-row:last-child {
            border-bottom: 0;
        }

        .oa-identity-row > i {
            color: var(--es-red);
            font-size: .75rem;
            margin-top: .15rem;
        }

        .oa-identity-row dt {
            font-size: .52rem;
            letter-spacing: .12rem;
            text-transform: uppercase;
            font-weight: 800;
            color: var(--es-muted);
            margin-bottom: .15rem;
        }

        .oa-identity-row dd {
            font-size: .7rem;
            color: var(--es-text);
            margin: 0;
            overflow-wrap: anywhere;
        }

    /* ── Detail sections (below grid) ── */
    .oa-section {
        background: var(--es-bg);
        border: 1px solid var(--es-border);
        border-radius: var(--es-radius-lg);
        box-shadow: var(--es-shadow-sm);
        margin-top: 1.4rem;
        overflow: hidden;
    }

    .oa-section-hdr {
        display: flex;
        align-items: center;
        gap: .75rem;
        flex-wrap: wrap;
        padding: 1rem 1.35rem;
        border-bottom: 1px solid var(--es-border);
        background: linear-gradient(155deg,#fff 0%,#f9fbfe 100%);
    }

    .oa-section-icon {
        width: 36px;
        height: 36px;
        border-radius: 11px;
        flex-shrink: 0;
        background: var(--es-grad-soft);
        border: 1px solid #f2cccf;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .88rem;
        color: var(--es-red);
    }

    .oa-section-title {
        font-size: .72rem;
        letter-spacing: .2rem;
        font-weight: 800;
        text-transform: uppercase;
        color: var(--es-red);
    }

    .oa-section-sub {
        font-size: .65rem;
        color: var(--es-muted);
        margin-top: .18rem;
    }

    .oa-section-body {
        padding: 1.2rem 1.35rem;
    }

    /* ── Detail cards inside sections ── */
    .oa-detail-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
        gap: .85rem;
    }

    .oa-detail-card {
        padding: .9rem 1rem;
        border-radius: var(--es-radius-md);
        border: 1px solid var(--es-border);
        background: var(--es-bg-alt);
        transition: transform .25s, box-shadow .25s;
        position: relative;
        overflow: hidden;
    }

        .oa-detail-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--es-shadow-md);
        }

        .oa-detail-card::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--es-grad);
            border-radius: 0 0 var(--es-radius-md) var(--es-radius-md);
            opacity: .5;
        }

        .oa-detail-card h3 {
            font-size: .65rem;
            letter-spacing: .16rem;
            font-weight: 800;
            text-transform: uppercase;
            color: var(--es-red);
            display: flex;
            align-items: center;
            gap: .4rem;
            margin-bottom: .75rem;
        }

    .oa-dl {
        display: grid;
        gap: .55rem;
    }

        .oa-dl dt {
            font-size: .52rem;
            letter-spacing: .1rem;
            text-transform: uppercase;
            font-weight: 800;
            color: var(--es-muted);
        }

        .oa-dl dd {
            font-size: .7rem;
            color: var(--es-text);
            margin: 0;
            overflow-wrap: anywhere;
        }

        .oa-dl a {
            color: var(--es-red);
            text-decoration: none;
        }

            .oa-dl a:hover {
                color: var(--es-dark);
            }

    /* ── Document cards ── */
    .oa-doc-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(180px,1fr));
        gap: .75rem;
    }

    .oa-doc-card {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: .75rem;
        padding: .9rem 1rem;
        min-height: 110px;
        border-radius: var(--es-radius-md);
        border: 1px solid var(--es-border);
        background: var(--es-bg-alt);
        color: inherit;
        text-decoration: none;
        transition: transform .25s, box-shadow .25s, border-color .25s;
    }

        .oa-doc-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--es-shadow-md);
            border-color: var(--es-border-strong);
        }

    .oa-doc-ico {
        width: 36px;
        height: 36px;
        border-radius: 11px;
        background: var(--es-grad);
        color: #fff;
        font-size: .9rem;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 6px 16px -6px rgba(179,18,23,.42);
        flex-shrink: 0;
    }

    .oa-doc-name {
        font-size: .72rem;
        font-weight: 700;
        color: var(--es-dark);
    }

    .oa-doc-action {
        font-size: .58rem;
        color: var(--es-muted);
        margin-top: .15rem;
    }

    .oa-doc-empty {
        grid-column: 1/-1;
        padding: 1.5rem;
        text-align: center;
        border: 1.5px dashed var(--es-border);
        border-radius: var(--es-radius-md);
        font-size: .72rem;
        color: var(--es-muted);
    }

    /* ── Rejection modal ── */
    .oa-modal .modal-content {
        border: 1px solid var(--es-border);
        border-radius: var(--es-radius-lg);
        overflow: hidden;
        box-shadow: var(--es-shadow-lg);
    }

    .oa-modal .modal-header {
        padding: 1.1rem 1.35rem;
        border-bottom: 1px solid var(--es-border);
        background: linear-gradient(155deg,#fff,#f9fbfe);
    }

    .oa-modal .modal-title {
        font-size: .9rem;
        font-weight: 800;
        color: var(--es-dark);
    }

    .oa-modal .modal-body {
        padding: 1.35rem;
        background: var(--es-bg);
    }

    .oa-modal .modal-footer {
        padding: 1rem 1.35rem;
        border-top: 1px solid var(--es-border);
        background: var(--es-bg);
    }

    .oa-modal .oa-control {
        height: auto;
        min-height: 44px;
        padding: .6rem .78rem;
    }

    .oa-modal textarea.oa-control {
        min-height: 110px;
        resize: vertical;
    }

    /* ── Responsive ── */
    @@media (max-width: 1024px) {
        .oa-grid {
            grid-template-columns: 1fr 270px;
        }
    }

    @@media (max-width: 860px) {
        .oa-grid {
            grid-template-columns: 1fr;
        }

        .oa-hero {
            grid-template-columns: auto 1fr;
        }

        .oa-hero__meta {
            grid-column: 1/-1;
            grid-template-columns: repeat(2,1fr);
        }
    }

    @@media (max-width: 580px) {
        .oa-hero {
            padding: 1.25rem 1.1rem 1rem;
        }

        .oa-hero__icon {
            width: 64px;
            height: 64px;
            font-size: 1.65rem;
        }

        .enroll-title {
            font-size: 1.35rem;
        }

        .oa-doc-grid {
            grid-template-columns: repeat(2,1fr);
        }

        .oa-form-footer {
            flex-direction: column;
            align-items: stretch;
        }

        .oa-form-actions {
            justify-content: stretch;
        }

            .oa-form-actions .btn-premium {
                flex: 1;
                justify-content: center;
            }
    }
</style>

<div class="oa-shell">

    <div class="oa-hero fade-up">
        <div class="oa-hero__icon"><i class="fa fa-file-circle-check"></i></div>

        <div>
            <div class="enroll-kicker">
                <i class="fa fa-sparkles"></i>
                Admissions Workspace
            </div>
            <h1 class="enroll-title">@applicantName</h1>
            <p class="enroll-subtitle" style="margin-top:.4rem;">
                Review, update and finalise the outcome for this application.
                All changes are recorded against the applicant record.
            </p>
        </div>

        <div class="oa-hero__meta">
            <div class="hero-stat">
                <div class="hero-stat__label">Course</div>
                <div class="hero-stat__value">@(ViewData["Course"] ?? "—")</div>
            </div>
            <div class="hero-stat">
                <div class="hero-stat__label">Current Status</div>
                <div class="hero-stat__value" style="display:flex;align-items:center;gap:.45rem;">
                    <span class="oa-status @statusCls">
                        <i class="fa @statusIcon"></i>@status
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="oa-grid">

        <div class="glass-card fade-up" style="animation-delay:.04s;">
            <div class="card-header" style="padding:1rem 1.35rem;border-bottom:1px solid var(--es-border);background:linear-gradient(155deg,#fff,#f9fbfe);display:flex;align-items:center;flex-wrap:wrap;gap:.75rem;">
                <div class="card-head-icon" style="width:36px;height:36px;border-radius:11px;background:var(--es-grad-soft);border:1px solid #f2cccf;display:flex;align-items:center;justify-content:center;font-size:.88rem;color:var(--es-red);">
                    <i class="fa fa-flag-checkered"></i>
                </div>
                <span class="card-title" style="font-size:.72rem;letter-spacing:.2rem;font-weight:800;text-transform:uppercase;color:var(--es-red);">
                    Decision Console
                </span>
                <span class="oa-status @statusCls" style="margin-left:auto;">
                    <i class="fa @statusIcon"></i>@status
                </span>
            </div>

            <div style="padding:1.2rem 1.35rem;">
                <p style="font-size:.7rem;color:var(--es-muted);margin:0 0 1.1rem;">
                    @statusCopy
                </p>

                <form asp-action="OnApply" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input asp-for="ApplicantId" type="hidden" />
                    <div asp-validation-summary="ModelOnly" style="font-size:.65rem;color:var(--es-red);margin-bottom:.75rem;"></div>

                    <div class="oa-field-grid">
                        <div>
                            <label class="oa-field-label" asp-for="CourseId">
                                <i class="fa fa-book"></i> Course
                            </label>
                            <input class="oa-control" asp-for="CourseId"
                                   value="@ViewData["Course"]" readonly />
                        </div>

                        <div>
                            <label class="oa-field-label" asp-for="HighestQualification">
                                <i class="fa fa-graduation-cap"></i> Highest Qualification
                            </label>
                            <select class="oa-control" asp-for="HighestQualification"
                                    asp-items="Html.GetEnumSelectList<HighestQualification>()">
                                <option disabled value="">Select option</option>
                            </select>
                        </div>

                        <div class="oa-field-wide">
                            <label class="oa-field-label" asp-for="Status">
                                <i class="fa fa-circle-dot"></i> Status / Outcome <span style="color:var(--es-red);margin-left:.2rem;">*</span>
                            </label>
                            <select class="oa-control status" asp-for="Status"
                                    asp-items="Html.GetEnumSelectList<ApplicationStatus>()">
                                <option disabled value="">Select option</option>
                            </select>
                            <div class="oa-control-help">
                                <i class="fa fa-circle-info"></i>
                                Changing the outcome may trigger applicant communication and workflow.

                            </div>
                        </div>
                    </div>

                    <div id="pendingFields" class="oa-pending-panel d-none">
                        <div class="oa-field-grid">
                            <div>
                                <label class="oa-field-label" asp-for="PendingStatusReason">
                                    <i class="fa fa-clock"></i> Pending Reason
                                </label>
                                <select class="oa-control" asp-for="PendingStatusReason" id="pendingReasonSelect">
                                    <option value="">Select reason…</option>
                                    <option>Awaiting documents</option>
                                    <option>Under review</option>
                                    <option>Needs clarification</option>
                                    <option>Background check in progress</option>
                                    <option>Capacity / scheduling delay</option>
                                </select>
                                <div class="d-none" id="pendingReasonError"
                                     style="font-size:.58rem;color:var(--es-red);margin-top:.3rem;">
                                    <i class="fa fa-circle-exclamation"></i> Pending reason is required.
                                </div>
                            </div>
                            <div>
                                <label class="oa-field-label" asp-for="PendingStatusMessage">
                                    <i class="fa fa-message"></i> Applicant Message
                                </label>
                                <input class="oa-control" asp-for="PendingStatusMessage"
                                       maxlength="250" placeholder="Optional message (max 250 chars)" />
                            </div>
                        </div>
                    </div>

                    <div class="oa-form-footer">
                        <div class="oa-form-note">
                            <i class="fa fa-lock"></i>
                            Changes are recorded against this application on save.
                        </div>
                        <div class="oa-form-actions">
                            <button type="button"
                                    class="btn-premium btn-premium--ghost"
                                    data-bs-toggle="modal"
                                    data-bs-target="#rejectionModal"
                                    style="color:var(--es-red);">
                                <i class="fa fa-ban me-2"></i>Record Rejection
                            </button>
                            <button type="submit" class="btn-premium btn-premium--primary">
                                <i class="fa fa-check me-2"></i>Save Decision
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <aside>
            <div class="glass-card progress-card fade-up" style="animation-delay:.08s;">
                <h5 class="progress-title">
                    <i class="fa fa-user-circle"></i>
                    Applicant Profile
                </h5>

                <div class="oa-identity-top">
                    <div class="oa-avatar" aria-hidden="true">
                        @(string.IsNullOrWhiteSpace(applicantInitials) ? "FO" : applicantInitials)
                    </div>
                    <div>
                        <div class="oa-identity-name">@Model.ApplicantTitle @applicantName</div>
                        <div class="oa-identity-id">@Model.IDNumber</div>
                    </div>
                </div>

                <dl class="oa-identity-list">
                    <div class="oa-identity-row">
                        <i class="fa fa-envelope"></i>
                        <div><dt>Email</dt><dd>@Model.Email</dd></div>
                    </div>
                    <div class="oa-identity-row">
                        <i class="fa fa-phone"></i>
                        <div><dt>Cellphone</dt><dd>@Model.Cellphone</dd></div>
                    </div>
                    <div class="oa-identity-row">
                        <i class="fa fa-earth-africa"></i>
                        <div><dt>Citizenship</dt><dd>@Model.Selection</dd></div>
                    </div>
                    <div class="oa-identity-row">
                        <i class="fa fa-venus-mars"></i>
                        <div><dt>Gender</dt><dd>@Model.Gender</dd></div>
                    </div>
                    <div class="oa-identity-row">
                        <i class="fa fa-wallet"></i>
                        <div><dt>Funding</dt><dd>@Model.FunderType</dd></div>
                    </div>
                </dl>

                <div class="lookup-badge-row" style="margin-top:.75rem;">
                    <span class="smart-badge smart-badge--soft">
                        <i class="fa fa-shield-halved"></i> Secure record
                    </span>
                    <span class="smart-badge @statusCls.Replace("oa-badge", "smart-badge")">
                        <i class="fa @statusIcon"></i> @status
                    </span>
                </div>
            </div>
        </aside>
    </div>

    <div class="oa-section fade-up" style="animation-delay:.12s;">
        <div class="oa-section-hdr">
            <div class="oa-section-icon"><i class="fa fa-address-card"></i></div>
            <div>
                <div class="oa-section-title">Application Record</div>
                <div class="oa-section-sub">Personal, study and guardian details submitted with this application.</div>
            </div>
        </div>
        <div class="oa-section-body">
            <div class="oa-detail-grid">

                <article class="oa-detail-card">
                    <h3><i class="fa fa-graduation-cap"></i> Study Profile</h3>
                    <dl class="oa-dl">
                        <div><dt>Course</dt><dd>@ViewData["Course"]</dd></div>
                        <div><dt>Qualification</dt><dd>@Model.HighestQualification</dd></div>
                        <div>
                            <dt>Outcome</dt><dd>
                            <span class="oa-status @statusCls" style="font-size:.52rem;padding:.24rem .52rem;">
                                <i class="fa @statusIcon"></i>@status
                            </span>
                        </dd>
                    </div>
                    <div><dt>Funding</dt><dd>@Model.FunderType</dd></div>
                </dl>
            </article>

            <article class="oa-detail-card">
                <h3><i class="fa fa-user"></i> Biographical</h3>
                <dl class="oa-dl">
                    <div><dt>Full Name</dt><dd>@Model.ApplicantTitle @applicantName</dd></div>
                    <div><dt>National ID</dt><dd>@Model.IDNumber</dd></div>
                    <div><dt>Gender</dt><dd>@Model.Gender</dd></div>
                    <div><dt>Citizenship</dt><dd>@Model.Selection</dd></div>
                </dl>
            </article>

            <article class="oa-detail-card">
                <h3><i class="fa fa-location-dot"></i> Contact &amp; Guardian</h3>
                <dl class="oa-dl">
                    <div><dt>Address</dt><dd>@Model.Line1, @Model.StreetName, @Model.Province</dd></div>
                    <div><dt>Contact</dt><dd>@Model.Cellphone · @Model.Email</dd></div>
                    <div><dt>Guardian</dt><dd>@Model.GuardianFirstName @Model.GuardianLastName · @Model.GuardianCellphone</dd></div>
                    @if (!string.IsNullOrWhiteSpace(Model.GuardianIDDoc))
                    {
                        <div>
                            <dt>Guardian ID</dt><dd>
                            <a asp-action="FileDownload"
                               asp-route-fileName="@Model.GuardianIDDoc"
                               asp-route-destinationFolder="GuardianID">
                                <i class="fa fa-download"></i> Download
                            </a>
                        </dd>
                    </div>
                }
            </dl>
        </article>

    </div>
</div>
</div>

<div class="oa-section fade-up" style="animation-delay:.16s;">
    <div class="oa-section-hdr">
        <div class="oa-section-icon"><i class="fa fa-paperclip"></i></div>
        <div>
            <div class="oa-section-title">Supporting Documents</div>
            <div class="oa-section-sub">Verify the applicant's submitted files before finalising the outcome.</div>
        </div>
        <span class="smart-badge smart-badge--soft" style="margin-left:auto;">
            <i class="fa fa-file-pdf"></i>
            @(hasDocs ? "Files attached" : "No files")
        </span>
    </div>
    <div class="oa-section-body">
        <div class="oa-doc-grid">
            @if (!string.IsNullOrWhiteSpace(Model.IDPassFileUrl))
            {
                <a class="oa-doc-card"
                   asp-action="ApplicantAttachmentDownload" asp-controller="Applications"
                   asp-route-fileId="@Model.IDPassFileUrl">
                    <span class="oa-doc-ico"><i class="fa fa-id-card"></i></span>
                    <span>
                        <span class="oa-doc-name">Identity Document</span>
                        <span class="oa-doc-action"><i class="fa fa-arrow-up-right-from-square"></i> Open secure file</span>
                    </span>
                </a>
            }
            @if (!string.IsNullOrWhiteSpace(Model.HighestQualFileUrl))
            {
                <a class="oa-doc-card"
                   asp-action="ApplicantAttachmentDownload" asp-controller="Applications"
                   asp-route-fileId="@Model.HighestQualFileUrl">
                    <span class="oa-doc-ico"><i class="fa fa-certificate"></i></span>
                    <span>
                        <span class="oa-doc-name">Qualification</span>
                        <span class="oa-doc-action"><i class="fa fa-arrow-up-right-from-square"></i> Open secure file</span>
                    </span>
                </a>
            }
            @if (!string.IsNullOrWhiteSpace(Model.ResidenceFileUrl))
            {
                <a class="oa-doc-card"
                   asp-action="ApplicantAttachmentDownload" asp-controller="Applications"
                   asp-route-fileId="@Model.ResidenceFileUrl">
                    <span class="oa-doc-ico"><i class="fa fa-house"></i></span>
                    <span>
                        <span class="oa-doc-name">Proof of Residence</span>
                        <span class="oa-doc-action"><i class="fa fa-arrow-up-right-from-square"></i> Open secure file</span>
                    </span>
                </a>
            }
            @if (!string.IsNullOrWhiteSpace(Model.GuardianIDDoc))
            {
                <a class="oa-doc-card"
                   asp-action="FileDownload"
                   asp-route-fileName="@Model.GuardianIDDoc"
                   asp-route-destinationFolder="GuardianID">
                    <span class="oa-doc-ico"><i class="fa fa-user-shield"></i></span>
                    <span>
                        <span class="oa-doc-name">Guardian ID</span>
                        <span class="oa-doc-action"><i class="fa fa-download"></i> Download document</span>
                    </span>
                </a>
            }
            @if (!hasDocs)
            {
                <div class="oa-doc-empty">
                    <i class="fa fa-folder-open"></i>
                    No supporting documents were attached to this application.
                </div>
            }
        </div>
    </div>
</div>
</div>

<div class="modal fade oa-modal" id="rejectionModal"
     data-bs-backdrop="static" data-bs-keyboard="false"
     tabindex="-1" aria-labelledby="rejectionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="OnRejectApplication" asp-controller="Applications" method="post">
                <div class="modal-header">
                    <div>
                        <div style="font-size:.55rem;letter-spacing:.2rem;font-weight:800;text-transform:uppercase;color:var(--es-red);margin-bottom:.2rem;">
                            Decision Record
                        </div>
                        <h5 class="modal-title" id="rejectionModalLabel">
                            <i class="fa fa-ban me-2" style="color:var(--es-red);"></i>Rejection Details
                        </h5>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <p style="font-size:.68rem;color:var(--es-muted);margin-bottom:1rem;">
                        Provide a clear audit record. The applicant will be notified with the reason and next steps.
                    </p>
                    <div class="oa-field-grid">
                        <div>
                            <label class="oa-field-label" for="rejectionReason">
                                <i class="fa fa-circle-exclamation"></i> Rejection Reason
                            </label>
                            <textarea id="rejectionReason" name="Reason" required
                                      rows="4" class="oa-control"
                                      placeholder="Primary reason(s)…"></textarea>
                        </div>
                        <div>
                            <label class="oa-field-label" for="rejectionComments">
                                <i class="fa fa-message"></i> Additional Comments
                            </label>
                            <textarea id="rejectionComments" name="AdditionalComments" required
                                      rows="4" class="oa-control"
                                      placeholder="Further clarification…"></textarea>
                        </div>
                        <div>
                            <label class="oa-field-label" for="nextSteps">
                                <i class="fa fa-route"></i> Next Step
                            </label>
                            <input id="nextSteps" name="NextSteps" required
                                   class="oa-control"
                                   placeholder="e.g. resubmit documents" />
                        </div>
                        <div>
                            <label class="oa-field-label" for="followUpDate">
                                <i class="fa fa-calendar"></i> Follow-up Date
                            </label>
                            <input id="followUpDate" name="FollowUpDate" required
                                   type="date" class="oa-control" />
                        </div>
                        <input type="hidden" name="ApplicationId" value="@Model.ApplicantId" />
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-premium btn-premium--ghost"
                            data-bs-dismiss="modal">
                        <i class="fa fa-xmark me-2"></i>Cancel
                    </button>
                    <button type="submit" class="btn-premium btn-premium--primary">
                        <i class="fa fa-check me-2"></i>Save Rejection
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const statusSel       = document.querySelector('select.status');
        const pendingPanel    = document.getElementById('pendingFields');
        const pendingReason   = document.getElementById('pendingReasonSelect');
        const pendingErrEl    = document.getElementById('pendingReasonError');

        if (!statusSel || !pendingPanel) return;

        function isPending() {
            return (statusSel.options[statusSel.selectedIndex]?.text || '').trim() === 'Pending';
        }

        function toggle() {
            pendingPanel.classList.toggle('d-none', !isPending());
            if (!isPending()) pendingErrEl?.classList.add('d-none');
        }

        toggle();
        statusSel.addEventListener('change', toggle);

        statusSel.closest('form')?.addEventListener('submit', function (e) {
            if (!isPending()) return;
            if (!(pendingReason?.value || '').trim()) {
                e.preventDefault();
                pendingErrEl?.classList.remove('d-none');
                pendingReason?.focus();
            }
        });
    });
</script>