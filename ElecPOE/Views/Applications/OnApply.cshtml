@using ForekOnline.Domain.Entities
@using static ForekOnline.Domain.Enums.EnumRegistry;
@model ForekOnline.Domain.ViewModels.ApplyViewModel

@{
    Application? application = ViewBag.Application as Application;

    string status = Model.Status.ToString() ?? "N/A";
    string StatusClass(string s) => s switch {
        "Approved" => "st-approved",
        "Pending" => "st-pending",
        "Submitted" => "st-submitted",
        "Rejected" => "st-rejected",
        _ => "st-neutral"
    };
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<style>
:root{
    --clr-dr:#320606;
    --clr-red:#9d1117;
    --clr-red-strong:#b31217;
    --clr-orange:#ff7a18;
    --clr-orange-soft:#f99b4a;
    --clr-soft:#fff8f6;
    --clr-border:#e3e4e7;
    --clr-border-alt:#d8d9dd;
    --clr-bg:#ffffff;
    --clr-bg-alt:#f5f6f8;
    --grad-accent:linear-gradient(95deg,#320606,#b31217 55%,#ff7a18);
    --grad-soft:linear-gradient(120deg,#32060611,#b3121714,#ff7a181e);
    --radius-xl:28px;
    --radius-lg:20px;
    --radius-md:14px;
    --shadow-soft:0 6px 18px -8px rgba(50,6,6,.25);
    --shadow-hover:0 10px 28px -14px rgba(50,6,6,.35);
    font-family:'Segoe UI',system-ui,sans-serif;
}
body { background:var(--clr-bg-alt); }

.page-shell { max-width:1250px; margin:0 auto; padding:1.5rem 1.25rem 3rem; }

.header-band {
    background:var(--clr-bg);
    border:1px solid var(--clr-border);
    border-radius:var(--radius-xl);
    padding:1.15rem 1.4rem 1rem;
    display:flex; gap:1.2rem; flex-wrap:wrap; align-items:center;
    position:relative; overflow:hidden;
}
.header-band:before{
    content:""; position:absolute; inset:0;
    background:var(--grad-soft); pointer-events:none;
}
.icon-pill {
    width:64px;height:64px; border-radius:22px; background:var(--grad-accent);
    display:flex; align-items:center; justify-content:center;
    color:#fff; font-size:1.55rem; box-shadow:0 10px 20px -10px rgba(179,18,23,.55);
}
.header-band h1 {
    margin:0; font-size:1.35rem; font-weight:600; letter-spacing:.5px; color:#222;
    display:flex; gap:.65rem; align-items:center;
}
.chip {
    margin-top:.45rem;
    font-size:.55rem; letter-spacing:.18rem; font-weight:700;
    background:var(--clr-soft); color:var(--clr-red-strong);
    padding:.45rem .8rem; border-radius:40px; display:inline-flex; gap:.45rem; align-items:center;
    text-transform:uppercase;
}
.actions-inline { margin-left:auto; display:flex; gap:.55rem; flex-wrap:wrap; }

.btn-accent, .btn-plain, .btn-outline {
    font-size:.65rem; letter-spacing:.12rem; font-weight:600;
    padding:.65rem 1.05rem; border-radius:12px; border:1px solid transparent;
    display:inline-flex; align-items:center; gap:.45rem; cursor:pointer; text-decoration:none;
    transition:.3s;
}
.btn-accent { background:var(--grad-accent); color:#fff; }
.btn-accent:hover { filter:brightness(.94); box-shadow:0 6px 16px -6px rgba(179,18,23,.4); }
.btn-plain { background:#fff; color:var(--clr-red-strong); border:1px solid var(--clr-border); }
.btn-plain:hover { background:var(--clr-red-strong); color:#fff; border-color:var(--clr-red-strong); }
.btn-outline { background:#fff; color:var(--clr-red-strong); border:1px solid var(--clr-red-strong); }
.btn-outline:hover { background:var(--grad-accent); color:#fff; }

.summary-grid {
    margin-top:1.25rem;
    display:grid; gap:1rem; grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
}
.summary-card {
    background:#fff; border:1px solid var(--clr-border);
    border-radius:var(--radius-lg);
    padding:.95rem .95rem .85rem;
    position:relative; overflow:hidden;
    display:flex; gap:.85rem; align-items:flex-start;
    transition:.35s;
}
.summary-card:before {
    content:""; position:absolute; inset:0;
    background:radial-gradient(circle at 85% 15%,rgba(255,122,24,.18),transparent 65%);
    opacity:.45; pointer-events:none;
}
.summary-card:hover { transform:translateY(-4px); border-color:var(--clr-border-alt); box-shadow:var(--shadow-soft); }

.sc-ico {
    width:46px;height:46px; border-radius:14px;
    background:var(--grad-accent); color:#fff;
    display:flex; align-items:center; justify-content:center;
    font-size:1rem; flex-shrink:0; box-shadow:0 6px 14px -8px rgba(179,18,23,.55);
}
.sc-label { font-size:.55rem; letter-spacing:.16rem; font-weight:700; text-transform:uppercase; color:#666; }
.sc-value { font-size:1.25rem; font-weight:600; background:var(--grad-accent); -webkit-background-clip:text; color:transparent; line-height:1.15; margin-top:.25rem; }
.sc-sub { font-size:.55rem; margin-top:.45rem; background:var(--clr-soft); color:var(--clr-red-strong); font-weight:600; padding:.3rem .55rem; border-radius:30px; display:inline-flex; gap:.35rem; align-items:center; letter-spacing:.08rem; }

.detail-layout { margin-top:1.2rem; display:grid; gap:1.25rem; grid-template-columns:repeat(auto-fit,minmax(320px,1fr)); }

.panel {
    background:#fff; border:1px solid var(--clr-border);
    border-radius:var(--radius-lg);
    padding:1rem .95rem .9rem;
    position:relative; overflow:hidden;
    display:flex; flex-direction:column; gap:.6rem;
    transition:.3s;
}
.panel:hover { border-color:var(--clr-border-alt); }
.panel h3 {
    margin:0;
    font-size:.7rem; letter-spacing:.18rem; font-weight:700;
    text-transform:uppercase; color:var(--clr-red-strong);
    display:flex; gap:.5rem; align-items:center;
}
.meta-list { list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:.55rem; font-size:.63rem; }
.meta-list li { line-height:1.25; color:#333; word-break:break-word; }
.meta-list li strong { color:#222; font-weight:600; }

.attach-bar {
    margin-top:1.5rem;
    background:#fff;
    border:1px solid var(--clr-border);
    border-radius:var(--radius-lg);
    padding:.9rem .95rem .95rem;
    display:flex; gap:.9rem; flex-wrap:wrap; align-items:center;
}
.attach-bar h4 {
    margin:0; font-size:.65rem; letter-spacing:.18rem; font-weight:700; text-transform:uppercase; color:var(--clr-red-strong);
    display:flex; gap:.45rem; align-items:center;
}
.attach-chip {
    width:60px;height:60px; border-radius:18px; background:var(--grad-accent); color:#fff;
    display:flex; align-items:center; justify-content:center; font-size:1.2rem; position:relative;
    text-decoration:none; transition:.35s;
    box-shadow:0 6px 16px -8px rgba(179,18,23,.55);
}
.attach-chip:hover { transform:translateY(-4px); filter:brightness(.94); }
.attach-chip span {
    position:absolute; bottom:4px; font-size:.5rem; letter-spacing:.12rem; font-weight:600; text-transform:uppercase;
}

.status-badge {
    font-size:.55rem; padding:.42rem .65rem; border-radius:30px;
    font-weight:700; letter-spacing:.09rem; display:inline-flex; gap:.4rem; align-items:center; border:1px solid transparent;
}
.st-approved { background:#e8f9ef; color:#1e7a45; border-color:#b7e8ca; }
.st-pending { background:#e9f5ff; color:#186994; border-color:#a9d8ee; }
.st-submitted { background:#fff3e0; color:#bc6b00; border-color:#f2c078; }
.st-rejected { background:#ffe6ea; color:#b31217; border-color:#f3b3b8; }
.st-neutral { background:#f0f1f3; color:#555; border-color:#dadde0; }

.inline-form-bar {
    margin-top:1.2rem;
    background:#fff;
    border:1px solid var(--clr-border);
    border-radius:var(--radius-lg);
    padding:1rem 1rem .6rem;
    box-shadow:0 4px 12px -6px rgba(0,0,0,.07);
}
.inline-form-bar .row { --bs-gutter-x:1rem; }
.inline-form-bar label { font-size:.63rem; letter-spacing:.14rem; text-transform:uppercase; font-weight:700; color:#555; }
.inline-form-bar .input-group-text { background:var(--clr-soft); border-color:var(--clr-border); }
.inline-form-bar .form-control, .inline-form-bar select {
    font-size:.72rem; border:1px solid var(--clr-border); border-radius:10px !important;
}
.inline-form-bar .form-control:focus, .inline-form-bar select:focus {
    border-color:var(--clr-red-strong); box-shadow:0 0 0 .15rem #b3121718;
}

.quick-actions { display:flex; gap:.55rem; flex-wrap:wrap; margin-top:.65rem; }

.modal-content { border-radius:20px; border:1px solid var(--clr-border); }
.modal-header { background:var(--grad-accent); border:none; }
.modal-header .modal-title { font-size:.75rem; letter-spacing:.18rem; font-weight:700; text-transform:uppercase; }
.modal-body textarea, .modal-body input[type="date"], .modal-body input[type="text"] {
    font-size:.72rem; border:1px solid var(--clr-border); border-radius:10px !important;
}
.modal-body textarea:focus, .modal-body input:focus {
    border-color:var(--clr-red-strong); box-shadow:0 0 0 .15rem #b3121718;
}

@@media (max-width: 820px){
    .attach-bar { justify-content:flex-start; }
}

.text-mono { font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono","Courier New", monospace; font-size:.6rem; letter-spacing:.1rem; }
</style>

<div class="page-shell">

    <div class="header-band">
        <div class="icon-pill"><i class="fa fa-file-pen"></i></div>
        <div>
            <h1>Application Details</h1>
            <div class="chip"><i class="fa fa-layer-group"></i> RECORD • @DateTime.UtcNow.ToString("yyyy-MM-dd")</div>
        </div>
        <div class="actions-inline">
            <button type="button" class="btn-plain" onclick="history.back()">
                <i class="fa fa-arrow-left"></i> Back
            </button>
            <a asp-action="Applications" asp-controller="Applications" class="btn-outline">
                <i class="fa fa-table"></i> List
            </a>
        </div>
    </div>

    <form asp-action="OnApply" method="post" enctype="multipart/form-data" class="inline-form-bar">
        <input asp-for="ApplicantId" type="hidden" />
        <div class="row g-3">
            <div class="col-md-3">
                <label>Course Chosen</label>
                <input class="form-control" asp-for="CourseId" value="@ViewData["Course"]" readonly />
            </div>
            <div class="col-md-3">
                <label>Highest Qualification</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fa fa-school text-danger"></i></span>
                    <select asp-for="HighestQualification" class="form-control" asp-items="Html.GetEnumSelectList<HighestQualification>()">
                        <option disabled selected value="">Select Option</option>
                    </select>
                </div>
            </div>
            <div class="col-md-3">
                <label>Status (Outcome)</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fa fa-flag text-danger"></i></span>
                    <select asp-for="Status" class="form-control status" asp-items="Html.GetEnumSelectList<ApplicationStatus>()">
                        <option disabled selected value="">Select Option</option>
                    </select>
                </div>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn-accent w-100"><i class="fa fa-save"></i> Save Changes</button>
            </div>

            <div id="pendingFields" class="col-12 d-none">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Pending Reason</label>
                        <select asp-for="PendingStatusReason" class="form-control" id="pendingReasonSelect">
                            <option value="">Select reason...</option>
                            <option value="Awaiting documents">Awaiting documents</option>
                            <option value="Under review">Under review</option>
                            <option value="Needs clarification">Needs clarification</option>
                            <option value="Background check in progress">Background check in progress</option>
                            <option value="Capacity / scheduling delay">Capacity / scheduling delay</option>
                        </select>
                        <div class="text-danger small d-none" id="pendingReasonError">
                            Pending reason is required when status is Pending.
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Optional message (user-facing)</label>
                        <input asp-for="PendingStatusMessage" class="form-control" maxlength="250" placeholder="Short message to the applicant (optional)" />
                        <div class="small text-muted">Max 250 characters.</div>
                    </div>
                </div>
            </div>

        </div>

        <div class="quick-actions">
           @*  <button type="button" id="btnApprove" class="btn-outline">
                <i class="fa fa-circle-check"></i> Mark Approved
            </button> *@
            <button type="button" id="btnReject" class="btn-plain" data-bs-toggle="modal" data-bs-target="#staticBackdrop">
                <i class="fa fa-ban"></i> Reject
            </button>
            <span class="status-badge @StatusClass(status)"><i class="fa fa-info-circle"></i> @status</span>
        </div>
    </form>

    <div class="summary-grid">
        <div class="summary-card">
            <div class="sc-ico"><i class="fa fa-user"></i></div>
            <div>
                <div class="sc-label">Applicant</div>
                <div class="sc-value" style="font-size:1.05rem;">@Model.ApplicantName @Model.ApplicantSurname</div>
                <div class="sc-sub"><i class="fa fa-id-card"></i> @Model.IDNumber</div>
            </div>
        </div>
        <div class="summary-card">
            <div class="sc-ico"><i class="fa fa-book"></i></div>
            <div>
                <div class="sc-label">Qualification</div>
                <div class="sc-value" style="font-size:1.05rem;">@Model.HighestQualification</div>
                <div class="sc-sub"><i class="fa fa-graduation-cap"></i> Highest Qual</div>
            </div>
        </div>
        <div class="summary-card">
            <div class="sc-ico"><i class="fa fa-venus-mars"></i></div>
            <div>
                <div class="sc-label">Gender</div>
                <div class="sc-value" style="font-size:1.05rem;">@Model.Gender</div>
                <div class="sc-sub"><i class="fa fa-globe"></i> @Model.Selection</div>
            </div>
        </div>
        <div class="summary-card">
            <div class="sc-ico"><i class="fa fa-bullseye"></i></div>
            <div>
                <div class="sc-label">Outcome</div>
                <div class="sc-value" style="font-size:1.05rem;">@status</div>
                <div class="sc-sub"><i class="fa fa-tag"></i> Status</div>
            </div>
        </div>
    </div>

    <div class="detail-layout">
        <div class="panel">
            <h3><i class="fa fa-graduation-cap"></i> Course & Status</h3>
            <ul class="meta-list">
                <li><strong>Course:</strong> @ViewData["Course"]</li>
                <li><strong>Highest Qualification:</strong> @Model.HighestQualification</li>
                <li><strong>Status (Outcome):</strong> @Model.Status</li>
                <li><strong>Funding Type:</strong> @Model.FunderType</li>
            </ul>
        </div>

        <div class="panel">
            <h3><i class="fa fa-id-card"></i> Biographical</h3>
            <ul class="meta-list">
                <li><strong>Full Name:</strong> @Model.ApplicantTitle @Model.ApplicantName @Model.ApplicantSurname</li>
                <li><strong>National ID:</strong> @Model.IDNumber</li>
                <li><strong>Gender:</strong> @Model.Gender</li>
                <li><strong>Citizenship:</strong> @Model.Selection</li>
                <li><strong>Address:</strong> @Model.Line1 | @Model.StreetName | @Model.Province</li>
            </ul>
        </div>

        <div class="panel">
            <h3><i class="fa fa-phone"></i> Contact & Guardian</h3>
            <ul class="meta-list">
                <li><strong>Cellphone:</strong> @Model.Cellphone</li>
                <li><strong>Email:</strong> @Model.Email</li>
                <li><strong>Guardian:</strong> @Model.GuardianFirstName @Model.GuardianLastName (@Model.GuardianCellphone)</li>
                <li>
                    <strong>Guardian ID Doc:</strong>
                    @if (!string.IsNullOrWhiteSpace(Model.GuardianIDDoc))
                    {
                        <a asp-action="FileDownload" asp-route-fileName="@Model.GuardianIDDoc" asp-route-destinationFolder="GuardianID" class="text-decoration-none" style="color:var(--clr-red-strong)">
                            <i class="fa fa-download"></i> Download
                        </a>
                    }
                    else { <span class="text-muted">Not Provided</span> }
                </li>
            </ul>
        </div>
    </div>

    <div class="attach-bar">
        <h4><i class="fa fa-paperclip"></i> Attachments</h4>
        @if (!string.IsNullOrWhiteSpace(Model.IDPassFileUrl))
        {
            <a asp-action="ApplicantAttachmentDownload"
               asp-controller="Applications"
               asp-route-fileId="@Model.IDPassFileUrl"
               class="attach-chip">
                <i class="fa fa-id-card"></i><span>ID</span>
            </a>

        }
        @if (!string.IsNullOrWhiteSpace(Model.HighestQualFileUrl))
        {
            <a asp-action="ApplicantAttachmentDownload"
               asp-controller="Applications"
               asp-route-fileId="@Model.HighestQualFileUrl"
               class="attach-chip">
                <i class="fa fa-certificate"></i><span>QUAL</span>
            </a>
        }
        @if (!string.IsNullOrWhiteSpace(Model.ResidenceFileUrl))
        {
            <a asp-action="FileDownload" asp-route-fileName="@Model.GuardianIDDoc" asp-route-destinationFolder="GuardianID" class="attach-chip" title="Guardian ID">
                <i class="fa fa-user-shield"></i><span>G-ID</span>
            </a>

            <a asp-action="ApplicantAttachmentDownload"
               asp-controller="Applications"
               asp-route-fileId="@Model.GuardianIDDoc"
               class="attach-chip">
                <i class="fa fa-user-shield"></i><span>G-ID</span>
            </a>
        }
    </div>
</div>

<div class="modal fade" id="staticBackdrop" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="OnRejectApplication" asp-controller="Applications" method="post">
                <div class="modal-header">
                    <h5 class="modal-title text-white"><i class="fa fa-ban"></i> Rejection Details</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label text-uppercase fw-semibold small">Rejection Reason</label>
                            <textarea name="Reason" required rows="4" class="form-control" placeholder="Primary reason(s)..."></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-uppercase fw-semibold small">Additional Comments</label>
                            <textarea name="AdditionalComments" required rows="4" class="form-control" placeholder="Further clarifications..."></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-uppercase fw-semibold small">Next Step</label>
                            <input name="NextSteps" required class="form-control" placeholder="E.g. Resubmit docs" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-uppercase fw-semibold small">Follow Up Date</label>
                            <input name="FollowUpDate" required type="date" class="form-control" />
                        </div>
                        <input type="hidden" name="ApplicationId" value="@Model.ApplicantId" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-plain" data-bs-dismiss="modal"><i class="fa fa-times"></i> Cancel</button>
                    <button type="submit" class="btn-accent"><i class="fa fa-save"></i> Save Rejection</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const statusSel = document.querySelector('.status');
        const pendingFields = document.getElementById('pendingFields');
        const pendingReasonSelect = document.getElementById('pendingReasonSelect');
        const pendingReasonError = document.getElementById('pendingReasonError');

        if (!statusSel || !pendingFields) {
            return;
        }

        function isPendingSelected() {
            const opt = statusSel.options[statusSel.selectedIndex];
            const text = (opt?.text || '').trim();
            return text === 'Pending';
        }

        function togglePendingFields() {
            const isPending = isPendingSelected();
            pendingFields.classList.toggle('d-none', !isPending);

            if (!isPending) {
                pendingReasonError?.classList.add('d-none');
            }
        }

        togglePendingFields();
        statusSel.addEventListener('change', togglePendingFields);

        const form = statusSel.closest('form');
        form?.addEventListener('submit', function (e) {
            if (!isPendingSelected()) {
                return;
            }

            const reason = (pendingReasonSelect?.value || '').trim();
            if (!reason) {
                e.preventDefault();
                pendingReasonError?.classList.remove('d-none');
                pendingReasonSelect?.focus();
            }
        });
    });
</script>
