@model ForekOnline.Domain.ViewModels.AssessmentAttemptViewModel
@{
    Layout = "_Layout";
    var timerEnabled = Model.TimerMinutes > 0;

    if (Model.EnableMathRendering)
    {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
        <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"></script>
        <script type="module" src="https://unpkg.com/mathlive@0.101.1/dist/mathlive.min.mjs"></script>

        <style>
            .math-answer-wrap {
                margin-top: .5rem;
            }

                .math-answer-wrap math-field {
                    display: block;
                    width: 100%;
                    font-size: 1.1rem;
                    min-height: 48px;
                    border: 1px solid #e1e4e8;
                    border-radius: 10px;
                    padding: .4rem .6rem;
                }

            .math-quick-toolbar {
                display: flex;
                gap: .3rem;
                flex-wrap: wrap;
                margin-bottom: .3rem;
            }

                .math-quick-toolbar button {
                    font-size: .55rem;
                    padding: .3rem .5rem;
                    border-radius: 8px;
                    border: 1px solid #e1e4e8;
                    background: #fff;
                    cursor: pointer;
                }

                    .math-quick-toolbar button:hover {
                        background: #b31217;
                        color: #fff;
                    }

            .math-preview-inline {
                display: inline-block;
                background: #fff5f5;
                border: 1px solid #e1e4e8;
                border-radius: 8px;
                padding: .2rem .5rem;
                margin: .15rem .1rem;
                font-size: .75rem;
            }
        </style>

        <script type="module">
            // Wait for DOM + MathLive to load
            document.addEventListener('DOMContentLoaded', () => {
                setTimeout(initMathAttempt, 300);
            });

            function initMathAttempt() {
                // 1) Render LaTeX in all question prompts and option text
                document.querySelectorAll('[data-question-prompt], [data-option-text]').forEach(el => {
                    renderLatex(el);
                });

                // 2) Replace short-answer text inputs with MathLive editors
                document.querySelectorAll('[data-short-answer-input]').forEach(input => {
                    const container = document.createElement('div');
                    container.className = 'math-answer-wrap';

                    // Quick-insert toolbar
                    const toolbar = document.createElement('div');
                    toolbar.className = 'math-quick-toolbar';
                    const symbols = [
                        { label: 'x/y', cmd: '\\frac{▢}{▢}' },
                        { label: '√', cmd: '\\sqrt{▢}' },
                        { label: 'x²', cmd: 'x^{▢}' },
                        { label: 'π', cmd: '\\pi' },
                        { label: '±', cmd: '\\pm' },
                        { label: '≤', cmd: '\\leq' },
                        { label: '≥', cmd: '\\geq' },
                        { label: '∞', cmd: '\\infty' },
                        { label: '∑', cmd: '\\sum_{▢}^{▢}' },
                        { label: '∫', cmd: '\\int_{▢}^{▢}' },
                    ];
                    symbols.forEach(s => {
                        const btn = document.createElement('button');
                        btn.type = 'button';
                        btn.textContent = s.label;
                        btn.addEventListener('click', (e) => {
                            e.preventDefault();
                            const mf = container.querySelector('math-field');
                            if (mf) { mf.executeCommand(['insert', s.cmd]); mf.focus(); }
                        });
                        toolbar.appendChild(btn);
                    });

                    // The MathLive field
                    const mathField = document.createElement('math-field');
                    mathField.setAttribute('virtual-keyboard-mode', 'manual');

                    // If there's already a value (e.g. re-render), pre-populate
                    const existing = input.value || '';
                    if (existing.includes('$')) {
                        const match = existing.match(/\$([^$]+)\$/);
                        if (match) mathField.setValue(match[1]);
                    } else if (existing.trim()) {
                        mathField.setValue(existing);
                    }

                    // Sync MathLive → hidden input on every keystroke
                    mathField.addEventListener('input', () => {
                        const latex = mathField.getValue('latex');
                        input.value = latex ? `$${latex}$` : '';
                    });

                    // Also allow plain text toggle
                    const toggleBtn = document.createElement('button');
                    toggleBtn.type = 'button';
                    toggleBtn.className = 'math-quick-toolbar';
                    toggleBtn.style.cssText = 'font-size:.5rem;padding:.25rem .5rem;margin-top:.3rem;border:1px solid #e1e4e8;border-radius:8px;background:#fff;cursor:pointer;';
                    toggleBtn.textContent = '⌨ Switch to plain text';
                    let isMathMode = true;
                    toggleBtn.addEventListener('click', (e) => {
                        e.preventDefault();
                        isMathMode = !isMathMode;
                        if (isMathMode) {
                            mathField.style.display = '';
                            toolbar.style.display = '';
                            input.style.display = 'none';
                            toggleBtn.textContent = '⌨ Switch to plain text';
                        } else {
                            mathField.style.display = 'none';
                            toolbar.style.display = 'none';
                            input.style.display = '';
                            input.focus();
                            toggleBtn.textContent = 'ƒ Switch to math editor';
                        }
                    });

                    container.appendChild(toolbar);
                    container.appendChild(mathField);
                    container.appendChild(toggleBtn);

                    input.style.display = 'none';
                    input.parentNode.insertBefore(container, input.nextSibling);
                });
            }

            function renderLatex(el) {
                if (!window.katex || !el) return;
                const html = el.innerHTML;
                el.innerHTML = html.replace(/\$\$([^$]+)\$\$|\$([^$]+)\$/g, (match, block, inline) => {
                    const latex = block || inline;
                    const isBlock = !!block;
                    const span = document.createElement(isBlock ? 'div' : 'span');
                    span.className = 'math-preview-inline';
                    try { katex.render(latex, span, { displayMode: isBlock, throwOnError: false }); }
                    catch { span.textContent = match; }
                    return span.outerHTML;
                });
            }
        </script>
    }
}

<style>

