@model ForekOnline.Domain.ViewModels.StudentListViewModel
@using static ForekOnline.Application.Common.Utility.Helper
@{
    var students = (Model.Students ?? Enumerable.Empty<ForekOnline.Domain.Entities.Student>()).ToList();
    bool isFallback = Model.IsFallBackStudents;
    string role = Model.Role ?? "";
    int deliveredCount = students.Count;
    int total = Model.TotalCount == 0 ? deliveredCount : Model.TotalCount;
    int activeCount = students.Count(s => s.IsActive);
    int inactiveCount = deliveredCount - activeCount;
    double activeRate = deliveredCount == 0 ? 0 : (double)activeCount / deliveredCount * 100;

    string Key(string src)
    {
        if (string.IsNullOrWhiteSpace(src)) return "unknown";
        src = src.Trim().ToLowerInvariant();
        if (src == "website") return "website";
        if (src == "forek online") return "forek";
        if (src == "referral") return "referral";
        if (src == "walk-in" || src == "walkin") return "walkin";
        return "unknown";
    }
    string BadgeClass(string k) => k switch
    {
        "website" => "src-website",
        "forek" => "src-forek",
        "referral" => "src-referral",
        "walkin" => "src-walkin",
        _ => "src-unknown"
    };
    string LabelFromKey(string k) => k switch
    {
        "website" => "Website",
        "forek" => "Forek Online",
        "referral" => "Referral",
        "walkin" => "Walk-In",
        _ => "Unknown"
    };
}

