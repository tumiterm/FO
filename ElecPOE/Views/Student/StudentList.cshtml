<div class="sl-shell">
    <div class="sl-header">
        <div>
            <h1>
                <span class="sl-header-icon"><i class="fa fa-user-graduate"></i></span>
                Registered Students
            </h1>
            <div class="sl-header-meta">
                <span class="sl-chip"><i class="fa fa-layer-group"></i> Directory</span>
                <span>@role</span>
            </div>
        </div>
        <div class="sl-header-actions">
            <button type="button" class="sl-btn" onclick="location.reload()"><i class="fa fa-rotate"></i> Refresh</button>
            <button type="button" class="sl-btn" id="btnFetchApi"><i class="fa fa-cloud-arrow-down"></i> Sync</button>
            <button type="button" class="sl-btn sl-btn-grad" id="btnExportCsv"><i class="fa fa-file-export"></i> CSV</button>
            <form method="post" asp-controller="Student" asp-action="BulkImportStudents" class="d-inline">
                @Html.AntiForgeryToken()
                <div class="input-group" style="max-width: 400px;">
                    <select name="source" class="form-select">
                        <option value="SQLite" selected>SQLite Cache</option>
                        <option value="API">External API</option>
                    </select>
                    <button type="submit" class="btn btn-warning"
                            onclick="return confirm('This will import all students into the main database. Continue?');">
                        <i class="fa fa-database me-1"></i> Bulk Import
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (isFallback)
    {
        <div class="sl-fallback">
            <i class="fa fa-plug-circle-exclamation"></i>
            <div><strong>Fallback Mode</strong> — Showing cached list. Sync when service returns.</div>
        </div>
    }

    <div class="sl-stats">
        <div class="sl-stat">
            <div class="sl-stat-top">
                <div class="sl-stat-icon"><i class="fa fa-users"></i></div>
                <div class="sl-stat-spark">
                    <span style="height:35%"></span><span style="height:55%"></span><span style="height:45%"></span><span style="height:75%"></span><span style="height:60%"></span><span style="height:90%"></span><span style="height:100%"></span>
                </div>
            </div>
            <div class="sl-stat-val" data-count="@total">0</div>
            <div class="sl-stat-label">Total Students</div>
            <div class="sl-stat-sub"><i class="fa fa-database"></i> All records</div>
        </div>
        <div class="sl-stat">
            <div class="sl-stat-top">
                <div class="sl-stat-icon"><i class="fa fa-check-circle"></i></div>
                <div class="sl-stat-spark">
                    <span style="height:50%"></span><span style="height:70%"></span><span style="height:65%"></span><span style="height:85%"></span><span style="height:100%"></span><span style="height:80%"></span><span style="height:90%"></span>
                </div>
            </div>
            <div class="sl-stat-val" data-count="@activeCount">0</div>
            <div class="sl-stat-label">Active</div>
            <div class="sl-stat-sub"><i class="fa fa-signal"></i> Currently enrolled</div>
        </div>
        <div class="sl-stat">
            <div class="sl-stat-top">
                <div class="sl-stat-icon"><i class="fa fa-user-xmark"></i></div>
                <div class="sl-stat-spark">
                    <span style="height:25%"></span><span style="height:40%"></span><span style="height:30%"></span><span style="height:20%"></span><span style="height:35%"></span><span style="height:15%"></span><span style="height:10%"></span>
                </div>
            </div>
            <div class="sl-stat-val" data-count="@inactiveCount">0</div>
            <div class="sl-stat-label">Inactive</div>
            <div class="sl-stat-sub"><i class="fa fa-pause-circle"></i> Not enrolled</div>
        </div>
        <div class="sl-stat">
            <div class="sl-stat-top">
                <div class="sl-stat-icon"><i class="fa fa-shield-halved"></i></div>
                <div class="sl-ring">
                    <svg width="52" height="52" viewBox="0 0 52 52">
                        <circle class="bg" cx="26" cy="26" r="21" />
                        <circle class="fill" cx="26" cy="26" r="21"
                                stroke-dasharray="131.95"
                                stroke-dashoffset="@((131.95 * (1 - activeRate / 100)).ToString("F2", System.Globalization.CultureInfo.InvariantCulture))" />
                    </svg>
                    <span class="lbl">@activeRate.ToString("F0")%</span>
                </div>
            </div>
            <div class="sl-stat-val">Rate</div>
            <div class="sl-stat-label">Active Rate</div>
            <div class="sl-stat-sub"><i class="fa fa-chart-pie"></i> Active / Total</div>
        </div>
    </div>

    <div class="sl-filters">
        <div class="sl-search">
            <i class="fa fa-search"></i>
            <input type="text" id="searchBox" class="sl-input" placeholder="Search name, ID, student no, phone..." autocomplete="off" />
        </div>
        <div class="sl-filter-group">
            <label><i class="fa fa-filter"></i> Status</label>
            <select id="statusFilter" class="sl-input" style="min-width:120px;">
                <option value="">All</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
            </select>
        </div>
        <div class="sl-filter-group">
            <label><i class="fa fa-tag"></i> Source</label>
            <select id="sourceFilter" class="sl-input" style="min-width:140px;">
                <option value="">Any</option>
                <option value="website">Website</option>
                <option value="forek">Forek Online</option>
                <option value="referral">Referral</option>
                <option value="walkin">Walk-In</option>
            </select>
        </div>
    </div>

    <div class="sl-table-panel">
        <div id="loaderOverlay" class="sl-loader hidden">
            <div class="sl-spinner"></div>
            <span id="loaderText">Loading…</span>
        </div>
        <div style="overflow-x:auto;">
            <table id="studentsTable">
                <thead>
                    <tr>
                        <th style="width:110px;">Actions</th>
                        <th>Full Name</th>
                        <th>ID Number</th>
                        <th>Cellphone</th>
                        <th>Student #</th>
                        <th>Status</th>
                        <th>Details</th>
                        <th>Source</th>
                    </tr>
                </thead>
                <tbody id="studentsTbody">
                    @foreach (var s in students)
                    {
                        var rawKey = Key(s.RegistrationSource ?? (isFallback ? "Walk-In" : "Website"));
                        <tr data-active="@(s.IsActive ? "active" : "inactive")" data-source="@rawKey">
                            <td>
                                <div style="display:flex;gap:.3rem;">
                                    <a class="sl-act sl-act-gallery"
                                       asp-action="OnViewAllFiles" asp-controller="Evidence"
                                       asp-route-StudentNumber="@s.StudentNumber" title="Gallery">
                                        <i class="fa fa-image"></i>
                                    </a>
                                    <a class="sl-act sl-act-track"
                                       asp-action="PlaceLearner" asp-controller="LearnerPlacement"
                                       asp-route-StudentNumber="@s.StudentNumber" title="Track">
                                        <i class="fa fa-route"></i>
                                    </a>
                                </div>
                            </td>
                            <td class="sl-name">@s.FirstName @s.LastName</td>
                            <td class="sl-mono">@MaskInput(s.IDNumber)</td>
                            <td class="sl-mono">@MaskInput(s.Cellphone)</td>
                            <td>@s.StudentNumber</td>
                            <td>
                                <span class="sl-status @(s.IsActive ? "sl-status-active" : "sl-status-inactive")">
                                    <i class="fa @(s.IsActive ? "fa-check-circle" : "fa-xmark")"></i>
                                    @(s.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td>
                                <a class="sl-act sl-act-info"
                                   asp-action="StudentDetail" asp-route-StudentNumber="@s.StudentNumber" title="Details">
                                    <i class="fa fa-circle-info"></i>
                                </a>
                            </td>
                            <td>
                                <span class="sl-src @BadgeClass(rawKey)">@LabelFromKey(rawKey)</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="sl-footer">
            <span class="sl-footer-info" id="rowsInfo">Showing @deliveredCount of @total record(s)</span>
            <div class="sl-pager">
                <button id="btnPrev" class="sl-pgbtn" disabled><i class="fa fa-chevron-left"></i> Prev</button>
                <span class="sl-footer-info" id="pageInfo">Page 1</span>
                <button id="btnNext" class="sl-pgbtn">Next <i class="fa fa-chevron-right"></i></button>
                <select id="pageSize" class="sl-pgsel" title="Page size">
                    <option value="10">10</option>
                    <option value="20" selected>20</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        'use strict';

        var currentPage = 1;
        var totalPages = 1;
        var totalCount = @total;
        var pageSizeSel = document.getElementById('pageSize');
        var tbody = document.getElementById('studentsTbody');
        var rowsInfo = document.getElementById('rowsInfo');
        var pageInfo = document.getElementById('pageInfo');
        var btnPrev = document.getElementById('btnPrev');
        var btnNext = document.getElementById('btnNext');
        var searchBox = document.getElementById('searchBox');
        var statusFilter = document.getElementById('statusFilter');
        var sourceFilter = document.getElementById('sourceFilter');
        var loader = document.getElementById('loaderOverlay');
        var loaderText = document.getElementById('loaderText');
        var btnExport = document.getElementById('btnExportCsv');
        var btnFetchApi = document.getElementById('btnFetchApi');

        function showLoader(msg) { loaderText.textContent = msg || 'Loading…'; loader.classList.remove('hidden'); }
        function hideLoader() { loader.classList.add('hidden'); }

        function buildQuery() {
            var p = new URLSearchParams();
            p.set('page', currentPage);
            p.set('pageSize', pageSizeSel.value);
            var q = searchBox.value.trim();
            if (q) p.set('q', q);
            if (statusFilter.value) p.set('status', statusFilter.value);
            if (sourceFilter.value) {
                var raw = sourceFilter.value;
                switch (raw) {
                    case 'website': raw = 'Website'; break;
                    case 'forek': raw = 'Forek Online'; break;
                    case 'referral': raw = 'Referral'; break;
                    case 'walkin': raw = 'Walk-In'; break;
                }
                p.set('registrationSource', raw);
            }
            return p.toString();
        }

        function normalizeKey(raw) {
            if (!raw) return 'unknown';
            raw = raw.trim().toLowerCase();
            if (raw === 'website') return 'website';
            if (raw === 'forek online') return 'forek';
            if (raw === 'referral') return 'referral';
            if (raw === 'walk-in' || raw === 'walkin') return 'walkin';
            return 'unknown';
        }

        function srcMeta(key) {
            switch (key) {
                case 'website':  return { cls: 'src-website',  text: 'Website' };
                case 'forek':    return { cls: 'src-forek',    text: 'Forek Online' };
                case 'referral': return { cls: 'src-referral', text: 'Referral' };
                case 'walkin':   return { cls: 'src-walkin',   text: 'Walk-In' };
                default:         return { cls: 'src-unknown',  text: 'Unknown' };
            }
        }

        function maskVal(v) {
            if (!v) return '';
            var s = v.toString();
            if (s.length === 13) return s.substring(0, 4) + '******' + s.substring(s.length - 3);
            if (s.length >= 6) {
                var show = Math.max(1, Math.floor(s.length / 4));
                return s.substring(0, show) + '*'.repeat(s.length - show * 2) + s.substring(s.length - show);
            }
            return s.replace(/.(?=.{2})/g, '*');
        }

        function renderRows(items) {
            tbody.innerHTML = '';
            items.forEach(function (s) {
                var key = normalizeKey(s.registrationSource || '');
                var sm = srcMeta(key);
                var isActive = s.isActive;
                var tr = document.createElement('tr');
                tr.setAttribute('data-active', isActive ? 'active' : 'inactive');
                tr.setAttribute('data-source', key);
                tr.innerHTML =
                    '<td><div style="display:flex;gap:.3rem;">' +
                        '<a class="sl-act sl-act-gallery" href="/Evidence/OnViewAllFiles?StudentNumber=' + encodeURIComponent(s.studentNumber || '') + '" title="Gallery"><i class="fa fa-image"></i></a>' +
                        '<a class="sl-act sl-act-track" href="/LearnerPlacement/PlaceLearner?StudentNumber=' + encodeURIComponent(s.studentNumber || '') + '" title="Track"><i class="fa fa-route"></i></a>' +
                    '</div></td>' +
                    '<td class="sl-name">' + ((s.firstName || '') + ' ' + (s.lastName || '')) + '</td>' +
                    '<td class="sl-mono">' + maskVal(s.idNumber) + '</td>' +
                    '<td class="sl-mono">' + maskVal(s.cellphone) + '</td>' +
                    '<td>' + (s.studentNumber || '') + '</td>' +
                    '<td><span class="sl-status ' + (isActive ? 'sl-status-active' : 'sl-status-inactive') + '"><i class="fa ' + (isActive ? 'fa-check-circle' : 'fa-xmark') + '"></i> ' + (isActive ? 'Active' : 'Inactive') + '</span></td>' +
                    '<td><a class="sl-act sl-act-info" href="/Student/StudentDetail?StudentNumber=' + encodeURIComponent(s.studentNumber || '') + '" title="Details"><i class="fa fa-circle-info"></i></a></td>' +
                    '<td><span class="sl-src ' + sm.cls + '">' + sm.text + '</span></td>';
                tbody.appendChild(tr);
            });
        }

        function updatePager() {
            pageInfo.textContent = 'Page ' + currentPage + ' / ' + totalPages;
            btnPrev.disabled = currentPage <= 1;
            btnNext.disabled = currentPage >= totalPages;
            rowsInfo.textContent = 'Page ' + currentPage + ' of ' + totalPages + ' · ' + totalCount + ' total';
        }

        function fetchPage() {
            showLoader('Loading…');
            fetch('/Student/PagedStudents?' + buildQuery(), { headers: { 'Accept': 'application/json' } })
                .then(function (r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
                .then(function (data) {
                    currentPage = data.page;
                    totalPages = data.totalPages;
                    totalCount = data.totalCount;
                    renderRows(data.items);
                    updatePager();
                })
                .catch(function (e) { alert('Failed to load students: ' + e.message); })
                .finally(hideLoader);
        }

        document.querySelectorAll('.sl-stat-val[data-count]').forEach(function (el) {
            var target = parseInt(el.getAttribute('data-count'), 10);
            if (isNaN(target) || target === 0) { el.textContent = '0'; return; }
            var duration = 1000;
            var start = performance.now();
            function tick(now) {
                var elapsed = now - start;
                var progress = Math.min(elapsed / duration, 1);
                var eased = 1 - Math.pow(1 - progress, 3);
                el.textContent = Math.round(eased * target).toLocaleString();
                if (progress < 1) requestAnimationFrame(tick);
            }
            requestAnimationFrame(tick);
        });

        var debounce;
        function triggerSearch() {
            clearTimeout(debounce);
            debounce = setTimeout(function () { currentPage = 1; fetchPage(); }, 320);
        }

        (function () {
            fetch('/Student/DistinctSources')
                .then(function (r) { return r.ok ? r.json() : []; })
                .then(function (list) {
                    var sel = sourceFilter;
                    list.forEach(function (src) {
                        var key = normalizeKey(src);
                        if (!sel.querySelector('option[value="' + key + '"]')) {
                            var opt = document.createElement('option');
                            opt.value = key;
                            opt.textContent = src;
                            sel.appendChild(opt);
                        }
                    });
                })
                .catch(function () {});
        })();

        searchBox.addEventListener('input', triggerSearch);
        statusFilter.addEventListener('change', function () { currentPage = 1; fetchPage(); });
        sourceFilter.addEventListener('change', function () { currentPage = 1; fetchPage(); });
        pageSizeSel.addEventListener('change', function () { currentPage = 1; fetchPage(); });
        btnPrev.addEventListener('click', function () { if (currentPage > 1) { currentPage--; fetchPage(); } });
        btnNext.addEventListener('click', function () { if (currentPage < totalPages) { currentPage++; fetchPage(); } });

        if (btnFetchApi) {
            btnFetchApi.addEventListener('click', function () { currentPage = 1; fetchPage(); });
        }

        btnExport.addEventListener('click', function () {
            var rows = Array.from(tbody.querySelectorAll('tr'));
            if (!rows.length) { alert('No rows to export.'); return; }
            var lines = ['Full Names,ID Number,Cellphone,Student Number,Status,Source'];
            rows.forEach(function (r) {
                var cells = r.querySelectorAll('td');
                var fullName = (cells[1] ? cells[1].innerText.trim() : '');
                var idNum = (cells[2] ? cells[2].innerText.trim() : '');
                var cell = (cells[3] ? cells[3].innerText.trim() : '');
                var stud = (cells[4] ? cells[4].innerText.trim() : '');
                var status = r.getAttribute('data-active') === 'active' ? 'Active' : 'Inactive';
                var source = srcMeta(r.getAttribute('data-source')).text;
                lines.push([fullName, idNum, cell, stud, status, source].map(function (v) { return '"' + v.replace(/"/g, '""') + '"'; }).join(','));
            });
            var blob = new Blob([lines.join('\r\n')], { type: 'text/csv;charset=utf-8;' });
            var a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = 'students-page' + currentPage + '-' + new Date().toISOString().slice(0, 10) + '.csv';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        });

        fetchPage();
    })();
</script>