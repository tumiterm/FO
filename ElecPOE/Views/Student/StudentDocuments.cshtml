@using static ForekOnline.Domain.Enums.EnumRegistry
@model dynamic
@{
    ViewData["Title"] = "Student Documents";
    var studentName = (string?)ViewData["name"] ?? "Student";
    var studentNumber = ViewData["StudentNumber"];
    var studentId = ViewData["StudentId"];
    var files = (IEnumerable<dynamic>?)Model?.FileModel ?? Enumerable.Empty<dynamic>();
    var totalFiles = files.Count();
}

<style>
:root {
    --sd-bg: #f5f7fb;
    --sd-surface: #ffffff;
    --sd-surface-soft: #f8fafc;
    --sd-border: #dfe6ef;
    --sd-text: #1b2430;
    --sd-muted: #6a7584;
    --sd-primary: #7d0e11;
    --sd-primary-2: #b31217;
    --sd-primary-3: #ff7a18;
    --sd-primary-grad: linear-gradient(125deg, #7d0e11 0%, #b31217 50%, #ff7a18 100%);
    --sd-ring: 0 0 0 .18rem rgba(179, 18, 23, .14);
    --sd-shadow-lg: 0 32px 58px -35px rgba(18, 31, 53, .45);
    --sd-shadow-md: 0 18px 36px -24px rgba(18, 31, 53, .34);
    --sd-radius-xl: 30px;
    --sd-radius-lg: 22px;
    --sd-radius-md: 15px;
}

.student-docs-shell { max-width: 1360px; margin: 0 auto; padding: 1.55rem 1rem 2.8rem; }
.hero-card {
    position: relative;
    border: 1px solid var(--sd-border);
    border-radius: var(--sd-radius-xl);
    background: radial-gradient(circle at top right, #ffffff 0, #f9fbff 45%, #f4f7fc 100%);
    overflow: hidden;
    box-shadow: var(--sd-shadow-lg);
    padding: 1.3rem;
}
.hero-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(150deg, rgba(179, 18, 23, .08), rgba(255, 122, 24, .08), transparent 62%);
    pointer-events: none;
}
.hero-grid { position: relative; display: grid; grid-template-columns: 1fr auto; gap: 1rem; align-items: center; }
.hero-left { display: flex; align-items: center; gap: 1rem; }
.hero-orb {
    width: 76px; height: 76px; border-radius: 24px; background: var(--sd-primary-grad);
    display: flex; justify-content: center; align-items: center; color: #fff; font-size: 1.85rem;
    box-shadow: 0 14px 26px -14px rgba(125, 14, 17, .9);
}
.hero-kicker {
    font-size: .62rem; letter-spacing: .18rem; font-weight: 800; text-transform: uppercase;
    color: var(--sd-primary);
}
.hero-title { margin: .15rem 0 0; color: var(--sd-text); font-size: 1.6rem; font-weight: 700; }
.hero-copy { margin: .3rem 0 0; color: var(--sd-muted); font-size: .86rem; max-width: 760px; }
.hero-actions { display: flex; flex-wrap: wrap; gap: .55rem; justify-content: flex-end; }

.premium-btn {
    border: 1px solid var(--sd-border); background: #fff; color: var(--sd-primary); border-radius: 13px;
    padding: .58rem .98rem; font-size: .59rem; text-transform: uppercase; letter-spacing: .12rem; font-weight: 700;
    display: inline-flex; align-items: center; gap: .4rem; text-decoration: none; transition: .22s ease;
}
.premium-btn:hover { background: var(--sd-primary-grad); color: #fff; border-color: var(--sd-primary); box-shadow: var(--sd-shadow-md); }
.premium-btn--primary { background: var(--sd-primary-grad); color: #fff; border-color: var(--sd-primary); }
.premium-btn--danger { background: #fff2f3; color: #7d0e11; border-color: #efcad0; }

.metrics-row { position: relative; margin-top: .95rem; display: grid; grid-template-columns: repeat(3, minmax(170px, 1fr)); gap: .7rem; }
.metric {
    border: 1px solid var(--sd-border); border-radius: 14px; padding: .72rem .86rem; background: rgba(255,255,255,.82);
}
.metric small { display:block; font-size:.54rem; letter-spacing:.11rem; text-transform:uppercase; color:var(--sd-muted); font-weight:700; }
.metric strong { font-size:1.02rem; color:var(--sd-text); }

.section-grid { margin-top: 1.3rem; display: grid; gap: 1rem; }
.glass-card {
    border: 1px solid var(--sd-border); border-radius: var(--sd-radius-lg); background: var(--sd-surface);
    box-shadow: var(--sd-shadow-md); overflow: hidden;
}
.card-header {
    padding: .92rem 1rem; border-bottom: 1px solid var(--sd-border);
    background: linear-gradient(155deg, #fff, #fbfdff);
    display: flex; gap: .7rem; align-items: center; justify-content: space-between; flex-wrap: wrap;
}
.card-title { margin: 0; font-size: .8rem; letter-spacing: .16rem; text-transform: uppercase; color: var(--sd-primary); font-weight: 800; }
.card-body { padding: 1rem; }

.field-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: .85rem; }
.field label { display:block; margin-bottom:.36rem; font-size:.53rem; letter-spacing:.12rem; text-transform:uppercase; font-weight:800; color:#4d5968; }
.required::after { content:'*'; color:#b31217; margin-left:.25rem; }
.input-wrap {
    display:flex; align-items:center; gap:.48rem; border:1px solid var(--sd-border); border-radius:13px;
    padding:.56rem .7rem; background:var(--sd-surface-soft); transition:.2s;
}
.input-wrap:focus-within { border-color: var(--sd-primary); box-shadow: var(--sd-ring); background:#fff; }
.input-wrap i { font-size:.77rem; color:#8a95a5; }
.input-wrap select, .input-wrap input[type='file'] { border:none; background:transparent; width:100%; outline:none; font-size:.72rem; color:var(--sd-text); }
.hint { font-size:.53rem; color:var(--sd-muted); margin-top:.25rem; }
.form-actions { margin-top: .78rem; display:flex; flex-wrap:wrap; gap:.5rem; }

.filter-bar { display:flex; flex-wrap:wrap; gap:.55rem; margin-bottom:.8rem; }
.search-wrap { position:relative; flex:1 1 300px; }
.search-wrap i { position:absolute; top:50%; left:.7rem; transform:translateY(-50%); color:#8d99a8; font-size:.7rem; }
.search-wrap input, .filter-select {
    border:1px solid var(--sd-border); border-radius:13px; background:#fff; font-size:.69rem;
}
.search-wrap input { width:100%; padding:.52rem .7rem .52rem 2rem; }
.filter-select { padding:.52rem .65rem; min-width:180px; }
.search-wrap input:focus, .filter-select:focus { outline:none; border-color:var(--sd-primary); box-shadow:var(--sd-ring); }

.table-wrap { overflow:auto; border:1px solid var(--sd-border); border-radius:16px; }
.doc-table { width:100%; border-collapse:separate; border-spacing:0; font-size:.66rem; }
.doc-table th { position:sticky; top:0; z-index:1; background:var(--sd-primary-grad); color:#fff; text-transform:uppercase; font-size:.53rem; letter-spacing:.14rem; padding:.55rem; }
.doc-table td { padding:.5rem .55rem; border-bottom:1px solid #e6ecf3; color:#334155; }
.doc-table tbody tr:nth-child(odd){ background:#fdfefe; }
.doc-table tbody tr:nth-child(even){ background:#f8fbff; }
.doc-table tbody tr:hover { background:#fff3ef; }

.pill { display:inline-flex; align-items:center; gap:.3rem; border:1px solid #d4deea; background:#eef4fb; color:#20405f; border-radius:99px; padding:.24rem .52rem; font-size:.48rem; font-weight:700; letter-spacing:.07rem; }
.date-pill { background:#f1f5f9; border:1px solid #dce5ef; color:#475569; }
.action-link { text-decoration:none; }
.empty-row { text-align:center; font-style:italic; color:#7a8796; }
.hidden-row { display:none !important; }

@media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-actions { justify-content: flex-start; }
    .metrics-row { grid-template-columns: 1fr; }
}
</style>

<div class="student-docs-shell">
    <section class="hero-card">
        <div class="hero-grid">
            <div class="hero-left">
                <div class="hero-orb"><i class="fa fa-file-circle-check"></i></div>
                <div>
                    <div class="hero-kicker"><i class="fa fa-sparkles"></i> Student Records Suite</div>
                    <h1 class="hero-title">Student Documents</h1>
                    <p class="hero-copy">Manage secure learner documents in one premium workspace. Upload, filter, audit and download with confidence.</p>
                </div>
            </div>

            <div class="hero-actions">
                <a asp-action="Index" asp-controller="Student" class="premium-btn"><i class="fa fa-arrow-left"></i> Back</a>
                <button id="btnExport" type="button" class="premium-btn"><i class="fa fa-file-export"></i> Export CSV</button>
                <button id="btnRefresh" type="button" class="premium-btn premium-btn--primary"><i class="fa fa-rotate"></i> Refresh</button>
            </div>
        </div>

        <div class="metrics-row">
            <div class="metric"><small>Learner</small><strong>@studentName</strong></div>
            <div class="metric"><small>Student Number</small><strong>@studentNumber</strong></div>
            <div class="metric"><small>Documents</small><strong>@totalFiles File(s)</strong></div>
        </div>
    </section>

    <div class="section-grid">
        <section class="glass-card">
            <div class="card-header">
                <h2 class="card-title"><i class="fa fa-cloud-arrow-up"></i> Upload Document</h2>
                <span class="pill"><i class="fa fa-shield-check"></i> PDF Only · Max 2MB</span>
            </div>
            <div class="card-body">
                <form asp-action="StudentDocuments" enctype="multipart/form-data" method="post" novalidate autocomplete="off">
                    @Html.AntiForgeryToken()
                    <div class="field-grid">
                        <div class="field">
                            <label class="required">Document Type</label>
                            <div class="input-wrap">
                                <i class="fa fa-diagram-project"></i>
                                <select name="DocumentName" required asp-items="Html.GetEnumSelectList<eLearnerAdministration>()">
                                    <option value="">Select document...</option>
                                </select>
                            </div>
                        </div>

                        <div class="field">
                            <label class="required">Document (PDF)</label>
                            <div class="input-wrap">
                                <i class="fa fa-file-pdf"></i>
                                <input id="fileInput" name="AttachmentFile" required type="file" accept="application/pdf" />
                            </div>
                            <small id="fileInfo" class="hint">Max 2MB • PDF only</small>
                        </div>
                    </div>

                    <input type="hidden" name="StudentNumber" value="@studentNumber" />
                    <input type="hidden" name="StudentId" value="@studentId" />

                    <div class="form-actions">
                        <button type="submit" class="premium-btn premium-btn--primary"><i class="fa fa-save"></i> Save</button>
                        <button type="reset" class="premium-btn"><i class="fa fa-undo"></i> Reset</button>
                        <a asp-action="Index" asp-controller="Student" class="premium-btn premium-btn--danger"><i class="fa fa-door-open"></i> Exit</a>
                    </div>
                </form>
            </div>
        </section>

        <section class="glass-card">
            <div class="card-header">
                <h2 class="card-title"><i class="fa fa-folder-open"></i> Uploaded Documents (@totalFiles)</h2>
                <span id="rowsInfo" class="pill"><i class="fa fa-database"></i> Loading...</span>
            </div>
            <div class="card-body">
                <div class="filter-bar">
                    <div class="search-wrap">
                        <i class="fa fa-search"></i>
                        <input id="searchBox" type="text" placeholder="Search type/date..." autocomplete="off" />
                    </div>
                    <select id="typeFilter" class="filter-select">
                        <option value="">All Types</option>
                        @foreach (var t in Enum.GetValues(typeof(eLearnerAdministration)).Cast<eLearnerAdministration>())
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                    <span id="perfInfo" class="pill date-pill"></span>
                </div>

                <div class="table-wrap">
                    <table class="doc-table" id="docsTable">
                        <thead>
                        <tr>
                            <th>Remove</th>
                            <th>Type</th>
                            <th>Added</th>
                            <th>Download</th>
                        </tr>
                        </thead>
                        <tbody id="docsBody">
                        @if (!files.Any())
                        {
                            <tr><td colspan="4" class="empty-row">No documents uploaded yet.</td></tr>
                        }
                        else
                        {
                            foreach (var a in files)
                            {
                                string type = a.DocumentName?.ToString() ?? "";
                                string created = a.CreatedOn?.ToString() ?? "";
                                string fileName = a.Document?.ToString() ?? "";
                                Guid attachmentId = a.AttachmentId;

                                <tr data-type="@type" data-text="@($"{type} {created}".ToLower())">
                                    <td>
                                        <a class="premium-btn action-link" href="@Url.Action("RemoveDocument", "Student", new { AttachmentId = attachmentId })" onclick="return confirm('Remove this document?');">
                                            <i class="fa fa-trash"></i> Remove
                                        </a>
                                    </td>
                                    <td><span class="pill"><i class="fa fa-file-pdf"></i>@type</span></td>
                                    <td><span class="pill date-pill" title="@created"><i class="fa fa-calendar"></i>@created</span></td>
                                    <td>
                                        <a class="premium-btn action-link" href="@Url.Action("AttachmentDownload", "Student", new { filename = fileName })">
                                            <i class="fa fa-download"></i> Download
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    </div>
</div>

@section Scripts {
<script>
(function(){
    const fi = document.getElementById('fileInput');
    const info = document.getElementById('fileInfo');

    fi?.addEventListener('change', function() {
        const f = this.files[0];
        if (!f) { info.textContent = 'Max 2MB • PDF only'; return; }
        if (f.type !== 'application/pdf') { alert('Only PDF files allowed.'); this.value = ''; info.textContent = 'Max 2MB • PDF only'; return; }
        if (f.size > (2 * 1024 * 1024)) { alert('File exceeds 2MB.'); this.value = ''; info.textContent = 'Max 2MB • PDF only'; return; }
        info.textContent = `${f.name} (${(f.size / 1024).toFixed(0)} KB)`;
    });

    const body = document.getElementById('docsBody');
    const rowsInfo = document.getElementById('rowsInfo');
    const perfInfo = document.getElementById('perfInfo');
    const searchBox = document.getElementById('searchBox');
    const typeFilter = document.getElementById('typeFilter');

    function norm(v){ return (v || '').toString().toLowerCase().trim(); }

    function apply(){
        const t0 = performance.now();
        const q = norm(searchBox.value);
        const tp = typeFilter.value;
        const rows = Array.from(body.querySelectorAll('tr'));

        let shown = 0, total = 0;
        rows.forEach(r => {
            if (r.querySelector('.empty-row')) return;
            total++;
            const txt = r.getAttribute('data-text') || '';
            const type = r.getAttribute('data-type') || '';
            let show = true;
            if (q && !txt.includes(q)) show = false;
            if (tp && type !== tp) show = false;
            r.classList.toggle('hidden-row', !show);
            if (show) shown++;
        });

        rowsInfo.innerHTML = `<i class="fa fa-database"></i> Showing ${shown} of ${total}` + (q || tp ? ' (filtered)' : '');
        perfInfo.textContent = 'Render ' + (performance.now() - t0).toFixed(1) + 'ms';
    }

    [searchBox, typeFilter].forEach(el => el?.addEventListener(el.tagName === 'INPUT' ? 'input' : 'change', apply));
    apply();

    document.getElementById('btnExport')?.addEventListener('click', () => {
        const visible = Array.from(body.querySelectorAll('tr:not(.hidden-row)')).filter(r => !r.querySelector('.empty-row'));
        if (!visible.length) { alert('No rows to export.'); return; }

        const lines = ['Type,Added,File'];
        visible.forEach(r => {
            const cells = r.querySelectorAll('td');
            const type = cells[1].innerText.trim();
            const added = cells[2].innerText.trim();
            const file = cells[3].innerText.trim();
            lines.push([type, added, file].map(v => '"' + v.replace(/"/g, '""') + '"').join(','));
        });

        const blob = new Blob([lines.join('\r\n')], { type: 'text/csv;charset=utf-8;' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'student-documents-' + new Date().toISOString().slice(0,10) + '.csv';
        document.body.appendChild(a); a.click(); document.body.removeChild(a);
    });

    document.getElementById('btnRefresh')?.addEventListener('click', () => location.reload());
})();
</script>
}
