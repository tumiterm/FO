@using static ForekOnline.Domain.Enums.EnumRegistry
@model dynamic
@{
    ViewData["Title"] = "Student Documents";
    var studentName = (string?)ViewData["name"] ?? "Student";
    var studentNumber = ViewData["StudentNumber"];
    var studentId = ViewData["StudentId"];
    // Expect Model.FileModel = IEnumerable<AttachmentLike>
    var files = (IEnumerable<dynamic>?)Model?.FileModel ?? Enumerable.Empty<dynamic>();
}

<style>
:root{
    --sd-bg:#ffffff;
    --sd-bg-alt:#f6f8fa;
    --sd-border:#e2e5ea;
    --sd-accent:#7d0e11;
    --sd-accent-grad:linear-gradient(120deg,#7d0e11,#b31217 55%,#ff7a18);
    --sd-soft:#fff4f2;
    --sd-text:#222;
    --sd-radius-xl:30px;
    --sd-radius-lg:24px;
    --sd-radius:14px;
    --sd-shadow:0 12px 34px -14px rgba(125,14,17,.32),0 5px 18px -10px rgba(125,14,17,.18);
    --sd-focus:0 0 0 .16rem #b3121726;
    font-family:'Segoe UI',system-ui,sans-serif;
}
.page-shell{max-width:1300px;margin:0 auto;padding:1.8rem 1.15rem 3rem;}
.header-band{
    background:var(--sd-bg);border:1px solid var(--sd-border);border-radius:var(--sd-radius-xl);
    padding:1.25rem 1.5rem 1.15rem;display:flex;gap:1.25rem;flex-wrap:wrap;align-items:center;
    position:relative;overflow:hidden;
}
.header-band:before{content:"";position:absolute;inset:0;background:linear-gradient(140deg,#7d0e1114,#b3121714,#ff7a1816);pointer-events:none;}
.icon-pill{width:74px;height:74px;border-radius:26px;background:var(--sd-accent-grad);display:flex;align-items:center;justify-content:center;font-size:2rem;color:#fff;box-shadow:0 10px 26px -10px rgba(179,18,23,.52);}
.header-band h1{margin:0;font-size:1.55rem;font-weight:600;letter-spacing:.55px;color:var(--sd-text);display:flex;align-items:center;gap:.55rem;}
.tagline{font-size:.6rem;letter-spacing:.18rem;font-weight:700;background:var(--sd-soft);color:var(--sd-accent);padding:.5rem .9rem;border-radius:40px;text-transform:uppercase;display:inline-flex;gap:.45rem;align-items:center;}
.toolbar{margin-left:auto;display:flex;gap:.6rem;flex-wrap:wrap;}
.btn, .btn-accent, .btn-outline, .btn-danger-soft{
    font-size:.58rem;letter-spacing:.12rem;font-weight:600;text-transform:uppercase;
    padding:.6rem 1.05rem;border-radius:14px;border:1px solid var(--sd-border);
    background:#fff;color:var(--sd-accent);display:inline-flex;align-items:center;gap:.5rem;
    cursor:pointer;transition:.3s;text-decoration:none;
}
.btn:hover,.btn-outline:hover{background:var(--sd-accent-grad);color:#fff;border-color:var(--sd-accent);box-shadow:var(--sd-shadow);}
.btn-accent{background:var(--sd-accent-grad);color:#fff;border:1px solid var(--sd-accent);}
.btn-accent:hover{filter:brightness(.94);}
.btn-danger-soft{background:#ffe8ea;color:#7d0e11;border:1px solid #f3c2c7;}
.btn-danger-soft:hover{background:var(--sd-accent-grad);color:#fff;border-color:var(--sd-accent);}

.section-grid{margin-top:1.6rem;display:grid;gap:1.3rem;}
.card-block{
    background:var(--sd-bg);border:1px solid var(--sd-border);border-radius:28px;
    padding:1.25rem 1.25rem 1.15rem;display:flex;flex-direction:column;gap:1.15rem;position:relative;overflow:hidden;
}
.card-block:before{content:"";position:absolute;inset:0;background:linear-gradient(145deg,#7d0e110f,#b3121710,#ff7a1810);pointer-events:none;}
.card-head{display:flex;align-items:center;gap:.6rem;flex-wrap:wrap;}
.card-head h2{margin:.1rem 0;font-size:.82rem;letter-spacing:.22rem;font-weight:700;text-transform:uppercase;color:var(--sd-accent);display:flex;align-items:center;gap:.5rem;}
.meta{font-size:.5rem;letter-spacing:.1rem;font-weight:600;color:#666;display:flex;gap:.9rem;flex-wrap:wrap;}
.meta span{display:inline-flex;align-items:center;gap:.3rem;}
.meta i{color:#b31217;font-size:.65rem;}
.badge-inline{background:#eef3f7;color:#16405d;border:1px solid #d0dde5;padding:.32rem .6rem;font-size:.48rem;font-weight:700;letter-spacing:.08rem;border-radius:30px;display:inline-flex;align-items:center;gap:.35rem;}

.field-grid{display:grid;gap:1rem;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));}
.field{display:flex;flex-direction:column;gap:.45rem;}
.field label{font-size:.5rem;letter-spacing:.15rem;text-transform:uppercase;font-weight:700;color:#4d555d;display:flex;align-items:center;gap:.35rem;}
.input-wrap{
    display:flex;align-items:center;gap:.45rem;background:#fff;border:1px solid var(--sd-border);
    padding:.55rem .7rem;border-radius:14px;transition:.25s;
}
.input-wrap:focus-within{border-color:var(--sd-accent);box-shadow:var(--sd-focus);}
.input-wrap i{font-size:.75rem;color:#888;}
.field select, .field input[type='file'], .field input[type='text']{
    width:100%;border:none;background:transparent;font-size:.7rem;outline:none;color:#222;
}
.required:after{content:"*";color:#b31217;margin-left:.25rem;font-weight:800;}
small.hint{font-size:.5rem;color:#777;margin-top:-.2rem;}
.validation-summary{font-size:.6rem;border:1px solid #f1d0d4;background:#fff5f7;color:#7d0e11;padding:.7rem .9rem;border-radius:14px;}

.actions-inline{display:flex;flex-wrap:wrap;gap:.7rem;margin-top:.2rem;}
.status-note{font-size:.5rem;letter-spacing:.14rem;color:#666;font-weight:600;margin-top:.4rem;}

.table-shell{background:var(--sd-bg);border:1px solid var(--sd-border);border-radius:28px;padding:1.15rem 1.05rem 1rem;overflow:auto;}
.table-meta{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.6rem;margin-bottom:.55rem;font-size:.5rem;letter-spacing:.14rem;font-weight:700;color:#666;}
.doc-table{width:100%;border-collapse:separate;border-spacing:0;font-size:.64rem;}
.doc-table thead th{
    background:var(--sd-accent-grad);color:#fff;font-size:.52rem;letter-spacing:.16rem;text-transform:uppercase;font-weight:700;padding:.55rem .55rem;position:sticky;top:0;z-index:2;
}
.doc-table tbody tr{transition:.18s;}
.doc-table tbody tr:nth-child(even){background:#fff;}
.doc-table tbody tr:nth-child(odd){background:#fffdfd;}
.doc-table tbody tr:hover{background:#fff4ef;}
.doc-table td{padding:.48rem .55rem;border-bottom:1px solid var(--sd-border);vertical-align:middle;color:#333;}
.action-link{
    font-weight:600;font-size:.48rem;letter-spacing:.08rem;text-transform:uppercase;
    background:#fff;padding:.4rem .6rem;border:1px solid var(--sd-border);border-radius:10px;
    text-decoration:none;display:inline-flex;gap:.35rem;align-items:center;color:var(--sd-accent);
    transition:.3s;
}
.action-link:hover{background:var(--sd-accent-grad);color:#fff;border-color:var(--sd-accent);box-shadow:0 4px 12px -6px rgba(179,18,23,.45);}
.pill-type{font-size:.48rem;font-weight:700;letter-spacing:.08rem;padding:.3rem .55rem;border-radius:30px;background:#eef2f7;color:#133349;border:1px solid #d3dae2;display:inline-flex;gap:.35rem;align-items:center;}
.pill-date{font-size:.46rem;padding:.28rem .5rem;border-radius:22px;background:#f0f1f3;color:#555;font-weight:600;letter-spacing:.06rem;display:inline-flex;gap:.3rem;align-items:center;}
.empty-row{text-align:center;font-style:italic;color:#777;}
.filter-bar{display:flex;flex-wrap:wrap;gap:.65rem;margin:0 0 .8rem;}
.filter-bar .search-wrap{position:relative;flex:1 1 300px;}
.filter-bar input{width:100%;padding:.55rem .7rem .55rem 2.1rem;border:1px solid var(--sd-border);border-radius:14px;font-size:.68rem;transition:.25s;background:#fff;}
.filter-bar input:focus{outline:none;border-color:var(--sd-accent);box-shadow:var(--sd-focus);}
.filter-bar i{position:absolute;top:50%;left:.7rem;transform:translateY(-50%);font-size:.7rem;color:#888;}
.filter-bar select{border:1px solid var(--sd-border);border-radius:14px;padding:.5rem .65rem;font-size:.65rem;transition:.25s;background:#fff;}
.filter-bar select:focus{outline:none;border-color:var(--sd-accent);box-shadow:var(--sd-focus);}
.hidden-row{display:none!important;}
.fade-in{animation:fade .5s ease;}
@@keyframes fade{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}
@@media (max-width:760px){
    .doc-table thead th:nth-child(3),
    .doc-table tbody td:nth-child(3){display:none;}
}
</style>

<div class="page-shell fade-in">
    <div class="header-band">
        <div class="icon-pill"><i class="fa fa-file-circle-plus"></i></div>
        <div>
            <h1>Student Documents</h1>
            <div class="tagline"><i class="fa fa-user-graduate"></i> @studentName</div>
        </div>
        <div class="toolbar">
            <a asp-action="Index" asp-controller="Student" class="btn"><i class="fa fa-arrow-left"></i> Back</a>
            <button id="btnExport" type="button" class="btn"><i class="fa fa-file-export"></i> Export CSV</button>
            <button id="btnRefresh" type="button" class="btn-outline"><i class="fa fa-rotate"></i> Refresh</button>
        </div>
    </div>

    <div class="section-grid">

        <!-- Upload Card -->
        <div class="card-block">
            <div class="card-head">
                <h2><i class="fa fa-upload"></i> Upload Document</h2>
                <div class="meta">
                    <span class="badge-inline"><i class="fa fa-id-card"></i>@studentNumber</span>
                    <span class="badge-inline"><i class="fa fa-hashtag"></i>@studentId</span>
                </div>
            </div>
            <form asp-action="StudentDocuments" enctype="multipart/form-data" method="post" novalidate autocomplete="off">
                @Html.AntiForgeryToken()
                <div class="field-grid">
                    <div class="field">
                        <label class="required">Document Type</label>
                        <div class="input-wrap">
                            <i class="fa fa-diagram-project"></i>
                            <select name="DocumentName" required asp-items="Html.GetEnumSelectList<eLearnerAdministration>()">
                                <option value="">Select document...</option>
                            </select>
                        </div>
                    </div>
                    <div class="field">
                        <label class="required">Document (PDF)</label>
                        <div class="input-wrap">
                            <i class="fa fa-file-pdf"></i>
                            <input id="fileInput" name="AttachmentFile" required type="file" accept="application/pdf" />
                        </div>
                        <small id="fileInfo" class="hint">Max 2MB • PDF only</small>
                    </div>
                </div>
                <input type="hidden" name="StudentNumber" value="@studentNumber" />
                <input type="hidden" name="StudentId" value="@studentId" />
                <div class="actions-inline">
                    <button type="submit" class="btn-accent"><i class="fa fa-save"></i> Save</button>
                    <button type="reset" class="btn-outline"><i class="fa fa-undo"></i> Reset</button>
                    <a asp-action="Index" asp-controller="Student" class="btn-danger-soft"><i class="fa fa-window-close"></i> Exit</a>
                </div>
                <div class="status-note"><strong>Note:</strong> Only PDF uploads are allowed.</div>
            </form>
        </div>

        <!-- Documents List -->
        <div class="card-block">
            <div class="card-head">
                <h2><i class="fa fa-folder-open"></i> Uploaded Documents (@files.Count())</h2>
            </div>

            <div class="filter-bar">
                <div class="search-wrap">
                    <i class="fa fa-search"></i>
                    <input id="searchBox" type="text" placeholder="Search type / date..." autocomplete="off" />
                </div>
                <select id="typeFilter">
                    <option value="">All Types</option>
                    @foreach (var t in Enum.GetValues(typeof(eLearnerAdministration)).Cast<eLearnerAdministration>())
                    {
                        <option value="@t">@t</option>
                    }
                </select>
            </div>

            <div class="table-shell">
                <div class="table-meta">
                    <span id="rowsInfo" class="badge-inline" style="background:#fff7f6;"><i class="fa fa-database"></i> Loading...</span>
                    <span id="perfInfo"></span>
                </div>
                <table class="doc-table" id="docsTable">
                    <thead>
                        <tr>
                            <th>Remove</th>
                            <th>Type</th>
                            <th>Added</th>
                            <th>Download</th>
                        </tr>
                    </thead>
                    <tbody id="docsBody">
                    @if(!files.Any())
                    {
                        <tr><td colspan="4" class="empty-row">No documents uploaded yet.</td></tr>
                    }
                    else
                    {
                        foreach (var a in files)
                        {
                            string type = a.DocumentName?.ToString() ?? "";
                            string created = a.CreatedOn?.ToString() ?? "";
                            string fileName = a.Document?.ToString() ?? "";
                            Guid attachmentId = a.AttachmentId;
                            <tr data-type="@type" data-text="@($"{type} {created}".ToLower())">
                                <td>
                                    <a class="action-link" href="@Url.Action("RemoveDocument","Student",new {AttachmentId = attachmentId})" onclick="return confirm('Remove this document?');">
                                        <i class="fa fa-trash"></i> Remove
                                    </a>
                                </td>
                                <td>
                                    <span class="pill-type"><i class="fa fa-file-pdf"></i> @type</span>
                                </td>
                                <td>
                                    <span class="pill-date" title="@created"><i class="fa fa-calendar"></i> @created</span>
                                </td>
                                <td>
                                    <a class="action-link" href="@Url.Action("AttachmentDownload","Student",new { filename = fileName })">
                                        <i class="fa fa-download"></i> Download
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts{
<script>
(function(){
    // File validation
    const fi=document.getElementById('fileInput');
    const info=document.getElementById('fileInfo');
    fi?.addEventListener('change', function(){
        const f=this.files[0];
        if(!f){ info.textContent='Max 2MB • PDF only'; return; }
        if(f.type!=='application/pdf'){ alert('Only PDF files allowed.'); this.value=''; info.textContent='Max 2MB • PDF only'; return; }
        if(f.size> (2*1024*1024)){ alert('File exceeds 2MB.'); this.value=''; info.textContent='Max 2MB • PDF only'; return; }
        info.textContent = `${f.name} (${(f.size/1024).toFixed(0)} KB)`;
    });

    // Filtering
    const body=document.getElementById('docsBody');
    const rowsInfo=document.getElementById('rowsInfo');
    const perfInfo=document.getElementById('perfInfo');
    const searchBox=document.getElementById('searchBox');
    const typeFilter=document.getElementById('typeFilter');
    function norm(v){return (v||'').toString().toLowerCase().trim();}

    function apply(){
        const t0=performance.now();
        const q=norm(searchBox.value);
        const tp=typeFilter.value;
        const rows=Array.from(body.querySelectorAll('tr'));
        let shown=0,total=0;
        rows.forEach(r=>{
            if(r.classList.contains('empty-row')) return;
            total++;
            const txt=r.getAttribute('data-text')||'';
            const type=r.getAttribute('data-type')||'';
            let show=true;
            if(q && !txt.includes(q)) show=false;
            if(tp && type!==tp) show=false;
            r.classList.toggle('hidden-row', !show);
            if(show) shown++;
        });
        rowsInfo.innerHTML = `<i class="fa fa-database"></i> Showing ${shown} of ${total} item(s)` + (q||tp? ' (filtered)':'');
        perfInfo.textContent = 'Render '+(performance.now()-t0).toFixed(1)+'ms';
    }
    [searchBox,typeFilter].forEach(el=> el.addEventListener(el.tagName==='INPUT'?'input':'change', apply));
    apply();

    // Export CSV
    const btnExport=document.getElementById('btnExport');
    btnExport?.addEventListener('click', ()=>{
        const visible=Array.from(body.querySelectorAll('tr:not(.hidden-row)')).filter(r=>!r.classList.contains('empty-row'));
        if(!visible.length){ alert('No rows to export.'); return; }
        const lines=['Type,Added,File'];
        visible.forEach(r=>{
            const cells=r.querySelectorAll('td');
            const type=cells[1].innerText.trim();
            const added=cells[2].innerText.trim();
            const file=cells[3].innerText.trim();
            lines.push([type,added,file].map(v=>'"'+v.replace(/"/g,'""')+'"').join(','));
        });
        const blob=new Blob([lines.join('\\r\\n')],{type:'text/csv;charset=utf-8;'});
        const a=document.createElement('a');
        a.href=URL.createObjectURL(blob);
        a.download='student-documents-'+new Date().toISOString().slice(0,10)+'.csv';
        document.body.appendChild(a);a.click();document.body.removeChild(a);
    });

    document.getElementById('btnRefresh')?.addEventListener('click', ()=>location.reload());
})();
</script>
}

