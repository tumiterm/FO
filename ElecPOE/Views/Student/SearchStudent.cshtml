@model List<ForekOnline.Domain.Entities.Student>
@{
    ViewData["Title"] = "Search Student";
    string? searchType  = ViewData["searchType"]  as string;
    string? searchValue = ViewData["searchValue"] as string;
    bool    hasSearched  = !string.IsNullOrWhiteSpace(searchType) && !string.IsNullOrWhiteSpace(searchValue);
    bool    hasResults   = Model != null && Model.Count > 0;
    int     resultCount  = Model?.Count ?? 0;
    string  typeLabel    = searchType switch {
        "IDNumber"       => "ID Number",
        "PassportNumber" => "Passport Number",
        _                => "Student Number"
    };


    var subtitle = hasSearched
        ? $"{resultCount} record{(resultCount == 1 ? "" : "s")} returned for \"{searchValue}\" ({typeLabel}). Click any card to open the full profile."
        : "Use the left panel to search by Student Number, South African ID, or Passport. Matching learner cards appear here.";
}

<link rel="stylesheet" href="~/css/Enrollment.css" />

<style>

.ss-shell {
    max-width: 1300px;
    margin: 0 auto;
    padding: 2.1rem 1.35rem 4rem;
}

/* ── Hero (mirrors enroll-hero exactly) ── */
.ss-hero {
    position: relative;
    overflow: hidden;
    background: var(--es-bg);
    border: 1px solid var(--es-border);
    border-radius: var(--es-radius-xl);
    box-shadow: var(--es-shadow-lg);
    padding: 1.6rem 1.75rem;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.25rem;
    align-items: center;
}
.ss-hero::before {
    content: "";
    position: absolute; inset: 0;
    background: var(--es-grad-soft);
    pointer-events: none;
}
.ss-hero > * { position: relative; z-index: 1; }

.ss-hero__icon {
    width: 82px; height: 82px;
    border-radius: 26px;
    background: var(--es-grad);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 2.35rem;
    box-shadow: 0 16px 32px -16px rgba(179,18,23,.45);
    animation: ss-pop .65s cubic-bezier(.34,1.56,.64,1) both;
    flex-shrink: 0;
}
@@keyframes ss-pop {
    from { transform: scale(.5) rotate(-8deg); opacity: 0; }
    to   { transform: scale(1) rotate(0);       opacity: 1; }
}
.ss-hero__meta {
    display: grid;
    gap: .75rem;
    min-width: 210px;
}

/* ── Content grid (sidebar + main) ── */
.ss-grid {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 1.5rem;
    margin-top: 1.8rem;
    align-items: start;
}

/* ── Search sidebar ── */
.ss-side { display: flex; flex-direction: column; gap: 1.1rem; }

.ss-search-card {
    display: flex; flex-direction: column; gap: 1rem;
}

.ss-field { display: flex; flex-direction: column; gap: .42rem; }
.ss-field-label {
    font-size: .55rem; letter-spacing: .16rem; text-transform: uppercase;
    font-weight: 800; color: var(--es-muted);
    display: flex; align-items: center; gap: .4rem;
}
.ss-field-label i { color: var(--es-red); }

.ss-input-wrap {
    position: relative;
    display: flex; align-items: center;
}
.ss-input-wrap i.ss-ico {
    position: absolute; left: .78rem; top: 50%;
    transform: translateY(-50%);
    color: var(--es-muted); font-size: .78rem; pointer-events: none;
    transition: color var(--es-speed);
}
.ss-input-wrap:focus-within i.ss-ico { color: var(--es-red); }

.ss-input,
.ss-select {
    width: 100%;
    height: 48px;
    border-radius: var(--es-radius-md);
    border: 1.5px solid var(--es-border);
    background: var(--es-bg);
    color: var(--es-text);
    font-size: .74rem; font-family: inherit; font-weight: 500;
    outline: none;
    transition: border-color var(--es-speed), box-shadow var(--es-speed);
}
.ss-input  { padding: 0 1rem 0 2.5rem; }
.ss-select { padding: 0 1rem; cursor: pointer; }
.ss-input:focus,
.ss-select:focus {
    border-color: var(--es-red);
    box-shadow: 0 0 0 .18rem rgba(179,18,23,.13);
    background: #fff;
}

.ss-actions {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: .6rem;
    align-items: center;
}
.ss-actions .btn-premium { height: 46px; justify-content: center; }
.ss-clear {
    width: 46px; height: 46px;
    display: flex; align-items: center; justify-content: center;
    border-radius: var(--es-radius-md);
    border: 1.5px solid rgba(217,78,38,.2);
    background: #fff2ee; color: var(--es-red);
    text-decoration: none; font-size: .9rem;
    transition: background var(--es-speed), box-shadow var(--es-speed);
    flex-shrink: 0;
}
.ss-clear:hover { background: var(--es-red); color: #fff; }

/* ── Summary chip ── */
.ss-summary {
    display: flex; align-items: flex-start; gap: .75rem;
    padding: .85rem .95rem;
    border-radius: var(--es-radius-md);
    background: linear-gradient(135deg, #f6fbf8, #fdf9f0);
    border: 1px solid var(--es-border);
    animation: ss-rise .35s ease both;
}
.ss-summary-icon {
    width: 36px; height: 36px; flex-shrink: 0;
    border-radius: 11px;
    background: #fff; color: var(--es-red);
    display: flex; align-items: center; justify-content: center;
    box-shadow: var(--es-shadow-sm); font-size: .88rem;
}
.ss-summary-copy { font-size: .7rem; color: var(--es-muted); line-height: 1.55; }
.ss-summary-copy em { color: var(--es-text); font-style: normal; font-weight: 700; }
.ss-state {
    display: inline-flex; align-items: center; gap: .38rem;
    margin-top: .38rem; font-size: .58rem; font-weight: 800;
    letter-spacing: .1rem; text-transform: uppercase;
}
.ss-state-ok  { color: #198754; }
.ss-state-nil { color: var(--es-red); }

/* ── Metric strip ── */
.ss-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: .6rem;
}
.ss-metric {
    border-radius: 14px;
    padding: .75rem .7rem;
    background: rgba(255,255,255,.78);
    border: 1px solid var(--es-border);
    box-shadow: var(--es-shadow-sm);
    position: relative; overflow: hidden;
    transition: transform .28s;
}
.ss-metric:hover { transform: translateY(-2px); }
.ss-metric::after {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0;
    height: 3px; background: var(--es-grad);
    border-radius: 0 0 14px 14px; opacity: .55;
}
.ss-metric-val {
    font-size: 1.25rem; font-weight: 800; line-height: 1;
    background: var(--es-grad);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.ss-metric-lbl {
    font-size: .52rem; letter-spacing: .12rem; text-transform: uppercase;
    font-weight: 700; color: var(--es-muted); margin-top: .25rem;
}

/* ── Results / how-to panel ── */
.ss-main { min-width: 0; display: flex; flex-direction: column; gap: 1.1rem; }

.ss-main-head {
    display: flex; justify-content: space-between; align-items: flex-start;
    gap: 1rem; flex-wrap: wrap;
}
.ss-main-title-eyebrow {
    font-size: .58rem; letter-spacing: .2rem; font-weight: 800;
    text-transform: uppercase; color: var(--es-red);
    display: flex; align-items: center; gap: .4rem; margin-bottom: .4rem;
}
.ss-main-h2 {
    font-size: 1.45rem; font-weight: 800; letter-spacing: -.4px;
    color: var(--es-dark); line-height: 1.2; margin: 0;
}
.ss-main-sub {
    font-size: .78rem; color: var(--es-muted); max-width: 560px;
    line-height: 1.65; margin-top: .4rem;
}
.ss-orb {
    width: 72px; height: 72px; flex-shrink: 0;
    border-radius: 22px;
    background: var(--es-grad-soft);
    border: 1px solid rgba(179,18,23,.12);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.6rem; color: var(--es-red);
    box-shadow: var(--es-shadow-sm);
}

/* ── Result cards ── */
.ss-results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: .85rem;
}
.ss-r-card {
    position: relative; overflow: hidden;
    display: grid;
    grid-template-columns: auto minmax(0,1fr);
    gap: .85rem;
    padding: 1rem 1rem 1rem 1rem;
    border-radius: 22px;
    border: 1px solid var(--es-border);
    background: rgba(255,255,255,.92);
    color: inherit; text-decoration: none;
    box-shadow: var(--es-shadow-sm);
    animation: ss-rise .4s var(--es-speed) both;
    transition: transform .28s, box-shadow .28s, border-color .28s;
}
.ss-r-card::before {
    content: ''; position: absolute; inset: 0;
    background: var(--es-grad-soft);
    pointer-events: none; opacity: 0;
    transition: opacity .28s;
}
.ss-r-card::after {
    content: ''; position: absolute;
    top: 0; left: 1rem; right: 1rem;
    height: 3px; border-radius: 0 0 3px 3px;
    background: var(--es-grad);
    transform: scaleX(.2); transform-origin: left;
    transition: transform .3s;
}
.ss-r-card:hover { transform: translateY(-4px); box-shadow: var(--es-shadow-md); border-color: var(--es-border-strong); color: inherit; }
.ss-r-card:hover::before { opacity: 1; }
.ss-r-card:hover::after  { transform: scaleX(1); }

.ss-r-card:nth-child(1) { animation-delay: .04s; }
.ss-r-card:nth-child(2) { animation-delay: .08s; }
.ss-r-card:nth-child(3) { animation-delay: .12s; }
.ss-r-card:nth-child(4) { animation-delay: .16s; }
.ss-r-card:nth-child(5) { animation-delay: .20s; }
.ss-r-card:nth-child(6) { animation-delay: .24s; }

@@keyframes ss-rise {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
}

.ss-av {
    position: relative; z-index: 1;
    width: 52px; height: 52px; flex-shrink: 0;
    border-radius: 16px;
    background: var(--es-grad);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 1.15rem;
    box-shadow: 0 10px 24px -8px rgba(179,18,23,.42);
    transition: transform .28s cubic-bezier(.34,1.56,.64,1);
}
.ss-r-card:hover .ss-av { transform: scale(1.08) rotate(-3deg); }

.ss-r-body  { position: relative; z-index: 1; min-width: 0; }
.ss-r-name  {
    font-size: .88rem; font-weight: 800; letter-spacing: -.02rem;
    color: var(--es-text);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.ss-r-meta  { display: flex; flex-wrap: wrap; gap: .38rem; margin-top: .55rem; }
.ss-r-tag   {
    display: inline-flex; align-items: center; gap: .3rem;
    height: 26px; padding: 0 .52rem;
    border-radius: 999px; font-size: .54rem; font-weight: 700;
    color: var(--es-muted);
    background: rgba(244,250,247,.9); border: 1px solid var(--es-border);
}
.ss-r-tag i { color: var(--es-red); font-size: .52rem; }

.ss-badge {
    display: inline-flex; align-items: center; gap: .3rem;
    height: 22px; padding: 0 .5rem;
    border-radius: 999px; font-size: .5rem; font-weight: 800;
    letter-spacing: .08rem; text-transform: uppercase;
}
.ss-badge-active  { background: #e8f9ef; color: #137a44; border: 1px solid #b7e6c8; }
.ss-badge-dereg   { background: #ffe6ea; color: #b31217; border: 1px solid #f3b4ba; }
.ss-badge-neutral { background: #f0f1f3; color: #555;    border: 1px solid #dadde0; }

.ss-arrow {
    position: absolute; right: .85rem; bottom: .85rem;
    color: #ccc; font-size: .75rem;
    transition: color .28s, transform .28s;
}
.ss-r-card:hover .ss-arrow { color: var(--es-red); transform: translateX(3px); }

/* ── Hint cards (how-to) ── */
.ss-hints-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: .85rem;
}
.ss-hint {
    position: relative; overflow: hidden;
    padding: 1.1rem;
    border-radius: 20px;
    background: rgba(255,255,255,.82);
    border: 1px solid var(--es-border);
    box-shadow: var(--es-shadow-sm);
}
.ss-hint::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(circle at 90% 0%, rgba(255,122,24,.1), transparent 45%);
    pointer-events: none;
}
.ss-hint-ico {
    width: 52px; height: 52px;
    border-radius: 16px;
    background: var(--es-grad-soft);
    border: 1px solid rgba(179,18,23,.1);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.15rem; color: var(--es-red);
    position: relative; z-index: 1;
}
.ss-hint-title {
    font-size: .9rem; font-weight: 800; letter-spacing: -.02rem;
    margin: .75rem 0 .35rem; position: relative; z-index: 1;
    color: var(--es-dark);
}
.ss-hint-desc {
    font-size: .72rem; color: var(--es-muted);
    line-height: 1.65; position: relative; z-index: 1;
}
.ss-hint-ex {
    display: inline-flex; align-items: center; gap: .35rem;
    margin-top: .8rem; padding: .35rem .65rem;
    border-radius: 999px;
    background: var(--es-rose); border: 1px solid rgba(179,18,23,.14);
    color: var(--es-red); font-size: .54rem; font-weight: 800;
    letter-spacing: .1rem; text-transform: uppercase;
    position: relative; z-index: 1;
}

/* ── Empty state ── */
.ss-empty {
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; text-align: center;
    min-height: 360px; gap: .75rem;
    border-radius: 24px;
    border: 1px solid var(--es-border);
    background: rgba(255,255,255,.72);
    box-shadow: var(--es-shadow-sm);
    padding: 2.5rem 1.5rem;
}
.ss-empty-ico {
    width: 84px; height: 84px;
    border-radius: 28px;
    background: var(--es-rose);
    color: var(--es-red); font-size: 1.9rem;
    display: flex; align-items: center; justify-content: center;
    box-shadow: var(--es-shadow-sm);
}
.ss-empty h3 { font-size: 1.35rem; font-weight: 800; letter-spacing: -.03rem; color: var(--es-dark); margin: 0; }
.ss-empty p  { max-width: 36rem; color: var(--es-muted); font-size: .82rem; line-height: 1.7; margin: 0; }

/* ── Responsive ── */
@@media (max-width: 1024px) {
    .ss-grid { grid-template-columns: 260px 1fr; gap: 1.1rem; }
}
@@media (max-width: 860px) {
    .ss-grid { grid-template-columns: 1fr; }
    .ss-hero { grid-template-columns: auto 1fr; }
    .ss-hero__meta { grid-column: 1 / -1; grid-template-columns: repeat(2,1fr); }
    .ss-actions { grid-template-columns: 1fr auto; }
    .ss-orb { display: none; }
}
@@media (max-width: 580px) {
    .ss-hero { padding: 1.25rem 1.1rem 1rem; }
    .ss-hero__icon { width: 64px; height: 64px; font-size: 1.65rem; }
    .enroll-title { font-size: 1.35rem; }
    .ss-results-grid { grid-template-columns: 1fr; }
    .ss-hints-grid   { grid-template-columns: 1fr; }
    .ss-metrics { grid-template-columns: repeat(3,1fr); }
}
</style>

<div class="ss-shell">

    <div class="ss-hero fade-up">
        <div class="ss-hero__icon"><i class="fa fa-magnifying-glass"></i></div>

        <div>
            <div class="enroll-kicker">
                <i class="fa fa-circle-nodes"></i>
                Student Intelligence Suite
            </div>
            <h1 class="enroll-title">Search Student</h1>
            <p class="enroll-subtitle">
                Look up any learner by Student Number, South African ID, or Passport.
                Results appear in a responsive card grid for instant review.
            </p>
        </div>

        <div class="ss-hero__meta">
            <div class="hero-stat">
                <div class="hero-stat__label">Workflow</div>
                <div class="hero-stat__value">Choose key → Enter value → Search</div>
            </div>
            <div class="hero-stat">
                <div class="hero-stat__label">Results</div>
                <div class="hero-stat__value">
                    @(hasSearched ? $"{resultCount} record{(resultCount == 1 ? "" : "s")} found" : "Awaiting query")
                </div>
            </div>
        </div>
    </div>

    <div class="ss-grid">

        <aside class="ss-side">
            <div class="glass-card progress-card fade-up">
                <h5 class="progress-title">
                    <i class="fa fa-sliders"></i>
                    Search Criteria
                </h5>

                <div class="ss-search-card">
                    <form method="get"
                          asp-action="SearchStudent"
                          asp-controller="Student"
                          autocomplete="off">

                        <div style="display:flex;flex-direction:column;gap:.85rem;">
                            <div class="ss-field">
                                <label class="ss-field-label" for="searchType">
                                    <i class="fa fa-filter"></i> Search By
                                </label>
                                <div class="ss-input-wrap">
                                    <select id="searchType"
                                            name="searchType"
                                            class="ss-select"
                                            onchange="syncPlaceholder(this)">
                                        <option value="StudentNumber" selected="@(searchType == "StudentNumber")">
                                            Student Number
                                        </option>
                                        <option value="IDNumber" selected="@(searchType == "IDNumber")">
                                            ID Number
                                        </option>
                                        <option value="PassportNumber" selected="@(searchType == "PassportNumber")">
                                            Passport Number
                                        </option>
                                    </select>
                                </div>
                            </div>

                            <div class="ss-field">
                                <label class="ss-field-label" for="searchValue">
                                    <i class="fa fa-keyboard"></i> Lookup Value
                                </label>
                                <div class="ss-input-wrap">
                                    <i class="fa fa-fingerprint ss-ico"></i>
                                    <input id="searchValue" name="searchValue" type="text"
                                           class="ss-input"
                                           value="@searchValue"
                                           placeholder="Enter student number…"
                                           spellcheck="false" />
                                </div>
                            </div>

                            <div class="ss-actions">
                                <button type="submit" class="btn-premium btn-premium--primary">
                                    <i class="fa fa-magnifying-glass me-2"></i>Search
                                </button>
                                @if (hasSearched)
                                {
                                    <a href="@Url.Action("SearchStudent","Student")"
                                       class="ss-clear" title="Clear search">
                                        <i class="fa fa-xmark"></i>
                                    </a>
                                }
                            </div>
                        </div>
                    </form>

                    @if (hasSearched)
                    {
                        <div class="ss-summary">
                            <div class="ss-summary-icon"><i class="fa fa-circle-info"></i></div>
                            <div>
                                <div class="ss-summary-copy">
                                    By <em>@typeLabel</em> for &ldquo;<em>@searchValue</em>&rdquo;
                                </div>
                                @if (hasResults)
                                {
                                    <span class="ss-state ss-state-ok">
                                        <i class="fa fa-check-circle"></i>
                                        @resultCount @(resultCount == 1 ? "record" : "records") found
                                    </span>
                                }
                                else
                                {
                                    <span class="ss-state ss-state-nil">
                                        <i class="fa fa-circle-xmark"></i> No records found
                                    </span>
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="ss-metrics">
                    <div class="ss-metric">
                        <div class="ss-metric-val">3</div>
                        <div class="ss-metric-lbl">Keys</div>
                    </div>
                    <div class="ss-metric">
                        <div class="ss-metric-val" id="metricResults">@resultCount</div>
                        <div class="ss-metric-lbl">Results</div>
                    </div>
                    <div class="ss-metric">
                        <div class="ss-metric-val">1</div>
                        <div class="ss-metric-lbl">Click</div>
                    </div>
                </div>

                <div class="lookup-badge-row" style="margin-top:.25rem;">
                    <span class="smart-badge smart-badge--soft">
                        <i class="fa fa-bolt"></i> Instant results
                    </span>
                    <span class="smart-badge smart-badge--soft">
                        <i class="fa fa-shield-halved"></i> Secure
                    </span>
                </div>
            </div>

            <div class="glass-card fade-up" style="padding:.95rem 1rem;display:flex;flex-direction:column;gap:.55rem;">
                <h5 class="progress-title" style="margin-bottom:.1rem;">
                    <i class="fa fa-compass"></i> Quick Nav
                </h5>
                <a asp-action="StudentList" asp-controller="Student"
                   class="btn-premium btn-premium--ghost" style="justify-content:center;">
                    <i class="fa fa-users-line me-2"></i>Student List
                </a>
                <a asp-action="EnrollStudent" asp-controller="Student"
                   class="btn-premium" style="justify-content:center;">
                    <i class="fa fa-user-plus me-2"></i>Enroll Student
                </a>
            </div>
        </aside>

        <main class="ss-main">
            <div class="ss-main-head">
                <div>
                    <div class="ss-main-title-eyebrow">
                        <i class="fa @(hasSearched ? "fa-list-check" : "fa-compass")"></i>
                        @(hasSearched ? "Results Workspace" : "Lookup Guide")
                    </div>
                    <h2 class="ss-main-h2">
                        @(hasSearched ? "Matching Learners" : "Choose a search key and begin")
                    </h2>
                    <p class="ss-main-sub">@subtitle</p>
                </div>
                <div class="ss-orb">
                    <i class="fa @(hasResults ? "fa-user-check" : hasSearched ? "fa-user-slash" : "fa-user-graduate")"></i>
                </div>
            </div>

            @if (hasSearched)
            {
                @if (hasResults)
                {
                    <div class="ss-results-grid">
                        @foreach (var s in Model!)
                        {
                            var enr    = s.EnrollmentHistory?.FirstOrDefault(e => e.IsActive)
                                      ?? s.EnrollmentHistory?.FirstOrDefault();
                            string course = enr?.CourseTitle ?? "";
                            if (course.Length > 40) course = course[..40] + "…";

                            <a class="ss-r-card"
                               asp-action="StudentDetail" asp-controller="Student"
                               asp-route-StudentNumber="@s.StudentNumber">

                                <div class="ss-av"><i class="fa fa-user"></i></div>

                                <div class="ss-r-body">
                                    <div class="ss-r-name">@s.FullName</div>
                                    <div class="ss-r-meta">
                                        <span class="ss-r-tag"><i class="fa fa-hashtag"></i>@s.StudentNumber</span>
                                        @if (!string.IsNullOrWhiteSpace(s.IDNumber))
                                        {
                                            <span class="ss-r-tag"><i class="fa fa-id-card"></i>@s.IDNumber</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(s.Cellphone))
                                        {
                                            <span class="ss-r-tag"><i class="fa fa-phone"></i>@s.Cellphone</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(course))
                                        {
                                            <span class="ss-r-tag" style="max-width:180px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                                <i class="fa fa-graduation-cap"></i>@course
                                            </span>
                                        }
                                        <span class="ss-badge @(s.Deregistered ? "ss-badge-dereg" : s.IsActive ? "ss-badge-active" : "ss-badge-neutral")">
                                            <i class="fa fa-circle" style="font-size:.42rem;"></i>
                                            @(s.Deregistered ? "Deregistered" : s.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </div>
                                </div>

                                <i class="fa fa-chevron-right ss-arrow"></i>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <div class="ss-empty">
                        <div class="ss-empty-ico"><i class="fa fa-user-magnifying-glass"></i></div>
                        <h3>No Students Found</h3>
                        <p>
                            No records matched <strong>&ldquo;@searchValue&rdquo;</strong>
                            when searching by <strong>@typeLabel</strong>.
                            Double-check the value or try a different search type.
                        </p>
                        <a href="@Url.Action("SearchStudent","Student")"
                           class="btn-premium btn-premium--primary" style="margin-top:.5rem;">
                            <i class="fa fa-rotate-left me-2"></i>New Search
                        </a>
                    </div>
                }
            }
            else
            {
                <div class="ss-hints-grid">
                    <div class="ss-hint">
                        <div class="ss-hint-ico"><i class="fa fa-hashtag"></i></div>
                        <div class="ss-hint-title">Student Number</div>
                        <div class="ss-hint-desc">
                            The unique alphanumeric identifier assigned to each learner at the time of enrollment in the Forek system.
                        </div>
                        <span class="ss-hint-ex"><i class="fa fa-lightbulb"></i> e.g. FIT202400142</span>
                    </div>
                    <div class="ss-hint">
                        <div class="ss-hint-ico"><i class="fa fa-id-card"></i></div>
                        <div class="ss-hint-title">ID Number</div>
                        <div class="ss-hint-desc">
                            The 13-digit South African national identity number printed on the learner's green ID book or smart ID card.
                        </div>
                        <span class="ss-hint-ex"><i class="fa fa-lightbulb"></i> e.g. 9001015800082</span>
                    </div>
                    <div class="ss-hint">
                        <div class="ss-hint-ico"><i class="fa fa-passport"></i></div>
                        <div class="ss-hint-title">Passport Number</div>
                        <div class="ss-hint-desc">
                            The international travel document number for foreign national learners who do not hold a South African ID.
                        </div>
                        <span class="ss-hint-ex"><i class="fa fa-lightbulb"></i> e.g. A12345678</span>
                    </div>
                </div>
            }
        </main>
    </div>
</div>

<script>
(function () {
    var ph = {
        StudentNumber:  'Enter student number\u2026',
        IDNumber:       'Enter 13-digit SA ID number\u2026',
        PassportNumber: 'Enter passport number\u2026'
    };

    function syncPlaceholder(sel) {
        var inp = document.getElementById('searchValue');
        if (inp) inp.placeholder = ph[sel.value] || '';
    }

    window.syncPlaceholder = syncPlaceholder;

    var sel = document.getElementById('searchType');
    var inp = document.getElementById('searchValue');
    if (sel) syncPlaceholder(sel);
    if (inp && !inp.value) inp.focus();
    inp?.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') inp.closest('form').submit();
    });
})();
</script>