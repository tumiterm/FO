              </div>
            </div>

            <input type="hidden" data-question-type name="Questions[${qIdx}].QuestionType" value="MultipleChoice" />

            <div class="input-wrap" style="max-width:220px;">
              <i class="fa fa-star"></i>
              <input type="number"
                     name="Questions[${qIdx}].Marks"
