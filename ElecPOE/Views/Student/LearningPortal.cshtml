        async function uploadQuestionImage(file) {
          const antiforgery = assessmentForm.querySelector('input[name="__RequestVerificationToken"]')?.value;

          const fd = new FormData();
          fd.append('file', file);

          const res = await fetch('@Url.Action("UploadQuestionImage", "Assessment")', {
            method: 'POST',
            headers: {
              ...(antiforgery ? { 'RequestVerificationToken': antiforgery } : {})
            },
            body: fd
          });

          if (!res.ok) {
            const txt = await res.text();
            throw new Error(txt || `Upload failed (HTTP ${res.status})`);
          }

          return await res.json();
        }

      function wireQuestionImageHandlers(card) {
      const fileInput = card.querySelector('input[type="file"][data-qimage]');
      const idInput = card.querySelector('input[type="hidden"][data-qimage-id]');
      const previewWrap = card.querySelector('[data-qimage-preview]');
      const previewImg = previewWrap?.querySelector('img');
      const clearBtn = card.querySelector('[data-qimage-clear]');
      const annotateChk = card.querySelector('input[type="checkbox"][data-enable-annotation]');

      let objectUrl = null;

      function clearImage() {
        if (objectUrl) {
          URL.revokeObjectURL(objectUrl);
          objectUrl = null;
        }

        if (fileInput) fileInput.value = '';
        if (idInput) idInput.value = '';
        if (previewWrap) previewWrap.style.display = 'none';
        if (previewImg) previewImg.src = '';

        if (annotateChk) annotateChk.checked = false;
      }

      clearBtn?.addEventListener('click', clearImage);

      fileInput?.addEventListener('change', async function () {
        const file = fileInput.files && fileInput.files.length > 0 ? fileInput.files[0] : null;
        if (!file) return;

        try {
          if (previewImg) {
            if (objectUrl) URL.revokeObjectURL(objectUrl);
            objectUrl = URL.createObjectURL(file);
            previewImg.src = objectUrl;
          }
          if (previewWrap) previewWrap.style.display = '';

          const data = await uploadQuestionImage(file);
          if (!data?.fileId) throw new Error('Upload did not return fileId.');

          if (idInput) idInput.value = data.fileId.toString();
        } catch (e) {
          alert(`Image upload failed: ${e.message || e}`);
          clearImage();
        }
      });
    }

