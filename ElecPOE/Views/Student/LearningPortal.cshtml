            </div>

            <div data-image-pane style="display:none;">
              <div class="input-wrap" style="align-items:flex-start;">
                <i class="fa fa-image" style="margin-top:.25rem;"></i>
                <div style="width:100%;">
                  <input type="hidden" name="Questions[${qIdx}].ImagePath" data-qimage-id value="" />
                  <input type="file" accept="image/*" data-qimage style="font-size:.62rem;" />

                    <div style="margin-top:.5rem;">
                  <label class="lp-check">
                    <input type="checkbox"
                           data-enable-annotation
                           name="Questions[${qIdx}].EnableAnnotation"
                           value="true" />
