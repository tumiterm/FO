          `;

          card.querySelector('[data-remove-question]')?.addEventListener('click', () => {
            card.remove();
            if (questionHost.querySelectorAll('.q-card').length === 0) {
              questionHost.innerHTML = `<div class="empty-box"><i class="fa fa-circle-info"></i> No questions added.</div>`;
            }
            reindexQuestions();
            updateMarksSummary();
          });

          card.querySelector('[data-type-btn="MathInput"]')?.addEventListener('click', () => setQuestionType(card, 'MathInput'));

          card.querySelector('[data-type-btn="MultipleChoice"]')?.addEventListener('click', () => setQuestionType(card, 'MultipleChoice'));
          card.querySelector('[data-type-btn="ShortAnswer"]')?.addEventListener('click', () => setQuestionType(card, 'ShortAnswer'));

          card.querySelector('[data-add-option]')?.addEventListener('click', () => addOptionRow(card));
          card.querySelector('[data-toggle-image]')?.addEventListener('click', () => {
