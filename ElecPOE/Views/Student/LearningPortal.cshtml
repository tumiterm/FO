                        <i class="fa fa-trash"></i> Remove Image
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="input-wrap">
              <i class="fa fa-pen"></i>
              <input type="text" name="Questions[${qIdx}].Prompt" placeholder="Question prompt..." required />
            </div>

            <div class="input-wrap" style="align-items:flex-start;">
              <i class="fa fa-circle-info" style="margin-top:.3rem;"></i>
              <textarea name="Questions[${qIdx}].Explanation" rows="2" placeholder="Optional explanation shown after submission..."></textarea>
            </div>

            <div data-pane="mcq">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-top:.2rem;">
                <div style="font-size:.52rem;letter-spacing:.14rem;font-weight:800;text-transform:uppercase;color:var(--lp-muted);">
                  Options
                </div>
                <button type="button" class="btn-el" data-add-option style="font-size:.48rem;padding:.4rem .6rem;">
                  <i class="fa fa-plus"></i> Add Option
                </button>
              </div>

              <div data-options-host style="margin-top:.5rem;"></div>

              <div style="margin-top:.35rem;font-size:.54rem;color:var(--lp-muted);font-weight:600;">
                Mark exactly one option as correct.
              </div>
            </div>

            <div data-pane="short" style="display:none;">
              <div style="margin-top:.25rem;font-size:.54rem;color:var(--lp-muted);font-weight:600;">
                Learners will type an answer. Marking rules are handled by the back-end (recommended: manual review or normalization rules).
              </div>
            </div>

               <div data-pane="math" style="display:none;">
              <div style="margin-top:.25rem;font-size:.54rem;color:var(--lp-muted);font-weight:600;">
                Learners will use an equation editor (MathLive) to enter their answer as LaTeX. Use $...$ in the prompt for inline math.
              </div>
