          questionHost.appendChild(card);

          addOptionRow(card);
          addOptionRow(card);

          const firstRadio = card.querySelector('input[type="radio"][data-correct-radio]');
          if (firstRadio) {
            firstRadio.checked = true;
            syncCorrectFlags(card);
          }

          wireQuestionImageHandlers(card);

          questionIndex++;
          updateMarksSummary();
        }

        btnAddQuestion.addEventListener('click', addQuestionCard);

        assessmentForm.addEventListener('submit', function (e) {
          const count = questionHost.querySelectorAll('.q-card').length;
          if (count === 0) {
            e.preventDefault();
            alert('Please add at least one question before saving the assessment.');
            return;
          }

          questionHost.querySelectorAll('.q-card').forEach(syncCorrectFlags);

          const target = getTargetMarks();
          const sum = getSumMarks();

          if (target > 0 && sum !== target) {
            e.preventDefault();
            alert(`Total question marks must equal Max Score.\n\nSum of question marks: ${sum}\nMax Score: ${target}`);
          }
        });

        updateMarksSummary();
      }

    function renderMathInElement(el) {
        if (!window.katex || !el) return;

        const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null, false);
        const textNodes = [];
        while (walker.nextNode()) textNodes.push(walker.currentNode);

        for (const node of textNodes) {
            const text = node.nodeValue;
            if (!text) continue;

            const regex = /(\$\$[\s\S]+?\$\$|\$[^$\n]+?\$)/g;
            if (!regex.test(text)) continue;

            regex.lastIndex = 0;
            const frag = document.createDocumentFragment();
            let lastIndex = 0;
            let match;

            while ((match = regex.exec(text)) !== null) {
                if (match.index > lastIndex) {
                    frag.appendChild(document.createTextNode(text.slice(lastIndex, match.index)));
                }

                const raw = match[0];
                const isBlock = raw.startsWith('$$');
                const latex = isBlock ? raw.slice(2, -2) : raw.slice(1, -1);

                const span = document.createElement(isBlock ? 'div' : 'span');
                try {
                    katex.render(latex, span, { displayMode: isBlock, throwOnError: false });
                } catch {
                    span.textContent = raw;
                }
                frag.appendChild(span);
                lastIndex = regex.lastIndex;
            }

            if (lastIndex < text.length) {
                frag.appendChild(document.createTextNode(text.slice(lastIndex)));
            }

            node.parentNode.replaceChild(frag, node);
        }
    }

    function updateMathPreview() {
        const chk = document.getElementById('chkEnableMath');
        if (!chk || !chk.checked) return;

        const previewEl = document.getElementById('assessmentPreview');
        if (!previewEl) return;

        // Build preview HTML from current questions
        const cards = [...document.querySelectorAll('#questionHost .q-card')];
        if (cards.length === 0) {
            previewEl.innerHTML = "<div class='empty-box'><i class='fa fa-eye'></i> Nothing to preview.</div>";
            return;
        }

        let html = '';
        cards.forEach((card, i) => {
            const prompt = card.querySelector('input[name$=".Prompt"]')?.value || '';
            const explanation = card.querySelector('textarea[name$=".Explanation"]')?.value || '';
            const marks = card.querySelector('input[data-qmarks]')?.value || '1';

            const options = [...card.querySelectorAll('[data-options-host] .answer-row')];
            let optionsHtml = '';
            options.forEach((row, oi) => {
                const text = row.querySelector('input[type="text"]')?.value || '';
                const isCorrect = row.querySelector('input[type="hidden"][data-correct-hidden]')?.value === 'true';
                optionsHtml += `<div class="resource-item" style="padding:.4rem .6rem;">
                    <span>${esc(String.fromCharCode(65 + oi))}. <span class="math-render">${esc(text)}</span></span>
                    ${isCorrect ? '<span style="color:#167846;font-weight:700;font-size:.55rem;">✓ Correct</span>' : ''}
                </div>`;
            });

            html += `<div class="q-card" style="margin-bottom:.6rem;">
                <h4 style="display:flex;justify-content:space-between;">
                    <span>Q${i + 1}</span>
                    <span class="stat-pill" style="font-size:.48rem;">${esc(marks)} mark(s)</span>
                </h4>
                <div class="math-render" style="font-size:.7rem;font-weight:600;">${esc(prompt)}</div>
                ${explanation ? `<div class="math-render" style="font-size:.6rem;color:var(--lp-muted);font-style:italic;">${esc(explanation)}</div>` : ''}
                ${optionsHtml}
            </div>`;
        });

        previewEl.innerHTML = html;

        // Render LaTeX in all .math-render spans
        previewEl.querySelectorAll('.math-render').forEach(el => {
            // Unescape the text first (we escaped it with esc())
            el.textContent = el.textContent; // already text
            renderMathInElement(el);
        });
    }

    const mathChk = document.getElementById('chkEnableMath');
    if (mathChk) {
        // Debounced preview update
        let mathPreviewTimer = null;
        function scheduleMathPreview() {
            clearTimeout(mathPreviewTimer);
            mathPreviewTimer = setTimeout(updateMathPreview, 400);
        }

        mathChk.addEventListener('change', scheduleMathPreview);

        // Listen for input changes in the question host
        document.getElementById('questionHost')?.addEventListener('input', scheduleMathPreview);
    }

    (function initMathSupport() {
    const esc = (s) => (s || '').toString()
        .replace(/&/g, '&amp;').replace(/</g, '&lt;')
        .replace(/>/g, '&gt;').replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');

    function renderLatexInElement(el) {
        if (!window.katex || !el) return;
        const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null, false);
        const nodes = [];
        while (walker.nextNode()) nodes.push(walker.currentNode);

        for (const node of nodes) {
            const text = node.nodeValue;
            if (!text) continue;
            const regex = /(\$\$[\s\S]+?\$\$|\$[^$\n]+?\$)/g;
            if (!regex.test(text)) continue;
            regex.lastIndex = 0;
            const frag = document.createDocumentFragment();
            let last = 0, match;
            while ((match = regex.exec(text)) !== null) {
                if (match.index > last) frag.appendChild(document.createTextNode(text.slice(last, match.index)));
                const raw = match[0];
                const isBlock = raw.startsWith('$$');
                const latex = isBlock ? raw.slice(2, -2) : raw.slice(1, -1);
                const span = document.createElement(isBlock ? 'div' : 'span');
                span.className = 'math-preview-inline';
                try { katex.render(latex, span, { displayMode: isBlock, throwOnError: false }); }
                catch { span.textContent = raw; }
                frag.appendChild(span);
                last = regex.lastIndex;
            }
           if (last < text.length) frag.appendChild(document.createTextNode(text.slice(last)));
           node.parentNode.replaceChild(frag, node);
        }
    }

    function createMathToolbar(targetInput) {
        const wrap = document.createElement('div');
        wrap.className = 'math-editor-wrap';
        wrap.innerHTML = `
            <div class="math-toolbar">
                <button type="button" data-tpl="\\frac{▢}{▢}"><i class="fa fa-divide"></i> Fraction</button>
                <button type="button" data-tpl="\\sqrt{▢}"><i class="fa fa-square-root-variable"></i> √</button>
                <button type="button" data-tpl="x^{▢}"><i class="fa fa-superscript"></i> Power</button>
                <button type="button" data-tpl="x_{▢}"><i class="fa fa-subscript"></i> Subscript</button>
                <button type="button" data-tpl="\\sum_{i=▢}^{▢}"><i class="fa fa-sigma"></i> Sum</button>
                <button type="button" data-tpl="\\int_{▢}^{▢}"><i class="fa fa-integral"></i> Integral</button>
                <button type="button" data-tpl="\\pi">π</button>
                <button type="button" data-tpl="\\theta">θ</button>
                <button type="button" data-tpl="\\infty">∞</button>
                <button type="button" data-tpl="\\pm">±</button>
                <button type="button" data-tpl="\\leq">≤</button>
                <button type="button" data-tpl="\\geq">≥</button>
                <button type="button" data-tpl="\\neq">≠</button>
            </div>
            <math-field></math-field>
            <div style="display:flex;gap:.4rem;margin-top:.4rem;">
                <button type="button" class="btn-el primary" data-insert-math style="font-size:.48rem;padding:.4rem .6rem;">
                    <i class="fa fa-check"></i> Insert Equation
                </button>
                <button type="button" class="btn-el" data-cancel-math style="font-size:.48rem;padding:.4rem .6rem;">
                    <i class="fa fa-times"></i> Cancel
                </button>
            </div>
        `;

        const mathField = wrap.querySelector('math-field');
         wrap.querySelectorAll('[data-tpl]').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                const tpl = btn.getAttribute('data-tpl');
                if (mathField) {
                    mathField.executeCommand(['insert', tpl]);
                    mathField.focus();
                }
            });
        });

        wrap.querySelector('[data-insert-math]').addEventListener('click', (e) => {
            e.preventDefault();
            const latex = mathField.getValue('latex');
            if (!latex || !latex.trim()) return;

            const insertion = ` $${latex}$ `;
            const pos = targetInput.selectionStart ?? targetInput.value.length;
            const before = targetInput.value.substring(0, pos);
            const after = targetInput.value.substring(pos);
            targetInput.value = before + insertion + after;
            targetInput.selectionStart = targetInput.selectionEnd = pos + insertion.length;
            targetInput.dispatchEvent(new Event('input', { bubbles: true }));

            mathField.setValue('');
            wrap.classList.remove('active');
        });
        wrap.querySelector('[data-cancel-math]').addEventListener('click', (e) => {
            e.preventDefault();
            mathField.setValue('');
            wrap.classList.remove('active');
        });

        return wrap;
    }

    function wireMathEditors(card) {
        const mathEnabled = document.getElementById('chkEnableMath');
        if (!mathEnabled || !mathEnabled.checked) return;

        const targets = [
            ...card.querySelectorAll('input[name$=".Prompt"]'),
            ...card.querySelectorAll('textarea[name$=".Explanation"]'),
            ...card.querySelectorAll('[data-options-host] input[type="text"]')
        ];

        targets.forEach(input => {
            if (input.dataset.mathWired) return;
            input.dataset.mathWired = 'true';

            const toggleBtn = document.createElement('button');
            toggleBtn.type = 'button';
            toggleBtn.className = 'btn-el';
            toggleBtn.style.cssText = 'font-size:.44rem;padding:.3rem .5rem;margin-top:.25rem;';
            toggleBtn.innerHTML = '<i class="fa fa-square-root-variable"></i> Math';
            toggleBtn.title = 'Open math equation editor';

            const editorWrap = createMathToolbar(input);

            toggleBtn.addEventListener('click', (e) => {
                e.preventDefault();
                editorWrap.classList.toggle('active');
                const mf = editorWrap.querySelector('math-field');
                if (mf && editorWrap.classList.contains('active')) mf.focus();
            });
            const inputWrap = input.closest('.input-wrap') || input.closest('.answer-row') || input.parentElement;
            inputWrap.after(editorWrap);
            inputWrap.after(toggleBtn);
        });
    }

    const questionHost = document.getElementById('questionHost');
    if (questionHost) {
        const observer = new MutationObserver(() => {
            const mathEnabled = document.getElementById('chkEnableMath');
            if (!mathEnabled || !mathEnabled.checked) return;
            questionHost.querySelectorAll('.q-card').forEach(wireMathEditors);
        });
        observer.observe(questionHost, { childList: true, subtree: true });

        document.getElementById('chkEnableMath')?.addEventListener('change', function () {
            if (this.checked) {
                questionHost.querySelectorAll('.q-card').forEach(wireMathEditors);
            }
        });
    }

    window.__renderLatexInElement = renderLatexInElement;
    })();
      renderSelected();
    })();
</script>
