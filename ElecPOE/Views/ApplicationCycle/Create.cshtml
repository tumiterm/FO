@using ForekOnline.Domain.Entities
@model ApplicationCycle

@{
    ViewData["Title"] = "Create Application Cycle";
}

<style>
:root{
    --cc-bg: var(--fo-bg, #f3f4f8);
    --cc-card: var(--fo-bg-card, #ffffff);
    --cc-text: var(--fo-text, #1a1a2e);
    --cc-text2: var(--fo-text-2, #4a4f5e);
    --cc-muted: var(--fo-muted, #6b7280);
    --cc-border: var(--fo-border, #e3e5eb);
    --cc-orange: var(--fo-orange, #e65100);
    --cc-orange-lt: var(--fo-orange-light, #ff8a50);
    --cc-orange-dk: var(--fo-orange-dark, #ac1900);
    --cc-radius: 16px;
    --cc-radius-lg: 22px;
    --cc-radius-sm: 10px;
    --cc-shadow: 0 1px 3px rgba(0,0,0,.05), 0 8px 24px rgba(0,0,0,.04);
    --cc-t: .22s cubic-bezier(.4,0,.2,1);
    --cc-grad: linear-gradient(135deg, var(--cc-orange), var(--cc-orange-dk));
}

[data-theme="dark"] .cc-shell{
    --cc-bg:#0e1018;
    --cc-card:#161a24;
    --cc-text:#e2e5eb;
    --cc-text2:#9ca3b4;
    --cc-muted:#6b7186;
    --cc-border:rgba(255,255,255,.08);
    --cc-shadow: 0 1px 3px rgba(0,0,0,.2), 0 12px 30px rgba(0,0,0,.18);
}

.cc-shell{ max-width: 1100px; margin: 0 auto; padding: .25rem 0 3rem; }

/* Header */
.cc-header{ display:flex; flex-wrap:wrap; align-items:center; gap: .85rem; margin-bottom: 1.1rem; }
.cc-title{
    margin:0;
    font-size:1.4rem;
    font-weight:800;
    letter-spacing:-.3px;
    color:var(--cc-text);
    display:flex; align-items:center; gap:.65rem;
}
.cc-title-icon{
    width:48px;height:48px;border-radius:14px;background:var(--cc-grad);
    display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.1rem;
    box-shadow:0 8px 24px rgba(230,81,0,.22);
}
.cc-sub{ font-size:.6rem; letter-spacing:.14rem; text-transform:uppercase; font-weight:700; color:var(--cc-muted); margin-top:.15rem; }
.cc-actions{ margin-left:auto; display:flex; gap:.4rem; flex-wrap:wrap; }
.cc-btn{
    font-size:.62rem; letter-spacing:.1rem; font-weight:800; text-transform:uppercase;
    padding:.55rem .9rem; border-radius: var(--cc-radius-sm);
    border:1px solid var(--cc-border); background:var(--cc-card); color:var(--cc-text2);
    display:inline-flex; align-items:center; gap:.4rem; cursor:pointer; text-decoration:none;
    transition: all var(--cc-t);
}
.cc-btn:hover{ border-color:var(--cc-orange); color:var(--cc-orange); box-shadow: 0 4px 14px rgba(230,81,0,.12); transform: translateY(-1px); }
.cc-btn-grad{ background:var(--cc-grad)!important; color:#fff!important; border:none!important; box-shadow:0 4px 16px rgba(230,81,0,.22); }
.cc-btn-grad:hover{ filter:brightness(1.08); box-shadow:0 6px 24px rgba(230,81,0,.3); color:#fff!important; }

/* Layout */
.cc-grid{ display:grid; grid-template-columns: 1.15fr .85fr; gap: 1rem; }
.cc-card{
    background: var(--cc-card);
    border: 1px solid var(--cc-border);
    border-radius: var(--cc-radius-lg);
    box-shadow: var(--cc-shadow);
    padding: 1.1rem 1.2rem;
}
.cc-card-title{
    display:flex; align-items:center; justify-content:space-between;
    margin-bottom: .85rem;
}
.cc-card-title h2{
    margin:0;
    font-size:.75rem;
    letter-spacing:.2rem;
    text-transform:uppercase;
    font-weight:900;
    color: var(--cc-text);
    display:flex; align-items:center; gap:.5rem;
}
.cc-chip{
    display:inline-flex; align-items:center; gap:.35rem;
    padding:.35rem .6rem;
    border-radius: 999px;
    border: 1px solid var(--cc-border);
    background: rgba(230,81,0,.06);
    color: var(--cc-orange);
    font-size:.52rem; letter-spacing:.14rem; text-transform:uppercase; font-weight:900;
}

/* Form */
.cc-form{ display:flex; flex-direction:column; gap: .9rem; }
.cc-row{ display:grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .8rem; }

.cc-label{
    font-size: .5rem;
    letter-spacing: .18rem;
    text-transform: uppercase;
    font-weight: 900;
    color: var(--cc-muted);
    margin-bottom: .25rem;
}
.cc-input{
    background: var(--cc-bg);
    border: 1px solid var(--cc-border);
    color: var(--cc-text);
    border-radius: var(--cc-radius-sm);
    padding: .6rem .7rem;
    width: 100%;
    font-size: .8rem;
    transition: all var(--cc-t);
}
.cc-input:focus{
    outline:none;
    border-color: var(--cc-orange);
    box-shadow: 0 0 0 3px rgba(230,81,0,.1);
}

.cc-help{ font-size:.68rem; color: var(--cc-muted); margin-top:.25rem; line-height:1.05rem; }

.cc-toggle{
    display:flex; gap:.4rem; flex-wrap:wrap;
}
.cc-pill{
    flex: 1 1 140px;
    display:flex; align-items:flex-start; gap:.6rem;
    padding:.75rem .8rem;
    border-radius: 16px;
    border:1px solid var(--cc-border);
    background: var(--cc-bg);
    cursor:pointer;
    transition: all var(--cc-t);
    user-select:none;
}
.cc-pill:hover{ transform: translateY(-2px); box-shadow: 0 12px 28px rgba(0,0,0,.06); }
.cc-pill.selected{ border-color: rgba(230,81,0,.55); box-shadow: 0 18px 38px rgba(230,81,0,.10); }
.cc-pill .ic{
    width: 38px; height: 38px; border-radius: 12px;
    display:flex; align-items:center; justify-content:center;
    background: rgba(230,81,0,.10); color: var(--cc-orange);
    font-size:.95rem;
}
.cc-pill strong{ display:block; font-size:.8rem; font-weight:900; color: var(--cc-text); }
.cc-pill span{ display:block; font-size:.68rem; font-weight:600; color: var(--cc-muted); margin-top:.15rem; }
.cc-pill .check{
    margin-left:auto;
    width: 22px; height: 22px; border-radius: 999px;
    border:1px solid var(--cc-border);
    display:flex; align-items:center; justify-content:center;
    color: transparent; background: var(--cc-card);
}
.cc-pill.selected .check{ background: var(--cc-orange); border-color: var(--cc-orange); color:#fff; }

.cc-actions2{ display:flex; gap:.5rem; flex-wrap:wrap; margin-top:.2rem; }
.cc-actions2 .cc-btn{ justify-content:center; }

/* Preview */
.cc-kv{
    border: 1px dashed var(--cc-border);
    border-radius: 16px;
    padding: .8rem .85rem;
    background: linear-gradient(135deg, rgba(230,81,0,.03), rgba(255,255,255,.0));
}
[data-theme="dark"] .cc-kv{ background: linear-gradient(135deg, rgba(230,81,0,.06), rgba(22,26,36,0)); }
.cc-k{ font-size:.5rem; letter-spacing:.18rem; text-transform:uppercase; font-weight:900; color: var(--cc-muted); }
.cc-v{ margin-top:.35rem; font-weight:900; color: var(--cc-text); font-size:.9rem; }
.cc-s{ margin-top:.25rem; font-size:.7rem; color: var(--cc-muted); line-height:1.05rem; }

@@media (max-width: 991.98px){
    .cc-grid{ grid-template-columns: 1fr; }
}
@@media (max-width: 575.98px){
    .cc-row{ grid-template-columns: 1fr; }
    .cc-header{ flex-direction: column; align-items:flex-start; }
    .cc-actions{ width:100%; margin-left:0; }
    .cc-actions .cc-btn{ flex:1; }
}
</style>

<div class="cc-shell">
    <div class="cc-header">
        <div>
            <h1 class="cc-title">
                <span class="cc-title-icon"><i class="fa fa-plus"></i></span>
                Create Application Cycle
            </h1>
            <div class="cc-sub">Define the window. The service enforces overlap and active uniqueness.</div>
        </div>
        <div class="cc-actions">
            <a class="cc-btn" asp-action="Index"><i class="fa fa-arrow-left"></i> Back</a>
            <button form="ccForm" type="submit" class="cc-btn cc-btn-grad"><i class="fa fa-save"></i> Save</button>
        </div>
    </div>

    <div class="cc-grid">
        <div class="cc-card">
            <div class="cc-card-title">
                <h2><i class="fa fa-sliders"></i> Cycle Setup</h2>
                <span class="cc-chip"><i class="fa fa-shield-halved"></i> Validated</span>
            </div>

            <form id="ccForm" class="cc-form" asp-action="Create" method="post" autocomplete="off">
                @Html.AntiForgeryToken()

                <div class="cc-row">
                    <div>
                        <div class="cc-label">Name</div>
                        <input asp-for="Name" class="cc-input" placeholder="Optional e.g. 2026 Intake" />
                        <div class="cc-help">If blank, a default name is generated from year + period.</div>
                    </div>
                    <div>
                        <div class="cc-label">Code</div>
                        <input asp-for="Code" class="cc-input" placeholder="Optional e.g. 2026-INTAKE" />
                        <div class="cc-help">If blank, code is auto-generated by the service.</div>
                    </div>
                </div>

                <div class="cc-row">
                    <div>
                        <div class="cc-label">Academic Year</div>
                        <input asp-for="AcademicYear" class="cc-input" type="number" min="2000" max="2100" required />
                    </div>
                    <div>
                        <div class="cc-label">Turnaround Days (TAT)</div>
                        <input asp-for="TurnaroundDays" class="cc-input" type="number" min="0" max="365" />
                    </div>
                </div>

                <div>
                    <div class="cc-label">Application Period</div>
                    <div class="cc-toggle" id="periodGrid">
                        <div class="cc-pill" data-target="ApplicationPeriod" data-value="Intake" tabindex="0" role="button">
                            <div class="ic"><i class="fa fa-layer-group"></i></div>
                            <div><strong>Intake</strong><span>Short intake window</span></div>
                            <div class="check"><i class="fa fa-check"></i></div>
                        </div>
                        <div class="cc-pill" data-target="ApplicationPeriod" data-value="Semester" tabindex="0" role="button">
                            <div class="ic"><i class="fa fa-calendar-alt"></i></div>
                            <div><strong>Semester</strong><span>Half-year period</span></div>
                            <div class="check"><i class="fa fa-check"></i></div>
                        </div>
                        <div class="cc-pill" data-target="ApplicationPeriod" data-value="Trimester" tabindex="0" role="button">
                            <div class="ic"><i class="fa fa-calendar-week"></i></div>
                            <div><strong>Trimester</strong><span>Three terms / year</span></div>
                            <div class="check"><i class="fa fa-check"></i></div>
                        </div>
                    </div>
                    <input asp-for="ApplicationPeriod" type="hidden" />
                </div>

                <div class="cc-row">
                    <div>
                        <div class="cc-label">Opens At</div>
                        <input asp-for="OpensAt" class="cc-input" type="datetime-local" required />
                    </div>
                    <div>
                        <div class="cc-label">Closes</div>
                        <input asp-for="Closes" class="cc-input" type="datetime-local" required />
                    </div>
                </div>

                <div>
                    <div class="cc-label">Is Active</div>
                    <div class="cc-toggle" id="activeGrid">
                        <div class="cc-pill" data-target="IsActive" data-value="true" tabindex="0" role="button">
                            <div class="ic"><i class="fa fa-bolt"></i></div>
                            <div><strong>Active</strong><span>Accept applications</span></div>
                            <div class="check"><i class="fa fa-check"></i></div>
                        </div>
                        <div class="cc-pill" data-target="IsActive" data-value="false" tabindex="0" role="button">
                            <div class="ic"><i class="fa fa-circle-pause"></i></div>
                            <div><strong>Inactive</strong><span>Draft / planned</span></div>
                            <div class="check"><i class="fa fa-check"></i></div>
                        </div>
                    </div>
                    <input asp-for="IsActive" type="hidden" />
                </div>

                <div>
                    <div class="cc-label">Description</div>
                    <textarea asp-for="Description" class="cc-input" rows="3" placeholder="Optional notes for admins…"></textarea>
                </div>

                <div class="cc-actions2">
                    <button type="submit" class="cc-btn cc-btn-grad"><i class="fa fa-save"></i> Save Cycle</button>
                    <a class="cc-btn" asp-action="Index"><i class="fa fa-xmark"></i> Cancel</a>
                </div>
            </form>
        </div>

        <aside class="cc-card">
            <div class="cc-card-title">
                <h2><i class="fa fa-eye"></i> Live Preview</h2>
                <span class="cc-chip"><i class="fa fa-wand-magic-sparkles"></i> Smart</span>
            </div>

            <div class="cc-kv">
                <div class="cc-k">Cycle</div>
                <div class="cc-v" id="pvName">—</div>
                <div class="cc-s">Auto-generated if left blank.</div>
            </div>
            <div class="cc-kv" style="margin-top:.75rem;">
                <div class="cc-k">Window</div>
                <div class="cc-v" id="pvWindow">—</div>
                <div class="cc-s">OpensAt must be before Closes.</div>
            </div>
            <div class="cc-kv" style="margin-top:.75rem;">
                <div class="cc-k">Policy</div>
                <div class="cc-v" id="pvPolicy">—</div>
                <div class="cc-s">Only one active cycle allowed per year + period.</div>
            </div>
        </aside>
    </div>
</div>

<script>
(function(){
    'use strict';

    var form = document.getElementById('ccForm');
    if(!form) return;

    var nameEl = form.querySelector('[name="Name"]');
    var yearEl = form.querySelector('[name="AcademicYear"]');
    var periodEl = form.querySelector('input[name="ApplicationPeriod"]');
    var opensEl = form.querySelector('[name="OpensAt"]');
    var closesEl = form.querySelector('[name="Closes"]');
    var activeEl = form.querySelector('input[name="IsActive"]');

    var pvName = document.getElementById('pvName');
    var pvWindow = document.getElementById('pvWindow');
    var pvPolicy = document.getElementById('pvPolicy');

    function fmt(dt){
        if(!dt) return '—';
        var d = new Date(dt);
        if(Number.isNaN(d.getTime())) return '—';
        return d.toLocaleString(undefined, { year:'numeric', month:'short', day:'2-digit', hour:'2-digit', minute:'2-digit' });
    }

    function updatePreview(){
        var yr = (yearEl && yearEl.value) ? yearEl.value.trim() : '';
        var per = (periodEl && periodEl.value) ? periodEl.value.trim() : '';
        var nm = (nameEl && nameEl.value) ? nameEl.value.trim() : '';
        pvName.textContent = nm || ((yr && per) ? (yr + ' ' + per) : '—');

        pvWindow.textContent = fmt(opensEl && opensEl.value) + ' → ' + fmt(closesEl && closesEl.value);

        var act = (activeEl && activeEl.value || '').toLowerCase();
        pvPolicy.textContent = (act === 'true' ? 'Active cycle (strict uniqueness enforced)' : 'Inactive (safe draft mode)');
    }

    function setSelected(target, value){
        var hidden = form.querySelector('input[name="' + target + '"]');
        if(hidden) hidden.value = value;

        document.querySelectorAll('.cc-pill[data-target="' + target + '"]').forEach(function(p){
            p.classList.toggle('selected', p.getAttribute('data-value') === value);
        });

        updatePreview();
    }

    function wirePills(containerId){
        var wrap = document.getElementById(containerId);
        if(!wrap) return;

        wrap.querySelectorAll('.cc-pill').forEach(function(p){
            function choose(){
                var t = p.getAttribute('data-target');
                var v = p.getAttribute('data-value');
                if(!t || v == null) return;
                setSelected(t, v);
            }
            p.addEventListener('click', choose);
            p.addEventListener('keydown', function(e){
                if(e.key === 'Enter' || e.key === ' '){ e.preventDefault(); choose(); }
            });
        });
    }

    wirePills('periodGrid');
    wirePills('activeGrid');

    if(periodEl && periodEl.value) setSelected('ApplicationPeriod', periodEl.value);
    if(activeEl && activeEl.value) setSelected('IsActive', activeEl.value.toLowerCase());
    if(activeEl && !activeEl.value) setSelected('IsActive', 'false');

    [nameEl, yearEl, opensEl, closesEl].forEach(function(el){
        if(!el) return;
        el.addEventListener('input', updatePreview);
        el.addEventListener('change', updatePreview);
    });

    updatePreview();
})();
</script>