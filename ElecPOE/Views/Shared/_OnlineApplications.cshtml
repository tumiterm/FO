@{
    Layout = null;
    var title = ViewData["Title"] as string ?? "Forek Online Applications";
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@500;600;700;800&display=swap" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

    <style>
        :root {
            --forek-orange: #ff6a00;
            --forek-red: #d7263d;
            --forek-ink: #0f172a;
            --forek-muted: #475569;
            --forek-border: rgba(15, 23, 42, 0.10);
            --forek-glass: rgba(255, 255, 255, 0.78);
            --forek-glass-strong: rgba(255, 255, 255, 0.90);
            --sidebar-width: 292px;
        }

        html, body {
            height: 100%;
        }

        .progress-card {
            position: relative;
            border-radius: 18px;
            border: 1px solid rgba(15, 23, 42, 0.10);
            background: linear-gradient(180deg, rgba(255,255,255,0.86), rgba(255,255,255,0.70));
            box-shadow: 0 18px 50px rgba(15, 23, 42, 0.10);
            overflow: hidden;
        }

            .progress-card::before {
                content: "";
                position: absolute;
                inset: 0 0 auto 0;
                height: 6px;
                background: linear-gradient(90deg, var(--forek-orange), var(--forek-red));
            }

        .step-dots {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: .5rem;
            margin-top: .35rem;
        }

        .step-dot {
            width: 11px;
            height: 11px;
            border-radius: 999px;
            border: 1px solid rgba(15, 23, 42, 0.16);
            background: rgba(15, 23, 42, 0.10);
        }

        .step-dot {
            width: 11px;
            height: 11px;
            border-radius: 999px;
            border: 1px solid rgba(15, 23, 42, 0.16);
            background: rgba(15, 23, 42, 0.10);
        }

            .step-dot.done,
            .step-dot.current {
                background: linear-gradient(135deg, var(--forek-orange), var(--forek-red));
                border-color: rgba(255, 106, 0, 0.30);
            }

        .progress-labels {
            font-size: .85rem;
            color: #64748b;
        }

            .progress-labels span {
                white-space: nowrap;
            }

        body {
            font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
            color: var(--forek-ink);
            background:
                radial-gradient(1200px 700px at 15% 10%, rgba(255, 106, 0, 0.18), transparent 55%),
                radial-gradient(900px 600px at 85% 0%, rgba(215, 38, 61, 0.16), transparent 55%),
                linear-gradient(180deg, #fff 0%, #fff7f3 35%, #fff 100%);
            position: relative;
            overflow-x: hidden;
        }

        .apps-bg {
            position: fixed;
            inset: 0;
            background-image: url('/Images/appsbg.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            opacity: 0.22;
            z-index: -2;
        }

        .apps-bg-overlay {
            position: fixed;
            inset: 0;
            background:
                radial-gradient(1200px 700px at 20% 15%, rgba(255, 106, 0, 0.22), transparent 55%),
                radial-gradient(1000px 650px at 80% 10%, rgba(215, 38, 61, 0.20), transparent 55%),
                rgba(255, 255, 255, 0.35);
            z-index: -1;
        }

        /* Top bar */
        .topbar {
            background: rgba(255, 255, 255, 0.70);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--forek-border);
        }

        .brand-chip {
            display: inline-flex;
            align-items: center;
            gap: .6rem;
            padding: .45rem .7rem;
            border-radius: 14px;
            border: 1px solid var(--forek-border);
            background: rgba(255, 255, 255, 0.80);
            box-shadow: 0 12px 34px rgba(15, 23, 42, 0.10);
        }

        .brand-mark {
            width: 38px;
            height: 38px;
            border-radius: 14px;
            background: linear-gradient(135deg, var(--forek-orange), var(--forek-red));
            box-shadow: 0 14px 30px rgba(255, 106, 0, 0.22);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #fff;
        }

        .badge-soft {
            border: 1px solid var(--forek-border);
            background: rgba(255, 255, 255, 0.70);
            color: var(--forek-ink);
        }

        .btn-forek {
            border: 0;
            color: #fff;
            background: linear-gradient(135deg, var(--forek-orange), var(--forek-red));
            box-shadow: 0 14px 30px rgba(255, 106, 0, 0.25);
        }

        .btn-outline-forek {
            border: 1px solid rgba(215, 38, 61, 0.35);
            color: var(--forek-ink);
            background: rgba(255, 255, 255, 0.70);
        }

        .btn-outline-forek:hover {
            border-color: rgba(255, 106, 0, 0.55);
            background: rgba(255, 255, 255, 0.90);
        }

        /* Layout grid */
        .app-shell {
            display: flex;
            min-height: 100vh;
        }

        /* Desktop sidebar */
        .sidebar {
            width: var(--sidebar-width);
            display: none;
            padding: 1rem;
        }

        @@media (min-width: 992px) {
            .sidebar {
                display: block;
                position: sticky;
                top: 0;
                height: 100vh;
            }
        }

        .sidebar-card {
            height: calc(100vh - 2rem);
            background: var(--forek-glass);
            backdrop-filter: blur(12px);
            border: 1px solid var(--forek-border);
            border-radius: 22px;
            box-shadow: 0 20px 60px rgba(15, 23, 42, 0.10);
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .sidebar-header {
            padding: 1rem 1rem .75rem 1rem;
            border-bottom: 1px solid var(--forek-border);
            background: rgba(255, 255, 255, 0.60);
        }

        .sidebar-body {
            padding: .75rem;
            overflow: auto;
        }

        .sidebar-footer {
            padding: .85rem 1rem;
            border-top: 1px solid var(--forek-border);
            background: rgba(255, 255, 255, 0.60);
        }

        .menu-title {
            font-size: .85rem;
            color: #64748b;
            letter-spacing: .02em;
            text-transform: uppercase;
        }

        .nav-pill {
            border: 1px solid var(--forek-border);
            background: rgba(255, 255, 255, 0.72);
            border-radius: 14px;
            padding: .7rem .75rem;
            display: flex;
            align-items: center;
            gap: .65rem;
            text-decoration: none;
            color: var(--forek-ink);
            transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
        }

        .nav-pill:hover {
            transform: translateY(-1px);
            box-shadow: 0 16px 40px rgba(15, 23, 42, 0.10);
            border-color: rgba(255, 106, 0, 0.30);
            color: var(--forek-ink);
        }

        .nav-icon {
            width: 38px;
            height: 38px;
            border-radius: 14px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, rgba(255, 106, 0, 0.18), rgba(215, 38, 61, 0.18));
            border: 1px solid rgba(255, 106, 0, 0.23);
        }

        .accordion-button {
            background: rgba(255, 255, 255, 0.72);
            border-radius: 14px !important;
            border: 1px solid var(--forek-border);
            color: var(--forek-ink);
            box-shadow: none !important;
        }

        .accordion-button:not(.collapsed) {
            border-color: rgba(255, 106, 0, 0.28);
            background: rgba(255, 255, 255, 0.85);
        }

        .accordion-item {
            background: transparent;
            border: 0;
        }

        .accordion-body {
            padding: .6rem .2rem .2rem .2rem;
        }

        .main {
            flex: 1;
            min-width: 0;
        }

        .main-inner {
            padding: 1rem;
        }

        .journey-card {
            background: rgba(255, 255, 255, 0.75);
            border: 1px solid var(--forek-border);
            border-radius: 18px;
        }

        .journey-step {
            position: relative;
            padding-left: 44px;
        }

            .journey-step::before {
                content: "";
                position: absolute;
                left: 16px;
                top: 6px;
                width: 12px;
                height: 12px;
                border-radius: 999px;
                background: rgba(15, 23, 42, 0.18);
                border: 1px solid rgba(15, 23, 42, 0.10);
            }

            .journey-step::after {
                content: "";
                position: absolute;
                left: 21px;
                top: 22px;
                bottom: -14px;
                width: 2px;
                background: rgba(15, 23, 42, 0.10);
            }

            .journey-step:last-child::after {
                display: none;
            }

            .journey-step.is-current::before,
            .journey-step.is-done::before {
                background: linear-gradient(135deg, var(--forek-orange), var(--forek-red));
                border-color: rgba(255, 106, 0, 0.30);
            }

            .journey-step.is-done .journey-title::after {
                content: "✓";
                margin-left: .5rem;
                font-weight: 800;
                color: var(--forek-ink);
                background: rgba(255, 106, 0, 0.12);
                border: 1px solid rgba(255, 106, 0, 0.20);
                border-radius: 999px;
                padding: .05rem .45rem;
                font-size: .75rem;
                vertical-align: middle;
            }

        .tat-badge {
            background: rgba(255, 106, 0, 0.12);
            border: 1px solid rgba(255, 106, 0, 0.25);
            color: var(--forek-ink);
        }

        @@media (min-width: 992px) {
            .main-inner {
                padding: 1.25rem 1.25rem 1.25rem 0;
            }
        }

        .content-card {
            background: var(--forek-glass-strong);
            backdrop-filter: blur(12px);
            border: 1px solid var(--forek-border);
            border-radius: 22px;
            box-shadow: 0 20px 60px rgba(15, 23, 42, 0.10);
            overflow: hidden;
        }

        .content-header {
            padding: 1rem 1.25rem;
            border-bottom: 1px solid var(--forek-border);
            background: rgba(255, 255, 255, 0.70);
        }

        .content-body {
            padding: 1.25rem;
        }

        /* Mobile offcanvas styling (uses same class names) */
        .offcanvas {
            background: var(--forek-glass);
            backdrop-filter: blur(12px);
        }

        .offcanvas-header {
            border-bottom: 1px solid var(--forek-border);
        }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>
    <div class="apps-bg" aria-hidden="true"></div>
    <div class="apps-bg-overlay" aria-hidden="true"></div>

    <header class="topbar py-3">
        <div class="container-fluid px-3 px-lg-4">
            <div class="d-flex align-items-center justify-content-between gap-2">
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-outline-forek d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#appSidebar" aria-controls="appSidebar">
                        <i class="fa-solid fa-bars" aria-hidden="true"></i>
                        <span class="ms-2 d-none d-sm-inline">Menu</span>
                    </button>

                    <div class="brand-chip">
                        <span class="brand-mark" aria-hidden="true">
                            <i class="fa-solid fa-bolt"></i>
                        </span>
                        <div class="lh-sm">
                            <div class="fw-semibold">Forek Online</div>
                            <div class="small text-muted">Applications & Registrations</div>
                        </div>
                    </div>
                </div>

                <div class="d-flex align-items-center gap-2">
                    <span class="badge badge-soft rounded-pill px-3 py-2 d-none d-md-inline-flex">
                        <i class="fa-solid fa-shield-halved me-2" aria-hidden="true"></i>
                        Secure Portal
                    </span>

                    <a class="btn btn-forek" href="#">
                        <i class="fa-solid fa-right-to-bracket me-2" aria-hidden="true"></i>
                        Sign in
                    </a>
                </div>
            </div>
        </div>
    </header>

    <div class="app-shell">
        <aside class="sidebar">
            <div class="sidebar-card">
                <div class="sidebar-header">
                    <div class="menu-title mb-2">Navigation</div>
                    <div class="small text-muted">Everything for applications & registrations.</div>
                </div>

                <div class="sidebar-body">
                    <div class="accordion" id="sidebarAccordion">
                        <div class="accordion-item mb-2">
                            <h2 class="accordion-header">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#appsGroup" aria-expanded="true" aria-controls="appsGroup">
                                    <i class="fa-solid fa-file-signature me-2" aria-hidden="true"></i>
                                    Applications
                                </button>
                            </h2>
                            <div id="appsGroup" class="accordion-collapse collapse show" data-bs-parent="#sidebarAccordion">
                                <div class="accordion-body">
                                    <div class="d-grid gap-2">
                                        <a class="nav-pill" href="#">
                                            <span class="nav-icon" aria-hidden="true"><i class="fa-solid fa-user-pen"></i></span>
                                            <div>
                                                <div class="fw-semibold">Profile</div>
                                                <div class="small text-muted">Personal details.</div>
                                            </div>
                                        </a>

                                        <a class="nav-pill" href="#">
                                            <span class="nav-icon" aria-hidden="true"><i class="fa-solid fa-clipboard-list"></i></span>
                                            <div>
                                                <div class="fw-semibold">Apply</div>
                                                <div class="small text-muted">Application.</div>
                                            </div>
                                        </a>

                                        <a class="nav-pill" href="#">
                                            <span class="nav-icon" aria-hidden="true"><i class="fa-solid fa-cloud-arrow-up"></i></span>
                                            <div>
                                                <div class="fw-semibold">Documents</div>
                                                <div class="small text-muted">Upload documents.</div>
                                            </div>
                                        </a>

                                        <a class="nav-pill" href="#">
                                            <span class="nav-icon" aria-hidden="true"><i class="fa-solid fa-bars-progress"></i></span>
                                            <div>
                                                <div class="fw-semibold">Track Status</div>
                                                <div class="small text-muted">See progress.</div>
                                            </div>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item mb-2">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#admissionsGroup" aria-expanded="false" aria-controls="admissionsGroup">
                                    <i class="fa-solid fa-user-check me-2" aria-hidden="true"></i>
                                    Admissions
                                </button>
                            </h2>
                            <div id="admissionsGroup" class="accordion-collapse collapse" data-bs-parent="#sidebarAccordion">
                                <div class="accordion-body">
                                    <div class="d-grid gap-2">
                                        <a class="nav-pill" href="#">
                                            <span class="nav-icon" aria-hidden="true"><i class="fa-solid fa-magnifying-glass"></i></span>
                                            <div>
                                                <div class="fw-semibold">Review</div>
                                                <div class="small text-muted">Qualification checks.</div>
                                            </div>
                                        </a>

                                        <a class="nav-pill" href="#">
                                            <span class="nav-icon" aria-hidden="true"><i class="fa-solid fa-envelope-open-text"></i></span>
                                            <div>
                                                <div class="fw-semibold">Aptitude Invitations</div>
                                                <div class="small text-muted">Invite to assessment.</div>
                                            </div>
                                        </a>

                                        <a class="nav-pill" href="#">
                                            <span class="nav-icon" aria-hidden="true"><i class="fa-solid fa-pen-ruler"></i></span>
                                            <div>
                                                <div class="fw-semibold">Aptitude Script</div>
                                                <div class="small text-muted">Manage the test script.</div>
                                            </div>
                                        </a>

                                        <a class="nav-pill" href="#">
                                            <span class="nav-icon" aria-hidden="true"><i class="fa-solid fa-square-poll-vertical"></i></span>
                                            <div>
                                                <div class="fw-semibold">Aptitude Results</div>
                                                <div class="small text-muted">Record & view outcomes.</div>
                                            </div>
                                        </a>

                                        <a class="nav-pill" href="#">
                                            <span class="nav-icon" aria-hidden="true"><i class="fa-solid fa-circle-check"></i></span>
                                            <div>
                                                <div class="fw-semibold">Decision</div>
                                                <div class="small text-muted">Approve / decline.</div>
                                            </div>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item mb-2">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#financeGroup" aria-expanded="false" aria-controls="financeGroup">
                                    <i class="fa-solid fa-wallet me-2" aria-hidden="true"></i>
                                    Finance
                                </button>
                            </h2>
                            <div id="financeGroup" class="accordion-collapse collapse" data-bs-parent="#sidebarAccordion">
                                <div class="accordion-body">
                                    <div class="d-grid gap-2">
                                        <a class="nav-pill" href="#">
                                            <span class="nav-icon" aria-hidden="true"><i class="fa-solid fa-shield"></i></span>
                                            <div>
                                                <div class="fw-semibold">Clearance</div>
                                                <div class="small text-muted">Verify & clear for registration.</div>
                                            </div>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item mb-2">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#registrationsGroup" aria-expanded="false" aria-controls="registrationsGroup">
                                    <i class="fa-solid fa-id-card-clip me-2" aria-hidden="true"></i>
                                    Registrations
                                </button>
                            </h2>
                            <div id="registrationsGroup" class="accordion-collapse collapse" data-bs-parent="#sidebarAccordion">
                                <div class="accordion-body">
                                    <div class="d-grid gap-2">
                                        <a class="nav-pill" href="#">
                                            <span class="nav-icon" aria-hidden="true"><i class="fa-solid fa-pen-to-square"></i></span>
                                            <div>
                                                <div class="fw-semibold">Registration</div>
                                                <div class="small text-muted">Finalize registration.</div>
                                            </div>
                                        </a>

                                        <a class="nav-pill" href="#">
                                            <span class="nav-icon" aria-hidden="true"><i class="fa-solid fa-file-contract"></i></span>
                                            <div>
                                                <div class="fw-semibold">Registration Docs</div>
                                                <div class="small text-muted">Sign documents.</div>
                                            </div>
                                        </a>

                                        <a class="nav-pill" href="#">
                                            <span class="nav-icon" aria-hidden="true"><i class="fa-solid fa-scale-balanced"></i></span>
                                            <div>
                                                <div class="fw-semibold">Code of Conduct</div>
                                                <div class="small text-muted">Accept & sign.</div>
                                            </div>
                                        </a>

                                        <a class="nav-pill" href="#">
                                            <span class="nav-icon" aria-hidden="true"><i class="fa-solid fa-people-group"></i></span>
                                            <div>
                                                <div class="fw-semibold">Induction</div>
                                                <div class="small text-muted">Become fully enrolled.</div>
                                            </div>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#supportGroup" aria-expanded="false" aria-controls="supportGroup">
                                    <i class="fa-solid fa-circle-question me-2" aria-hidden="true"></i>
                                    Support
                                </button>
                            </h2>
                            <div id="supportGroup" class="accordion-collapse collapse" data-bs-parent="#sidebarAccordion">
                                <div class="accordion-body">
                                    <div class="d-grid gap-2">
                                        <a class="nav-pill" href="#">
                                            <span class="nav-icon" aria-hidden="true"><i class="fa-solid fa-headset"></i></span>
                                            <div>
                                                <div class="fw-semibold">Help Desk</div>
                                                <div class="small text-muted">Get assistance.</div>
                                            </div>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="sidebar-footer small text-muted">
                    <div class="d-flex align-items-center justify-content-between">
                        <span><i class="fa-regular fa-clock me-2" aria-hidden="true"></i>Fast • Secure</span>
                        <span class="badge badge-soft rounded-pill px-3 py-2">
                            v1
                        </span>
                    </div>
                </div>
            </div>
        </aside>

        <main class="main">
            <div class="main-inner">
                <div class="content-card">
                    <div class="content-header d-flex flex-wrap align-items-center justify-content-between gap-2">
                        <div>
                            <div class="fw-bold">@title</div>
                            <div class="small text-muted">Use the menu to navigate application and registration tasks.</div>
                        </div>

                        <div class="d-flex align-items-center gap-2">
                            <a class="btn btn-outline-forek" href="#">
                                <i class="fa-solid fa-house me-2" aria-hidden="true"></i>
                                Home
                            </a>
                        </div>
                    </div>

                    <div class="content-body">
                        @RenderBody()
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div class="offcanvas offcanvas-start" tabindex="-1" id="appSidebar" aria-labelledby="appSidebarLabel">
        <div class="offcanvas-header">
            <div class="d-flex align-items-center gap-2" id="appSidebarLabel">
                <span class="brand-mark" aria-hidden="true">
                    <i class="fa-solid fa-bolt"></i>
                </span>
                <div class="lh-sm">
                    <div class="fw-semibold">Forek Online</div>
                    <div class="small text-muted">Menu</div>
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            <div class="d-grid gap-2">
                <div class="menu-title mt-1">Applications</div>
                <a class="nav-pill" href="#"><span class="nav-icon" aria-hidden="true"><i class="fa-solid fa-plus"></i></span><div><div class="fw-semibold">New Application</div><div class="small text-muted">Start a new one.</div></div></a>
                <a class="nav-pill" href="#"><span class="nav-icon" aria-hidden="true"><i class="fa-solid fa-list-check"></i></span><div><div class="fw-semibold">My Applications</div><div class="small text-muted">Track progress.</div></div></a>
                <a class="nav-pill" href="#"><span class="nav-icon" aria-hidden="true"><i class="fa-solid fa-upload"></i></span><div><div class="fw-semibold">Upload Documents</div><div class="small text-muted">Submit files.</div></div></a>

                <div class="menu-title mt-3">Registrations</div>
