        --fo-orange: @Model.PrimaryColor;
        --fo-orange-light: @Model.PrimaryColorLight;
        --fo-orange-dark: @Model.PrimaryColorDark;
        --fo-amber: @Model.AccentColor;
        --fo-bg: @Model.BackgroundColor;
        --fo-text: @Model.TextColor;
        --fo-muted: #6b7280;
        --fo-border: #e5e7eb;
        --fo-card-shadow: 0 1px 3px rgba(0,0,0,.08), 0 4px 12px rgba(0,0,0,.04);
        --fo-card-shadow-hover: 0 4px 16px rgba(0,0,0,.10), 0 8px 24px rgba(0,0,0,.06);
        --fo-radius: 10px;
        --fo-transition: .2s ease;
    }
