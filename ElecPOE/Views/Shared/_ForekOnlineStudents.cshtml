@model ForekOnline.Domain.ViewModels.ForekOnlineStudentsSectionViewModel
<div class="fos-summary-meta" data-fos-count="@Model.Count" data-fos-total="@Model.Count">
    @if (!Model.Students.Any())
    {
        <div class="fos-empty">No Forek Online students matched.</div>
    }
    else
    {
        <div class="fos-grid">
            @foreach (var s in Model.Students)
            {
                var identity = !string.IsNullOrWhiteSpace(s.IDNumber) ? s.IDNumber : s.PassportNumber;
                <div class="fos-card" data-student-identity="@identity">
                    <div class="fos-summary">
                        <div class="fos-line">
                            <span class="fos-name"><i class="fa fa-user"></i> @s.FirstName @s.LastName</span>
                            <span class="fos-badge @(s.IsActive ? "is-active" : "is-inactive")">@((s.IsActive ? "ACTIVE" : "INACTIVE"))</span>
                        </div>
                        <div class="fos-meta">
                            <span><i class="fa fa-id-card"></i> @identity</span>
                            @if (!string.IsNullOrWhiteSpace(s.Email))
                            {
                                <span><i class="fa fa-envelope"></i> @s.Email</span>
                            }
                            <span><i class="fa fa-layer-group"></i> @(s.EnrollmentHistory?.Count ?? 0) enrollment(s)</span>
                        </div>
                        <button type="button"
                                class="fos-toggle"
                                data-load-state="idle"
                                aria-expanded="false"
                                aria-controls="enroll-@identity">
                            Details <i class="fa fa-chevron-down"></i>
                        </button>
                    </div>
                    <div class="fos-details" id="enroll-@identity" hidden>
                        <div class="fos-details-placeholder" data-placeholder>
                            <span class="fos-inline-loader"></span> Loading enrollment history...
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
<style>
    .fos-grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit,minmax(300px,1fr));
    }

    .fos-card {
        background: #fff;
        border: 1px solid #e4e6ea;
        border-radius: 22px;
        padding: .85rem .95rem .9rem;
        display: flex;
        flex-direction: column;
        gap: .55rem;
        position: relative;
    }

        .fos-card:hover {
            border-color: #d4d6da;
            box-shadow: 0 4px 10px -6px rgba(50,6,6,.12);
        }

    .fos-summary {
        display: flex;
        flex-direction: column;
        gap: .55rem;
    }

    .fos-name {
        font-weight: 600;
    }

    .fos-meta {
        display: flex;
        flex-direction: column;
        gap: .25rem;
        font-size: .6rem;
        letter-spacing: .05rem;
        color: #555;
    }

        .fos-meta span i {
            margin-right: .35rem;
            color: #b31217;
        }

    .fos-badge {
        background: #fff5f3;
        color: #b31217;
        font-size: .55rem;
        font-weight: 700;
        padding: .28rem .6rem;
        border-radius: 30px;
    }

        .fos-badge.is-inactive {
            background: #f2f2f2;
            color: #777;
        }

    .fos-toggle {
        align-self: flex-start;
        background: linear-gradient(95deg,#320606,#b31217 55%,#ff7a18);
        color: #fff;
        border: none;
        padding: .45rem .75rem;
        font-size: .55rem;
        letter-spacing: .12rem;
        border-radius: 18px;
        cursor: pointer;
        display: inline-flex;
        gap: .45rem;
        align-items: center;
    }

        .fos-toggle[disabled] {
            opacity: .55;
            cursor: wait;
        }

    .fos-details {
        margin-top: .45rem;
        padding: .55rem .4rem .4rem;
        border-top: 1px dashed #ddd;
    }

    .fos-details-placeholder {
        font-size: .55rem;
        color: #555;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .fos-inline-loader {
        width: 14px;
        height: 14px;
        border: 3px solid #b31217;
        border-top-color: transparent;
        border-radius: 50%;
        animation: rot .8s linear infinite;
    }
    @@keyframes rot {
        to

    {
        transform: rotate(360deg)
    }

    }

    .fos-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .58rem;
        letter-spacing: .04rem;
        margin-top: .3rem;
    }

        .fos-table th {
            background: #32060611;
            text-align: left;
            padding: .35rem .45rem;
            font-weight: 600;
        }

        .fos-table td {
            padding: .35rem .45rem;
            border-top: 1px solid #eee;
        }

    .fos-status {
        font-weight: 600;
        font-size: .55rem;
        padding: .2rem .45rem;
        border-radius: 14px;
        background: #fff5f3;
        color: #b31217;
    }

    .fos-empty {
        font-size: .65rem;
        color: #555;
        padding: .6rem .2rem;
    }
</style>