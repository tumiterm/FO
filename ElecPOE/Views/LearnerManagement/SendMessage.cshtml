@model ElecPOE.ViewModels.SendLearnerMessageViewModel
@{ ViewData["Title"] = "Send Notification"; }
<div class="d-flex justify-content-between align-items-center mb-4"><div><h1 class="h3 mb-1">Send Learner Notification</h1><p class="text-muted mb-0">Use in-app messaging now; WhatsApp items are recorded in the integration outbox.</p></div><a asp-action="Groups" class="btn btn-outline-secondary">My Groups</a></div>
<form asp-action="SendMessage" method="post">@Html.AntiForgeryToken()<div class="row g-4"><div class="col-lg-7"><div class="card"><div class="card-header">Recipients</div><div class="card-body"><div class="form-check mb-3"><input asp-for="AllMyStudents" class="form-check-input"><label asp-for="AllMyStudents" class="form-check-label">All My Students</label></div><label class="form-label">Specific group</label><select asp-for="GroupId" class="form-select mb-3"><option value="">No group selected</option>@foreach(var g in Model.Groups){<option value="@g.Id">@g.GroupName</option>}</select><label class="form-label">Or selected students</label><div class="border rounded p-2 overflow-auto" style="max-height:320px">@foreach(var s in Model.Students){<label class="d-flex gap-2 border-bottom py-2"><input type="checkbox" name="StudentIds" value="@s.StudentId"><span>@s.StudentName <small class="text-muted">(@s.StudentNumber)</small></span></label>}</div></div></div></div><div class="col-lg-5"><div class="card"><div class="card-header">Message</div><div class="card-body"><div asp-validation-summary="ModelOnly" class="text-danger"></div><textarea asp-for="Message" class="form-control mb-3" rows="8" maxlength="500" placeholder="Enter notification message"></textarea><div class="form-check mb-2"><input asp-for="SendInApp" class="form-check-input"><label asp-for="SendInApp" class="form-check-label">Send in-app notification</label></div><div class="form-check mb-3"><input asp-for="QueueWhatsApp" class="form-check-input"><label asp-for="QueueWhatsApp" class="form-check-label">Queue WhatsApp message (integration skeleton)</label></div><button class="btn btn-primary w-100">Process Message</button></div></div></div></div></form>
