@model ElecPOE.ViewModels.TakeAttendanceViewModel
@using ForekOnline.Domain.Entities
@{ ViewData["Title"] = "Take Attendance"; }
<div class="d-flex justify-content-between align-items-center mb-4"><div><div class="badge mb-2" style="background:@Model.GroupColor">@Model.GroupName</div><h1 class="h3 mb-1">Take Attendance</h1><p class="text-muted mb-0">Mark each learner, then save a draft or submit.</p></div><a asp-action="Group" asp-route-id="@Model.GroupId" class="btn btn-outline-secondary">Back to Group</a></div>
<form asp-action="SaveAttendance" method="post" id="attendanceForm">@Html.AntiForgeryToken()<input asp-for="SessionId" type="hidden"><input asp-for="GroupId" type="hidden"><div class="card card-body mb-4"><div class="row g-3"><div class="col-md-3"><label asp-for="AttendanceDate" class="form-label"></label><input asp-for="AttendanceDate" class="form-control"></div><div class="col-md-2"><label asp-for="StartTime" class="form-label"></label><input asp-for="StartTime" type="time" class="form-control"></div><div class="col-md-2"><label asp-for="EndTime" class="form-label"></label><input asp-for="EndTime" type="time" class="form-control"></div><div class="col-md-5"><label asp-for="Topic" class="form-label"></label><input asp-for="Topic" class="form-control"></div><div class="col-md-8"><label asp-for="Note" class="form-label">Session note</label><input asp-for="Note" class="form-control"></div><div class="col-md-4"><label asp-for="EditReason" class="form-label">Edit reason (when changing submitted data)</label><input asp-for="EditReason" class="form-control"></div></div></div>
<div class="d-flex flex-wrap gap-2 mb-3"><button type="button" class="btn btn-sm btn-outline-success" id="markAll">Mark all present</button><button type="button" class="btn btn-sm btn-outline-secondary" id="clearAll">Clear all</button><button type="button" class="btn btn-sm btn-outline-dark" id="showNotMarked">Filter not marked</button><button type="button" class="btn btn-sm btn-link" id="showAll">Show all</button></div>
<div class="card"><div class="table-responsive"><table class="table align-middle mb-0"><thead><tr><th>Student</th><th style="min-width:180px">Status</th><th style="min-width:260px">Comment</th></tr></thead><tbody>@for(var i=0;i<Model.Entries.Count;i++){<tr class="attendance-row"><td><input asp-for="Entries[i].StudentId" type="hidden"><input asp-for="Entries[i].StudentName" type="hidden"><input asp-for="Entries[i].StudentNumber" type="hidden"><strong>@Model.Entries[i].StudentName</strong><div class="small text-muted">@Model.Entries[i].StudentNumber</div></td><td><select asp-for="Entries[i].Status" asp-items="Html.GetEnumSelectList<LearnerAttendanceStatus>()" class="form-select attendance-status"></select></td><td><input asp-for="Entries[i].Comment" class="form-control" placeholder="Optional comment"></td></tr>}</tbody></table></div><div class="card-footer d-flex justify-content-end gap-2"><button name="Submit" value="false" class="btn btn-outline-secondary">Save as Draft</button><button name="Submit" value="true" class="btn btn-primary">Submit Attendance</button></div></div></form>
@section Scripts{<script>const notMarked='0';document.getElementById('markAll').onclick=()=>document.querySelectorAll('.attendance-status').forEach(x=>x.value='1');document.getElementById('clearAll').onclick=()=>document.querySelectorAll('.attendance-status').forEach(x=>x.value=notMarked);document.getElementById('showNotMarked').onclick=()=>document.querySelectorAll('.attendance-row').forEach(x=>x.hidden=x.querySelector('.attendance-status').value!==notMarked);document.getElementById('showAll').onclick=()=>document.querySelectorAll('.attendance-row').forEach(x=>x.hidden=false);</script>}
