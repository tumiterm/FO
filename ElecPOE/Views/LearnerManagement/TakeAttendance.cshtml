@model ElecPOE.ViewModels.TakeAttendanceViewModel
@using ForekOnline.Domain.Entities
@{
    ViewData["Title"] = "Take Attendance";
    var totalLearners = Model.Entries.Count;
    var markedLearners = Model.Entries.Count(x => x.Status != LearnerAttendanceStatus.NotMarked);
    var presentLearners = Model.Entries.Count(x => x.Status == LearnerAttendanceStatus.Present);
    var absentLearners = Model.Entries.Count(x => x.Status == LearnerAttendanceStatus.Absent);
    var completionPercentage = totalLearners == 0 ? 0 : (int)Math.Round(markedLearners * 100d / totalLearners);
}

@section Styles {
    <style>
        .attendance-page {
            --attendance-ink: #132238;
            --attendance-muted: #64748b;
            --attendance-border: #e7ebf2;
            --attendance-surface: #ffffff;
            --attendance-soft: #f7f9fc;
            --attendance-accent: var(--fo-orange, #f47b20);
            --attendance-accent-dark: var(--fo-orange-dark, #d85f0b);
            color: var(--attendance-ink);
            padding-bottom: 2rem;
        }

        .attendance-hero {
            position: relative;
            overflow: hidden;
            isolation: isolate;
            margin-bottom: 1.5rem;
            padding: clamp(1.4rem, 3vw, 2.25rem);
            border: 1px solid rgba(255, 255, 255, .16);
            border-radius: 24px;
            background:
                radial-gradient(circle at 86% 18%, rgba(255, 255, 255, .2), transparent 22%),
                linear-gradient(125deg, #17243a 0%, #243b5e 56%, var(--attendance-accent-dark) 145%);
            box-shadow: 0 24px 55px rgba(15, 23, 42, .16);
            color: #fff;
        }

        .attendance-hero::before,
        .attendance-hero::after {
            position: absolute;
            z-index: -1;
            border-radius: 999px;
            content: "";
            pointer-events: none;
        }

        .attendance-hero::before {
            top: -95px;
            right: -50px;
            width: 270px;
            height: 270px;
            border: 55px solid rgba(255, 255, 255, .055);
        }

        .attendance-hero::after {
            right: 24%;
            bottom: -100px;
            width: 210px;
            height: 210px;
            background: rgba(244, 123, 32, .13);
            filter: blur(2px);
        }

        .attendance-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: .5rem;
            margin-bottom: .9rem;
            padding: .38rem .72rem;
            border: 1px solid rgba(255, 255, 255, .22);
            border-radius: 999px;
            background: rgba(255, 255, 255, .1);
            color: rgba(255, 255, 255, .88);
            font-size: .72rem;
            font-weight: 800;
            letter-spacing: .1em;
            text-transform: uppercase;
            backdrop-filter: blur(8px);
        }

        .attendance-group-dot {
            width: .58rem;
            height: .58rem;
            border: 2px solid rgba(255, 255, 255, .65);
            border-radius: 50%;
            background: @Model.GroupColor;
            box-shadow: 0 0 0 4px rgba(255, 255, 255, .1);
        }

        .attendance-hero h1 {
            margin-bottom: .55rem;
            color: #fff;
            font-size: clamp(1.75rem, 4vw, 2.6rem);
            font-weight: 850;
            letter-spacing: -.045em;
        }

        .attendance-hero p {
            max-width: 680px;
            margin-bottom: 0;
            color: rgba(255, 255, 255, .72);
            font-size: .96rem;
        }

        .attendance-back {
            display: inline-flex;
            align-items: center;
            gap: .5rem;
            padding: .7rem 1rem;
            border: 1px solid rgba(255, 255, 255, .22);
            border-radius: 12px;
            background: rgba(255, 255, 255, .1);
            color: #fff;
            font-size: .84rem;
            font-weight: 700;
            text-decoration: none;
            backdrop-filter: blur(9px);
            transition: transform .2s ease, background .2s ease;
        }

        .attendance-back:hover {
            transform: translateY(-2px);
            background: rgba(255, 255, 255, .18);
            color: #fff;
        }

        .attendance-metrics {
            position: relative;
            z-index: 2;
            margin-top: -2.35rem;
            padding: 0 1rem;
        }

        .attendance-metric {
            height: 100%;
            padding: 1rem 1.1rem;
            border: 1px solid rgba(226, 232, 240, .85);
            border-radius: 17px;
            background: rgba(255, 255, 255, .96);
            box-shadow: 0 13px 30px rgba(15, 23, 42, .09);
            backdrop-filter: blur(12px);
        }

        .attendance-metric-icon {
            display: grid;
            width: 2.35rem;
            height: 2.35rem;
            flex: 0 0 auto;
            place-items: center;
            border-radius: 12px;
            font-size: 1rem;
        }

        .metric-total .attendance-metric-icon { background: #eef2ff; color: #4f46e5; }
        .metric-present .attendance-metric-icon { background: #e9fbf2; color: #168a56; }
        .metric-absent .attendance-metric-icon { background: #fff0ef; color: #dc3e37; }
        .metric-progress .attendance-metric-icon { background: #fff5e9; color: #dc6c11; }

        .attendance-metric-label {
            margin-bottom: .1rem;
            color: var(--attendance-muted);
            font-size: .7rem;
            font-weight: 750;
            letter-spacing: .06em;
            text-transform: uppercase;
        }

        .attendance-metric-value {
            color: var(--attendance-ink);
            font-size: 1.45rem;
            font-weight: 850;
            letter-spacing: -.035em;
            line-height: 1.1;
        }

        .attendance-panel {
            overflow: hidden;
            border: 1px solid var(--attendance-border);
            border-radius: 20px;
            background: var(--attendance-surface);
            box-shadow: 0 12px 35px rgba(15, 23, 42, .055);
        }

        .attendance-panel-header {
            padding: 1.15rem 1.3rem;
            border-bottom: 1px solid var(--attendance-border);
            background: linear-gradient(180deg, #fff, #fbfcfe);
        }

        .attendance-panel-title {
            margin: 0;
            color: var(--attendance-ink);
            font-size: 1rem;
            font-weight: 800;
            letter-spacing: -.015em;
        }

        .attendance-panel-subtitle {
            margin: .22rem 0 0;
            color: var(--attendance-muted);
            font-size: .78rem;
        }

        .attendance-form-body { padding: 1.3rem; }

        .attendance-page .form-label {
            margin-bottom: .42rem;
            color: #45546a;
            font-size: .74rem;
            font-weight: 750;
        }

        .attendance-page .form-control,
        .attendance-page .form-select {
            min-height: 46px;
            border-color: #dce2eb;
            border-radius: 11px;
            background-color: #fbfcfe;
            color: var(--attendance-ink);
            font-size: .86rem;
            transition: border-color .18s ease, box-shadow .18s ease, background .18s ease;
        }

        .attendance-page .form-control:focus,
        .attendance-page .form-select:focus {
            border-color: var(--attendance-accent);
            background: #fff;
            box-shadow: 0 0 0 .22rem rgba(244, 123, 32, .12);
        }

        .attendance-toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 1rem 1.2rem;
            border-bottom: 1px solid var(--attendance-border);
            background: #fff;
        }

        .attendance-search {
            position: relative;
            width: min(100%, 350px);
        }

        .attendance-search i {
            position: absolute;
            top: 50%;
            left: .95rem;
            z-index: 1;
            color: #94a3b8;
            transform: translateY(-50%);
        }

        .attendance-search .form-control {
            padding-left: 2.7rem;
            background: var(--attendance-soft);
        }

        .attendance-action {
            display: inline-flex;
            min-height: 40px;
            align-items: center;
            justify-content: center;
            gap: .46rem;
            padding: .58rem .82rem;
            border: 1px solid #dfe4ec;
            border-radius: 10px;
            background: #fff;
            color: #4b5b70;
            font-size: .76rem;
            font-weight: 750;
            white-space: nowrap;
            transition: border-color .18s ease, color .18s ease, transform .18s ease, box-shadow .18s ease;
        }

        .attendance-action:hover {
            border-color: #c8d0dc;
            color: var(--attendance-ink);
            transform: translateY(-1px);
            box-shadow: 0 6px 15px rgba(15, 23, 42, .07);
        }

        .attendance-action.active {
            border-color: rgba(244, 123, 32, .35);
            background: #fff8f2;
            color: var(--attendance-accent-dark);
        }

        .attendance-action-success {
            border-color: #bdebd3;
            background: #effbf5;
            color: #147447;
        }

        .attendance-export {
            border-color: #b9dfca;
            background: linear-gradient(135deg, #17864f, #116a3e);
            color: #fff;
            box-shadow: 0 7px 18px rgba(17, 106, 62, .18);
        }

        .attendance-export:hover {
            border-color: #116a3e;
            color: #fff;
            box-shadow: 0 9px 22px rgba(17, 106, 62, .24);
        }

        .attendance-table { margin: 0; }

        .attendance-table thead th {
            padding: .8rem 1.15rem;
            border-bottom: 1px solid var(--attendance-border);
            background: #f7f9fc;
            color: #718096;
            font-size: .68rem;
            font-weight: 800;
            letter-spacing: .075em;
            text-transform: uppercase;
            white-space: nowrap;
        }

        .attendance-table tbody td {
            padding: .9rem 1.15rem;
            border-color: #edf0f5;
            vertical-align: middle;
        }

        .attendance-table tbody tr { transition: background .18s ease; }
        .attendance-table tbody tr:hover { background: #fbfcff; }

        .learner-avatar {
            display: grid;
            width: 2.6rem;
            height: 2.6rem;
            flex: 0 0 auto;
            place-items: center;
            border-radius: 13px;
            background: linear-gradient(135deg, #eef2f8, #e3e9f2);
            color: #53657d;
            font-size: .76rem;
            font-weight: 850;
            letter-spacing: .025em;
        }

        .learner-name {
            overflow: hidden;
            color: var(--attendance-ink);
            font-size: .87rem;
            font-weight: 750;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .learner-number {
            margin-top: .13rem;
            color: var(--attendance-muted);
            font-size: .72rem;
        }

        .attendance-status {
            border-left-width: 4px !important;
            font-weight: 650;
        }

        .attendance-status.status-not-marked { border-left-color: #94a3b8 !important; }
        .attendance-status.status-present { border-left-color: #20a568 !important; background-color: #f4fcf8; }
        .attendance-status.status-absent { border-left-color: #e2544b !important; background-color: #fff8f7; }
        .attendance-status.status-late { border-left-color: #e4a11b !important; background-color: #fffcf3; }
        .attendance-status.status-excused { border-left-color: #6366f1 !important; background-color: #f7f7ff; }

        .attendance-empty {
            display: none;
            padding: 3rem 1rem;
            color: var(--attendance-muted);
            text-align: center;
        }

        .attendance-empty-icon {
            display: grid;
            width: 3.5rem;
            height: 3.5rem;
            margin: 0 auto .75rem;
            place-items: center;
            border-radius: 18px;
            background: #f1f5f9;
            color: #7b8ba2;
            font-size: 1.3rem;
        }

        .attendance-progress {
            height: 6px;
            overflow: hidden;
            border-radius: 999px;
            background: #edf1f6;
        }

        .attendance-progress-bar {
            width: @completionPercentage%;
            height: 100%;
            border-radius: inherit;
            background: linear-gradient(90deg, var(--attendance-accent), #ffad42);
            transition: width .25s ease;
        }

        .attendance-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 1rem 1.2rem;
            border-top: 1px solid var(--attendance-border);
            background: linear-gradient(180deg, #fff, #fafbfd);
        }

        .attendance-footer-copy {
            color: var(--attendance-muted);
            font-size: .76rem;
        }

        .attendance-primary,
        .attendance-secondary {
            display: inline-flex;
            min-height: 44px;
            align-items: center;
            justify-content: center;
            gap: .48rem;
            padding: .68rem 1rem;
            border-radius: 11px;
            font-size: .8rem;
            font-weight: 800;
        }

        .attendance-primary {
            border: 1px solid var(--attendance-accent-dark);
            background: linear-gradient(135deg, var(--attendance-accent), var(--attendance-accent-dark));
            color: #fff;
            box-shadow: 0 8px 20px rgba(216, 95, 11, .2);
        }

        .attendance-primary:hover { color: #fff; transform: translateY(-1px); }

        .attendance-secondary {
            border: 1px solid #d9e0e9;
            background: #fff;
            color: #516176;
        }

        .attendance-secondary:hover { border-color: #bcc6d3; color: var(--attendance-ink); }

        @@media (max-width: 991.98px) {
            .attendance-metrics { margin-top: 1rem; padding: 0; }
            .attendance-toolbar { align-items: stretch; flex-direction: column; }
            .attendance-search { width: 100%; }
        }

        @@media (max-width: 767.98px) {
            .attendance-hero { border-radius: 18px; }
            .attendance-panel { border-radius: 16px; }
            .attendance-table thead { display: none; }
            .attendance-table,
            .attendance-table tbody,
            .attendance-table tr,
            .attendance-table td { display: block; width: 100%; }
            .attendance-table tbody tr { padding: .35rem 0; border-bottom: 1px solid var(--attendance-border); }
            .attendance-table tbody td { padding: .55rem 1rem; border: 0; }
            .attendance-table tbody td:first-child { padding-top: .85rem; }
            .attendance-table tbody td:last-child { padding-bottom: .85rem; }
            .attendance-footer { align-items: stretch; flex-direction: column; }
            .attendance-footer-actions { display: grid !important; grid-template-columns: 1fr 1fr; width: 100%; }
            .attendance-action { flex: 1 1 auto; }
        }

        @@media print {
            .attendance-back,
            .attendance-toolbar,
            .attendance-footer { display: none !important; }
            .attendance-hero { color: #000; background: #fff; box-shadow: none; }
            .attendance-hero h1,
            .attendance-hero p { color: #000; }
            .attendance-metrics { margin-top: 0; }
            .attendance-panel,
            .attendance-metric { box-shadow: none; }
        }
    </style>
}

<div class="attendance-page">
    <section class="attendance-hero" aria-labelledby="attendanceTitle">
        <div class="d-flex flex-column flex-lg-row align-items-lg-start justify-content-between gap-4">
            <div>
                <div class="attendance-eyebrow">
                    <span class="attendance-group-dot" aria-hidden="true"></span>
                    <span>@Model.GroupName</span>
                </div>
                <h1 id="attendanceTitle">Attendance register</h1>
                <p>Record the session, mark every learner and submit a reliable register. You can export the live table to Excel at any time.</p>
            </div>
            <a asp-action="Group" asp-route-id="@Model.GroupId" class="attendance-back">
                <i class="bi bi-arrow-left" aria-hidden="true"></i>
                Back to group
            </a>
        </div>
    </section>

    <div class="attendance-metrics">
        <div class="row g-3">
            <div class="col-6 col-xl-3">
                <div class="attendance-metric metric-total d-flex align-items-center gap-3">
                    <span class="attendance-metric-icon"><i class="bi bi-people-fill" aria-hidden="true"></i></span>
                    <div>
                        <div class="attendance-metric-label">Learners</div>
                        <div class="attendance-metric-value" id="totalCount">@totalLearners</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="attendance-metric metric-present d-flex align-items-center gap-3">
                    <span class="attendance-metric-icon"><i class="bi bi-person-check-fill" aria-hidden="true"></i></span>
                    <div>
                        <div class="attendance-metric-label">Present</div>
                        <div class="attendance-metric-value" id="presentCount">@presentLearners</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="attendance-metric metric-absent d-flex align-items-center gap-3">
                    <span class="attendance-metric-icon"><i class="bi bi-person-x-fill" aria-hidden="true"></i></span>
                    <div>
                        <div class="attendance-metric-label">Absent</div>
                        <div class="attendance-metric-value" id="absentCount">@absentLearners</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="attendance-metric metric-progress d-flex align-items-center gap-3">
                    <span class="attendance-metric-icon"><i class="bi bi-pie-chart-fill" aria-hidden="true"></i></span>
                    <div class="flex-grow-1">
                        <div class="attendance-metric-label">Completed</div>
                        <div class="attendance-metric-value"><span id="completionCount">@completionPercentage</span>%</div>
                        <div class="attendance-progress mt-2" aria-hidden="true">
                            <div class="attendance-progress-bar" id="completionBar"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <form asp-action="SaveAttendance" method="post" id="attendanceForm" class="mt-4">
        @Html.AntiForgeryToken()
        <input asp-for="SessionId" type="hidden" />
        <input asp-for="GroupId" type="hidden" />

        <section class="attendance-panel mb-4" aria-labelledby="sessionDetailsTitle">
            <div class="attendance-panel-header d-flex align-items-center gap-3">
                <span class="attendance-metric-icon metric-progress" style="background:#fff5e9;color:#dc6c11">
                    <i class="bi bi-calendar2-week" aria-hidden="true"></i>
                </span>
                <div>
                    <h2 class="attendance-panel-title" id="sessionDetailsTitle">Session details</h2>
                    <p class="attendance-panel-subtitle">Add context to make this register easy to identify later.</p>
                </div>
            </div>
            <div class="attendance-form-body">
                <div class="row g-3">
                    <div class="col-md-4 col-xl-3">
                        <label asp-for="AttendanceDate" class="form-label">Attendance date</label>
                        <input asp-for="AttendanceDate" class="form-control" />
                    </div>
                    <div class="col-6 col-md-4 col-xl-2">
                        <label asp-for="StartTime" class="form-label">Start time</label>
                        <input asp-for="StartTime" type="time" class="form-control" />
                    </div>
                    <div class="col-6 col-md-4 col-xl-2">
                        <label asp-for="EndTime" class="form-label">End time</label>
                        <input asp-for="EndTime" type="time" class="form-control" />
                    </div>
                    <div class="col-xl-5">
                        <label asp-for="Topic" class="form-label">Session topic</label>
                        <input asp-for="Topic" class="form-control" placeholder="What was covered in this session?" />
                    </div>
                    <div class="col-lg-7">
                        <label asp-for="Note" class="form-label">Session note</label>
                        <input asp-for="Note" class="form-control" placeholder="Optional note for this attendance register" />
                    </div>
                    <div class="col-lg-5">
                        <label asp-for="EditReason" class="form-label">Edit reason</label>
                        <input asp-for="EditReason" class="form-control" placeholder="Required when changing submitted data" />
                    </div>
                </div>
            </div>
        </section>

        <section class="attendance-panel" aria-labelledby="registerTitle">
            <div class="attendance-panel-header d-flex flex-wrap align-items-center justify-content-between gap-3">
                <div>
                    <h2 class="attendance-panel-title" id="registerTitle">Learner register</h2>
                    <p class="attendance-panel-subtitle"><span id="visibleCount">@totalLearners</span> of @totalLearners learners shown</p>
                </div>
                <button type="button" class="attendance-action attendance-export" id="exportExcel">
                    <i class="bi bi-file-earmark-excel-fill" aria-hidden="true"></i>
                    Export to Excel
                </button>
            </div>

            <div class="attendance-toolbar">
                <div class="attendance-search">
                    <i class="bi bi-search" aria-hidden="true"></i>
                    <label for="learnerSearch" class="visually-hidden">Search learners</label>
                    <input type="search" class="form-control" id="learnerSearch" placeholder="Search name or student number..." autocomplete="off" />
                </div>
                <div class="d-flex flex-wrap gap-2" role="group" aria-label="Attendance actions">
                    <button type="button" class="attendance-action attendance-action-success" id="markAll">
                        <i class="bi bi-check2-all" aria-hidden="true"></i> Mark all present
                    </button>
                    <button type="button" class="attendance-action" id="clearAll">
                        <i class="bi bi-arrow-counterclockwise" aria-hidden="true"></i> Reset
                    </button>
                    <button type="button" class="attendance-action" id="showNotMarked">
                        <i class="bi bi-funnel" aria-hidden="true"></i> Not marked
                    </button>
                    <button type="button" class="attendance-action active" id="showAll">
                        <i class="bi bi-list-ul" aria-hidden="true"></i> All learners
                    </button>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table attendance-table align-middle" id="attendanceTable">
                    <thead>
                        <tr>
                            <th style="width:42%">Learner</th>
                            <th style="min-width:190px">Attendance status</th>
                            <th style="min-width:280px">Comment</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < Model.Entries.Count; i++)
                        {
                            var nameParts = Model.Entries[i].StudentName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                            var initials = string.Concat(nameParts.Take(2).Select(x => char.ToUpperInvariant(x[0])));
                            <tr class="attendance-row" data-search="@($"{Model.Entries[i].StudentName} {Model.Entries[i].StudentNumber}".ToLowerInvariant())">
                                <td>
                                    <input asp-for="Entries[i].StudentId" type="hidden" />
                                    <input asp-for="Entries[i].StudentName" type="hidden" />
                                    <input asp-for="Entries[i].StudentNumber" type="hidden" />
                                    <div class="d-flex align-items-center gap-3">
                                        <span class="learner-avatar" aria-hidden="true">@initials</span>
                                        <div class="min-w-0">
                                            <div class="learner-name">@Model.Entries[i].StudentName</div>
                                            <div class="learner-number">@Model.Entries[i].StudentNumber</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <label asp-for="Entries[i].Status" class="visually-hidden">Attendance status for @Model.Entries[i].StudentName</label>
                                    <select asp-for="Entries[i].Status" asp-items="Html.GetEnumSelectList<LearnerAttendanceStatus>()" class="form-select attendance-status"></select>
                                </td>
                                <td>
                                    <label asp-for="Entries[i].Comment" class="visually-hidden">Comment for @Model.Entries[i].StudentName</label>
                                    <input asp-for="Entries[i].Comment" class="form-control attendance-comment" placeholder="Add an optional comment..." />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div class="attendance-empty" id="attendanceEmpty" role="status">
                    <span class="attendance-empty-icon"><i class="bi bi-search" aria-hidden="true"></i></span>
                    <strong class="d-block mb-1">No learners found</strong>
                    <span class="small">Try another search or clear the active filter.</span>
                </div>
            </div>

            <div class="attendance-footer">
                <div class="attendance-footer-copy">
                    <i class="bi bi-shield-check me-1" aria-hidden="true"></i>
                    Drafts remain editable. Submit only when the register is complete.
                </div>
                <div class="attendance-footer-actions d-flex gap-2">
                    <button name="Submit" value="false" class="attendance-secondary" type="submit">
                        <i class="bi bi-cloud-arrow-down" aria-hidden="true"></i> Save draft
                    </button>
                    <button name="Submit" value="true" class="attendance-primary" type="submit">
                        <i class="bi bi-check2-circle" aria-hidden="true"></i> Submit attendance
                    </button>
                </div>
            </div>
        </section>
    </form>
</div>

@section Scripts {
    <script>
        (() => {
            'use strict';

            const status = Object.freeze({
                notMarked: '@((int)LearnerAttendanceStatus.NotMarked)',
                present: '@((int)LearnerAttendanceStatus.Present)',
                absent: '@((int)LearnerAttendanceStatus.Absent)',
                late: '@((int)LearnerAttendanceStatus.Late)',
                excused: '@((int)LearnerAttendanceStatus.Excused)'
            });
            const rows = Array.from(document.querySelectorAll('.attendance-row'));
            const searchInput = document.getElementById('learnerSearch');
            const notMarkedButton = document.getElementById('showNotMarked');
            const showAllButton = document.getElementById('showAll');
            const emptyState = document.getElementById('attendanceEmpty');
            let activeFilter = 'all';

            const statusClassMap = {
                [status.notMarked]: 'status-not-marked',
                [status.present]: 'status-present',
                [status.absent]: 'status-absent',
                [status.late]: 'status-late',
                [status.excused]: 'status-excused'
            };

            function applyStatusStyle(select) {
                Object.values(statusClassMap).forEach(className => select.classList.remove(className));
                select.classList.add(statusClassMap[select.value] || statusClassMap[status.notMarked]);
            }

            function updateMetrics() {
                const values = rows.map(row => row.querySelector('.attendance-status').value);
                const total = values.length;
                const marked = values.filter(value => value !== status.notMarked).length;
                const completion = total ? Math.round((marked / total) * 100) : 0;

                document.getElementById('totalCount').textContent = total;
                document.getElementById('presentCount').textContent = values.filter(value => value === status.present).length;
                document.getElementById('absentCount').textContent = values.filter(value => value === status.absent).length;
                document.getElementById('completionCount').textContent = completion;
                document.getElementById('completionBar').style.width = `${completion}%`;
            }

            function applyFilters() {
                const query = searchInput.value.trim().toLocaleLowerCase();
                let visible = 0;

                rows.forEach(row => {
                    const matchesSearch = !query || row.dataset.search.includes(query);
                    const matchesStatus = activeFilter === 'all' || row.querySelector('.attendance-status').value === status.notMarked;
                    const shouldShow = matchesSearch && matchesStatus;
                    row.hidden = !shouldShow;
                    if (shouldShow) visible += 1;
                });

                document.getElementById('visibleCount').textContent = visible;
                emptyState.style.display = visible === 0 ? 'block' : 'none';
            }

            function setFilter(filter) {
                activeFilter = filter;
                const showingAll = filter === 'all';
                showAllButton.classList.toggle('active', showingAll);
                notMarkedButton.classList.toggle('active', !showingAll);
                applyFilters();
            }

            function updateAllStatuses(value) {
                rows.forEach(row => {
                    const select = row.querySelector('.attendance-status');
                    select.value = value;
                    applyStatusStyle(select);
                });
                updateMetrics();
                applyFilters();
            }

            function csvCell(value) {
                let text = String(value ?? '').replace(/\r?\n/g, ' ').trim();
                if (text && ['=', '+', '-', String.fromCharCode(64)].includes(text[0])) {
                    text = `'${text}`;
                }
                return `"${text.replace(/"/g, '""')}"`;
            }

            function formatDateForExport(value) {
                if (!value) return '';
                const date = new Date(`${value}T00:00:00`);
                return Number.isNaN(date.getTime())
                    ? value
                    : new Intl.DateTimeFormat('en-ZA', { day: '2-digit', month: 'long', year: 'numeric' }).format(date);
            }

            function exportToExcel() {
                const groupName = '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(Model.GroupName))';
                const attendanceDate = document.getElementById('AttendanceDate')?.value || '';
                const startTime = document.getElementById('StartTime')?.value || '';
                const endTime = document.getElementById('EndTime')?.value || '';
                const topic = document.getElementById('Topic')?.value || '';
                const note = document.getElementById('Note')?.value || '';
                const exportedAt = new Intl.DateTimeFormat('en-ZA', { dateStyle: 'medium', timeStyle: 'short' }).format(new Date());
                const lines = [
                    ['Attendance Register', groupName],
                    ['Attendance date', formatDateForExport(attendanceDate)],
                    ['Session time', [startTime, endTime].filter(Boolean).join(' - ')],
                    ['Topic', topic],
                    ['Session note', note],
                    ['Exported', exportedAt],
                    [],
                    ['Learner', 'Student number', 'Status', 'Comment']
                ];

                rows.forEach(row => {
                    const name = row.querySelector('input[name$=".StudentName"]')?.value || '';
                    const number = row.querySelector('input[name$=".StudentNumber"]')?.value || '';
                    const statusSelect = row.querySelector('.attendance-status');
                    const attendanceStatus = statusSelect?.options[statusSelect.selectedIndex]?.text || '';
                    const comment = row.querySelector('.attendance-comment')?.value || '';
                    lines.push([name, number, attendanceStatus, comment]);
                });

                const csv = lines.map(line => line.map(csvCell).join(',')).join('\r\n');
                const blob = new Blob(['\ufeff', csv], { type: 'text/csv;charset=utf-8' });
                const slug = groupName.toLocaleLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '') || 'group';
                const filename = `attendance-${slug}-${attendanceDate || new Date().toISOString().slice(0, 10)}.csv`;

                if (navigator.msSaveOrOpenBlob) {
                    navigator.msSaveOrOpenBlob(blob, filename);
                    return;
                }

                const url = URL.createObjectURL(blob);
                const link = document.createElement('a');
                link.href = url;
                link.download = filename;
                link.style.display = 'none';
                document.body.appendChild(link);
                link.click();
                window.setTimeout(() => {
                    link.remove();
                    URL.revokeObjectURL(url);
                }, 0);
            }

            rows.forEach(row => {
                const select = row.querySelector('.attendance-status');
                applyStatusStyle(select);
                select.addEventListener('change', () => {
                    applyStatusStyle(select);
                    updateMetrics();
                    applyFilters();
                });
            });

            document.getElementById('markAll').addEventListener('click', () => updateAllStatuses(status.present));
            document.getElementById('clearAll').addEventListener('click', () => updateAllStatuses(status.notMarked));
            notMarkedButton.addEventListener('click', () => setFilter('notMarked'));
            showAllButton.addEventListener('click', () => setFilter('all'));
            searchInput.addEventListener('input', applyFilters);
            document.getElementById('exportExcel').addEventListener('click', exportToExcel);

            updateMetrics();
            applyFilters();
        })();
    </script>
}
