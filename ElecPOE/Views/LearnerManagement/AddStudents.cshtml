@model ElecPOE.ViewModels.AddStudentsViewModel
@{ ViewData["Title"] = "Add Students"; }
<div class="d-flex justify-content-between align-items-center mb-4"><div><h1 class="h3 mb-1">Add Students to My List</h1><p class="text-muted mb-0">Students may be linked to more than one facilitator.</p></div><a asp-action="MyStudents" class="btn btn-outline-secondary">Back to My Students</a></div>
<form method="get" class="card card-body mb-4"><div class="row g-3 align-items-end"><div class="col-md-7"><label class="form-label">Search students</label><input name="search" value="@Model.Search" class="form-control" placeholder="Student number, ID/passport, first or last name"></div><div class="col-md-3"><label class="form-label">Enrollment status</label><input name="enrollmentStatus" value="@Model.EnrollmentStatus" class="form-control" placeholder="Active"></div><div class="col-md-2"><button class="btn btn-dark w-100">Search</button></div></div></form>
<form asp-action="AddStudents" method="post">@Html.AntiForgeryToken()<div class="card"><div class="card-header d-flex justify-content-between align-items-center"><span>Select learners</span><button class="btn btn-primary">Add Selected</button></div><div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead><tr><th><input type="checkbox" id="selectAll"></th><th>Student</th><th>ID / Passport</th><th>Programme</th><th>Allocation</th></tr></thead><tbody>
@foreach(var s in Model.Students){<tr class="@(s.AlreadyMine ? "table-light" : "")"><td><input class="student-check" type="checkbox" name="StudentIds" value="@s.Id" disabled="@s.AlreadyMine"></td><td><strong>@s.StudentName</strong><div class="small text-muted">@s.StudentNumber</div></td><td>@(s.IdentityNumber ?? "—")</td><td>@(s.Course ?? "—")<div class="small text-muted">@s.EnrollmentStatus</div></td><td>@if(s.AlreadyMine){<span class="badge bg-success">Already in My Students</span>}else if(s.OtherFacilitatorCount > 0){<div class="alert alert-warning py-1 px-2 mb-0 small"><i class="fa fa-exclamation-triangle"></i> Linked to @s.OtherFacilitatorCount other facilitator(s). You may still add this student.</div>}else{<span class="text-muted">Not currently allocated</span>}</td></tr>}
</tbody></table></div></div></form>
@section Scripts{<script>document.getElementById('selectAll')?.addEventListener('change',e=>document.querySelectorAll('.student-check:not(:disabled)').forEach(x=>x.checked=e.target.checked));</script>}
