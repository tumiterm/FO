@model ElecPOE.ViewModels.MyStudentsViewModel

@{
    ViewData["Title"] = "My Students";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">My Students</h1>
        <p class="text-muted mb-0">Your facilitator-owned learner list.</p>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="AddStudents" class="btn btn-primary">
            <i class="fa fa-user-plus me-1"></i>Add Students
        </a>

        <a asp-action="Groups" class="btn btn-outline-secondary">
            My Groups
        </a>
    </div>
</div>

<form method="get" class="card card-body mb-4">
    <div class="row g-3 align-items-end">

        <div class="col-md-5">
            <label class="form-label">Search</label>
            <input name="search"
                   value="@Model.Search"
                   class="form-control"
                   placeholder="Name or student number" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Group</label>
            <select name="GroupId" class="form-select">
                <option value="">All groups</option>

                @foreach (var g in Model.Groups)
                {
                    <option value="@g.Id" selected="@(Model.GroupId == g.Id ? "selected" : null)">
                        @g.GroupName
                    </option>
                }
            </select>
        </div>

        <div class="col-md-2 form-check ms-2">
            <input class="form-check-input"
                   type="checkbox"
                   name="ungroupedOnly"
                   value="true"
                   id="ungrouped"
            @(Model.UngroupedOnly ? "checked" : "") />

            <label class="form-check-label" for="ungrouped">
                Ungrouped only
            </label>
        </div>

        <div class="col-md-auto">
            <button type="submit" class="btn btn-dark">
                Filter
            </button>
        </div>

    </div>
</form>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Programme</th>
                    <th>Contact</th>
                    <th>Groups</th>
                    <th>Attendance</th>
                    <th>Last contact</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Students.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">
                            No students match this view. Add students to begin.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var s in Model.Students)
                    {
                        <tr>
                            <td>
                                <strong>@s.StudentName</strong>
                                <div class="small text-muted">
                                    @s.StudentNumber · @s.EnrollmentStatus
                                </div>
                            </td>

                            <td>@(s.Course ?? "—")</td>

                            <td>@(s.ContactNumber ?? "—")</td>

                            <td>
                                @if (s.Groups == null || !s.Groups.Any())
                                {
                                    <span class="badge bg-light text-dark">
                                        Ungrouped
                                    </span>
                                }
                                else
                                {
                                    foreach (var g in s.Groups)
                                    {
                                        <a asp-action="Group"
                                           asp-route-id="@g.Id"
                                           class="badge text-decoration-none me-1"
                                           style="background:@g.Color;color:white">
                                            @g.Name
                                        </a>
                                    }
                                }
                            </td>

                            <td>
                                @s.AttendanceSummary

                                <div class="small text-muted">
                                    @(s.LastAttendanceDate?.ToString("dd MMM yyyy") ?? "No date")
                                </div>
                            </td>

                            <td>
                                @(s.LastCommunicationDate?.ToString("dd MMM yyyy") ?? "—")
                            </td>

                            <td>
                                <form asp-action="RemoveStudent"
                                      method="post"
                                      onsubmit="return confirm('Remove this student from your list? Historical attendance remains available.');">

                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="linkId" value="@s.LinkId" />

                                    <input name="reason"
                                           class="form-control form-control-sm mb-1"
                                           placeholder="Optional reason" />

                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        Remove
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>