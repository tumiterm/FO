@model ElecPOE.ViewModels.GroupsViewModel
@{ ViewData["Title"] = "My Groups"; }
<div class="d-flex justify-content-between align-items-center mb-4"><div><h1 class="h3 mb-1">My Learning Groups</h1><p class="text-muted mb-0">Organize students for communication and attendance.</p></div><a asp-action="MyStudents" class="btn btn-outline-secondary">My Students</a></div>
@if(Model.UngroupedStudentCount > 0){<div class="alert alert-warning"><i class="fa fa-exclamation-circle me-2"></i><strong>@Model.UngroupedStudentCount</strong> of your students are not assigned to any group. <a asp-action="MyStudents" asp-route-ungroupedOnly="true">View them</a>.</div>}
<div class="row g-4"><div class="col-lg-8"><div class="row g-3">@if(!Model.Groups.Any()){<div class="col-12"><div class="card card-body text-center text-muted py-5">Create your first group using the form.</div></div>}@foreach(var g in Model.Groups){<div class="col-md-6"><div class="card h-100" style="border-top:5px solid @g.Color"><div class="card-body"><div class="d-flex justify-content-between"><h2 class="h5">@g.Name</h2><span class="badge" style="background:@g.Color">@g.Status</span></div><p class="text-muted small" style="min-height:3rem">@(g.Note ?? "No group note")</p><div class="d-flex gap-3 small mb-3"><span><strong>@g.StudentCount</strong> students</span><span><strong>@g.AttendanceSessionCount</strong> sessions</span></div><div class="d-flex flex-wrap gap-2"><a asp-action="Group" asp-route-id="@g.Id" class="btn btn-sm btn-primary">Open Group</a><a asp-action="TakeAttendance" asp-route-groupId="@g.Id" class="btn btn-sm btn-outline-success">Take Attendance</a><a asp-action="SendMessage" asp-route-groupId="@g.Id" class="btn btn-sm btn-outline-secondary">Message</a></div></div></div></div>}</div></div>
<div class="col-lg-4"><div class="card"><div class="card-header">Create Group</div><div class="card-body"><form asp-action="CreateGroup" method="post">@Html.AntiForgeryToken()<div asp-validation-summary="ModelOnly" class="text-danger"></div><div class="mb-3"><label asp-for="Create.GroupName" class="form-label"></label><input asp-for="Create.GroupName" class="form-control"></div><div class="mb-3"><label asp-for="Create.Color" class="form-label">Group color</label><input asp-for="Create.Color" type="color" class="form-control form-control-color"></div><div class="mb-3"><label asp-for="Create.Note" class="form-label">Optional note</label><textarea asp-for="Create.Note" class="form-control" rows="4"></textarea></div><button class="btn btn-primary w-100">Create Group</button></form></div></div></div></div>
