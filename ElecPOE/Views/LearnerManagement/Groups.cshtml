@model ElecPOE.ViewModels.GroupsViewModel
@{ ViewData["Title"] = "My Groups"; }
@section Styles { <link rel="stylesheet" href="~/css/learner-management.css" asp-append-version="true" /> }
<div class="lm-page">
    <section class="lm-hero"><div class="lm-hero-row"><div><div class="lm-eyebrow"><i class="bi bi-collection"></i> Learner organisation</div><h1>My learning groups</h1><p>Create purposeful cohorts for attendance and communication, then move into each group when it is time to facilitate.</p></div><div class="lm-hero-actions"><a asp-action="MyStudents" class="lm-btn lm-btn-light"><i class="bi bi-people"></i> My students</a></div></div></section>
    @if (Model.UngroupedStudentCount > 0) { <div class="lm-alert"><i class="bi bi-exclamation-triangle-fill"></i><div><strong>@Model.UngroupedStudentCount learner(s) still need a group.</strong><div class="mt-1">Assigning them keeps attendance and communication workflows organised. <a asp-action="MyStudents" asp-route-ungroupedOnly="true" class="fw-bold">Review learners</a></div></div></div> }
    <div class="lm-grid-sidebar">
        <div>
            <div class="lm-panel-head px-0 pt-0 border-0"><div><h2 class="lm-panel-title">Active groups <span class="lm-count-pill">@Model.Groups.Count</span></h2><p class="lm-panel-subtitle">Open a group to manage its roster, attendance and messages.</p></div></div>
            <div class="lm-card-grid">
                @if (!Model.Groups.Any()) { <div class="lm-panel"><div class="lm-empty"><span class="lm-empty-icon"><i class="bi bi-collection"></i></span><strong class="d-block">No groups yet</strong><span class="small">Create your first learning group using the form.</span></div></div> }
                @foreach (var g in Model.Groups)
                {
                    <article class="lm-group-card" style="--group-color:@g.Color"><div class="d-flex align-items-start justify-content-between gap-2"><div><span class="lm-badge" style="background:@g.Color;color:#fff">@g.Status</span><h2 class="mt-2">@g.Name</h2></div><i class="bi bi-people fs-4 text-muted"></i></div><p>@(g.Note ?? "No group note has been added yet.")</p><div class="lm-group-metrics"><div><strong>@g.StudentCount</strong><span>Learners</span></div><div><strong>@g.AttendanceSessionCount</strong><span>Sessions</span></div><div><strong>@g.Created.ToString("dd MMM")</strong><span>Created</span></div></div><div class="d-flex flex-wrap gap-2 mt-3"><a asp-action="Group" asp-route-id="@g.Id" class="lm-btn lm-btn-primary lm-btn-sm"><i class="bi bi-arrow-right-circle"></i> Open group</a><a asp-action="TakeAttendance" asp-route-groupId="@g.Id" class="lm-btn lm-btn-outline lm-btn-sm"><i class="bi bi-clipboard-check"></i> Attendance</a><a asp-action="SendMessage" asp-route-groupId="@g.Id" class="lm-btn lm-btn-outline lm-btn-sm" title="Message group"><i class="bi bi-send"></i></a></div></article>
                }
            </div>
        </div>
        <aside class="lm-panel"><div class="lm-panel-head"><div><h2 class="lm-panel-title">Create a group</h2><p class="lm-panel-subtitle">Set up a new learner cohort.</p></div><span class="lm-stat-icon"><i class="bi bi-plus-lg"></i></span></div><div class="lm-panel-body"><form asp-action="CreateGroup" method="post">@Html.AntiForgeryToken()<div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div><div class="mb-3"><label asp-for="Create.GroupName" class="lm-label">Group name</label><input asp-for="Create.GroupName" class="form-control" placeholder="e.g. Electrical NQF 4 — A" /><span asp-validation-for="Create.GroupName" class="text-danger small"></span></div><div class="mb-3"><label asp-for="Create.Color" class="lm-label">Group colour</label><div class="lm-color-field"><input asp-for="Create.Color" type="color" class="form-control form-control-color" /><span class="small text-muted">Used to identify the group.</span></div></div><div class="mb-3"><label asp-for="Create.Note" class="lm-label">Purpose or note</label><textarea asp-for="Create.Note" class="form-control" rows="4" placeholder="Optional context for this group"></textarea></div><button class="lm-btn lm-btn-primary w-100"><i class="bi bi-plus-circle"></i> Create learning group</button></form></div></aside>
    </div>
</div>
