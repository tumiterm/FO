@model ElecPOE.ViewModels.GroupDetailsViewModel
@{ ViewData["Title"] = Model.Group.GroupName; }
<div class="card mb-4" style="border-top:6px solid @Model.Group.Color"><div class="card-body d-flex flex-wrap justify-content-between gap-3"><div><div class="small text-muted">Learning Group</div><h1 class="h3 mb-1">@Model.Group.GroupName</h1><p class="mb-0 text-muted">@(Model.Group.Note ?? "No group note")</p></div><div class="d-flex align-items-center gap-2"><a asp-action="TakeAttendance" asp-route-groupId="@Model.Group.Id" class="btn btn-success">Take Attendance</a><a asp-action="SendMessage" asp-route-groupId="@Model.Group.Id" class="btn btn-primary">Send Notification</a><a asp-action="Groups" class="btn btn-outline-secondary">All Groups</a></div></div></div>
<div class="row g-4"><div class="col-lg-8"><div class="card"><div class="card-header">Group students (@Model.Members.Count)</div><div class="table-responsive"><table class="table align-middle mb-0"><thead><tr><th>Student</th><th>Programme</th><th>Attendance</th><th></th></tr></thead><tbody>@if(!Model.Members.Any()){<tr><td colspan="4" class="text-center text-muted py-4">No students in this group.</td></tr>}@foreach(var s in Model.Members){<tr><td><strong>@s.StudentName</strong><div class="small text-muted">@s.StudentNumber</div></td><td>@(s.Course ?? "—")</td><td>@s.AttendanceSummary</td><td><form asp-action="RemoveGroupStudent" method="post">@Html.AntiForgeryToken()<input type="hidden" name="groupId" value="@Model.Group.Id"><input type="hidden" name="linkId" value="@s.LinkId"><button class="btn btn-sm btn-outline-danger">Remove</button></form></td></tr>}</tbody></table></div></div>
<div class="card mt-4"><div class="card-header">Attendance history</div><div class="table-responsive"><table class="table mb-0"><thead><tr><th>Date</th><th>Topic</th><th>Status</th><th></th></tr></thead><tbody>@if(!Model.RecentSessions.Any()){<tr><td colspan="4" class="text-center text-muted py-4">No attendance sessions yet.</td></tr>}@foreach(var s in Model.RecentSessions){<tr><td>@s.AttendanceDate.ToString("dd MMM yyyy")</td><td>@(s.Topic ?? "—")</td><td><span class="badge @(s.Status == ForekOnline.Domain.Entities.AttendanceSessionStatus.Submitted ? "bg-success" : "bg-secondary")">@s.Status</span></td><td><a asp-action="TakeAttendance" asp-route-groupId="@Model.Group.Id" asp-route-sessionId="@s.Id">View / edit</a></td></tr>}</tbody></table></div></div></div>
<div class="col-lg-4"><div class="card mb-3"><div class="card-header">Group settings</div><div class="card-body"><form asp-action="EditGroup" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Group.Id"><div class="mb-2"><label class="form-label">Group name</label><input name="GroupName" value="@Model.Group.GroupName" class="form-control" required maxlength="120"></div><div class="mb-2"><label class="form-label">Color</label><input name="Color" value="@Model.Group.Color" type="color" class="form-control form-control-color"></div><div class="mb-3"><label class="form-label">Note</label><textarea name="Note" class="form-control" rows="3">@Model.Group.Note</textarea></div><button class="btn btn-outline-primary w-100">Update Group</button></form></div></div><div class="card"><div class="card-header">Add My Students</div><div class="card-body"><form asp-action="AddGroupStudents" method="post">@Html.AntiForgeryToken()<input type="hidden" name="groupId" value="@Model.Group.Id"><div class="overflow-auto mb-3" style="max-height:420px">@if(!Model.AvailableStudents.Any()){<p class="text-muted">All your students are already in this group.</p>}@foreach(var s in Model.AvailableStudents){<label class="d-flex gap-2 border-bottom py-2"><input type="checkbox" name="linkIds" value="@s.LinkId"><span><strong>@s.StudentName</strong><br><small class="text-muted">@s.StudentNumber</small></span></label>}</div><button class="btn btn-primary w-100" disabled="@(!Model.AvailableStudents.Any())">Add Selected</button></form></div></div><form asp-action="ArchiveGroup" method="post" class="mt-3" onsubmit="return confirm('Archive this group?');">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Group.Id"><button class="btn btn-outline-danger w-100">Archive Group</button></form></div></div>
