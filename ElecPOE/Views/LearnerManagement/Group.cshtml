@model ElecPOE.ViewModels.GroupDetailsViewModel
@{ ViewData["Title"] = Model.Group.GroupName; }
@section Styles { <link rel="stylesheet" href="~/css/learner-management.css" asp-append-version="true" /> }
<div class="lm-page">
    <section class="lm-hero" style="border-left:7px solid @Model.Group.Color"><div class="lm-hero-row"><div><div class="lm-eyebrow"><i class="bi bi-collection"></i> Learning group</div><h1>@Model.Group.GroupName</h1><p>@(Model.Group.Note ?? "No group note has been added. Use group settings to give this cohort some context.")</p></div><div class="lm-hero-actions"><a asp-action="Groups" class="lm-btn lm-btn-light"><i class="bi bi-arrow-left"></i> All groups</a><a asp-action="SendMessage" asp-route-groupId="@Model.Group.Id" class="lm-btn lm-btn-light"><i class="bi bi-send"></i> Message</a><a asp-action="TakeAttendance" asp-route-groupId="@Model.Group.Id" class="lm-btn lm-btn-primary"><i class="bi bi-clipboard-check"></i> Take attendance</a></div></div></section>
    <div class="lm-stat-grid"><div class="lm-stat orange"><div class="lm-stat-top"><span class="lm-kicker">Group roster</span><span class="lm-stat-icon"><i class="bi bi-people"></i></span></div><div class="lm-stat-value">@Model.Members.Count</div><div class="lm-stat-label">Learners in this group</div></div><div class="lm-stat green"><div class="lm-stat-top"><span class="lm-kicker">Attendance</span><span class="lm-stat-icon"><i class="bi bi-calendar-check"></i></span></div><div class="lm-stat-value">@Model.RecentSessions.Count</div><div class="lm-stat-label">Recent sessions available</div></div><div class="lm-stat blue"><div class="lm-stat-top"><span class="lm-kicker">Available</span><span class="lm-stat-icon"><i class="bi bi-person-plus"></i></span></div><div class="lm-stat-value">@Model.AvailableStudents.Count</div><div class="lm-stat-label">My students ready to add</div></div><div class="lm-stat"><div class="lm-stat-top"><span class="lm-kicker">Status</span><span class="lm-stat-icon"><i class="bi bi-activity"></i></span></div><div class="lm-stat-value fs-4 mt-4">@Model.Group.Status</div><div class="lm-stat-label">Current group state</div></div></div>
    <div class="lm-grid-sidebar"><main><section class="lm-panel"><div class="lm-panel-head"><div><h2 class="lm-panel-title">Group roster</h2><p class="lm-panel-subtitle">Learners currently included in this cohort.</p></div><span class="lm-count-pill">@Model.Members.Count</span></div><div class="table-responsive"><table class="lm-table"><thead><tr><th>Learner</th><th>Programme</th><th>Attendance</th><th></th></tr></thead><tbody>@if (!Model.Members.Any()) { <tr><td colspan="4"><div class="lm-empty"><span class="lm-empty-icon"><i class="bi bi-people"></i></span><strong class="d-block">This group is empty</strong><span class="small">Add learners from your student list.</span></div></td></tr> }@foreach (var s in Model.Members) { var parts=s.StudentName.Split(' ',StringSplitOptions.RemoveEmptyEntries); var initials=string.Concat(parts.Take(2).Select(x=>char.ToUpperInvariant(x[0]))); <tr><td><div class="lm-person"><span class="lm-avatar">@initials</span><div><div class="lm-person-name">@s.StudentName</div><div class="lm-meta">@s.StudentNumber</div></div></div></td><td>@(s.Course ?? "—")</td><td><strong>@s.AttendanceSummary</strong></td><td><form asp-action="RemoveGroupStudent" method="post" onsubmit="return confirm('Remove this learner from the group?');">@Html.AntiForgeryToken()<input type="hidden" name="groupId" value="@Model.Group.Id" /><input type="hidden" name="linkId" value="@s.LinkId" /><button class="lm-btn lm-btn-danger lm-btn-sm"><i class="bi bi-x-lg"></i> Remove</button></form></td></tr> }</tbody></table></div></section>
    <section class="lm-panel"><div class="lm-panel-head"><div><h2 class="lm-panel-title">Attendance history</h2><p class="lm-panel-subtitle">Open a register to review or continue editing it.</p></div><a asp-action="TakeAttendance" asp-route-groupId="@Model.Group.Id" class="lm-btn lm-btn-primary lm-btn-sm"><i class="bi bi-plus-lg"></i> New register</a></div><div class="table-responsive"><table class="lm-table"><thead><tr><th>Date</th><th>Topic</th><th>Status</th><th></th></tr></thead><tbody>@if (!Model.RecentSessions.Any()) { <tr><td colspan="4"><div class="lm-empty"><span class="lm-empty-icon"><i class="bi bi-calendar2"></i></span><strong class="d-block">No attendance sessions yet</strong></div></td></tr> }@foreach (var s in Model.RecentSessions) { <tr><td><strong>@s.AttendanceDate.ToString("dd MMM yyyy")</strong></td><td>@(s.Topic ?? "No topic")</td><td><span class="lm-badge @(s.Status == ForekOnline.Domain.Entities.AttendanceSessionStatus.Submitted ? "lm-badge-success" : "")">@s.Status</span></td><td><a asp-action="TakeAttendance" asp-route-groupId="@Model.Group.Id" asp-route-sessionId="@s.Id" class="lm-btn lm-btn-outline lm-btn-sm">View / edit</a></td></tr> }</tbody></table></div></section></main>
    <aside><section class="lm-panel"><div class="lm-panel-head"><div><h2 class="lm-panel-title">Group settings</h2><p class="lm-panel-subtitle">Keep the group details current.</p></div><i class="bi bi-sliders text-muted"></i></div><div class="lm-panel-body"><form asp-action="EditGroup" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Group.Id" /><div class="mb-3"><label class="lm-label">Group name</label><input name="GroupName" value="@Model.Group.GroupName" class="form-control" required maxlength="120" /></div><div class="mb-3"><label class="lm-label">Group colour</label><div class="lm-color-field"><input name="Color" value="@Model.Group.Color" type="color" class="form-control form-control-color" /><span class="small text-muted">Visual identifier</span></div></div><div class="mb-3"><label class="lm-label">Group note</label><textarea name="Note" class="form-control" rows="4">@Model.Group.Note</textarea></div><button class="lm-btn lm-btn-outline w-100"><i class="bi bi-check2"></i> Save changes</button></form></div></section>
    <section class="lm-panel"><div class="lm-panel-head"><div><h2 class="lm-panel-title">Add my students</h2><p class="lm-panel-subtitle">Select learners to include.</p></div><span class="lm-count-pill">@Model.AvailableStudents.Count</span></div><form asp-action="AddGroupStudents" method="post">@Html.AntiForgeryToken()<input type="hidden" name="groupId" value="@Model.Group.Id" /><div class="lm-scroll">@if (!Model.AvailableStudents.Any()) { <div class="lm-empty py-4"><span class="small">All your students are already in this group.</span></div> }@foreach (var s in Model.AvailableStudents) { <label class="lm-check-row"><input type="checkbox" name="linkIds" value="@s.LinkId" /><span><strong class="d-block small">@s.StudentName</strong><span class="lm-meta">@s.StudentNumber</span></span></label> }</div><div class="lm-panel-body pt-3"><button class="lm-btn lm-btn-primary w-100" disabled="@(!Model.AvailableStudents.Any())"><i class="bi bi-person-plus"></i> Add selected</button></div></form></section>
    <form asp-action="ArchiveGroup" method="post" class="mt-3" onsubmit="return confirm('Archive this group?');">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Group.Id" /><button class="lm-btn lm-btn-danger w-100"><i class="bi bi-archive"></i> Archive group</button></form></aside></div>
</div>
