@model ElecPOE.ViewModels.AdminLearnerManagementViewModel
@{
    ViewData["Title"] = "Facilitator Learner Management";
    var totalAllocated = Model.Facilitators.Sum(x => x.StudentCount);
    var submittedSessions = Model.RecentAttendance.Count(x => x.Status == ForekOnline.Domain.Entities.AttendanceSessionStatus.Submitted);
}
@section Styles { <link rel="stylesheet" href="~/css/learner-management.css" asp-append-version="true" /> }
<div class="lm-page">
    <section class="lm-hero"><div class="lm-hero-row"><div><div class="lm-eyebrow"><i class="bi bi-shield-check"></i> Administration overview</div><h1>Facilitator learner management</h1><p>Monitor allocation coverage, learning groups, attendance, communication and facilitator activity from one operational dashboard.</p></div><div class="lm-hero-actions"><button type="button" class="lm-btn lm-btn-light" id="refreshDashboard"><i class="bi bi-arrow-clockwise"></i> Refresh view</button></div></div></section>
    <div class="lm-stat-grid"><div class="lm-stat orange"><div class="lm-stat-top"><span class="lm-kicker">Facilitators</span><span class="lm-stat-icon"><i class="bi bi-person-badge"></i></span></div><div class="lm-stat-value">@Model.Facilitators.Count</div><div class="lm-stat-label">With learner management visibility</div></div><div class="lm-stat red"><div class="lm-stat-top"><span class="lm-kicker">Needs allocation</span><span class="lm-stat-icon"><i class="bi bi-person-exclamation"></i></span></div><div class="lm-stat-value">@Model.UnassignedStudents.Count</div><div class="lm-stat-label">Unassigned learners (first 100)</div></div><div class="lm-stat blue"><div class="lm-stat-top"><span class="lm-kicker">Shared allocation</span><span class="lm-stat-icon"><i class="bi bi-people"></i></span></div><div class="lm-stat-value">@Model.MultipleFacilitatorStudents.Count</div><div class="lm-stat-label">Multi-facilitator learners</div></div><div class="lm-stat green"><div class="lm-stat-top"><span class="lm-kicker">Learning groups</span><span class="lm-stat-icon"><i class="bi bi-collection"></i></span></div><div class="lm-stat-value">@Model.Groups.Count</div><div class="lm-stat-label">Across all facilitators</div></div></div>
    <section class="lm-panel"><div class="lm-panel-head"><div><h2 class="lm-panel-title">Facilitator coverage</h2><p class="lm-panel-subtitle">@totalAllocated active learner link(s) across the current facilitator team.</p></div><span class="lm-badge lm-badge-info"><i class="bi bi-activity"></i> Live overview</span></div><div class="table-responsive"><table class="lm-table"><thead><tr><th>Facilitator</th><th>Students</th><th>Active groups</th><th>Attendance sessions</th><th>Coverage</th><th>Last activity</th></tr></thead><tbody>@if (!Model.Facilitators.Any()) { <tr><td colspan="6"><div class="lm-empty">No facilitator activity is available.</div></td></tr> }@foreach (var f in Model.Facilitators) { var width = totalAllocated == 0 ? 0 : Math.Min(100, (int)Math.Round(f.StudentCount * 100d / Math.Max(1, Model.Facilitators.Max(x => x.StudentCount)))); <tr><td><div class="lm-person"><span class="lm-avatar"><i class="bi bi-person"></i></span><div><div class="lm-person-name">@f.FacilitatorName</div><div class="lm-meta">Facilitator</div></div></div></td><td><strong>@f.StudentCount</strong></td><td>@f.ActiveGroupCount</td><td>@f.AttendanceSessionCount</td><td style="min-width:130px"><div class="lm-progress"><span style="width:@width%"></span></div></td><td>@(f.LastActivityUtc?.ToString("dd MMM yyyy HH:mm") ?? "No activity")</td></tr> }</tbody></table></div></section>
    <section class="lm-admin-section"><div class="lm-admin-tabs" role="tablist"><button type="button" class="lm-admin-tab active" data-pane="allocation"><i class="bi bi-person-lines-fill me-1"></i> Allocation exceptions</button><button type="button" class="lm-admin-tab" data-pane="groups"><i class="bi bi-collection me-1"></i> Group overview</button><button type="button" class="lm-admin-tab" data-pane="operations"><i class="bi bi-clock-history me-1"></i> Recent operations</button><button type="button" class="lm-admin-tab" data-pane="audit"><i class="bi bi-shield-check me-1"></i> Activity audit</button></div>
        <div class="lm-admin-pane" data-pane-content="allocation"><div class="lm-grid-2"><section class="lm-panel"><div class="lm-panel-head"><div><h2 class="lm-panel-title">Unassigned learners</h2><p class="lm-panel-subtitle">First 100 learners without an active facilitator.</p></div><span class="lm-count-pill">@Model.UnassignedStudents.Count</span></div><div class="table-responsive lm-scroll"><table class="lm-table"><thead><tr><th>Learner</th><th>Student number</th></tr></thead><tbody>@if (!Model.UnassignedStudents.Any()) { <tr><td colspan="2"><div class="lm-empty py-4"><span class="lm-badge lm-badge-success">All covered</span></div></td></tr> }@foreach (var s in Model.UnassignedStudents) { <tr><td><strong>@s.FullName</strong></td><td>@s.StudentNumber</td></tr> }</tbody></table></div></section><section class="lm-panel"><div class="lm-panel-head"><div><h2 class="lm-panel-title">Shared learners</h2><p class="lm-panel-subtitle">Learners linked to multiple facilitators.</p></div><span class="lm-count-pill">@Model.MultipleFacilitatorStudents.Count</span></div><div class="table-responsive lm-scroll"><table class="lm-table"><thead><tr><th>Learner</th><th>Facilitators</th></tr></thead><tbody>@if (!Model.MultipleFacilitatorStudents.Any()) { <tr><td colspan="2"><div class="lm-empty py-4">No shared allocations.</div></td></tr> }@foreach (var s in Model.MultipleFacilitatorStudents) { <tr><td><strong>@s.StudentName</strong><div class="lm-meta">@s.StudentNumber</div></td><td>@string.Join(", ", s.Facilitators)</td></tr> }</tbody></table></div></section></div></div>
        <div class="lm-admin-pane" data-pane-content="groups" hidden><section class="lm-panel"><div class="lm-panel-head"><div><h2 class="lm-panel-title">Group overview</h2><p class="lm-panel-subtitle">Ownership, size, attendance volume and status.</p></div><span class="lm-count-pill">@Model.Groups.Count</span></div><div class="table-responsive"><table class="lm-table"><thead><tr><th>Facilitator</th><th>Group</th><th>Note</th><th>Students</th><th>Sessions</th><th>Status</th></tr></thead><tbody>@foreach (var row in Model.Groups) { <tr><td><strong>@row.FacilitatorName</strong></td><td><span class="lm-status-dot" style="background:@row.Group.Color"></span>@row.Group.Name</td><td><span class="lm-note-truncate">@(row.Group.Note ?? "—")</span></td><td>@row.Group.StudentCount</td><td>@row.Group.AttendanceSessionCount</td><td><span class="lm-badge">@row.Group.Status</span></td></tr> }</tbody></table></div></section></div>
        <div class="lm-admin-pane" data-pane-content="operations" hidden><div class="lm-grid-2"><section class="lm-panel"><div class="lm-panel-head"><div><h2 class="lm-panel-title">Recent attendance</h2><p class="lm-panel-subtitle">@submittedSessions submitted session(s) in this activity window.</p></div><i class="bi bi-calendar-check text-muted"></i></div><div class="table-responsive lm-scroll"><table class="lm-table"><thead><tr><th>Date</th><th>Facilitator / group</th><th>Status</th><th>Records</th></tr></thead><tbody>@foreach (var s in Model.RecentAttendance) { <tr><td>@s.AttendanceDate.ToString("dd MMM yyyy")</td><td><strong>@s.Facilitator.Name @s.Facilitator.LastName</strong><div class="lm-meta">@s.LearningGroup.GroupName</div></td><td><span class="lm-badge @(s.Status == ForekOnline.Domain.Entities.AttendanceSessionStatus.Submitted ? "lm-badge-success" : "")">@s.Status</span></td><td>@s.Records.Count</td></tr> }</tbody></table></div></section><section class="lm-panel"><div class="lm-panel-head"><div><h2 class="lm-panel-title">Message delivery</h2><p class="lm-panel-subtitle">Recent in-app and WhatsApp activity.</p></div><i class="bi bi-send text-muted"></i></div><div class="table-responsive lm-scroll"><table class="lm-table"><thead><tr><th>Time</th><th>Channel</th><th>Learner</th><th>Status</th></tr></thead><tbody>@foreach (var m in Model.RecentMessages) { <tr><td>@m.QueuedUtc.ToString("dd MMM HH:mm")</td><td><span class="lm-badge">@m.Channel</span></td><td>@m.Student.FullName</td><td><span class="lm-badge">@m.Status</span></td></tr> }</tbody></table></div></section></div></div>
        <div class="lm-admin-pane" data-pane-content="audit" hidden><section class="lm-panel"><div class="lm-panel-head"><div><h2 class="lm-panel-title">Recent activity audit</h2><p class="lm-panel-subtitle">Traceable facilitator learner-management events.</p></div><span class="lm-count-pill">@Model.RecentActivity.Count</span></div><div class="table-responsive"><table class="lm-table"><thead><tr><th>Time</th><th>User</th><th>Event</th><th>Entity</th><th>Details</th></tr></thead><tbody>@foreach (var a in Model.RecentActivity) { <tr><td>@a.EventUtc.ToString("dd MMM yyyy HH:mm")</td><td><strong>@a.ActorUser.Name @a.ActorUser.LastName</strong></td><td><span class="lm-badge lm-badge-info">@a.EventType</span></td><td>@a.EntityType</td><td><span class="lm-note-truncate">@(a.Notes ?? a.NewValue ?? "—")</span></td></tr> }</tbody></table></div></section></div>
    </section>
</div>
@section Scripts { <script>(()=>{const tabs=Array.from(document.querySelectorAll('.lm-admin-tab'));const panes=Array.from(document.querySelectorAll('.lm-admin-pane'));tabs.forEach(tab=>tab.addEventListener('click',()=>{tabs.forEach(x=>x.classList.toggle('active',x===tab));panes.forEach(p=>p.hidden=p.dataset.paneContent!==tab.dataset.pane);}));document.getElementById('refreshDashboard')?.addEventListener('click',()=>window.location.reload());})();</script> }
