@model ElecPOE.ViewModels.AdminLearnerManagementViewModel
@{ ViewData["Title"] = "Facilitator Learner Management"; }
<div class="mb-4"><h1 class="h3 mb-1">Facilitator Learner Management</h1><p class="text-muted mb-0">Coverage, groups, communication, attendance, and audit visibility.</p></div>
<div class="row g-3 mb-4"><div class="col-md-3"><div class="card card-body"><div class="text-muted small">Facilitators</div><div class="display-6">@Model.Facilitators.Count</div></div></div><div class="col-md-3"><div class="card card-body"><div class="text-muted small">Unassigned students</div><div class="display-6 text-warning">@Model.UnassignedStudents.Count</div></div></div><div class="col-md-3"><div class="card card-body"><div class="text-muted small">Multi-facilitator learners</div><div class="display-6">@Model.MultipleFacilitatorStudents.Count</div></div></div><div class="col-md-3"><div class="card card-body"><div class="text-muted small">Learning groups</div><div class="display-6">@Model.Groups.Count</div></div></div></div>
<div class="card mb-4"><div class="card-header">Facilitator coverage</div><div class="table-responsive"><table class="table mb-0"><thead><tr><th>Facilitator</th><th>Students</th><th>Active groups</th><th>Attendance sessions</th><th>Last activity</th></tr></thead><tbody>@foreach(var f in Model.Facilitators){<tr><td>@f.FacilitatorName</td><td>@f.StudentCount</td><td>@f.ActiveGroupCount</td><td>@f.AttendanceSessionCount</td><td>@(f.LastActivityUtc?.ToString("dd MMM yyyy HH:mm") ?? "—")</td></tr>}</tbody></table></div></div>
<div class="row g-4 mb-4"><div class="col-lg-6"><div class="card h-100"><div class="card-header">Unassigned students (first 100)</div><div class="table-responsive" style="max-height:420px"><table class="table mb-0"><thead><tr><th>Student</th><th>Number</th></tr></thead><tbody>@foreach(var s in Model.UnassignedStudents){<tr><td>@s.FullName</td><td>@s.StudentNumber</td></tr>}</tbody></table></div></div></div><div class="col-lg-6"><div class="card h-100"><div class="card-header">Students linked to multiple facilitators</div><div class="table-responsive" style="max-height:420px"><table class="table mb-0"><thead><tr><th>Student</th><th>Facilitators</th></tr></thead><tbody>@foreach(var s in Model.MultipleFacilitatorStudents){<tr><td><strong>@s.StudentName</strong><div class="small text-muted">@s.StudentNumber</div></td><td>@string.Join(", ", s.Facilitators)</td></tr>}</tbody></table></div></div></div></div>
<div class="card mb-4"><div class="card-header">Group overview</div><div class="table-responsive"><table class="table mb-0"><thead><tr><th>Facilitator</th><th>Group</th><th>Note</th><th>Students</th><th>Sessions</th><th>Status</th></tr></thead><tbody>@foreach(var row in Model.Groups){<tr><td>@row.FacilitatorName</td><td><span class="badge me-2" style="background:@row.Group.Color">&nbsp;</span>@row.Group.Name</td><td>@(row.Group.Note ?? "—")</td><td>@row.Group.StudentCount</td><td>@row.Group.AttendanceSessionCount</td><td>@row.Group.Status</td></tr>}</tbody></table></div></div>
<div class="row g-4"><div class="col-lg-6"><div class="card"><div class="card-header">Recent attendance</div><div class="table-responsive"><table class="table mb-0"><thead><tr><th>Date</th><th>Facilitator / group</th><th>Status</th><th>Records</th></tr></thead><tbody>@foreach(var s in Model.RecentAttendance){<tr><td>@s.AttendanceDate.ToString("dd MMM yyyy")</td><td>@s.Facilitator.Name @s.Facilitator.LastName<div class="small text-muted">@s.LearningGroup.GroupName</div></td><td>@s.Status</td><td>@s.Records.Count</td></tr>}</tbody></table></div></div></div><div class="col-lg-6"><div class="card"><div class="card-header">Message / WhatsApp logs</div><div class="table-responsive"><table class="table mb-0"><thead><tr><th>Time</th><th>Channel</th><th>Student</th><th>Status</th></tr></thead><tbody>@foreach(var m in Model.RecentMessages){<tr><td>@m.QueuedUtc.ToString("dd MMM HH:mm")</td><td>@m.Channel</td><td>@m.Student.FullName</td><td>@m.Status</td></tr>}</tbody></table></div></div></div></div>
<div class="card mt-4"><div class="card-header">Recent activity audit</div><div class="table-responsive"><table class="table mb-0"><thead><tr><th>Time</th><th>User</th><th>Event</th><th>Entity</th><th>Details</th></tr></thead><tbody>@foreach(var a in Model.RecentActivity){<tr><td>@a.EventUtc.ToString("dd MMM yyyy HH:mm")</td><td>@a.ActorUser.Name @a.ActorUser.LastName</td><td>@a.EventType</td><td>@a.EntityType</td><td class="small text-muted">@(a.Notes ?? a.NewValue ?? "—")</td></tr>}</tbody></table></div></div>
