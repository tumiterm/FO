@section Styles {
    <style>
        .progress-card {
            position: relative;
            border-radius: 18px;
            border: 1px solid rgba(15, 23, 42, 0.10);
            background: linear-gradient(180deg, rgba(255,255,255,0.86), rgba(255,255,255,0.70));
            box-shadow: 0 18px 50px rgba(15, 23, 42, 0.10);
            overflow: hidden;
        }

            .progress-card::before {
                content: "";
                position: absolute;
                inset: 0 0 auto 0;
                height: 6px;
                background: linear-gradient(90deg, #ff6a00, #d7263d);
            }

        .progress-labels {
            font-size: .85rem;
            color: #64748b;
        }

            .progress-labels span {
                white-space: nowrap;
            }

        .step-dots {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: .5rem;
            margin-top: .35rem;
        }

        .step-dot {
            width: 11px;
            height: 11px;
            border-radius: 999px;
            border: 1px solid rgba(15, 23, 42, 0.16);
            background: rgba(15, 23, 42, 0.10);
        }

            .step-dot.done,
            .step-dot.current {
                background: linear-gradient(135deg, #ff6a00, #d7263d);
                border-color: rgba(255, 106, 0, 0.30);
            }


        .highlighted-card {
            border: 1px solid rgba(255,106,0,.35);
            background: rgba(255,106,0,.06);
            box-shadow: 0 16px 40px rgba(255,106,0,.10);
        }

        .stage-row {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: .5rem;
            margin-top: .5rem;
        }

        .stage-pill {
            display: flex;
            align-items: center;
            gap: .45rem;
            padding: .45rem .55rem;
            border-radius: 14px;
            border: 1px solid rgba(15, 23, 42, 0.10);
            background: rgba(255, 255, 255, 0.65);
            min-height: 40px;
        }

        .stage-dot {
            width: 10px;
            height: 10px;
            border-radius: 999px;
            background: rgba(15, 23, 42, 0.18);
            border: 1px solid rgba(15, 23, 42, 0.12);
            flex: 0 0 auto;
        }

        .stage-text {
            font-size: .85rem;
            color: #0f172a;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .stage-here {
            margin-left: auto;
            font-size: .7rem;
            font-weight: 700;
            color: #0f172a;
            background: rgba(255, 106, 0, 0.12);
            border: 1px solid rgba(255, 106, 0, 0.22);
            padding: .1rem .45rem;
            border-radius: 999px;
            white-space: nowrap;
        }

        .stage-lock {
            margin-left: auto;
            color: rgba(15, 23, 42, 0.35);
        }

        .stage-item.is-done .stage-dot,
        .stage-item.is-current .stage-dot {
            background: linear-gradient(135deg, #ff6a00, #d7263d);
            border-color: rgba(255, 106, 0, 0.25);
        }

        /* Aggressive lock */
        .stage-item.is-locked .stage-pill {
            background: rgba(255, 255, 255, 0.30);
            border-color: rgba(15, 23, 42, 0.08);
            opacity: 0.65;
            filter: grayscale(0.45);
        }

        .stage-item.is-locked .stage-text {
            color: rgba(15, 23, 42, 0.55);
        }

        @@media (max-width: 420px) {
            .stage-here

        {
            display: none;
        }

        }

    </style>
}

@{
    Layout = "_OnlineApplications";
    ViewData["Title"] = "Applicant Profile";
}

@{
    var fullName = "Itumeleng Oliphant";
    var gender = "Male";
    var studentNumber = "FIT20260017";
    var age = 23;
    var course = "Information Technology (Support Services)";
    var appStatus = "In Review"; 
    var currentStage = "Admissions"; // demo: Profile | Admissions | Finance | Registration
    var turnaroundText = "5 working days"; 
    var lastUpdatedBy = "Admissions Officer"; 
    var lastUpdatedAgo = "2 days ago"; 
    var isInReview = true; 

}

<div class="row g-2 g-md-3 align-items-start mb-2">
    <!-- Left: Welcome + badges -->
    <div class="col-12 col-lg-7">
        <div class="d-flex align-items-center gap-2 mb-2">
            <span style="width:44px;height:44px;border-radius:16px;display:inline-flex;align-items:center;justify-content:center;background:linear-gradient(135deg,rgba(255,106,0,.18),rgba(215,38,61,.18));border:1px solid rgba(255,106,0,.22);">
                <i class="fa-solid fa-user-graduate" aria-hidden="true"></i>
            </span>
            <div class="min-w-0">
                <h2 class="h5 fw-bold mb-0 text-truncate">Welcome, @fullName</h2>
                <div class="text-muted small">Manage your application and registration journey.</div>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2 align-items-center">
            <span class="badge badge-soft rounded-pill px-3 py-2">
                <i class="fa-solid fa-id-badge me-2" aria-hidden="true"></i>
                Ref: @studentNumber
            </span>

            <button class="btn btn-outline-forek btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#appDetails" aria-expanded="false" aria-controls="appDetails">
                <i class="fa-solid fa-circle-info me-2" aria-hidden="true"></i>
                Application details
            </button>
        </div>

        <div class="collapse mt-2" id="appDetails">
            <div class="p-3 rounded-4 border" style="background: rgba(255,255,255,.65); border-color: rgba(15,23,42,.10) !important;">
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge badge-soft rounded-pill px-3 py-2">
                        <i class="fa-solid fa-venus-mars me-2" aria-hidden="true"></i>@gender
                    </span>
                    <span class="badge badge-soft rounded-pill px-3 py-2">
                        <i class="fa-solid fa-cake-candles me-2" aria-hidden="true"></i>Age: @age
                    </span>
                    <span class="badge badge-soft rounded-pill px-3 py-2 text-truncate" style="max-width: 100%;">
                        <i class="fa-solid fa-graduation-cap me-2" aria-hidden="true"></i>@course
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Primary actions (tight + aligned) -->
    <div class="col-12 col-lg-5">
        <div class="d-grid gap-2 d-sm-flex justify-content-lg-end">
            <a class="btn btn-outline-forek" href="#">
                <i class="fa-solid fa-pen-to-square me-2" aria-hidden="true"></i>
                Edit Profile
            </a>
            <a class="btn btn-forek" href="#">
                <i class="fa-solid fa-plus me-2" aria-hidden="true"></i>
                New Application
            </a>
        </div>
    </div>
    <div class="col-12">
        <div class="progress-card p-3">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                <div>
                    <div class="fw-bold">Application Progress</div>
                    <div class="text-muted small">A quick view of how far your application is.</div>
                </div>

                <span class="badge rounded-pill px-3 py-2" style="background: rgba(255,106,0,.12); border:1px solid rgba(255,106,0,.25); color: #0f172a;">
                    In Review
                </span>
            </div>

            <div class="mt-2">
                <div class="stage-row">
                    <div class="stage-item is-done">
                        <div class="stage-pill">
                            <span class="stage-dot"></span>
                            <span class="stage-text">Profile</span>
                        </div>
                    </div>

                    <div class="stage-item is-current">
                        <div class="stage-pill">
                            <span class="stage-dot"></span>
                            <span class="stage-text">Admissions</span>
                            <span class="stage-here">You are here</span>
                        </div>
                    </div>

                    <div class="stage-item is-locked" title="Locked until Admissions approves">
                        <div class="stage-pill">
                            <span class="stage-dot"></span>
                            <span class="stage-text">Finance</span>
                            <i class="fa-solid fa-lock stage-lock" aria-hidden="true"></i>
                        </div>
                    </div>

                    <div class="stage-item is-locked" title="Locked until Finance clears you">
                        <div class="stage-pill">
                            <span class="stage-dot"></span>
                            <span class="stage-text">Registration</span>
                            <i class="fa-solid fa-lock stage-lock" aria-hidden="true"></i>
                        </div>
                    </div>
                </div>

                <div class="progress mt-2" role="progressbar" aria-label="Application progress" aria-valuenow="45" aria-valuemin="0" aria-valuemax="100" style="height: 10px;">
                    <div class="progress-bar" style="width:45%; background: linear-gradient(135deg, #ff6a00, #d7263d);"></div>
                </div>

                <!-- Reassurance strip -->
                <div class="status-strip mt-2">
                    <i class="fa-solid fa-circle-info me-2" aria-hidden="true"></i>
                    We’re reviewing your application. You’ll hear from us within <strong>@turnaroundText</strong>. No action needed unless notified.
                </div>

                <!-- Audit trail -->
                <div class="small text-muted mt-2">
                    <i class="fa-regular fa-clock me-2" aria-hidden="true"></i>
                    Last updated by <strong>@lastUpdatedBy</strong> • @lastUpdatedAgo
                </div>
            </div>
        </div>
    </div>
</div>
<div class="row g-2 g-md-3">
    <div class="col-12 col-lg-6">
        <div class="p-3 p-md-4 rounded-4 border" style="background: rgba(255,255,255,.75); border-color: rgba(15,23,42,.10) !important;">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="fw-semibold">Requirements Checklist</div>
                    <div class="text-muted small">What you still need to complete.</div>
                </div>
                <span class="badge badge-soft rounded-pill px-3 py-2">
                    <i class="fa-solid fa-list-check me-2" aria-hidden="true"></i>
                    3/6 done
                </span>
            </div>

            <div class="d-grid gap-2 mt-3">
                <div class="d-flex align-items-start justify-content-between gap-2 p-2 rounded-3" style="border:1px solid rgba(15,23,42,.08); background: rgba(255,255,255,.55);">
                    <div class="min-w-0">
                        <div class="fw-semibold text-truncate">
                            <i class="fa-regular fa-circle-check me-2" aria-hidden="true"></i>
                            Profile completed
                        </div>
                        <div class="text-muted small">Personal details captured.</div>
                    </div>
                    <span class="badge rounded-pill px-3 py-2" style="background: rgba(22,163,74,.12); border:1px solid rgba(22,163,74,.25); color:#0f172a;">
                        Done
                    </span>
                </div>

                <div class="d-flex align-items-start justify-content-between gap-2 p-2 rounded-3" style="border:1px solid rgba(15,23,42,.08); background: rgba(255,255,255,.55);">
                    <div class="min-w-0">
                        <div class="fw-semibold text-truncate">
                            <i class="fa-solid fa-upload me-2" aria-hidden="true"></i>
                            Upload outstanding documents
                        </div>
                        <div class="text-muted small">3 of 5 documents uploaded.</div>
                    </div>
                    <span class="badge rounded-pill px-3 py-2" style="background: rgba(255,106,0,.12); border:1px solid rgba(255,106,0,.25); color:#0f172a;">
                        Action
                    </span>
                </div>

                <div class="d-flex align-items-start justify-content-between gap-2 p-2 rounded-3" style="border:1px solid rgba(15,23,42,.08); background: rgba(255,255,255,.55);">
                    <div class="min-w-0">
                        <div class="fw-semibold text-truncate">
                            <i class="fa-solid fa-user-check me-2" aria-hidden="true"></i>
                            Admissions decision
                        </div>
                        <div class="text-muted small">Pending review outcome.</div>
                    </div>
                    <span class="badge badge-soft rounded-pill px-3 py-2">
                        Pending
                    </span>
                </div>
            </div>

            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mt-3">
                <a class="text-decoration-none fw-semibold" href="#">
                    View all requirements
                    <i class="fa-solid fa-arrow-right ms-2" aria-hidden="true"></i>
                </a>

                <div class="d-flex gap-2">
                    <a class="btn btn-outline-forek btn-sm" href="#">
                        <i class="fa-solid fa-upload me-2" aria-hidden="true"></i>
                        Upload
                    </a>
                    <a class="btn btn-forek btn-sm" href="#">
                        <i class="fa-solid fa-clipboard-check me-2" aria-hidden="true"></i>
                        Continue
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="p-3 p-md-4 rounded-4 border" style="background: rgba(255,255,255,.75); border-color: rgba(15,23,42,.10) !important;">
            <div class="fw-semibold">Quick Actions</div>
            <div class="text-muted small">Common tasks.</div>

            <div class="d-grid gap-2 mt-3">
                <a class="btn btn-outline-forek" href="#">
                    <i class="fa-solid fa-upload me-2" aria-hidden="true"></i>
                    Upload Documents
                </a>
                <a class="btn btn-outline-forek" href="#">
                    <i class="fa-solid fa-pen-to-square me-2" aria-hidden="true"></i>
                    Continue Application
                </a>
                <a class="btn btn-outline-forek" href="#">
                    <i class="fa-solid fa-receipt me-2" aria-hidden="true"></i>
                    View Registration History
                </a>
            </div>
        </div>
    </div>
</div>