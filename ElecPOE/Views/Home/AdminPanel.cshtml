/* ===== OVERVIEW STRIP (4 metric cards) ===== */
.admin-dash .overview-row {
    margin-top:1.75rem;
    display:grid; gap:1.125rem;
    grid-template-columns:repeat(4,1fr);
}

@@media(max-width:1100px) { .admin-dash .overview-row { grid-template-columns:repeat(2,1fr); } }
@@media(max-width:580px)  { .admin-dash .overview-row { grid-template-columns:1fr; } }

.admin-dash .ov-card {
    background:var(--card); border-radius:20px;
    border:1px solid var(--border);
    padding:1.5rem 1.5rem 1.375rem;
    display:flex; flex-direction:column; gap:.75rem;
    position:relative; overflow:hidden;
    box-shadow:var(--sh-sm);
    transition:transform .3s ease,box-shadow .3s ease;
}

.admin-dash .ov-card:hover { transform:translateY(-4px); box-shadow:var(--sh-md); }

/* Color top bar */
.admin-dash .ov-card::before {
    content:''; position:absolute; top:0; left:0; right:0;
    height:3px; background:var(--ov-color,var(--red));
    border-radius:20px 20px 0 0;
}

/* Subtle tint wash */
.admin-dash .ov-card::after {
    content:''; position:absolute; top:0; right:0;
