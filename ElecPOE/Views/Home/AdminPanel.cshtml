/* KPI color helpers */
.k-red    { --kc:var(--red);    }
.k-blue   { --kc:var(--blue);   }
.k-green  { --kc:var(--green);  }
.k-violet { --kc:var(--violet); }
.k-teal   { --kc:var(--teal);   }
