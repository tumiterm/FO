}

.admin-dash .spark b:nth-child(1) { animation-delay:.04s; }
.admin-dash .spark b:nth-child(2) { animation-delay:.12s; opacity:.5; }
.admin-dash .spark b:nth-child(3) { animation-delay:.20s; opacity:.7; }
.admin-dash .spark b:nth-child(4) { animation-delay:.28s; opacity:.9; }

