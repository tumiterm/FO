    max-width: 1480px;
    margin: 0 auto;
}

/* ===== HERO ===== */
.admin-dash .dash-hero {
    border-radius: 28px;
    background: linear-gradient(148deg,#0B0608 0%,#190609 38%,#0E0812 72%,#07040F 100%);
