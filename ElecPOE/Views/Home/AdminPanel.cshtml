    }

        #dynamicNotificationsModal .modal-header .modal-title {
            margin: 0;
            font-weight: 600;
            letter-spacing: .5px;
            font-size: .9rem;
            display: flex;
            align-items: center;
            gap: .55rem;
        }

        #dynamicNotificationsModal .modal-header i {
            font-size: .95rem;
            filter: drop-shadow(0 2px 4px rgba(0,0,0,.25));
        }

    /* Base button style reinstated (was removed when dashboard refactored) */
