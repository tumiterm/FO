/* ===== ADMIN DASHBOARD 2026 ===== */
.admin-dash {
    /* Color tokens */
    --red:    #B41C22;   --red-lt:    rgba(180,28,34,.09);
    --orange: #EA580C;   --orange-lt: rgba(234,88,12,.09);
