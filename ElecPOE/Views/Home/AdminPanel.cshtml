@{
    ViewData["Title"] = "Admin Command Centre";
    ViewData["MetaDescription"] = "Forek Online administration command centre.";

    int formative   = (int?)ViewData["Formative"] ?? 0;
    int summative   = (int?)ViewData["Summative"] ?? 0;
    int practical   = (int?)ViewData["Practical"] ?? 0;
    int iisa        = (int?)ViewData["IISA"] ?? 0;
    int idDocs      = (int?)ViewData["ID"] ?? 0;
    int cvDocs      = (int?)ViewData["CV"] ?? 0;
    int matric      = (int?)ViewData["Matric"] ?? 0;
    int guardian    = (int?)ViewData["Guardian"] ?? 0;
    int enrollForms = (int?)ViewData["EnrollmentForm"] ?? 0;
    int induction   = (int?)ViewData["InductionForm"] ?? 0;
    int declaration = (int?)ViewData["Declaration"] ?? 0;
    int conduct     = (int?)ViewData["Conduct"] ?? 0;
    int nated       = (int?)ViewData["NATED"] ?? 0;
    int electrician = (int?)ViewData["Electrician"] ?? 0;
    int welder      = (int?)ViewData["Welder"] ?? 0;
    int plumber     = (int?)ViewData["Plumber"] ?? 0;

    int totalAssess      = formative + summative + practical + iisa;
    int totalLearnerDocs = idDocs + cvDocs + matric + guardian;
    int totalTraining    = enrollForms + induction + declaration + conduct;
    int totalReports     = nated + electrician + welder + plumber;
    int grandTotal       = totalAssess + totalLearnerDocs + totalTraining + totalReports;

    string currentUser = ViewData["CurrentUser"]?.ToString()?.Trim() ?? "Administrator";
    string role = ViewData["role"]?.ToString() ?? "Administrator";
    string firstName = currentUser.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "Administrator";
    string greeting = DateTime.Now.Hour < 12 ? "Good morning" : DateTime.Now.Hour < 18 ? "Good afternoon" : "Good evening";
    double share(int part, int whole) => whole == 0 ? 0 : (double)part / whole * 100;
}

@section Styles {
<style>
    :root {
        --ap-red: #b41c22;
        --ap-red-strong: #8f1119;
        --ap-grad: linear-gradient(110deg, #3d0608, #b41c22 58%, #d65a20);
    }

    .admin-command {
        --ap-red: #d92632;
        --ap-red-soft: rgba(217, 38, 50, .14);
        --ap-gold: #f1a94e;
        --ap-green: #55d6a5;
        --ap-blue: #73a7ff;
        --ap-violet: #b193ff;
        --ap-text: #f7f4f5;
        --ap-muted: #9b98a6;
        --ap-panel: rgba(18, 18, 29, .88);
        --ap-line: rgba(255, 255, 255, .085);
        width: min(1440px, calc(100% - 32px));
        margin: 0 auto;
        padding: 42px 0 72px;
        color: var(--ap-text);
        font-family: Inter, sans-serif;
    }

    .admin-command * { box-sizing: border-box; }

    .admin-command a:focus-visible,
    .admin-command button:focus-visible {
        outline: 3px solid rgba(241, 169, 78, .7);
        outline-offset: 3px;
    }

    .admin-command .command-hero {
        position: relative;
        min-height: 410px;
        overflow: hidden;
        display: grid;
        grid-template-columns: minmax(0, 1.45fr) minmax(330px, .75fr);
        border: 1px solid rgba(255, 255, 255, .09);
        border-radius: 32px;
        background:
            radial-gradient(circle at 88% 12%, rgba(217, 38, 50, .25), transparent 34%),
            radial-gradient(circle at 20% 115%, rgba(128, 50, 121, .21), transparent 38%),
            linear-gradient(135deg, #18101a 0%, #10101a 52%, #0c0c14 100%);
        box-shadow: 0 36px 90px rgba(0, 0, 0, .42), inset 0 1px rgba(255, 255, 255, .04);
    }

    .admin-command .command-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        opacity: .22;
        pointer-events: none;
        background-image:
            linear-gradient(rgba(255,255,255,.045) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,.045) 1px, transparent 1px);
        background-size: 52px 52px;
        mask-image: linear-gradient(90deg, #000, transparent 75%);
    }

    .admin-command .hero-copy {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 58px 64px;
    }

    .admin-command .eyebrow,
    .admin-command .section-kicker {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 18px;
        color: #d9a7aa;
        font-size: .68rem;
        font-weight: 800;
        letter-spacing: .18em;
        text-transform: uppercase;
    }

    .admin-command .eyebrow::before,
    .admin-command .section-kicker::before {
        content: "";
        width: 28px;
        height: 1px;
        background: linear-gradient(90deg, var(--ap-red), var(--ap-gold));
    }

    .admin-command .hero-copy h1 {
        max-width: 760px;
        margin: 0;
        font-family: "Space Grotesk", Inter, sans-serif;
        font-size: clamp(2.35rem, 5vw, 4.85rem);
        font-weight: 700;
        letter-spacing: -.055em;
        line-height: .98;
    }

    .admin-command .hero-copy h1 span {
        color: transparent;
        background: linear-gradient(105deg, #ffffff 4%, #d5a4a9 52%, #f1a94e 100%);
        -webkit-background-clip: text;
        background-clip: text;
    }

    .admin-command .hero-copy p {
        max-width: 630px;
        margin: 24px 0 0;
        color: #aaa6b2;
        font-size: .98rem;
        line-height: 1.75;
    }

    .admin-command .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 32px;
    }

    .admin-command .primary-action,
    .admin-command .secondary-action {
        min-height: 48px;
        padding: 0 20px;
        border: 1px solid transparent;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        color: #fff;
        font-size: .76rem;
        font-weight: 800;
        letter-spacing: .035em;
        text-decoration: none;
        transition: transform .2s ease, border-color .2s ease, background .2s ease, box-shadow .2s ease;
    }

    .admin-command .primary-action {
        background: linear-gradient(135deg, #e32c38, #a80f1b);
        box-shadow: 0 14px 30px rgba(190, 24, 35, .28), inset 0 1px rgba(255,255,255,.18);
    }

    .admin-command .secondary-action {
        border-color: rgba(255,255,255,.11);
        background: rgba(255,255,255,.055);
    }

    .admin-command .primary-action:hover,
    .admin-command .secondary-action:hover {
        color: #fff;
        transform: translateY(-2px);
        border-color: rgba(255,255,255,.22);
    }

    .admin-command .hero-status {
        position: relative;
        z-index: 1;
        margin: 22px;
        padding: 28px;
        align-self: stretch;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        border: 1px solid rgba(255,255,255,.1);
        border-radius: 24px;
        background: linear-gradient(155deg, rgba(255,255,255,.085), rgba(255,255,255,.025));
        box-shadow: inset 0 1px rgba(255,255,255,.07);
        backdrop-filter: blur(22px);
    }

    .admin-command .status-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 15px;
    }

    .admin-command .profile {
        display: flex;
        align-items: center;
        gap: 13px;
        min-width: 0;
    }

    .admin-command .avatar {
        width: 46px;
        height: 46px;
        flex: 0 0 46px;
        border-radius: 15px;
        display: grid;
        place-items: center;
        color: #fff;
        background: linear-gradient(145deg, #e12d39, #76101b);
        box-shadow: 0 10px 24px rgba(182, 24, 36, .28);
    }

    .admin-command .profile strong,
    .admin-command .profile span { display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .admin-command .profile strong { font-size: .84rem; }
    .admin-command .profile span { margin-top: 3px; color: var(--ap-muted); font-size: .66rem; }

    .admin-command .live-pill {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 7px 10px;
        border: 1px solid rgba(85, 214, 165, .2);
        border-radius: 99px;
        color: #71e8b8;
        background: rgba(85, 214, 165, .08);
        font-size: .6rem;
        font-weight: 800;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .admin-command .live-pill::before {
        content: "";
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #55d6a5;
        box-shadow: 0 0 10px #55d6a5;
    }

    .admin-command .record-total { margin: 40px 0 26px; }
    .admin-command .record-total span { color: var(--ap-muted); font-size: .67rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; }
    .admin-command .record-total strong { display: block; margin-top: 8px; font-family: "Space Grotesk", sans-serif; font-size: clamp(3.2rem, 5vw, 5.35rem); letter-spacing: -.07em; line-height: .92; }
    .admin-command .record-total small { display: block; margin-top: 12px; color: #aaa6b2; font-size: .72rem; }

    .admin-command .status-foot {
        padding-top: 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        border-top: 1px solid rgba(255,255,255,.08);
        color: var(--ap-muted);
        font-size: .68rem;
    }

    .admin-command .status-foot strong { color: #e1dee5; font-weight: 700; }

    .admin-command .section-heading {
        margin: 58px 0 22px;
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 24px;
    }

    .admin-command .section-kicker { margin-bottom: 9px; }
    .admin-command .section-heading h2 { margin: 0; font-family: "Space Grotesk", sans-serif; font-size: clamp(1.55rem, 3vw, 2.2rem); letter-spacing: -.035em; }
    .admin-command .section-heading p { max-width: 470px; margin: 0; color: var(--ap-muted); font-size: .78rem; line-height: 1.65; text-align: right; }

    .admin-command .quick-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
    }

    .admin-command .quick-card {
        position: relative;
        min-height: 210px;
        overflow: hidden;
        padding: 24px;
        display: flex;
        flex-direction: column;
        border: 1px solid var(--ap-line);
        border-radius: 22px;
        color: var(--ap-text);
        background: var(--ap-panel);
        text-decoration: none;
        box-shadow: inset 0 1px rgba(255,255,255,.025);
        transition: transform .25s ease, border-color .25s ease, background .25s ease, box-shadow .25s ease;
    }

    .admin-command .quick-card::after {
        content: "";
        position: absolute;
        right: -50px;
        bottom: -65px;
        width: 150px;
        height: 150px;
        border-radius: 50%;
        background: var(--card-glow);
        filter: blur(35px);
        opacity: .22;
        transition: opacity .25s ease, transform .25s ease;
    }

    .admin-command .quick-card:hover {
        color: #fff;
        transform: translateY(-5px);
        border-color: rgba(255,255,255,.18);
        background: rgba(23,23,36,.98);
        box-shadow: 0 24px 48px rgba(0,0,0,.25);
    }

    .admin-command .quick-card:hover::after { opacity: .42; transform: scale(1.15); }

    .admin-command .quick-icon {
        width: 46px;
        height: 46px;
        display: grid;
        place-items: center;
        border: 1px solid color-mix(in srgb, var(--card-color), transparent 65%);
        border-radius: 14px;
        color: var(--card-color);
        background: color-mix(in srgb, var(--card-color), transparent 89%);
        font-size: 1rem;
    }

    .admin-command .quick-card h3 { margin: auto 0 7px; font-size: .96rem; font-weight: 800; }
    .admin-command .quick-card p { margin: 0; color: var(--ap-muted); font-size: .72rem; line-height: 1.55; }
    .admin-command .quick-link { margin-top: 18px; display: flex; align-items: center; justify-content: space-between; color: #d8d4dc; font-size: .66rem; font-weight: 800; letter-spacing: .06em; text-transform: uppercase; }
    .admin-command .quick-link i { transition: transform .2s ease; }
    .admin-command .quick-card:hover .quick-link i { transform: translateX(4px); }

    .admin-command .metric-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
    }

    .admin-command .metric-card {
        --metric: var(--ap-red);
        position: relative;
        overflow: hidden;
        padding: 24px;
        border: 1px solid var(--ap-line);
        border-radius: 22px;
        background: linear-gradient(145deg, rgba(24,24,37,.94), rgba(15,15,25,.96));
    }

    .admin-command .metric-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 24px;
        right: 24px;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--metric), transparent);
    }

    .admin-command .metric-head { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
    .admin-command .metric-head span { color: var(--ap-muted); font-size: .68rem; font-weight: 800; letter-spacing: .09em; text-transform: uppercase; }
    .admin-command .metric-head i { color: var(--metric); }
    .admin-command .metric-value { margin-top: 24px; display: flex; align-items: end; justify-content: space-between; gap: 14px; }
    .admin-command .metric-value strong { font-family: "Space Grotesk", sans-serif; font-size: 2.65rem; letter-spacing: -.06em; line-height: 1; }
    .admin-command .metric-value span { color: var(--metric); font-size: .68rem; font-weight: 800; }
    .admin-command .meter { height: 4px; margin-top: 20px; overflow: hidden; border-radius: 10px; background: rgba(255,255,255,.06); }
    .admin-command .meter span { display: block; width: calc(var(--share) * 1%); height: 100%; border-radius: inherit; background: var(--metric); box-shadow: 0 0 14px var(--metric); }
    .admin-command .metric-card > p { margin: 13px 0 0; color: #777482; font-size: .66rem; }

    .admin-command .operations-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .admin-command .operation-panel {
        padding: 28px;
        border: 1px solid var(--ap-line);
        border-radius: 24px;
        background: rgba(18,18,29,.76);
    }

    .admin-command .operation-head { display: flex; align-items: center; justify-content: space-between; gap: 20px; padding-bottom: 22px; border-bottom: 1px solid var(--ap-line); }
    .admin-command .operation-title { display: flex; align-items: center; gap: 13px; }
    .admin-command .operation-icon { width: 42px; height: 42px; display: grid; place-items: center; border-radius: 13px; color: var(--panel-color); background: color-mix(in srgb, var(--panel-color), transparent 88%); }
    .admin-command .operation-title h3 { margin: 0; font-size: .9rem; }
    .admin-command .operation-title span { display: block; margin-top: 4px; color: var(--ap-muted); font-size: .65rem; }
    .admin-command .operation-total { color: var(--panel-color); font-family: "Space Grotesk", sans-serif; font-size: 1.5rem; font-weight: 700; }

    .admin-command .breakdown { display: grid; gap: 17px; margin-top: 23px; }
    .admin-command .breakdown-row { display: grid; grid-template-columns: 105px minmax(0,1fr) 44px; align-items: center; gap: 13px; }
    .admin-command .breakdown-label { color: #bbb7c2; font-size: .69rem; white-space: nowrap; }
    .admin-command .breakdown-track { height: 6px; overflow: hidden; border-radius: 10px; background: rgba(255,255,255,.055); }
    .admin-command .breakdown-track span { display: block; width: max(4px, calc(var(--row-share) * 1%)); height: 100%; border-radius: inherit; background: linear-gradient(90deg, color-mix(in srgb, var(--panel-color), #fff 14%), var(--panel-color)); }
    .admin-command .breakdown-value { color: #ebe8ee; font-size: .72rem; font-weight: 800; text-align: right; }

    #dynamicNotificationsModal .modal-header { color: #fff; border-bottom: 0; background: linear-gradient(110deg, #3d0608, #b41c22 58%, #d65a20); }

    @@media (max-width: 1120px) {
        .admin-command .command-hero { grid-template-columns: 1fr; }
        .admin-command .hero-status { min-height: 280px; }
        .admin-command .quick-grid, .admin-command .metric-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    @@media (max-width: 760px) {
        .admin-command { width: min(100% - 22px, 1440px); padding-top: 24px; }
        .admin-command .command-hero { border-radius: 24px; }
        .admin-command .hero-copy { padding: 38px 26px 28px; }
        .admin-command .hero-status { margin: 10px; padding: 23px; }
        .admin-command .section-heading { margin-top: 44px; display: block; }
        .admin-command .section-heading p { margin-top: 10px; text-align: left; }
        .admin-command .operations-grid { grid-template-columns: 1fr; }
    }

    @@media (max-width: 540px) {
        .admin-command .quick-grid, .admin-command .metric-grid { grid-template-columns: 1fr; }
        .admin-command .quick-card { min-height: 180px; }
        .admin-command .hero-actions > * { width: 100%; }
        .admin-command .status-top { align-items: flex-start; }
        .admin-command .live-pill { padding: 7px; font-size: 0; }
        .admin-command .operation-panel { padding: 22px 18px; }
        .admin-command .breakdown-row { grid-template-columns: 86px minmax(0,1fr) 36px; gap: 8px; }
    }

    @@media (prefers-reduced-motion: reduce) {
        .admin-command *, .admin-command *::before, .admin-command *::after { scroll-behavior: auto !important; transition: none !important; }
    }

        .nav-overlay {
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: rgba(9, 9, 13, .82);
            backdrop-filter: blur(14px) saturate(1.3);
            -webkit-backdrop-filter: blur(14px) saturate(1.3);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 20px;
            opacity: 0;
            visibility: hidden;
            transition: opacity .28s ease, visibility .28s ease;
            pointer-events: none;
        }

            .nav-overlay.is-active {
                opacity: 1;
                visibility: visible;
                pointer-events: all;
            }

        .nav-spin-wrap {
            position: relative;
            width: 62px;
            height: 62px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .nav-spin-outer {
            position: absolute;
            inset: 0;
            border-radius: 50%;
            border: 3px solid rgba(255, 255, 255, .06);
            border-top-color: var(--ap-gold);
            border-right-color: rgba(241, 169, 78, .3);
            animation: nav-spin .68s linear infinite;
        }

        .nav-spin-inner {
            position: absolute;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 2px solid transparent;
            border-bottom-color: var(--ap-red);
            border-left-color: rgba(217, 38, 50, .22);
            animation: nav-spin .92s linear infinite reverse;
        }

        .nav-overlay-copy strong {
            display: block;
            font-family: 'Space Grotesk', Inter, sans-serif;
            font-size: 1rem;
            font-weight: 700;
            color: #f7f4f5;
            text-align: center;
            margin-bottom: 5px;
        }

        .nav-overlay-copy span {
            display: block;
            font-size: .68rem;
            font-weight: 700;
            letter-spacing: .16em;
            text-transform: uppercase;
            color: rgba(255, 255, 255, .33);
            text-align: center;
        }


    .admin-command .pulse-strip {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: 1.15fr repeat(4, 1fr);
        gap: 1px;
        width: calc(100% - 64px);
        margin: -34px auto 56px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,.09);
        border-radius: 22px;
        background: rgba(255,255,255,.08);
        box-shadow: 0 24px 55px rgba(0,0,0,.3);
        backdrop-filter: blur(18px);
    }

    .admin-command .pulse-item {
        min-width: 0;
        padding: 18px 20px;
        background: rgba(18,18,29,.94);
    }

    .admin-command .pulse-item:first-child {
        display: flex;
        align-items: center;
        gap: 12px;
        background: linear-gradient(135deg, rgba(217,38,50,.92), rgba(143,17,25,.94));
    }

    .admin-command .pulse-item > i {
        display: grid;
        place-items: center;
        flex: 0 0 36px;
        width: 36px;
        height: 36px;
        border-radius: 12px;
        background: rgba(255,255,255,.12);
        color: #fff;
    }

    .admin-command .pulse-label {
        display: block;
        overflow: hidden;
        color: rgba(255,255,255,.44);
        font-size: .63rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-overflow: ellipsis;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .admin-command .pulse-item:first-child .pulse-label { color: rgba(255,255,255,.68); }
    .admin-command .pulse-value { display: block; margin-top: 5px; color: #fff; font-size: 1.05rem; font-weight: 800; }
    .admin-command .pulse-value small { margin-left: 5px; color: var(--ap-green); font-size: .62rem; font-weight: 700; }

    @@media (max-width: 900px) {
        .admin-command .pulse-strip { grid-template-columns: repeat(2, 1fr); width: calc(100% - 28px); }
        .admin-command .pulse-item:first-child { grid-column: 1 / -1; }
    }

    @@media (max-width: 520px) {
        .admin-command .pulse-strip { grid-template-columns: 1fr; margin-top: -20px; }
        .admin-command .pulse-item:first-child { grid-column: auto; }
    }

        @@keyframes nav-spin {
            to {
                transform: rotate(360deg);
            }
        }


        .admin-command {
            padding-top: 22px;
            padding-bottom: 44px;
        }

            .admin-command .command-hero {
                min-height: 260px;
                border-radius: 26px;
            }

            .admin-command .hero-copy {
                padding: 32px 40px;
            }

            .admin-command .eyebrow {
                margin-bottom: 10px;
                font-size: .6rem;
            }

            .admin-command .hero-copy h1 {
                font-size: clamp(1.3rem, 2.4vw, 2.25rem);
            }

            .admin-command .hero-copy p {
                font-size: .8rem;
                line-height: 1.55;
                margin-top: 12px;
            }

            .admin-command .hero-actions {
                margin-top: 18px;
                gap: 8px;
            }

            .admin-command .primary-action,
            .admin-command .secondary-action {
                min-height: 38px;
                padding: 0 14px;
                font-size: .68rem;
                border-radius: 12px;
            }

            .admin-command .hero-status {
                margin: 14px;
                padding: 18px;
                border-radius: 20px;
            }

            .admin-command .avatar {
                width: 38px;
                height: 38px;
                flex: 0 0 38px;
                border-radius: 12px;
            }

            .admin-command .profile strong {
                font-size: .76rem;
            }

            .admin-command .profile span {
                font-size: .62rem;
            }

            .admin-command .record-total {
                margin: 18px 0 12px;
            }

                .admin-command .record-total span {
                    font-size: .6rem;
                }

                .admin-command .record-total strong {
                    font-size: clamp(1.9rem, 3vw, 2.85rem);
                    margin-top: 5px;
                }

                .admin-command .record-total small {
                    font-size: .63rem;
                    margin-top: 6px;
                }

            .admin-command .status-foot {
                padding-top: 11px;
                font-size: .62rem;
            }

            .admin-command .live-pill {
                padding: 5px 9px;
                font-size: .56rem;
            }

            .admin-command .pulse-strip {
                margin-top: -18px;
                margin-bottom: 32px;
                border-radius: 18px;
            }

            .admin-command .pulse-item {
                padding: 12px 15px;
            }

            .admin-command .pulse-label {
                font-size: .56rem;
            }

            .admin-command .pulse-value {
                font-size: .92rem;
                margin-top: 4px;
            }

            .admin-command .pulse-item > i {
                flex: 0 0 30px;
                width: 30px;
                height: 30px;
                border-radius: 10px;
                font-size: .8rem;
            }

            .admin-command .section-heading {
                margin-top: 30px;
                margin-bottom: 13px;
                gap: 14px;
            }

            .admin-command .section-kicker {
                font-size: .58rem;
                margin-bottom: 6px;
            }

            .admin-command .section-heading h2 {
                font-size: clamp(1.1rem, 1.9vw, 1.6rem);
            }

            .admin-command .section-heading p {
                font-size: .72rem;
            }

            .admin-command .quick-grid {
                gap: 11px;
            }

            .admin-command .quick-card {
                min-height: 185px;
                padding: 18px;
                border-radius: 19px;
            }

                .admin-command .quick-card::before {
                    content: "";
                    position: absolute;
                    top: 0;
                    left: 18px;
                    right: 18px;
                    height: 1px;
                    background: linear-gradient(90deg, transparent, var(--card-color), transparent);
                    opacity: .5;
                    transition: opacity .25s ease, left .25s ease, right .25s ease;
                }

                .admin-command .quick-card:hover::before {
                    opacity: 1;
                    left: 8px;
                    right: 8px;
                }

                .admin-command .quick-card:hover {
                    box-shadow: 0 20px 44px rgba(0,0,0,.35), 0 0 0 1px color-mix(in srgb, var(--card-color) 32%, transparent);
                }

            .admin-command .quick-icon {
                width: 40px;
                height: 40px;
                border-radius: 12px;
                font-size: .9rem;
            }

            .admin-command .quick-card h3 {
                font-size: .88rem;
            }

            .admin-command .quick-card p {
                font-size: .67rem;
            }

            .admin-command .quick-link {
                font-size: .59rem;
                margin-top: 12px;
            }

            .admin-command .metric-grid {
                gap: 11px;
            }

            .admin-command .metric-card {
                padding: 18px;
                border-radius: 19px;
                transition: transform .25s ease, border-color .25s ease, box-shadow .25s ease;
            }

                .admin-command .metric-card:hover {
                    transform: translateY(-3px);
                    border-color: color-mix(in srgb, var(--metric) 30%, transparent);
                    box-shadow: 0 0 0 1px color-mix(in srgb, var(--metric) 18%, transparent), 0 16px 36px rgba(0,0,0,.26);
                }

            .admin-command .metric-head span {
                font-size: .6rem;
            }

            .admin-command .metric-value {
                margin-top: 14px;
            }

                .admin-command .metric-value strong {
                    font-size: 2.05rem;
                }

                .admin-command .metric-value span {
                    font-size: .62rem;
                }

            .admin-command .meter {
                margin-top: 12px;
                height: 3px;
            }
                /* Animate meter fill on page load */
                .admin-command .meter span {
                    animation: apMeterFill 1.1s cubic-bezier(.25,.8,.25,1) both .35s;
                }

            .admin-command .metric-card > p {
                font-size: .6rem;
                margin-top: 9px;
            }

        @@keyframes apMeterFill {
            from {
                width: 0;
            }

            to {
                width: calc(var(--share) * 1%);
            }
        }

        /* ── Operation panels — spiced up ── */
        .admin-command .operations-grid {
            gap: 11px;
        }

        .admin-command .operation-panel {
            padding: 20px;
            border-radius: 21px;
            border-left: 2px solid var(--panel-color);
            background: linear-gradient(155deg, rgba(20,20,34,.96), rgba(12,12,22,.98));
        }

        .admin-command .operation-head {
            padding-bottom: 14px;
        }

        .admin-command .operation-icon {
            width: 36px;
            height: 36px;
            border-radius: 11px;
            font-size: .88rem;
        }

        .admin-command .operation-title h3 {
            font-size: .82rem;
        }

        .admin-command .operation-title span {
            font-size: .6rem;
        }

        .admin-command .operation-total {
            font-size: 1.3rem;
        }

        .admin-command .breakdown {
            gap: 11px;
            margin-top: 16px;
        }

        .admin-command .breakdown-label {
            font-size: .64rem;
        }

        .admin-command .breakdown-value {
            font-size: .67rem;
        }

        .admin-command .breakdown-track {
            height: 5px;
        }

            .admin-command .breakdown-track span {
                animation: apTrackFill .9s cubic-bezier(.25,.8,.25,1) both .55s;
            }

        @@keyframes apTrackFill {
            from {
                width: 0;
            }

            to {
                width: max(4px, calc(var(--row-share) * 1%));
            }
        }

        .admin-command .command-hero {
            animation: apFadeUp .45s ease both;
        }

        .admin-command .pulse-strip {
            animation: apFadeUp .45s ease both .06s;
        }

        .admin-command section:nth-of-type(2) {
            animation: apFadeUp .45s ease both .1s;
        }

        .admin-command section:nth-of-type(3) {
            animation: apFadeUp .45s ease both .15s;
        }

        .admin-command section:nth-of-type(4) {
            animation: apFadeUp .45s ease both .2s;
        }

        @@keyframes apFadeUp {
            from {
                opacity: 0;
                transform: translateY(12px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@media (max-width: 760px) {
            .admin-command .command-hero {
                border-radius: 20px;
            }

            .admin-command .hero-copy {
                padding: 22px 22px 18px;
            }

            .admin-command .hero-status {
                margin: 8px;
                padding: 14px;
            }
        }

</style>
}

<main class="admin-command">
    <section class="command-hero" aria-labelledby="admin-welcome-title">
        <div class="hero-copy">
            <div class="eyebrow">Forek administration suite</div>
            <h1 id="admin-welcome-title">@greeting, <span>@firstName.</span></h1>
            <p>
                Your operational command centre for people, learning, assessments and compliance.
                Start a priority task or review the platform-wide record position below.
            </p>
            <div class="hero-actions">
                <a class="primary-action" asp-controller="Student" asp-action="SearchStudent">
                    <i class="fa-solid fa-magnifying-glass"></i> Find a learner
                </a>
                <a class="secondary-action" asp-controller="Student" asp-action="EnrollStudent">
                    <i class="fa-solid fa-user-plus"></i> Enrol new learner
                </a>
            </div>
        </div>

        <aside class="hero-status" aria-label="Administrator and platform status">
            <div class="status-top">
                <div class="profile">
                    <span class="avatar" aria-hidden="true"><i class="fa-solid fa-user-shield"></i></span>
                    <span>
                        <strong>@currentUser</strong>
                        <span>@role access</span>
                    </span>
                </div>
                <span class="live-pill">Live</span>
            </div>
            <div class="record-total">
                <span>Records under management</span>
                <strong>@grandTotal.ToString("N0")</strong>
                <small>Across four core administration areas</small>
            </div>
            <div class="status-foot">
                <span><i class="fa-regular fa-calendar me-2"></i>@DateTime.Now.ToString("dddd, dd MMMM")</span>
                <strong>Platform v2</strong>
            </div>
        </aside>
    </section>

    <div class="pulse-strip" aria-label="Administration record summary">
        <div class="pulse-item">
            <i class="fa-solid fa-wave-square" aria-hidden="true"></i>
            <span><span class="pulse-label">Portfolio pulse</span><strong class="pulse-value">Live overview</strong></span>
        </div>
        <div class="pulse-item"><span class="pulse-label">Assessments</span><strong class="pulse-value">@totalAssess.ToString("N0") <small>@share(totalAssess, grandTotal).ToString("0")%</small></strong></div>
        <div class="pulse-item"><span class="pulse-label">Learner documents</span><strong class="pulse-value">@totalLearnerDocs.ToString("N0") <small>@share(totalLearnerDocs, grandTotal).ToString("0")%</small></strong></div>
        <div class="pulse-item"><span class="pulse-label">Training records</span><strong class="pulse-value">@totalTraining.ToString("N0") <small>@share(totalTraining, grandTotal).ToString("0")%</small></strong></div>
        <div class="pulse-item"><span class="pulse-label">Trade reports</span><strong class="pulse-value">@totalReports.ToString("N0") <small>@share(totalReports, grandTotal).ToString("0")%</small></strong></div>
    </div>

    <section aria-labelledby="quick-actions-title">
        <div class="section-heading">
            <div>
                <div class="section-kicker">Priority workspace</div>
                <h2 id="quick-actions-title">Where would you like to begin?</h2>
            </div>
            <p>Direct access to the areas administrators use most, without navigating through multiple menus.</p>
        </div>

        <div class="quick-grid">
            <a class="quick-card" style="--card-color:#73a7ff;--card-glow:#397ae5" asp-controller="Student" asp-action="StudentAnalytics">
                <span class="quick-icon"><i class="fa-solid fa-graduation-cap"></i></span>
                <h3 class="text-white">Learner management</h3>
                <p>Review learner profiles, enrolments and supporting documentation.</p>
                <span class="quick-link">Open learners <i class="fa-solid fa-arrow-right"></i></span>
            </a>
            <a class="quick-card" style="--card-color:#f07880;--card-glow:#d92632" asp-controller="Assessment" asp-action="List">
                <span class="quick-icon"><i class="fa-solid fa-file-signature"></i></span>
                <h3 class="text-white">Assessments</h3>
                <p>Manage assessment activity, uploads and learner evidence.</p>
                <span class="quick-link">Open assessments <i class="fa-solid fa-arrow-right"></i></span>
            </a>
            <a class="quick-card" style="--card-color:#55d6a5;--card-glow:#1d9d70" asp-controller="Employee" asp-action="AdminEmployeePortal">
                <span class="quick-icon"><i class="fa-solid fa-id-badge"></i></span>
                <h3 class="text-white">Employee portal</h3>
                <p>Access employee records and administrative workforce tools.</p>
                <span class="quick-link">Open employees <i class="fa-solid fa-arrow-right"></i></span>
            </a>
            <a class="quick-card" style="--card-color:#f1a94e;--card-glow:#c7791d" asp-controller="Applications" asp-action="Applications">
                <span class="quick-icon"><i class="fa-solid fa-users-gear"></i></span>
                <h3 class="text-white">Online Applications</h3>
                <p>Access and control all online applications.</p>
                <span class="quick-link">Manage Online Applications <i class="fa-solid fa-arrow-right"></i></span>
            </a>
        </div>
    </section>

    <section aria-labelledby="portfolio-title">
        <div class="section-heading">
            <div>
                <div class="section-kicker">Portfolio pulse</div>
                <h2 id="portfolio-title">Administration at a glance</h2>
            </div>
            <p>A current distribution of records already captured across the platform's primary administration areas.</p>
        </div>

        <div class="metric-grid">
            <article class="metric-card" style="--metric:#f07880;--share:@share(totalAssess, grandTotal).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)">
                <div class="metric-head"><span>Assessments</span><i class="fa-solid fa-file-pen"></i></div>
                <div class="metric-value"><strong>@totalAssess.ToString("N0")</strong><span>@share(totalAssess, grandTotal).ToString("0")%</span></div>
                <div class="meter"><span></span></div>
                <p>Formative, summative, practical and IISA records</p>
            </article>
            <article class="metric-card" style="--metric:#73a7ff;--share:@share(totalLearnerDocs, grandTotal).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)">
                <div class="metric-head"><span>Learner documents</span><i class="fa-solid fa-folder-open"></i></div>
                <div class="metric-value"><strong>@totalLearnerDocs.ToString("N0")</strong><span>@share(totalLearnerDocs, grandTotal).ToString("0")%</span></div>
                <div class="meter"><span></span></div>
                <p>Identity, CV, matric and guardian documents</p>
            </article>
            <article class="metric-card" style="--metric:#55d6a5;--share:@share(totalTraining, grandTotal).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)">
                <div class="metric-head"><span>Training records</span><i class="fa-solid fa-clipboard-check"></i></div>
                <div class="metric-value"><strong>@totalTraining.ToString("N0")</strong><span>@share(totalTraining, grandTotal).ToString("0")%</span></div>
                <div class="meter"><span></span></div>
                <p>Enrolment, induction and compliance records</p>
            </article>
            <article class="metric-card" style="--metric:#b193ff;--share:@share(totalReports, grandTotal).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)">
                <div class="metric-head"><span>Progress reports</span><i class="fa-solid fa-chart-line"></i></div>
                <div class="metric-value"><strong>@totalReports.ToString("N0")</strong><span>@share(totalReports, grandTotal).ToString("0")%</span></div>
                <div class="meter"><span></span></div>
                <p>NATED and trade progression results</p>
            </article>
        </div>
    </section>

    <section aria-labelledby="operations-title">
        <div class="section-heading">
            <div>
                <div class="section-kicker">Operational detail</div>
                <h2 id="operations-title">Record composition</h2>
            </div>
            <p>See exactly where the current record volume sits within each administration category.</p>
        </div>

        <div class="operations-grid">
            <article class="operation-panel" style="--panel-color:#f07880">
                <div class="operation-head">
                    <div class="operation-title"><span class="operation-icon"><i class="fa-solid fa-file-pen"></i></span><span><h3 class="text-white">Assessment records</h3><span>Evidence and submissions</span></span></div>
                    <strong class="operation-total">@totalAssess.ToString("N0")</strong>
                </div>
                <div class="breakdown">
                    <div class="breakdown-row"><span class="breakdown-label">Formative</span><span class="breakdown-track"><span style="--row-share:@share(formative,totalAssess).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"></span></span><strong class="breakdown-value">@formative</strong></div>
                    <div class="breakdown-row"><span class="breakdown-label">Summative</span><span class="breakdown-track"><span style="--row-share:@share(summative,totalAssess).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"></span></span><strong class="breakdown-value">@summative</strong></div>
                    <div class="breakdown-row"><span class="breakdown-label">Practical</span><span class="breakdown-track"><span style="--row-share:@share(practical,totalAssess).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"></span></span><strong class="breakdown-value">@practical</strong></div>
                    <div class="breakdown-row"><span class="breakdown-label">IISA</span><span class="breakdown-track"><span style="--row-share:@share(iisa,totalAssess).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"></span></span><strong class="breakdown-value">@iisa</strong></div>
                </div>
            </article>

            <article class="operation-panel" style="--panel-color:#73a7ff">
                <div class="operation-head">
                    <div class="operation-title"><span class="operation-icon"><i class="fa-solid fa-folder-open"></i></span><span><h3 class="text-white">Learner documents</h3><span>Onboarding and identity</span></span></div>
                    <strong class="operation-total">@totalLearnerDocs.ToString("N0")</strong>
                </div>
                <div class="breakdown">
                    <div class="breakdown-row"><span class="breakdown-label">Identity</span><span class="breakdown-track"><span style="--row-share:@share(idDocs,totalLearnerDocs).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"></span></span><strong class="breakdown-value">@idDocs</strong></div>
                    <div class="breakdown-row"><span class="breakdown-label">CV</span><span class="breakdown-track"><span style="--row-share:@share(cvDocs,totalLearnerDocs).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"></span></span><strong class="breakdown-value">@cvDocs</strong></div>
                    <div class="breakdown-row"><span class="breakdown-label">Matric</span><span class="breakdown-track"><span style="--row-share:@share(matric,totalLearnerDocs).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"></span></span><strong class="breakdown-value">@matric</strong></div>
                    <div class="breakdown-row"><span class="breakdown-label">Guardian ID</span><span class="breakdown-track"><span style="--row-share:@share(guardian,totalLearnerDocs).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"></span></span><strong class="breakdown-value">@guardian</strong></div>
                </div>
            </article>

            <article class="operation-panel" style="--panel-color:#55d6a5">
                <div class="operation-head">
                    <div class="operation-title"><span class="operation-icon"><i class="fa-solid fa-clipboard-check"></i></span><span><h3 class="text-white">Training administration</h3><span>Onboarding and compliance</span></span></div>
                    <strong class="operation-total">@totalTraining.ToString("N0")</strong>
                </div>
                <div class="breakdown">
                    <div class="breakdown-row"><span class="breakdown-label">Enrolment</span><span class="breakdown-track"><span style="--row-share:@share(enrollForms,totalTraining).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"></span></span><strong class="breakdown-value">@enrollForms</strong></div>
                    <div class="breakdown-row"><span class="breakdown-label">Induction</span><span class="breakdown-track"><span style="--row-share:@share(induction,totalTraining).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"></span></span><strong class="breakdown-value">@induction</strong></div>
                    <div class="breakdown-row"><span class="breakdown-label">Declaration</span><span class="breakdown-track"><span style="--row-share:@share(declaration,totalTraining).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"></span></span><strong class="breakdown-value">@declaration</strong></div>
                    <div class="breakdown-row"><span class="breakdown-label">Conduct</span><span class="breakdown-track"><span style="--row-share:@share(conduct,totalTraining).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"></span></span><strong class="breakdown-value">@conduct</strong></div>
                </div>
            </article>

            <article class="operation-panel" style="--panel-color:#b193ff">
                <div class="operation-head">
                    <div class="operation-title"><span class="operation-icon"><i class="fa-solid fa-chart-line"></i></span><span><h3 class="text-white">Progress reporting</h3><span>Programme and trade results</span></span></div>
                    <strong class="operation-total">@totalReports.ToString("N0")</strong>
                </div>
                <div class="breakdown">
                    <div class="breakdown-row"><span class="breakdown-label">NATED</span><span class="breakdown-track"><span style="--row-share:@share(nated,totalReports).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"></span></span><strong class="breakdown-value">@nated</strong></div>
                    <div class="breakdown-row"><span class="breakdown-label">Electrician</span><span class="breakdown-track"><span style="--row-share:@share(electrician,totalReports).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"></span></span><strong class="breakdown-value">@electrician</strong></div>
                    <div class="breakdown-row"><span class="breakdown-label">Welder</span><span class="breakdown-track"><span style="--row-share:@share(welder,totalReports).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"></span></span><strong class="breakdown-value">@welder</strong></div>
                    <div class="breakdown-row"><span class="breakdown-label">Plumber</span><span class="breakdown-track"><span style="--row-share:@share(plumber,totalReports).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"></span></span><strong class="breakdown-value">@plumber</strong></div>
                </div>
            </article>
        </div>
    </section>
    <div class="nav-overlay" id="navOverlay" role="status" aria-live="polite" aria-label="Loading page">
        <div class="nav-spin-wrap">
            <div class="nav-spin-outer"></div>
            <div class="nav-spin-inner"></div>
        </div>
        <div class="nav-overlay-copy">
            <strong>Opening</strong>
            <span>Loading&hellip;</span>
        </div>
    </div>

</main>
@await Html.PartialAsync("_DynamicNotifications")
<script>window.__notificationsEndpoint = '/Notification/Index';</script>
<script src="~/js/notifications.js" asp-append-version="true"></script>
<script>
    (function () {
    const overlay = document.getElementById('navOverlay');
    if (!overlay) return;
    document.querySelectorAll('a.quick-card').forEach(function (card) {
    card.addEventListener('click', function () {
    overlay.classList.add('is-active');
    });
    });
    })();
</script>
