</style>

<div class="admin-dash">

    <!-- ===== HERO ===== -->
    <header class="dash-hero">
        <div class="hero-icon"><i class="fa fa-gauge-high"></i></div>

        <div class="hero-body">
            <h1 class="hero-title">Administrative Intelligence</h1>
            <p class="hero-sub">
                Real-time snapshot of document flow, assessment workload, and departmental reporting output.
            </p>
            <div class="hero-tags">
                <span class="hero-tag tag-live">Live</span>
                <span class="hero-tag"><i class="fa fa-layer-group"></i>&nbsp;Platform v2</span>
                <span class="hero-tag"><i class="fa fa-database"></i>&nbsp;@grandTotal Records</span>
                <span class="hero-tag"><i class="fa fa-calendar-days"></i>&nbsp;@DateTime.Now.ToString("dd MMM yyyy")</span>
            </div>
        </div>

        <div class="hero-toolbar">
            <button class="htb-btn" onclick="location.reload()">
                <i class="fa fa-rotate"></i> Refresh
            </button>
            <button class="htb-btn" data-bs-toggle="modal" data-bs-target="#staticBackdrop2">
                <i class="fa fa-circle-info"></i> What's New
            </button>
        </div>
    </header>

    <!-- ===== OVERVIEW STRIP ===== -->
    <div class="overview-row">

        <!-- Assessments -->
        <div class="ov-card"
             style="--ov-color:var(--red);--ov-lt:var(--red-lt);--pct:@((int)Math.Round(pct(totalAssess, grandTotal)))">
            <div class="ov-label">
                <span class="ov-ico"><i class="fa fa-file-pen"></i></span>
                Assessments
            </div>
            <div class="ov-num-row">
                <div class="ov-number">@totalAssess</div>
                <div class="donut" title="@Math.Round(pct(totalAssess, grandTotal))% of total records">
                    <span class="donut-pct">@((int)Math.Round(pct(totalAssess, grandTotal)))%</span>
                </div>
            </div>
            <div class="ov-break">
                <div class="ov-tags-lbl">Form &nbsp;·&nbsp; Sum &nbsp;·&nbsp; Prac &nbsp;·&nbsp; IISA</div>
                <div class="ov-vals">@formative &nbsp;/&nbsp; @summative &nbsp;/&nbsp; @practical &nbsp;/&nbsp; @iisa</div>
            </div>
        </div>

        <!-- Learner Docs -->
        <div class="ov-card"
             style="--ov-color:var(--blue);--ov-lt:var(--blue-lt);--pct:@((int)Math.Round(pct(totalLearnerDocs, grandTotal)))">
            <div class="ov-label">
                <span class="ov-ico"><i class="fa fa-id-card"></i></span>
                Learner Docs
            </div>
            <div class="ov-num-row">
                <div class="ov-number">@totalLearnerDocs</div>
                <div class="donut" title="@Math.Round(pct(totalLearnerDocs, grandTotal))% of total records">
                    <span class="donut-pct">@((int)Math.Round(pct(totalLearnerDocs, grandTotal)))%</span>
                </div>
            </div>
            <div class="ov-break">
                <div class="ov-tags-lbl">ID &nbsp;·&nbsp; CV &nbsp;·&nbsp; Matric &nbsp;·&nbsp; Guardian</div>
                <div class="ov-vals">@idDocs &nbsp;/&nbsp; @cvDocs &nbsp;/&nbsp; @matric &nbsp;/&nbsp; @guardian</div>
            </div>
        </div>

        <!-- Training Docs -->
        <div class="ov-card"
             style="--ov-color:var(--teal);--ov-lt:var(--teal-lt);--pct:@((int)Math.Round(pct(totalTraining, grandTotal)))">
            <div class="ov-label">
                <span class="ov-ico"><i class="fa fa-school"></i></span>
                Training Docs
            </div>
            <div class="ov-num-row">
                <div class="ov-number">@totalTraining</div>
                <div class="donut" title="@Math.Round(pct(totalTraining, grandTotal))% of total records">
                    <span class="donut-pct">@((int)Math.Round(pct(totalTraining, grandTotal)))%</span>
                </div>
            </div>
            <div class="ov-break">
                <div class="ov-tags-lbl">Enr &nbsp;·&nbsp; Ind &nbsp;·&nbsp; Dec &nbsp;·&nbsp; Conduct</div>
                <div class="ov-vals">@enrollForms &nbsp;/&nbsp; @induction &nbsp;/&nbsp; @declaration &nbsp;/&nbsp; @conduct</div>
            </div>
        </div>

        <!-- Reports -->
        <div class="ov-card"
             style="--ov-color:var(--violet);--ov-lt:var(--violet-lt);--pct:@((int)Math.Round(pct(totalReports, grandTotal)))">
            <div class="ov-label">
                <span class="ov-ico"><i class="fa fa-chart-line"></i></span>
                Progress Reports
            </div>
            <div class="ov-num-row">
                <div class="ov-number">@totalReports</div>
                <div class="donut" title="@Math.Round(pct(totalReports, grandTotal))% of total records">
                    <span class="donut-pct">@((int)Math.Round(pct(totalReports, grandTotal)))%</span>
                </div>
            </div>
            <div class="ov-break">
                <div class="ov-tags-lbl">Nated &nbsp;·&nbsp; Elec &nbsp;·&nbsp; Weld &nbsp;·&nbsp; Plmb</div>
                <div class="ov-vals">@nated &nbsp;/&nbsp; @electrician &nbsp;/&nbsp; @welder &nbsp;/&nbsp; @plumber</div>
            </div>
        </div>

    </div><!-- /overview-row -->

    <!-- ===== DETAIL PANELS ===== -->
    <div class="detail-grid">

        <!-- Assessment Uploads -->
        <div class="det-panel" style="--pc:var(--red);--pc-lt:var(--red-lt);">
            <div class="det-head">
                <div class="det-ico"><i class="fa fa-file-pen"></i></div>
                <div>
                    <div class="det-title">Assessment Uploads</div>
                    <div class="det-sub">Formative, summative, practical &amp; IISA workload</div>
                </div>
            </div>
            <div class="kpi-grid">
                <div class="kpi-box k-red">
                    <div class="kpi-lbl">Formatives</div>
                    <div class="kpi-val">@formative</div>
                    <div class="spark">
                        <b style="height:40%;"></b><b style="height:68%;"></b>
                        <b style="height:52%;"></b><b style="height:88%;"></b>
                    </div>
                </div>
                <div class="kpi-box k-violet">
                    <div class="kpi-lbl">Summatives</div>
                    <div class="kpi-val">@summative</div>
                    <div class="spark">
                        <b style="height:32%;"></b><b style="height:88%;"></b>
                        <b style="height:58%;"></b><b style="height:42%;"></b>
                    </div>
                </div>
                <div class="kpi-box k-teal">
                    <div class="kpi-lbl">Practicals</div>
