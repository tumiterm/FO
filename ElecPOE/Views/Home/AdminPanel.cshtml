}

/* Live pulse tag */
.admin-dash .tag-live {
    background:rgba(5,150,105,.18); color:#34D399;
    border-color:rgba(52,211,153,.25);
}

.admin-dash .tag-live::before {
    content:''; width:6px; height:6px; border-radius:50%;
