}

.admin-dash .dash-hero::before {
    content:''; position:absolute; inset:0; pointer-events:none;
    background:
        radial-gradient(ellipse 110% 65% at -5% 55%,rgba(180,28,34,.25) 0%,transparent 52%),
        radial-gradient(ellipse 70% 55% at 105% 15%,rgba(234,88,12,.13) 0%,transparent 50%),
        radial-gradient(ellipse 55% 40% at 65% 105%,rgba(124,58,237,.09) 0%,transparent 45%);
}

.admin-dash .dash-hero::after {
    content:''; position:absolute; inset:0; pointer-events:none;
    background-image:
        linear-gradient(rgba(255,255,255,.016) 1px,transparent 1px),
        linear-gradient(90deg,rgba(255,255,255,.016) 1px,transparent 1px);
    background-size:28px 28px;
}

.admin-dash .hero-icon {
    position:relative; z-index:1; flex-shrink:0;
    width:84px; height:84px; border-radius:24px;
    background:linear-gradient(135deg,#8E0F14,#B41C22 50%,#D43030);
    display:flex; align-items:center; justify-content:center;
    font-size:2.1rem; color:#fff;
    box-shadow:
        0 0 0 1px rgba(255,255,255,.07),
        0 8px 32px rgba(180,28,34,.55),
        0 0 56px rgba(180,28,34,.22);
}

.admin-dash .hero-body {
    position:relative; z-index:1; flex:1; min-width:200px;
}

.admin-dash .hero-title {
    margin:0; font-size:1.85rem; font-weight:800;
    color:#FFFFFF; letter-spacing:-.6px; line-height:1.12;
}

.admin-dash .hero-sub {
    margin:.45rem 0 0; font-size:.8rem; font-weight:400;
    color:rgba(255,255,255,.44); line-height:1.6; max-width:520px;
}

.admin-dash .hero-tags {
    display:flex; flex-wrap:wrap; gap:.5rem; margin-top:1rem;
}

.admin-dash .hero-tag {
    font-size:.58rem; font-weight:700; letter-spacing:1.3px; text-transform:uppercase;
    padding:.34rem .8rem; border-radius:99px;
    background:rgba(255,255,255,.07); color:rgba(255,255,255,.5);
