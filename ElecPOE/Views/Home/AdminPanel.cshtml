    animation:ap-pulse 1.6s ease-in-out infinite;
}

@@keyframes ap-pulse {
    0%,100% { opacity:1; }
    50%      { opacity:.3; }
}

/* Glass toolbar buttons */
.admin-dash .hero-toolbar {
    position:relative; z-index:1;
    display:flex; gap:.625rem; flex-wrap:wrap; flex-shrink:0;
}

.admin-dash .htb-btn {
    font-family:inherit; font-size:.68rem; font-weight:600;
    letter-spacing:.5px; text-transform:uppercase;
    padding:.68rem 1.2rem; border-radius:99px;
    border:1px solid rgba(255,255,255,.13);
    background:rgba(255,255,255,.07);
    color:rgba(255,255,255,.68);
    display:inline-flex; align-items:center; gap:.45rem;
