@model ForekOnline.Domain.ViewModels.ResourceListViewModel
@using ForekOnline.Application.Common.Utility
@using static ForekOnline.Domain.Enums.EnumRegistry

@{
    Layout = null;

    var resources = Model.Resources?.ToList() ?? new();
    var categories = Model.Categories ?? new();

    int total = resources.Count;
    int distinctCategories = resources.Select(r => r.CategoryName).Distinct().Count();
    var byCategory = resources
        .Where(r => !string.IsNullOrWhiteSpace(r.CategoryName))
        .GroupBy(r => r.CategoryName)
        .OrderByDescending(g => g.Count())
        .ToList();

    var topCategory = byCategory.FirstOrDefault()?.Key ?? "All";
}

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <title>Resources — Forek Online</title>
    <meta name="viewport" content="width=device-width,initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <style>
        :root {
            --d-bg: #0c0e14;
            --d-bg-2: #12151e;
            --d-bg-3: #181c28;
            --d-surface: rgba(255,255,255,.04);
            --d-surface-2: rgba(255,255,255,.06);
            --d-surface-3: rgba(255,255,255,.08);
            --d-glass: rgba(24,28,40,.72);
            --d-glass-border: rgba(255,255,255,.08);
            --d-glass-border-2: rgba(255,255,255,.12);
            --d-text: #e8eaf0;
            --d-text-2: #9ba1b0;
            --d-text-3: #6b7186;
            --d-accent: #ff7a18;
            --d-accent-2: #ff9547;
            --d-red: #ef4444;
            --d-green: #22c55e;
            --d-blue: #3b82f6;
            --d-indigo: #818cf8;
            --d-grad: linear-gradient(135deg, #ff7a18 0%, #b31217 50%, #320606 100%);
            --d-shadow: 0 4px 24px rgba(0,0,0,.4);
            --d-shadow-lg: 0 12px 48px rgba(0,0,0,.5);
            --d-radius: 16px;
            --d-radius-sm: 10px;
            --d-radius-lg: 24px;
            --d-transition: .25s cubic-bezier(.4,0,.2,1);
        }

        [data-theme="light"] {
            --d-bg: #f5f6fa;
            --d-bg-2: #eceef3;
            --d-bg-3: #e4e6ec;
            --d-surface: rgba(0,0,0,.03);
            --d-surface-2: rgba(0,0,0,.05);
            --d-surface-3: rgba(0,0,0,.07);
            --d-glass: rgba(255,255,255,.82);
            --d-glass-border: rgba(0,0,0,.08);
            --d-glass-border-2: rgba(0,0,0,.12);
            --d-text: #1a1a2e;
            --d-text-2: #555b6e;
            --d-text-3: #8e93a3;
            --d-shadow: 0 4px 24px rgba(0,0,0,.08);
            --d-shadow-lg: 0 12px 48px rgba(0,0,0,.12);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background: var(--d-bg);
            color: var(--d-text);
            -webkit-font-smoothing: antialiased;
            min-height: 100vh;
            overflow-x: hidden;
        }

            body::before {
                content: "";
                position: fixed;
                inset: 0;
                background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.025'/%3E%3C/svg%3E");
                pointer-events: none;
                z-index: 9999;
            }

        /* Sidebar */
        .sidebar {
            position: fixed;
            left: 0;
            top: 0;
            bottom: 0;
            width: 260px;
            background: var(--d-bg-2);
            border-right: 1px solid var(--d-glass-border);
            display: flex;
            flex-direction: column;
            z-index: 100;
            transition: transform .3s;
        }

        .sidebar-brand {
            padding: 1.4rem 1.3rem;
            display: flex;
            align-items: center;
            gap: .75rem;
            border-bottom: 1px solid var(--d-glass-border);
        }

        .sidebar-brand-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: var(--d-grad);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            color: #fff;
            box-shadow: 0 4px 16px rgba(255,122,24,.3);
        }

        .sidebar-brand-text {
            font-weight: 800;
            font-size: .95rem;
            letter-spacing: -.2px;
        }

            .sidebar-brand-text small {
                display: block;
                font-size: .58rem;
                font-weight: 500;
                color: var(--d-text-3);
                letter-spacing: .3px;
                text-transform: uppercase;
                margin-top: 1px;
            }

        .sidebar-nav {
            flex: 1;
            padding: 1rem 0;
            overflow-y: auto;
        }

        .nav-section-label {
            font-size: .54rem;
            letter-spacing: .2rem;
            text-transform: uppercase;
            font-weight: 700;
            color: var(--d-text-3);
            padding: .6rem 1.3rem .35rem;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: .65rem;
            padding: .6rem 1.3rem;
            font-size: .82rem;
            font-weight: 600;
            color: var(--d-text-2);
            text-decoration: none;
            margin: 0 .5rem;
            border-radius: var(--d-radius-sm);
            transition: all var(--d-transition);
        }

            .sidebar-link i {
                font-size: 1rem;
                width: 1.2rem;
                text-align: center;
                opacity: .7;
            }

            .sidebar-link:hover {
                background: var(--d-surface-2);
                color: var(--d-text);
            }

                .sidebar-link:hover i {
                    opacity: 1;
                }

            .sidebar-link.active {
                background: var(--d-grad);
                color: #fff;
                box-shadow: 0 4px 16px rgba(255,122,24,.25);
            }

                .sidebar-link.active i {
                    opacity: 1;
                }

        .sidebar-footer {
            padding: 1rem 1.3rem;
            border-top: 1px solid var(--d-glass-border);
            font-size: .65rem;
            color: var(--d-text-3);
        }

        /* Topbar */
        .topbar {
            position: fixed;
            top: 0;
            left: 260px;
            right: 0;
            height: 64px;
            background: var(--d-glass);
            border-bottom: 1px solid var(--d-glass-border);
            display: flex;
            align-items: center;
            padding: 0 1.5rem;
            gap: 1rem;
            z-index: 99;
        }

        .topbar-live {
            display: flex;
            align-items: center;
            gap: .5rem;
            font-size: .7rem;
            font-weight: 600;
            color: var(--d-text-2);
        }

        .live-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--d-green);
            animation: pulse-dot 2s infinite;
        }

        @@keyframes pulse-dot {
            0%, 100% {
                box-shadow: 0 0 0 0 rgba(34,197,94,.6);
            }

            50% {
                box-shadow: 0 0 0 6px rgba(34,197,94,0);
            }
        }

        .topbar-search {
            flex: 1;
            max-width: 520px;
            position: relative;
        }

            .topbar-search input {
                width: 100%;
                background: var(--d-surface-2);
                border: 1px solid var(--d-glass-border);
                border-radius: var(--d-radius-sm);
                padding: .55rem .85rem .55rem 2.3rem;
                font-size: .78rem;
                color: var(--d-text);
                transition: all var(--d-transition);
            }

                .topbar-search input::placeholder {
                    color: var(--d-text-3);
                }

                .topbar-search input:focus {
                    outline: none;
                    border-color: var(--d-accent);
                    box-shadow: 0 0 0 3px rgba(255,122,24,.12);
                    background: var(--d-surface-3);
                }

            .topbar-search .bi-search {
                position: absolute;
                left: .8rem;
                top: 50%;
                transform: translateY(-50%);
                color: var(--d-text-3);
                font-size: .85rem;
            }

        .search-hint {
            position: absolute;
            right: .65rem;
            top: 50%;
            transform: translateY(-50%);
            font-size: .55rem;
            font-weight: 600;
            color: var(--d-text-3);
            background: var(--d-surface-2);
            padding: .2rem .45rem;
            border-radius: 5px;
            border: 1px solid var(--d-glass-border);
            pointer-events: none;
        }

        .topbar-actions {
            display: flex;
            align-items: center;
            gap: .6rem;
            margin-left: auto;
        }

        .topbar-btn {
            width: 38px;
            height: 38px;
            border-radius: var(--d-radius-sm);
            border: 1px solid var(--d-glass-border);
            background: var(--d-surface);
            color: var(--d-text-2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            transition: all var(--d-transition);
            position: relative;
            cursor: pointer;
        }

            .topbar-btn:hover {
                background: var(--d-surface-3);
                color: var(--d-text);
                border-color: var(--d-glass-border-2);
            }

        .topbar-avatar {
            width: 36px;
            height: 36px;
            border-radius: var(--d-radius-sm);
            background: var(--d-grad);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 800;
            font-size: .75rem;
            cursor: pointer;
        }

        .theme-toggle {
            cursor: pointer;
        }

        .sidebar-toggle {
            display: none;
            width: 40px;
            height: 40px;
            border: 1px solid var(--d-glass-border);
            background: var(--d-surface);
            border-radius: var(--d-radius-sm);
            color: var(--d-text);
            font-size: 1.1rem;
            cursor: pointer;
        }

        /* Layout */
        .main-area {
            margin-left: 260px;
            padding-top: 64px;
            min-height: 100vh;
        }

        .main-content {
            padding: 1.5rem 1.6rem 3rem;
            max-width: 1280px;
            margin: 0 auto;
        }

        .page-header {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.25rem;
        }

            .page-header h1 {
                font-size: 1.55rem;
                font-weight: 800;
                letter-spacing: -.3px;
                display: flex;
                align-items: center;
                gap: .65rem;
            }

                .page-header h1 .icon-box {
                    width: 48px;
                    height: 48px;
                    border-radius: 14px;
                    background: var(--d-grad);
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    color: #fff;
                    font-size: 1.25rem;
                    box-shadow: 0 8px 24px rgba(255,122,24,.25);
                }

        .page-header-sub {
            font-size: .74rem;
            color: var(--d-text-3);
            margin-top: .25rem;
            line-height: 1.3;
        }

        .page-header-actions {
            display: flex;
            gap: .5rem;
            margin-left: auto;
        }

        .btn-glass {
            background: var(--d-surface-2);
            border: 1px solid var(--d-glass-border);
            color: var(--d-text);
            padding: .5rem .85rem;
            border-radius: var(--d-radius-sm);
            font-size: .72rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            transition: all var(--d-transition);
            text-decoration: none;
            cursor: pointer;
        }

            .btn-glass:hover {
                background: var(--d-surface-3);
                border-color: var(--d-glass-border-2);
                color: var(--d-text);
            }

        .btn-grad {
            background: var(--d-grad);
            border: none;
            color: #fff;
            padding: .55rem .95rem;
            border-radius: var(--d-radius-sm);
            font-size: .72rem;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: .45rem;
            transition: all var(--d-transition);
            text-decoration: none;
            box-shadow: 0 4px 16px rgba(255,122,24,.25);
        }

            .btn-grad:hover {
                filter: brightness(1.1);
                box-shadow: 0 6px 24px rgba(255,122,24,.35);
                transform: translateY(-1px);
                color: #fff;
            }

        /* Stats */
        .stats-grid {
            display: grid;
            gap: 1rem;
            grid-template-columns: repeat(4, 1fr);
            margin-bottom: 1.1rem;
        }

        .stat-card {
            background: var(--d-glass);
            border: 1px solid var(--d-glass-border);
            border-radius: var(--d-radius-lg);
            padding: 1.1rem;
            position: relative;
            overflow: hidden;
            transition: all .4s var(--d-transition);
        }

            .stat-card:hover {
                transform: translateY(-4px);
                border-color: var(--d-glass-border-2);
                box-shadow: var(--d-shadow-lg);
            }

        .stat-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: .75rem;
        }

        .stat-icon {
            width: 44px;
            height: 44px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.15rem;
        }

        .stat-card:nth-child(1) .stat-icon {
            background: rgba(255,122,24,.15);
            color: var(--d-accent);
        }

        .stat-card:nth-child(2) .stat-icon {
            background: rgba(59,130,246,.15);
            color: var(--d-blue);
        }

        .stat-card:nth-child(3) .stat-icon {
            background: rgba(34,197,94,.15);
            color: var(--d-green);
        }

        .stat-card:nth-child(4) .stat-icon {
            background: rgba(129,140,248,.15);
            color: var(--d-indigo);
        }

        .stat-value {
            font-size: 1.8rem;
            font-weight: 800;
            letter-spacing: -.5px;
            line-height: 1;
        }

        .stat-label {
            font-size: .6rem;
            letter-spacing: .15rem;
            text-transform: uppercase;
            font-weight: 700;
            color: var(--d-text-3);
            margin-top: .35rem;
        }

        .pill {
            font-size: .58rem;
            padding: .35rem .6rem;
            border-radius: 30px;
            letter-spacing: .1rem;
            font-weight: 800;
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            text-transform: uppercase;
            border: 1px solid transparent;
            background: var(--d-surface-2);
            color: var(--d-text-2);
        }

        /* Filter */
        .filter-bar {
            background: var(--d-glass);
            border: 1px solid var(--d-glass-border);
            border-radius: var(--d-radius-lg);
            padding: .85rem 1.1rem;
            display: flex;
            flex-wrap: wrap;
            gap: .75rem;
            align-items: center;
            margin-bottom: 1rem;
        }

        .filter-group {
            display: flex;
            flex-direction: column;
            gap: .2rem;
        }

            .filter-group label {
                font-size: .52rem;
                letter-spacing: .18rem;
                text-transform: uppercase;
                font-weight: 800;
                color: var(--d-text-3);
            }

        .filter-input {
            background: var(--d-surface-2);
            border: 1px solid var(--d-glass-border);
            color: var(--d-text);
            padding: .5rem .7rem;
            font-size: .72rem;
            border-radius: var(--d-radius-sm);
            transition: all var(--d-transition);
            min-width: 180px;
        }

            .filter-input:focus {
                outline: none;
                border-color: var(--d-accent);
                box-shadow: 0 0 0 3px rgba(255,122,24,.1);
            }

        .filter-search {
            flex: 1;
            min-width: 260px;
            position: relative;
        }

            .filter-search input {
                width: 100%;
                background: var(--d-surface-2);
                border: 1px solid var(--d-glass-border);
                color: var(--d-text);
                padding: .55rem .85rem .55rem 2.2rem;
                font-size: .74rem;
                border-radius: var(--d-radius-sm);
                transition: all var(--d-transition);
            }

                .filter-search input::placeholder {
                    color: var(--d-text-3);
                }

                .filter-search input:focus {
                    outline: none;
                    border-color: var(--d-accent);
                    box-shadow: 0 0 0 3px rgba(255,122,24,.1);
                }

            .filter-search i {
                position: absolute;
                left: .75rem;
                top: 50%;
                transform: translateY(-50%);
                color: var(--d-text-3);
            }

        /* Table panel */
        .table-panel {
            background: var(--d-glass);
            border: 1px solid var(--d-glass-border);
            border-radius: var(--d-radius-lg);
            overflow: hidden;
        }

            .table-panel table {
                width: 100%;
                border-collapse: collapse;
                font-size: .74rem;
            }

            .table-panel thead th {
                background: var(--d-surface-2);
                font-size: .55rem;
                letter-spacing: .18rem;
                text-transform: uppercase;
                font-weight: 900;
                color: var(--d-text-3);
                padding: .75rem .85rem;
                border-bottom: 1px solid var(--d-glass-border);
                position: sticky;
                top: 0;
                z-index: 2;
                white-space: nowrap;
            }

            .table-panel tbody tr {
                transition: background var(--d-transition);
                border-bottom: 1px solid var(--d-glass-border);
            }

                .table-panel tbody tr:hover {
                    background: var(--d-surface-2);
                }

            .table-panel td {
                padding: .65rem .85rem;
                vertical-align: middle;
                color: var(--d-text-2);
            }

                .table-panel td:first-child {
                    padding-left: 1rem;
                }

        .name-strong {
            font-weight: 800;
            color: var(--d-text);
            letter-spacing: -.1px;
        }

        .cat-badge {
            font-size: .58rem;
            padding: .35rem .6rem;
            border-radius: 30px;
            letter-spacing: .1rem;
            font-weight: 800;
            text-transform: uppercase;
            background: rgba(255,122,24,.10);
            border: 1px solid rgba(255,122,24,.18);
            color: var(--d-accent);
            white-space: nowrap;
        }

        .action-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 34px;
            height: 34px;
            border-radius: 8px;
            font-size: .95rem;
            transition: all var(--d-transition);
            text-decoration: none;
            cursor: pointer;
        }

        .action-open {
            color: var(--d-accent);
            background: rgba(255,122,24,.1);
        }

            .action-open:hover {
                background: var(--d-accent);
                color: #fff;
                box-shadow: 0 4px 12px rgba(255,122,24,.3);
            }

        .action-copy {
            color: var(--d-blue);
            background: rgba(59,130,246,.1);
        }

            .action-copy:hover {
                background: var(--d-blue);
                color: #fff;
                box-shadow: 0 4px 12px rgba(59,130,246,.3);
            }

        .muted {
            color: var(--d-text-3);
        }

        /* Modal */
        .modal-content {
            background: var(--d-bg-3) !important;
            border: 1px solid var(--d-glass-border-2) !important;
            border-radius: var(--d-radius-lg) !important;
            box-shadow: var(--d-shadow-lg);
        }

        .modal-header {
            background: var(--d-grad);
            border: none;
            border-radius: var(--d-radius-lg) var(--d-radius-lg) 0 0;
            padding: 1rem 1.2rem;
        }

        .modal-title {
            font-size: .75rem;
            letter-spacing: .18rem;
            text-transform: uppercase;
            font-weight: 900;
        }

        .modal-body {
            padding: 1.2rem;
        }

            .modal-body .form-control,
            .modal-body select,
            .modal-body textarea {
                background: var(--d-surface-2) !important;
                border: 1px solid var(--d-glass-border) !important;
                color: var(--d-text) !important;
                border-radius: var(--d-radius-sm);
                font-size: .74rem !important;
            }

                .modal-body .form-control:focus,
                .modal-body select:focus,
                .modal-body textarea:focus {
                    border-color: var(--d-accent) !important;
                    box-shadow: 0 0 0 3px rgba(255,122,24,.12) !important;
                }

            .modal-body label {
                font-size: .55rem;
                letter-spacing: .15rem;
                text-transform: uppercase;
                font-weight: 800;
                color: var(--d-text-3);
                margin-bottom: .3rem;
            }

        .btn-modal-cancel {
            background: var(--d-surface-2);
            border: 1px solid var(--d-glass-border);
            color: var(--d-text);
            font-size: .65rem;
            letter-spacing: .12rem;
            padding: .6rem 1rem;
            border-radius: var(--d-radius-sm);
            font-weight: 800;
            text-transform: uppercase;
        }

        .btn-modal-save {
            background: var(--d-grad);
            color: #fff;
            border: none;
            font-size: .65rem;
            letter-spacing: .12rem;
            padding: .6rem 1rem;
            border-radius: var(--d-radius-sm);
            font-weight: 900;
            text-transform: uppercase;
        }

            .btn-modal-save:hover {
                filter: brightness(1.08);
            }

        .audience-box {
            background: var(--d-surface-2);
            border: 1px solid var(--d-glass-border);
            border-radius: var(--d-radius-sm);
            padding: .7rem .75rem;
            display: flex;
            flex-wrap: wrap;
            gap: .55rem 1rem;
            align-items: center;
        }

            .audience-box .form-check {
                margin: 0;
                display: inline-flex;
                gap: .45rem;
                align-items: center;
                padding-left: 0;
            }

                .audience-box .form-check input {
                    margin: 0;
                }

            .audience-box .audience-hint {
                font-size: .62rem;
                font-weight: 700;
                color: var(--d-text-3);
                letter-spacing: .12rem;
                text-transform: uppercase;
                opacity: .9;
            }

        @@media (max-width: 991.98px) {
            .sidebar {
                transform: translateX(-100%);
            }

                .sidebar.show {
                    transform: translateX(0);
                    box-shadow: var(--d-shadow-lg);
                }

            .topbar {
                left: 0;
            }

            .main-area {
                margin-left: 0;
            }

            .sidebar-toggle {
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media (max-width: 575.98px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }

            .main-content {
                padding: 1rem .75rem 2rem;
            }
        }

        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,.1);
            border-radius: 999px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: rgba(255,255,255,.2);
            }

        .hidden {
            display: none !important;
        }
    </style>
</head>

<body>
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <div class="sidebar-brand-icon"><i class="bi bi-lightning-charge-fill"></i></div>
            <div class="sidebar-brand-text">
                Forek Online
                <small>Enterprise Portal</small>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section-label">Main</div>
            <a href="@Url.Action("Dashboard", "Applications")" class="sidebar-link"><i class="bi bi-grid-1x2-fill"></i> Dashboard</a>
            <a href="@Url.Action("Applications", "Applications")" class="sidebar-link"><i class="bi bi-people-fill"></i> Applications</a>
            <a href="@Url.Action("Calendar", "Applications")" class="sidebar-link"><i class="bi bi-calendar3"></i> Calendar</a>
            <a href="@Url.Action("Index", "ApplicationCycle")" class="sidebar-link"><i class="bi bi-arrow-repeat"></i> Application Cycles</a>

            <div class="nav-section-label mt-3">Management</div>
            <a href="@Url.Action("StudentAnalytics", "Student")" class="sidebar-link"><i class="bi bi-mortarboard-fill"></i> Students</a>
            <a href="@Url.Action("AdminEmployeePortal", "Employee")" class="sidebar-link"><i class="bi bi-person-badge-fill"></i> Employees</a>
            <a href="@Url.Action("ListResources", "Resource")" class="sidebar-link active"><i class="bi bi-folder-fill"></i> Resources</a>

            <div class="nav-section-label mt-3">System</div>
            <a href="@Url.Action("RetrieveUsers", "Auth")" class="sidebar-link"><i class="bi bi-shield-lock-fill"></i> Users</a>
            <a href="@Url.Action("RetrieveUsers", "Auth")" class="sidebar-link"><i class="bi bi-gear-fill"></i> Settings</a>
        </nav>

        <div class="sidebar-footer">
            &copy; @DateTime.UtcNow.Year Forek ICT Services
        </div>
    </aside>

    <div class="topbar">
        <button class="sidebar-toggle" id="sidebarToggle"><i class="bi bi-list"></i></button>

        <div class="topbar-live">
            <span class="live-dot"></span>
            Updated just now
        </div>

        <div class="topbar-search">
            <i class="bi bi-search"></i>
            <input id="globalSearch" placeholder="Search resources..." autocomplete="off" />
            <span class="search-hint">/</span>
        </div>

        <div class="topbar-actions">
            <button class="topbar-btn theme-toggle" id="themeToggle" title="Toggle theme">
                <i class="bi bi-moon-stars-fill"></i>
            </button>
            <button class="topbar-btn" id="btnRefresh" title="Refresh">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
            <div class="topbar-avatar" title="Account">IO</div>
        </div>
    </div>

    <div class="main-area">
        <div class="main-content">

            <div class="page-header">
                <div>
                    <h1>
                        <span class="icon-box"><i class="bi bi-folder-fill"></i></span>
                        Resources
                    </h1>
                    <div class="page-header-sub">
                        Ultra-fast shared library with categories, tags, and access targeting.
                        <span class="pill ms-2"><i class="bi bi-stars"></i> Premium Library</span>
                    </div>
                </div>

                <div class="page-header-actions">
                    <button class="btn-glass" id="btnOpenShare" type="button" data-bs-toggle="modal" data-bs-target="#modalUpload">
                        <i class="bi bi-share-fill"></i> Share
                    </button>
                    <button class="btn-glass" id="btnExportCsv" type="button">
                        <i class="bi bi-filetype-csv"></i> Export
                    </button>
                    <button class="btn-grad" type="button" id="btnPrimaryShare" data-bs-toggle="modal" data-bs-target="#modalUpload">
                        <i class="bi bi-plus-circle-fill"></i> New Resource
                    </button>
                </div>
            </div>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-top">
                        <div class="stat-icon"><i class="bi bi-archive-fill"></i></div>
                    </div>
                    <div class="stat-value" data-count="@total">0</div>
                    <div class="stat-label">Total Resources</div>
                </div>

                <div class="stat-card">
                    <div class="stat-top">
                        <div class="stat-icon"><i class="bi bi-grid-1x2-fill"></i></div>
                    </div>
                    <div class="stat-value" data-count="@distinctCategories">0</div>
                    <div class="stat-label">Categories</div>
                </div>

                <div class="stat-card">
                    <div class="stat-top">
                        <div class="stat-icon"><i class="bi bi-funnel-fill"></i></div>
                    </div>
                    <div class="stat-value" id="statVisible">@total</div>
                    <div class="stat-label">Visible Now</div>
                </div>

                <div class="stat-card">
                    <div class="stat-top">
                        <div class="stat-icon"><i class="bi bi-fire"></i></div>
                    </div>
                    <div class="stat-value">@topCategory</div>
                    <div class="stat-label">Top Category</div>
                </div>
            </div>

            <div class="filter-bar">
                <div class="filter-search">
                    <i class="bi bi-search"></i>
                    <input id="tableSearch" placeholder="Search title, description, tags, creator..." autocomplete="off" />
                </div>

                <div class="filter-group">
                    <label><i class="bi bi-tags-fill"></i> Category</label>
                    <select id="categoryFilter" class="filter-input">
                        <option value="">All</option>
                        @foreach (var g in byCategory)
                        {
                            <option value="@g.Key">@g.Key</option>
                        }
                    </select>
                </div>

                <div class="filter-group">
                    <label><i class="bi bi-person-fill"></i> Creator</label>
                    <input id="creatorFilter" class="filter-input" placeholder="Name..." />
                </div>

                <div class="filter-group ms-auto">
                    <label><i class="bi bi-lightning-charge-fill"></i> Mode</label>
                    <select id="displayMode" class="filter-input" style="min-width: 170px;">
                        <option value="limited">Limited (fast)</option>
                        <option value="all">Show all</option>
                    </select>
                </div>
            </div>

            <div class="table-panel">
                <div style="overflow-x:auto;">
                    <table id="resourcesTable">
                        <thead>
                            <tr>
                                <th style="width:38%;">Resource</th>
                                <th style="width:28%;">Description</th>
                                <th style="width:14%;">Category</th>
                                <th style="width:14%;">Created By</th>
                                <th style="width:6%;"></th>
                                <th style="width:6%;"></th>
                                <th style="width:6%;"></th>
                            </tr>
                        </thead>
                        <tbody id="resourcesBody">
                            @foreach (var r in resources)
                            {
                                var hasStoredPdf = !string.IsNullOrWhiteSpace(r.FileId);

                                <tr data-name="@r.Name"
                                    data-desc="@r.Description"
                                    data-cat="@r.CategoryName"
                                    data-creator="@r.CreatedBy"
                                    data-url="@r.FileURL">

                                    <td>
                                        <div class="name-strong">@r.Name</div>
                                        @if (!string.IsNullOrWhiteSpace(r.Tags))
                                        {
                                            <div class="muted" style="font-size:.66rem;margin-top:.2rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="@r.Tags">
                                                <i class="bi bi-hash"></i> @r.Tags
                                            </div>
                                        }
                                    </td>
                                    <td title="@r.Description">
                                        <span style="display:inline-block;max-width: 520px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                            @r.Description
                                        </span>
                                    </td>
                                    <td><span class="cat-badge">@r.CategoryName</span></td>
                                    <td><span style="font-weight:700;color:var(--d-text);">@r.CreatedBy</span></td>
                                    <td>
                                        @if (hasStoredPdf)
                                        {
                                            <button type="button"
                                                    class="action-icon action-open btnPreview"
                                                    data-preview-url="@Url.Action("Preview", "Resource", new { id = r.ResourceId })"
                                                    title="Preview PDF">
                                                <i class="bi bi-eye-fill"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <a class="action-icon action-open" href="@r.FileURL" target="_blank" rel="noopener" title="Open link">
                                                <i class="bi bi-box-arrow-up-right"></i>
                                            </a>
                                        }
                                    </td>

                                    <td>
                                        @if (hasStoredPdf)
                                        {
                                            <a class="action-icon action-copy" href="@Url.Action("Download", "Resource", new { id = r.ResourceId })" title="Download PDF">
                                                <i class="bi bi-download"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <button type="button" class="action-icon action-copy btnCopy" title="Copy link">
                                                <i class="bi bi-link-45deg"></i>
                                            </button>
                                        }
                                    </td>

                                    <td>
                                        <form asp-action="Delete" asp-controller="Resource" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@r.ResourceId" />
                                            <button type="button"
                                                    class="action-icon btnDelete"
                                                    data-id="@r.ResourceId"
                                                    data-name="@r.Name"
                                                    style="background:rgba(239,68,68,.12);color:var(--d-red);"
                                                    title="Delete">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </form>
                                    </td>

                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between align-items-center px-3 py-2" style="border-top:1px solid var(--d-glass-border);">
                    <div class="pill" id="rowsInfo"><i class="bi bi-eye-fill"></i> Showing @total</div>
                    <div class="pill" id="filterInfo"><i class="bi bi-funnel-fill"></i> Ready</div>
                </div>
            </div>

        </div>
    </div>

    <div class="modal fade" id="pdfPreviewModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-white"><i class="bi bi-file-earmark-pdf-fill"></i> Preview PDF</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" style="padding:0;">
                    <iframe id="pdfPreviewFrame" style="width:100%;height:75vh;border:0;" src=""></iframe>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalUpload" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-white"><i class="bi bi-share-fill"></i> Share Resource</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <form asp-action="AddResource" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="modal-body">
                        <div asp-validation-summary="All" class="text-danger mb-2"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label>Category</label>
                                <select name="CategoryId" asp-items="@categories" class="form-control" required></select>
                            </div>

                            <div class="col-md-6">
                                <label>Title</label>
                                <input name="Name" class="form-control" required />
                            </div>

                            <div class="col-md-12">
                                <label>Description</label>
                                <textarea name="Description" class="form-control" rows="3"></textarea>
                            </div>

                            <div class="col-md-12">
                                <label>Tags (comma-separated)</label>
                                <input name="Tags" class="form-control" placeholder="electronics, circuit-basics, first-year" />
                            </div>

                            <div class="col-md-6">
                                <label>Upload File</label>
                                <input name="File" type="file" class="form-control" accept="application/pdf,.pdf" />
                                <div class="muted mt-1" style="font-size:.68rem;">PDF only • Max 3 MB.</div>
                            </div>

                            <div class="col-md-6">
                                <label>Or Add Link</label>
                                <input name="ExternalUrl" class="form-control" placeholder="https://youtube.com/... or https://drive.google.com/..." />
                                <div class="muted mt-1" style="font-size:.68rem;">YouTube / Google Drive / Website links supported.</div>
                            </div>

                            <div class="col-md-12">
                                <label>Audience</label>

                                <div class="audience-box">
                                    <span class="audience-hint"><i class="bi bi-shield-check"></i> Visibility</span>

                                    <input type="hidden" name="IsPublic" value="false" />
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="IsPublic" value="true" id="audEveryone" checked />
                                        <label class="form-check-label" for="audEveryone" style="margin:0;color:var(--d-text-2);font-weight:800;font-size:.72rem;">
                                            Everyone
                                        </label>
                                    </div>

                                    <span class="audience-hint">or roles:</span>

                                    @foreach (eSysRole role in Enum.GetValues(typeof(eSysRole)))
                                    {
                                        if (role is eSysRole.None)
                                        {
                                            continue;
                                        }

                                        var id = $"role_{role}";
                                        <div class="form-check">
                                            <input class="form-check-input audRole" type="checkbox" name="SelectedRoles" value="@role" id="@id" />
                                            <label class="form-check-label" for="@id" style="margin:0;color:var(--d-text-2);font-weight:800;font-size:.72rem;">
                                                @role
                                            </label>
                                        </div>
                                    }
                                </div>

                                <div class="muted mt-2" style="font-size:.68rem;">
                                    Tip: uncheck <strong>Everyone</strong> to target only selected roles (e.g. Facilitator / Student).
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-info mt-3 mb-0" style="font-size:.74rem;background:var(--d-surface-2);border:1px solid var(--d-glass-border);color:var(--d-text-2);">
                            Provide either a <strong>file</strong> or a <strong>link</strong> (not both).
                        </div>
                    </div>

                    <div class="modal-footer d-flex gap-2" style="border-top:1px solid var(--d-glass-border);padding: 1rem 1.2rem;">
                        <button type="button" class="btn-modal-cancel" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i> Cancel</button>
                        <button class="btn-modal-save" type="submit"><i class="bi bi-check2-circle"></i> Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-white"><i class="bi bi-trash-fill"></i> Confirm delete</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div style="font-size:.78rem;color:var(--d-text-2);line-height:1.5;">
                        You are about to delete:
                        <div class="mt-2 name-strong" id="deleteResourceName"></div>
                        <div class="muted mt-1" style="font-size:.7rem;">
                            This is a <strong>soft delete</strong> (it will be hidden from users).
                        </div>
                    </div>
                </div>
                <div class="modal-footer" style="border-top:1px solid var(--d-glass-border);">
                    <button type="button" class="btn-modal-cancel" data-bs-dismiss="modal">
                        <i class="bi bi-x-lg"></i> Cancel
                    </button>

                    <form id="deleteConfirmForm" asp-action="Delete" asp-controller="Resource" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" id="deleteResourceId" value="" />
                        <button type="submit" class="btn-modal-save" style="background:linear-gradient(135deg,#ef4444 0%,#b31217 50%,#320606 100%);">
                            <i class="bi bi-trash-fill"></i> Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="d-none" id="sidebarOverlay" style="position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:99;"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <script>
        (function () {
            'use strict';

            const html = document.documentElement;
            const themeBtn = document.getElementById('themeToggle');
            const savedTheme = localStorage.getItem('fo-theme') || 'dark';
            html.setAttribute('data-theme', savedTheme);
            updateThemeIcon();

            themeBtn.addEventListener('click', function () {
                const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
                html.setAttribute('data-theme', next);
                localStorage.setItem('fo-theme', next);
                updateThemeIcon();
            });

            function updateThemeIcon() {
                const icon = themeBtn.querySelector('i');
                icon.className = html.getAttribute('data-theme') === 'dark'
                    ? 'bi bi-moon-stars-fill'
                    : 'bi bi-sun-fill';
            }

            const sidebar = document.getElementById('sidebar');
            const sidebarToggle = document.getElementById('sidebarToggle');
            const overlay = document.getElementById('sidebarOverlay');

            sidebarToggle.addEventListener('click', function () {
                sidebar.classList.toggle('show');
                overlay.classList.toggle('d-none');
            });

            overlay.addEventListener('click', function () {
                sidebar.classList.remove('show');
                overlay.classList.add('d-none');
            });

            document.addEventListener('keydown', function (e) {
                if (e.key === '/' && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') {
                    e.preventDefault();
                    document.getElementById('globalSearch').focus();
                }
            });

            const globalSearch = document.getElementById('globalSearch');
            const tableSearch = document.getElementById('tableSearch');
            globalSearch.addEventListener('input', function () {
                tableSearch.value = this.value;
                tableSearch.dispatchEvent(new Event('input'));
            });

            const btnRefresh = document.getElementById('btnRefresh');
            btnRefresh.addEventListener('click', function () { location.reload(); });

            document.querySelectorAll('.stat-value[data-count]').forEach(function (el) {
                const target = parseInt(el.getAttribute('data-count'), 10);
                if (isNaN(target) || target === 0) { el.textContent = '0'; return; }
                const duration = 900;
                const start = performance.now();
                function tick(now) {
                    const elapsed = now - start;
                    const progress = Math.min(elapsed / duration, 1);
                    const eased = 1 - Math.pow(1 - progress, 3);
                    el.textContent = Math.round(eased * target).toLocaleString();
                    if (progress < 1) requestAnimationFrame(tick);
                }
                requestAnimationFrame(tick);
            });

            const chkEveryone = document.getElementById('audEveryone');
            const roleChecks = Array.from(document.querySelectorAll('.audRole'));

            chkEveryone.addEventListener('change', function () {
                if (chkEveryone.checked) {
                    roleChecks.forEach(c => c.checked = false);
                }
            });

            roleChecks.forEach(function (c) {
                c.addEventListener('change', function () {
                    if (c.checked) {
                        chkEveryone.checked = false;
                    }
                });
            });

            const DEFAULT_LIMIT = 200;
            const body = document.getElementById('resourcesBody');
            const categoryFilter = document.getElementById('categoryFilter');
            const creatorFilter = document.getElementById('creatorFilter');
            const displayMode = document.getElementById('displayMode');
            const rowsInfo = document.getElementById('rowsInfo');
            const filterInfo = document.getElementById('filterInfo');
            const statVisible = document.getElementById('statVisible');

            function norm(v) { return (v || '').toString().toLowerCase().trim(); }

            function applyFilters() {
                const t0 = performance.now();
                const q = norm(tableSearch.value);
                const cat = categoryFilter.value;
                const creator = norm(creatorFilter.value);
                const filtering = !!(q || cat || creator);

                const limitedMode = displayMode.value === 'limited';
                const rows = Array.from(body.querySelectorAll('tr'));

                let shown = 0;
                let matched = 0;

                rows.forEach(r => {
                    const name = norm(r.getAttribute('data-name'));
                    const desc = norm(r.getAttribute('data-desc'));
                    const tags = norm(r.querySelector('.muted')?.textContent || '');
                    const rc = r.getAttribute('data-cat');
                    const cr = norm(r.getAttribute('data-creator'));

                    let show = true;

                    if (q && !(name.includes(q) || desc.includes(q) || tags.includes(q))) show = false;
                    if (cat && rc !== cat) show = false;
                    if (creator && !cr.includes(creator)) show = false;

                    if (show) {
                        matched++;
                        if (limitedMode && !filtering && shown >= DEFAULT_LIMIT) {
                            show = false;
                        }
                    }

                    r.classList.toggle('hidden', !show);
                    if (show) shown++;
                });

                rowsInfo.innerHTML = '<i class="bi bi-eye-fill"></i> Showing ' + shown.toLocaleString();
                statVisible.textContent = shown.toLocaleString();

                const ms = (performance.now() - t0).toFixed(1);
                filterInfo.innerHTML = filtering
                    ? '<i class="bi bi-funnel-fill"></i> Filtered • ' + ms + 'ms'
                    : (limitedMode ? '<i class="bi bi-lightning-charge-fill"></i> Limited • ' + ms + 'ms' : '<i class="bi bi-infinity"></i> All • ' + ms + 'ms');
            }

            tableSearch.addEventListener('input', applyFilters);
            categoryFilter.addEventListener('change', applyFilters);
            creatorFilter.addEventListener('input', applyFilters);
            displayMode.addEventListener('change', applyFilters);

            applyFilters();

            document.querySelectorAll('.btnCopy').forEach(function (btn) {
                btn.addEventListener('click', async function () {
                    const tr = btn.closest('tr');
                    const url = (tr?.getAttribute('data-url') || '').trim();
                    if (!url) return;
                    try {
                        await navigator.clipboard.writeText(url);
                        btn.innerHTML = '<i class="bi bi-check2"></i>';
                        setTimeout(() => btn.innerHTML = '<i class="bi bi-link-45deg"></i>', 1100);
                    } catch {
                        prompt('Copy link:', url);
                    }
                });
            });

            document.getElementById('btnExportCsv').addEventListener('click', function () {
                const visible = Array.from(body.querySelectorAll('tr:not(.hidden)'));
                if (!visible.length) { alert('No rows to export.'); return; }

                const lines = ['Name,Description,Category,CreatedBy,Url'];
                visible.forEach(r => {
                    const name = (r.querySelector('td:nth-child(1) .name-strong')?.innerText || '').trim();
                    const desc = (r.querySelector('td:nth-child(2)')?.innerText || '').trim();
                    const cat = (r.querySelector('td:nth-child(3)')?.innerText || '').trim();
                    const creator = (r.querySelector('td:nth-child(4)')?.innerText || '').trim();
                    const url = (r.getAttribute('data-url') || '').trim();

                    const row = [name, desc, cat, creator, url]
                        .map(v => '"' + v.replace(/"/g, '""') + '"')
                        .join(',');

                    lines.push(row);
                });

                const blob = new Blob([lines.join('\r\n')], { type: 'text/csv;charset=utf-8;' });
                const a = document.createElement('a');
                a.href = URL.createObjectURL(blob);
                a.download = 'resources-' + new Date().toISOString().slice(0, 10) + '.csv';
                document.body.appendChild(a); a.click(); document.body.removeChild(a);
            });

            document.addEventListener('hidden.bs.modal', function () {
                if (!document.querySelector('.modal.show')) {
                    document.querySelectorAll('.modal-backdrop').forEach(function (b) { b.remove(); });
                    document.body.classList.remove('modal-open');
                    document.body.style.removeProperty('overflow');
                    document.body.style.removeProperty('padding-right');
                }
            });

            const shouldOpenModal = '@((ViewData["OpenUploadModal"] as bool?) == true ? "1" : "0")';
            if (shouldOpenModal === '1') {
                const el = document.getElementById('modalUpload');
                if (el) {
                    const modal = new bootstrap.Modal(el);
                    modal.show();
                }
            }

          document.querySelectorAll('.btnPreview').forEach(function (btn) {
            btn.addEventListener('click', function () {
                const url = btn.getAttribute('data-preview-url');
                const frame = document.getElementById('pdfPreviewFrame');
                frame.src = url;

                const el = document.getElementById('pdfPreviewModal');
                const modal = new bootstrap.Modal(el);
                modal.show();
            });
        });

          document.getElementById('pdfPreviewModal').addEventListener('hidden.bs.modal', function () {
            const frame = document.getElementById('pdfPreviewFrame');
            frame.src = '';
        });

        const deleteModalEl = document.getElementById('deleteConfirmModal');
        const deleteModal = deleteModalEl ? new bootstrap.Modal(deleteModalEl) : null;

        document.querySelectorAll('.btnDelete').forEach(function (btn) {
            btn.addEventListener('click', function () {
                const id = btn.getAttribute('data-id');
                const name = btn.getAttribute('data-name') || 'this resource';

                const idInput = document.getElementById('deleteResourceId');
                const nameEl = document.getElementById('deleteResourceName');

                if (idInput) idInput.value = id;
                if (nameEl) nameEl.textContent = name;

                if (deleteModal) deleteModal.show();
            });
        });

        })();
    </script>
</body>
</html>