@model ForekOnline.Domain.ViewModels.CourseModuleViewModel
@using static ForekOnline.Domain.Enums.EnumRegistry
@{
    ViewData["Title"] = "Modify Course";
}

<style>
:root {
    --c-grad: linear-gradient(95deg,#320606,#b31217 55%,#ff7a18);
    --c-soft: #fff5f3;
    --c-border: #e2e5ea;
    --c-border-alt:#c9ccd1;
    --c-radius: 18px;
}
.form-shell {
    max-width:1100px;
    margin:0 auto;
    padding:1.8rem 1.3rem 2.8rem;
}
.panel {
    background:#fff;
    border:1px solid var(--c-border);
    border-radius:32px;
    box-shadow:0 14px 38px -18px rgba(50,6,6,.28),0 6px 20px -10px rgba(50,6,6,.20);
    overflow:hidden;
    position:relative;
}
.panel__head {
    padding:1.2rem 1.4rem 1.05rem;
    background:var(--c-grad);
    color:#fff;
    display:flex;
    align-items:center;
    gap:.9rem;
}
.panel__head h1 {
    margin:0;
    font-size:1.35rem;
    font-weight:600;
    letter-spacing:.5px;
    display:flex;
    align-items:center;
    gap:.6rem;
}
.panel__sub {
    font-size:.55rem;
    letter-spacing:.18rem;
    font-weight:700;
    text-transform:uppercase;
    opacity:.85;
}
.section {
    padding:1.35rem 1.4rem .65rem;
    border-top:1px solid var(--c-border);
    display:flex;
    flex-direction:column;
    gap:1.15rem;
    position:relative;
}
.section:first-of-type {
    border-top:none;
}
.section-title {
    font-size:.6rem;
    font-weight:700;
    letter-spacing:.18rem;
    text-transform:uppercase;
    color:#b31217;
    display:flex;
    align-items:center;
    gap:.55rem;
    margin:0;
}
.helper {
    font-size:.57rem;
    letter-spacing:.06rem;
    color:#666;
    margin-top:-.35rem;
}
.field-grid {
    display:grid;
    gap:1.05rem;
    grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
}
.form-floating > label {
    font-size:.72rem;
    letter-spacing:.05rem;
}
.form-control, .form-select {
    border-color:var(--c-border);
    border-radius:var(--c-radius);
}
.form-control:focus, .form-select:focus {
    border-color:#b31217;
    box-shadow:0 0 0 .2rem rgba(179,18,23,.15);
}
.badge-live {
    background:var(--c-grad);
    color:#fff;
    font-size:.55rem;
    letter-spacing:.14rem;
    padding:.4rem .75rem;
    border-radius:30px;
    font-weight:600;
    box-shadow:0 6px 16px -8px rgba(179,18,23,.45);
}
.inline-meta {
    display:flex;
    flex-wrap:wrap;
    gap:.75rem;
}
.meta-box {
    flex:1 1 260px;
    background:var(--c-soft);
    border:1px solid var(--c-border);
    border-radius:22px;
    padding:.75rem .9rem .6rem;
    position:relative;
    display:flex;
    flex-direction:column;
    gap:.35rem;
    font-size:.58rem;
    letter-spacing:.08rem;
}
.meta-box strong {
    font-size:.62rem;
    letter-spacing:.12rem;
    text-transform:uppercase;
    color:#b31217;
}
.toggle-active {
    display:flex;
    align-items:center;
    gap:.6rem;
    padding:.65rem .85rem;
    background:#fff;
    border:1px solid var(--c-border);
    border-radius:20px;
    font-size:.65rem;
    letter-spacing:.08rem;
    cursor:pointer;
    user-select:none;
    transition:.3s;
}
.toggle-active:hover {
    border-color:var(--c-border-alt);
    background:var(--c-soft);
}
.actions {
    margin-top:.8rem;
    display:flex;
    flex-wrap:wrap;
    gap:.75rem;
    justify-content:space-between;
    align-items:center;
    background:#fff;
    border:1px solid var(--c-border);
    border-radius:28px;
    padding:1.05rem 1.15rem .9rem;
}
.actions-left, .actions-right {
    display:flex;
    gap:.65rem;
    flex-wrap:wrap;
}
.btn-pill {
    border-radius:24px;
    font-size:.63rem;
    font-weight:600;
    letter-spacing:.08rem;
    text-transform:uppercase;
    padding:.6rem 1.05rem;
    display:inline-flex;
    align-items:center;
    gap:.45rem;
}
.btn-pill i {
    font-size:.75rem;
}
.credit-indicator {
    margin-top:-.55rem;
    font-size:.55rem;
    letter-spacing:.09rem;
    color:#555;
    display:flex;
    align-items:center;
    gap:.5rem;
}
.credit-bar-wrapper {
    background:#f1f3f6;
    border-radius:12px;
    height:10px;
    width:100%;
    overflow:hidden;
    position:relative;
    flex:1;
}
.credit-bar {
    background:var(--c-grad);
    height:100%;
    width:0%;
    transition:.5s;
}
@@media (max-width:680px){
    .field-grid { grid-template-columns:1fr; }
    .panel__head { flex-direction:column; align-items:flex-start; }
}
</style>

<div class="form-shell">
    <div class="panel">
        <div class="panel__head">
            <h1><i class="fa fa-layer-group"></i> Course Management</h1>
            <span class="panel__sub">MODIFY • CURATION</span>
            <span class="ms-auto badge-live"><i class="fa fa-pen-to-square me-1"></i> Edit Mode</span>
        </div>

        <form asp-action="OnModifyCourse" class="needs-validation" novalidate>
            <input type="hidden" asp-for="CourseId" />

            <div class="section">
                <h2 class="section-title"><i class="fa fa-book-open"></i> Core Details</h2>
                <p class="helper">Update foundational course descriptors & taxonomy.</p>

                <div class="field-grid">
                    <div class="form-floating">
                        <input asp-for="Name" class="form-control" placeholder="Course Name" required />
                        <label asp-for="Name"></label>
                        <div class="invalid-feedback">Course name is required.</div>
                    </div>

                    <div class="form-floating">
                        <select asp-for="Type" class="form-select" asp-items="Html.GetEnumSelectList<eCourseType>()">
                            <option value="">Select Type</option>
                        </select>
                        <label asp-for="Type">Course Type</label>
                        <div class="invalid-feedback">Select a course type.</div>
                    </div>

                    <div class="form-floating">
                        <select asp-for="CourseNQFLevel" class="form-select" asp-items="Html.GetEnumSelectList<eNQF>()">
                            <option value="">Select NQF</option>
                        </select>
                        <label asp-for="CourseNQFLevel">NQF Level</label>
                        <div class="invalid-feedback">Select an NQF level.</div>
                    </div>

                    <div class="form-floating">
                        <input asp-for="CourseCredit" class="form-control" placeholder="Credits" required />
                        <label asp-for="CourseCredit">Credit</label>
                        <div class="invalid-feedback">Course credit is required.</div>
                        <div class="credit-indicator">
                            <span><i class="fa fa-gauge-high text-danger"></i> Credit Load</span>
                            <div class="credit-bar-wrapper">
                                <div class="credit-bar" id="creditBar"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="section">
                <h2 class="section-title"><i class="fa fa-user-clock"></i> Audit Trail</h2>
                <p class="helper">Immutable operational metadata for provenance.</p>
                <div class="inline-meta">
                    <div class="meta-box">
                        <strong>Modified By</strong>
                        <input asp-for="ModifiedBy" readonly class="form-control mt-1" />
                    </div>
                    <div class="meta-box">
                        <strong>Modified On</strong>
                        <input asp-for="ModifiedOn" readonly class="form-control mt-1" />
                    </div>
                    <div class="meta-box">
                        <strong>Status</strong>
                        <label class="toggle-active mt-1">
                            <input asp-for="IsActive" class="form-check-input me-1" />
                            <span id="activeStatusText">Active</span>
                        </label>
                    </div>
                </div>
            </div>

            <div class="section">
                <h2 class="section-title"><i class="fa fa-shield-halved"></i> Validation & Commit</h2>
                <p class="helper">Review accuracy then persist changes. Reset reverts unsaved edits.</p>
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                <div class="actions">
                    <div class="actions-left">
                        <button type="submit" class="btn btn-success btn-pill">
                            <i class="fa fa-save"></i> Save Changes
                        </button>
                        <button type="reset" class="btn btn-outline-warning btn-pill">
                            <i class="fa fa-rotate-left"></i> Reset
                        </button>
                    </div>
                    <div class="actions-right">
                        <a asp-action="GetActiveCourses" class="btn btn-danger btn-pill">
                            <i class="fa fa-circle-xmark"></i> Exit
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const form = document.querySelector('.needs-validation');
            form?.addEventListener('submit', e => {
                if (!form.checkValidity()) {
                    e.preventDefault();
                    e.stopPropagation();
                }
                form.classList.add('was-validated');
            });

            // Active status label toggle
            const activeInput = document.getElementById('@Html.IdFor(m => m.IsActive)');
            const activeText = document.getElementById('activeStatusText');
            function syncActive() {
                if (!activeInput || !activeText) return;
                activeText.textContent = activeInput.checked ? 'Active' : 'Inactive';
                activeText.classList.toggle('text-danger', !activeInput.checked);
            }
            activeInput?.addEventListener('change', syncActive);
            syncActive();

            // Credit progress bar (simple heuristic)
            const creditInput = document.getElementById('@Html.IdFor(m => m.CourseCredit)');
            const creditBar = document.getElementById('creditBar');
            function updateCreditBar() {
                if (!creditInput || !creditBar) return;
                let val = parseFloat(creditInput.value);
                if (isNaN(val) || val < 0) val = 0;
                // Assume soft cap at 240 for visual scaling
                const pct = Math.min(100, (val / 240) * 100);
                creditBar.style.width = pct.toFixed(1) + '%';
            }
            creditInput?.addEventListener('input', updateCreditBar);
            updateCreditBar();
        })();
    </script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
