@model IEnumerable<ForekOnline.Domain.ViewModels.CourseViewModel>
@using static ForekOnline.Domain.Enums.EnumRegistry
@{
    var courses = Model?.ToList() ?? new List<ForekOnline.Domain.ViewModels.CourseViewModel>();
    var typeGroups = courses.GroupBy(c => c.Type ?? "Unknown").OrderByDescending(g => g.Count()).ToList();
    var total = courses.Count;
    var avgCredits = courses.Any() ? courses.Where(c => c.Credit.HasValue).Average(c => c.Credit ?? 0).ToString("F0") : "0";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<style>
    .crs-shell {
        --crs-red: #ac1900;
        --crs-hot: #e65100;
        --crs-grad: linear-gradient(135deg, #ac1900 0%, #c53030 55%, #e65100 100%);
        --crs-glow: rgba(172,25,0,.32);
        --crs-green: #059669;
        --crs-green-soft: #ecfdf5;
        --crs-green-border: #a7f3d0;
        --crs-amber: #b45309;
        --crs-amber-soft: #fffbeb;
        --crs-amber-border: #fde68a;
        --crs-bg: #f4f5f7;
        --crs-card: #ffffff;
        --crs-border: #e5e7eb;
        --crs-border-h: #d1d5db;
        --crs-text: #111827;
        --crs-text-2: #4b5563;
        --crs-text-3: #9ca3af;
        --crs-r-sm: 8px;
        --crs-r: 12px;
        --crs-r-lg: 18px;
        --crs-r-xl: 22px;
        --crs-sh: 0 1px 3px rgba(0,0,0,.06), 0 2px 6px rgba(0,0,0,.04);
        --crs-sh-md: 0 4px 16px rgba(0,0,0,.08), 0 2px 6px rgba(0,0,0,.04);
        --crs-sh-lg: 0 12px 36px rgba(0,0,0,.11), 0 4px 12px rgba(0,0,0,.06);
        --crs-t: .26s cubic-bezier(.4,0,.2,1);
        max-width: 1440px;
        margin: 0 auto;
        padding: 1.75rem 1.25rem 3.5rem;
        font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
        animation: crsPageIn .55s ease;
    }

    @@keyframes crsPageIn {
        from {
            opacity: 0;
            transform: translateY(14px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .crs-hero {
        background: var(--crs-grad);
        border-radius: var(--crs-r-xl);
        padding: 1.4rem 1.75rem;
        display: flex;
        flex-wrap: wrap;
        gap: 1.25rem;
        align-items: center;
        position: relative;
        overflow: hidden;
        box-shadow: 0 8px 32px -8px var(--crs-glow), var(--crs-sh-md);
    }

        .crs-hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/svg%3E");
            pointer-events: none;
        }

    .crs-hero-icon {
        width: 58px;
        height: 58px;
        border-radius: 16px;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.22);
        backdrop-filter: blur(8px);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.55rem;
        color: #fff;
        flex-shrink: 0;
        position: relative;
        z-index: 1;
        box-shadow: 0 4px 16px rgba(0,0,0,.18);
    }

    .crs-hero-copy {
        flex: 1;
        position: relative;
        z-index: 1;
    }

        .crs-hero-copy h1 {
            margin: 0;
            font-family: 'Space Grotesk', 'Inter', sans-serif;
            font-size: 1.45rem;
            font-weight: 700;
            color: #fff;
            letter-spacing: -.3px;
            line-height: 1.2;
        }

    .crs-kicker {
        font-size: .56rem;
        letter-spacing: .2rem;
        font-weight: 700;
        text-transform: uppercase;
        color: rgba(255,255,255,.65);
        margin-top: .3rem;
        display: inline-flex;
        gap: .4rem;
        align-items: center;
    }

    .crs-hero-acts {
        display: flex;
        gap: .55rem;
        flex-wrap: wrap;
        margin-left: auto;
        position: relative;
        z-index: 1;
    }

    .crs-btn-ghost {
        font-size: .6rem;
        letter-spacing: .1rem;
        font-weight: 600;
        text-transform: uppercase;
        padding: .55rem 1rem;
        border-radius: var(--crs-r-sm);
        border: 1px solid rgba(255,255,255,.3);
        background: rgba(255,255,255,.1);
        color: #fff;
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        text-decoration: none;
        cursor: pointer;
        transition: all var(--crs-t);
        backdrop-filter: blur(4px);
    }

        .crs-btn-ghost:hover {
            background: rgba(255,255,255,.22);
            border-color: rgba(255,255,255,.5);
            color: #fff;
            transform: translateY(-1px);
        }

    .crs-btn-white {
        font-size: .6rem;
        letter-spacing: .1rem;
        font-weight: 700;
        text-transform: uppercase;
        padding: .58rem 1.2rem;
        border-radius: var(--crs-r-sm);
        border: none;
        background: #fff;
        color: var(--crs-red);
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        cursor: pointer;
        transition: all var(--crs-t);
        box-shadow: 0 2px 12px rgba(0,0,0,.15);
    }

        .crs-btn-white:hover {
            background: #fff3f3;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,0,0,.2);
        }

    .crs-stats {
        display: grid;
        gap: .9rem;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        margin-top: 1.25rem;
    }

    .crs-stat {
        background: var(--crs-card);
        border: 1px solid var(--crs-border);
        border-left: 3px solid var(--crs-border);
        border-radius: var(--crs-r-lg);
        padding: 1rem 1.1rem .9rem;
        display: flex;
        flex-direction: column;
        gap: .35rem;
        overflow: hidden;
        position: relative;
        box-shadow: var(--crs-sh);
        transition: all var(--crs-t);
    }

        .crs-stat:nth-child(1) {
            border-left-color: var(--crs-red);
        }

        .crs-stat:nth-child(2) {
            border-left-color: var(--crs-hot);
        }

        .crs-stat:nth-child(3) {
            border-left-color: var(--crs-green);
        }

        .crs-stat:nth-child(4) {
            border-left-color: var(--crs-amber);
        }

        .crs-stat:nth-child(5) {
            border-left-color: #6366f1;
        }

        .crs-stat:nth-child(6) {
            border-left-color: #0891b2;
        }

        .crs-stat:nth-child(7) {
            border-left-color: #7c3aed;
        }

        .crs-stat:nth-child(8) {
            border-left-color: #0f766e;
        }

        .crs-stat:nth-child(9) {
            border-left-color: #ea580c;
        }

        .crs-stat:hover {
            transform: translateY(-3px) scale(1.015);
            box-shadow: var(--crs-sh-md);
        }

    .crs-stat-label {
        font-size: .5rem;
        letter-spacing: .17rem;
        text-transform: uppercase;
        font-weight: 700;
        color: var(--crs-text-3);
    }

    .crs-stat-val {
        font-size: 2rem;
        font-weight: 800;
        line-height: 1;
        background: var(--crs-grad);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        letter-spacing: -.5px;
    }

    .crs-stat-chip {
        font-size: .46rem;
        letter-spacing: .11rem;
        font-weight: 700;
        background: #fef2f2;
        color: var(--crs-red);
        border: 1px solid rgba(172,25,0,.12);
        padding: .28rem .55rem;
        border-radius: 30px;
        align-self: flex-start;
    }

    .crs-filter {
        margin-top: 1.25rem;
        background: var(--crs-card);
        border: 1px solid var(--crs-border);
        border-radius: var(--crs-r-lg);
        padding: .9rem 1.1rem;
        display: flex;
        gap: .85rem;
        flex-wrap: wrap;
        align-items: flex-end;
        box-shadow: var(--crs-sh);
    }

    .crs-fg {
        display: flex;
        flex-direction: column;
        gap: .3rem;
    }

        .crs-fg label {
            font-size: .48rem;
            letter-spacing: .15rem;
            text-transform: uppercase;
            font-weight: 700;
            color: var(--crs-text-3);
        }

    .crs-filter input[type="text"],
    .crs-filter input[type="number"],
    .crs-filter select {
        background: var(--crs-bg);
        border: 1px solid var(--crs-border);
        font-size: .7rem;
        color: var(--crs-text);
        padding: .48rem .7rem;
        border-radius: var(--crs-r-sm);
        min-width: 150px;
        transition: all var(--crs-t);
        font-family: inherit;
    }

        .crs-filter input:focus, .crs-filter select:focus {
            outline: none;
            border-color: var(--crs-red);
            box-shadow: 0 0 0 3px rgba(172,25,0,.1);
            background: #fff;
        }

    .crs-search-wrap {
        position: relative;
        flex: 1 1 260px;
    }

        .crs-search-wrap .crs-si {
            position: absolute;
            top: 50%;
            left: .75rem;
            transform: translateY(-50%);
            font-size: .68rem;
            color: var(--crs-text-3);
            pointer-events: none;
        }

        .crs-search-wrap input {
            width: 100%;
            padding-left: 2.1rem;
        }

        .crs-search-wrap .crs-kbd {
            position: absolute;
            top: 50%;
            right: .65rem;
            transform: translateY(-50%);
            font-size: .46rem;
            font-weight: 600;
            color: var(--crs-text-3);
            background: var(--crs-bg);
            border: 1px solid var(--crs-border);
            padding: .12rem .35rem;
            border-radius: 4px;
        }

    .crs-view-toggle {
        display: flex;
        border: 1px solid var(--crs-border);
        border-radius: var(--crs-r-sm);
        overflow: hidden;
        margin-left: auto;
    }

        .crs-view-toggle button {
            background: var(--crs-bg);
            border: none;
            padding: .45rem .65rem;
            cursor: pointer;
            color: var(--crs-text-3);
            font-size: .68rem;
            transition: all var(--crs-t);
        }

            .crs-view-toggle button.active {
                background: var(--crs-red);
                color: #fff;
            }

            .crs-view-toggle button:hover:not(.active) {
                background: #fef2f2;
                color: var(--crs-red);
            }

    .crs-table-shell {
        margin-top: 1.1rem;
        background: var(--crs-card);
        border: 1px solid var(--crs-border);
        border-radius: var(--crs-r-lg);
        padding: 1.1rem 1rem .9rem;
        box-shadow: var(--crs-sh);
        overflow: hidden;
        transition: box-shadow var(--crs-t);
    }

        .crs-table-shell:hover {
            box-shadow: var(--crs-sh-md);
        }

    .crs-table-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: .5rem;
        margin-bottom: .7rem;
    }

    .crs-meta-badge {
        font-size: .5rem;
        letter-spacing: .11rem;
        font-weight: 700;
        text-transform: uppercase;
        background: #fef2f2;
        color: var(--crs-red);
        border: 1px solid rgba(172,25,0,.12);
        padding: .35rem .65rem;
        border-radius: 30px;
    }

    .crs-scroll {
        overflow-x: auto;
    }

    .crs-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        font-size: .7rem;
    }

        .crs-table thead th {
            background: var(--crs-grad);
            color: #fff;
            font-size: .5rem;
            letter-spacing: .18rem;
            text-transform: uppercase;
            font-weight: 700;
            padding: .65rem .7rem;
            position: sticky;
            top: 0;
            z-index: 3;
            border-bottom: 2px solid rgba(0,0,0,.12);
            white-space: nowrap;
        }

            .crs-table thead th:first-child {
                border-radius: var(--crs-r-sm) 0 0 0;
            }

            .crs-table thead th:last-child {
                border-radius: 0 var(--crs-r-sm) 0 0;
            }

        .crs-table tbody tr:nth-child(even) {
            background: #fafbfc;
        }

        .crs-table tbody tr:nth-child(odd) {
            background: #fff;
        }

        .crs-table tbody tr {
            transition: background var(--crs-t);
        }

            .crs-table tbody tr:hover {
                background: #fef2f2;
            }

        .crs-table td {
            padding: .55rem .7rem;
            border-bottom: 1px solid var(--crs-border);
            vertical-align: middle;
            color: var(--crs-text);
        }

    .crs-course-name {
        font-weight: 600;
        max-width: 280px;
    }

    .crs-cb {
        width: 34px;
        text-align: center;
    }

        .crs-cb input[type="checkbox"] {
            width: 15px;
            height: 15px;
            cursor: pointer;
            accent-color: var(--crs-red);
        }

    .crs-pill {
        font-weight: 600;
        font-size: .5rem;
        letter-spacing: .06rem;
        text-transform: uppercase;
        background: #fef2f2;
        color: var(--crs-red);
        border: 1px solid rgba(172,25,0,.18);
        padding: .4rem .65rem;
        border-radius: 30px;
        text-decoration: none;
        display: inline-flex;
        gap: .3rem;
        align-items: center;
        transition: all var(--crs-t);
    }

        .crs-pill:hover {
            background: var(--crs-red);
            color: #fff;
            border-color: var(--crs-red);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(172,25,0,.3);
        }

    .crs-pill-green {
        background: var(--crs-green-soft);
        color: var(--crs-green);
        border-color: var(--crs-green-border);
    }

        .crs-pill-green:hover {
            background: var(--crs-green);
            color: #fff;
            border-color: var(--crs-green);
            box-shadow: 0 4px 12px rgba(5,150,105,.25);
        }

    .crs-badge-type {
        font-size: .48rem;
        padding: .3rem .55rem;
        border-radius: 30px;
        font-weight: 700;
        letter-spacing: .07rem;
        display: inline-flex;
        gap: .25rem;
        align-items: center;
        background: #fef2f2;
        color: var(--crs-red);
        border: 1px solid rgba(172,25,0,.15);
    }

    .crs-date {
        font-size: .63rem;
        color: var(--crs-text-2);
    }

        .crs-date .crs-rel {
            font-weight: 600;
            color: var(--crs-text);
        }

    .crs-empty {
        text-align: center;
        padding: 3.5rem 2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .9rem;
    }

    .crs-empty-icon {
        width: 88px;
        height: 88px;
        border-radius: 24px;
        background: linear-gradient(135deg, #fef2f2, #fffbeb);
        border: 1px solid var(--crs-border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
        color: var(--crs-red);
    }

    .crs-empty h3 {
        font-size: 1rem;
        font-weight: 700;
        color: var(--crs-text);
        margin: 0;
    }

    .crs-empty p {
        font-size: .72rem;
        color: var(--crs-text-3);
        max-width: 340px;
        margin: 0;
    }

    .crs-grid-view {
        display: none;
        grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
        gap: 1rem;
        margin-top: 1rem;
    }

    .crs-grid-view.active { display: grid; }

    .crs-list-view.hidden {
        display: none;
    }

    .crs-grid-card {
        background: var(--crs-card);
        border: 1px solid var(--crs-border);
        border-radius: var(--crs-r-lg);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        box-shadow: var(--crs-sh);
        transition: all var(--crs-t);
        min-height: 250px;
        position: relative;
    }

    .crs-grid-card::before {
        content: "";
        position: absolute;
        inset: 0 auto 0 0;
        width: 4px;
        background: var(--crs-grad);
    }

    .crs-grid-card:hover {
        border-color: rgba(172,25,0,.35);
        box-shadow: var(--crs-sh-lg);
        transform: translateY(-4px);
    }

    .cgc-head {
        padding: 1.1rem 1.1rem .9rem 1.25rem;
        display: flex;
        gap: .8rem;
        align-items: flex-start;
        background: linear-gradient(155deg,#fff 35%,#fff8f6 100%);
        border-bottom: 1px solid var(--crs-border);
    }

    .cgc-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        display: grid;
        place-items: center;
        flex-shrink: 0;
        color: #fff;
        background: var(--crs-grad);
        box-shadow: 0 6px 16px rgba(172,25,0,.22);
    }

    .cgc-heading { min-width: 0; flex: 1; }

    .crs-grid-card .cgc-title {
        font-size: .88rem;
        font-weight: 700;
        color: var(--crs-text);
        line-height: 1.35;
        overflow-wrap: anywhere;
        margin-bottom: .4rem;
    }

    .cgc-credit {
        flex-shrink: 0;
        border-radius: 999px;
        padding: .28rem .5rem;
        background: #fff;
        border: 1px solid rgba(172,25,0,.16);
        color: var(--crs-red);
        font-size: .52rem;
        font-weight: 800;
        white-space: nowrap;
    }

    .crs-grid-card .cgc-meta {
        padding: .85rem 1.1rem .8rem 1.25rem;
        display: grid;
        gap: .55rem;
        color: var(--crs-text-2);
        font-size: .62rem;
    }

    .cgc-meta span { display: flex; align-items: center; gap: .5rem; min-width: 0; }
    .cgc-meta i { width: 16px; color: var(--crs-red); text-align: center; }
    .cgc-meta strong { color: var(--crs-text); font-weight: 600; overflow-wrap: anywhere; }

    .crs-grid-card .cgc-acts {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .5rem;
        margin-top: auto;
        padding: .8rem 1.1rem .95rem 1.25rem;
        border-top: 1px solid var(--crs-border);
        background: #fafafa;
    }

    .cgc-acts .crs-pill { justify-content: center; }

    .crs-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .6rem;
        margin-top: .7rem;
        font-size: .52rem;
        letter-spacing: .1rem;
        color: var(--crs-text-3);
        flex-wrap: wrap;
    }

    .crs-btn-mini {
        padding: .35rem .65rem;
        font-size: .48rem;
        letter-spacing: .12rem;
        border-radius: var(--crs-r-sm);
        border: 1px solid var(--crs-border);
        background: var(--crs-card);
        color: var(--crs-red);
        cursor: pointer;
        font-weight: 600;
        transition: all var(--crs-t);
    }

        .crs-btn-mini:hover {
            background: var(--crs-red);
            color: #fff;
        }

    .crs-kbd-tip {
        font-size: .46rem;
        color: var(--crs-text-3);
        display: flex;
        gap: .35rem;
        align-items: center;
    }

        .crs-kbd-tip kbd {
            background: var(--crs-bg);
            border: 1px solid var(--crs-border);
            padding: .12rem .3rem;
            border-radius: 4px;
            font-size: .44rem;
            font-family: inherit;
            font-weight: 600;
        }

    .crs-limit-note {
        font-size: .48rem;
        letter-spacing: .11rem;
        font-weight: 700;
        background: var(--crs-amber-soft);
        color: var(--crs-amber);
        border: 1px solid var(--crs-amber-border);
        padding: .3rem .55rem;
        border-radius: 30px;
        display: inline-flex;
        gap: .3rem;
        align-items: center;
    }

    .crs-export {
        position: relative;
        display: inline-block;
    }

    .crs-export-menu {
        display: none;
        position: absolute;
        top: 100%;
        right: 0;
        margin-top: .4rem;
        background: var(--crs-card);
        border: 1px solid var(--crs-border);
        border-radius: var(--crs-r);
        box-shadow: var(--crs-sh-lg);
        min-width: 176px;
        z-index: 50;
        overflow: hidden;
        animation: crsMenuIn .2s ease;
    }

    @@keyframes crsMenuIn {
        from {
            opacity: 0;
            transform: translateY(-5px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .crs-export-menu.show {
        display: block;
    }

    .crs-export-menu button {
        width: 100%;
        text-align: left;
        border: none;
        background: none;
        padding: .55rem .9rem;
        font-size: .6rem;
        font-weight: 600;
        color: var(--crs-text);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .45rem;
        transition: background .2s;
        letter-spacing: .04rem;
        font-family: inherit;
    }

        .crs-export-menu button:hover {
            background: #fef2f2;
            color: var(--crs-red);
        }

        .crs-export-menu button i {
            width: 15px;
            text-align: center;
            color: var(--crs-text-3);
        }

    .crs-modal {
        --crs-red: #ac1900;
        --crs-grad: linear-gradient(135deg, #ac1900 0%, #c53030 55%, #e65100 100%);
        --crs-bg: #f4f5f7;
        --crs-card: #ffffff;
        --crs-border: #e5e7eb;
        --crs-text: #111827;
        --crs-text-2: #4b5563;
        --crs-text-3: #9ca3af;
        --crs-amber: #b45309;
        --crs-amber-soft: #fffbeb;
        --crs-amber-border: #fde68a;
        --crs-r-sm: 8px;
        --crs-r: 12px;
        --crs-r-xl: 22px;
        --crs-sh-lg: 0 12px 36px rgba(0,0,0,.11), 0 4px 12px rgba(0,0,0,.06);
        --crs-t: .26s cubic-bezier(.4,0,.2,1);
        font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
    }

    .crs-modal .modal-dialog { padding: .75rem; }

    .crs-modal .modal-content {
        border: 1px solid var(--crs-border);
        border-radius: var(--crs-r-xl);
        box-shadow: var(--crs-sh-lg);
        overflow: hidden;
    }

    .crs-modal .modal-header {
        background: var(--crs-grad);
        color: #fff;
        border: none;
        padding: 1.3rem 1.75rem 1.2rem;
    }

        .crs-modal .modal-header h5 {
            font-family: 'Space Grotesk', 'Inter', sans-serif;
            font-weight: 700;
            font-size: 1.05rem;
            display: flex;
            align-items: center;
            gap: .5rem;
            margin: 0;
        }

        .crs-modal .modal-header .btn-close {
            filter: brightness(0) invert(1);
            opacity: .8;
        }

    .crs-modal-sub {
        font-size: .55rem;
        letter-spacing: .16rem;
        font-weight: 600;
        opacity: .7;
        margin-top: .25rem;
        text-transform: uppercase;
    }

    .crs-modal .modal-body {
        padding: 1.5rem 1.75rem 1.2rem;
        background: var(--crs-bg);
    }

    .crs-modal .modal-footer {
        background: var(--crs-card);
        border-top: 1px solid var(--crs-border);
        padding: .9rem 1.75rem;
    }

    .crs-modal-row {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .crs-modal-fg {
        flex: 1 1 220px;
        display: flex;
        flex-direction: column;
        gap: .35rem;
    }

        .crs-modal-fg label {
            font-size: .52rem;
            font-weight: 700;
            color: var(--crs-text-3);
            letter-spacing: .14rem;
            text-transform: uppercase;
        }

        .crs-modal-fg input, .crs-modal-fg select {
            border: 1px solid var(--crs-border);
            border-radius: var(--crs-r-sm);
            font-size: .78rem;
            padding: .55rem .75rem;
            background: #fff;
            color: var(--crs-text);
            transition: all var(--crs-t);
            font-family: inherit;
        }

            .crs-modal-fg input:focus, .crs-modal-fg select:focus {
                outline: none;
                border-color: var(--crs-red);
                box-shadow: 0 0 0 3px rgba(172,25,0,.1);
            }

    .crs-dup {
        background: var(--crs-amber-soft);
        border: 1px solid var(--crs-amber-border);
        border-radius: var(--crs-r);
        padding: .8rem .9rem;
        margin-top: .75rem;
        display: none;
        animation: crsDupIn .25s ease;
    }

    @@keyframes crsDupIn {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .crs-dup-title {
        font-size: .58rem;
        font-weight: 700;
        letter-spacing: .1rem;
        color: var(--crs-amber);
        display: flex;
        align-items: center;
        gap: .35rem;
        margin-bottom: .45rem;
    }

    .crs-dup-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

        .crs-dup-list li {
            font-size: .65rem;
            padding: .3rem .45rem;
            border-radius: var(--crs-r-sm);
            color: #78350f;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: background .2s;
        }

            .crs-dup-list li:hover {
                background: rgba(253,230,138,.35);
            }

        .crs-dup-list .crs-dup-tag {
            font-size: .47rem;
            font-weight: 700;
            background: #fde68a;
            color: #78350f;
            padding: .18rem .38rem;
            border-radius: 20px;
        }

    .crs-dup-note {
        margin-top: .5rem;
        font-size: .52rem;
        font-weight: 600;
        color: var(--crs-amber);
        display: flex;
        align-items: center;
        gap: .3rem;
    }

    .crs-hidden {
        display: none !important;
    }

    .modal-backdrop {
        backdrop-filter: blur(4px);
    }

    @@media (max-width: 900px) {
        .crs-table thead th:nth-child(6), .crs-table td:nth-child(6) {
            display: none;
        }

        .crs-stats {
            grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
        }
    }

    @@media (max-width: 740px) {
        .crs-table thead th:nth-child(5), .crs-table td:nth-child(5) {
            display: none;
        }

        .crs-hero {
            padding: 1.1rem 1.2rem;
        }

        .crs-hero-icon {
            width: 48px;
            height: 48px;
            font-size: 1.25rem;
        }

        .crs-hero-copy h1 {
            font-size: 1.2rem;
        }
    }

    @@media (max-width: 540px) {
        .crs-table thead th:nth-child(7), .crs-table td:nth-child(7) {
            display: none;
        }

        .crs-hero-acts {
            margin-left: 0;
            width: 100%;
        }
    }


    @@media (max-width: 767.98px) {
        .crs-grid-view { grid-template-columns: repeat(auto-fill,minmax(250px,1fr)); }
        .crs-modal .modal-dialog { margin: .5rem auto; padding: .35rem; }
        .crs-modal .modal-header { padding: 1rem 1.1rem; }
        .crs-modal .modal-body { padding: 1rem; }
        .crs-modal .modal-footer { padding: .8rem 1rem; }
        .crs-modal-row { display: grid; grid-template-columns: 1fr; gap: .8rem; }
        .crs-modal-fg { min-width: 0; }
        .crs-modal-fg input, .crs-modal-fg select { width: 100%; min-height: 42px; }
    }

    @@media (max-width: 540px) {
        .crs-shell { padding: 1rem .65rem 2.5rem; }
        .crs-filter { align-items: stretch; }
        .crs-search-wrap, .crs-fg, .crs-filter input[type="text"],
        .crs-filter input[type="number"], .crs-filter select { width: 100%; max-width: none !important; }
        .crs-view-toggle { align-self: flex-end; }
        .crs-grid-view { grid-template-columns: 1fr; }
        .cgc-head { padding-right: .85rem; }
        .crs-grid-card .cgc-acts { grid-template-columns: 1fr; }
        .crs-modal .modal-footer { display: grid; grid-template-columns: 1fr; gap: .5rem; }
        .crs-modal .modal-footer button { width: 100%; justify-content: center; margin: 0; }
    }

    .crs-detail-strip { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:.55rem; padding:.85rem 1rem; background:linear-gradient(135deg,#fafafa,#fff); border-top:1px solid var(--crs-border); }
    .crs-detail { min-width:0; }
    .crs-detail small { display:block; color:var(--crs-text-3); font-size:.43rem; letter-spacing:.1rem; text-transform:uppercase; font-weight:800; }
    .crs-detail strong { display:block; color:var(--crs-text); font-size:.62rem; margin-top:.18rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .crs-premium-chip { display:inline-flex; align-items:center; gap:.28rem; padding:.28rem .5rem; border-radius:999px; font-size:.48rem; font-weight:800; letter-spacing:.04rem; background:#f5f3ff; color:#6d28d9; border:1px solid #ddd6fe; }
    .crs-pill-purple { background:#f5f3ff; color:#6d28d9; border-color:#ddd6fe; }
    .crs-pill-purple:hover { background:#6d28d9; color:#fff; }
    .crs-modal .modal-dialog-xl { max-width:1180px; }
    .crs-section { margin-top:1rem; padding:1rem; border:1px solid var(--crs-border); border-radius:var(--crs-r); background:#fafafa; }
    .crs-section-title { display:flex; align-items:center; gap:.55rem; margin-bottom:.8rem; color:var(--crs-text); font-family:'Space Grotesk',sans-serif; font-size:.78rem; font-weight:800; }
    .crs-section-title i { color:var(--crs-red); }
    .crs-modal-row.crs-three { grid-template-columns:repeat(3,minmax(0,1fr)); }
    .crs-modal-fg textarea { width:100%; min-height:82px; resize:vertical; background:var(--crs-bg); border:1px solid var(--crs-border); border-radius:var(--crs-r-sm); padding:.6rem .72rem; font-size:.7rem; }
    .crs-switch-grid { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:.65rem; margin-top:.85rem; }
    .crs-switch { display:flex; align-items:center; gap:.55rem; padding:.65rem .75rem; border:1px solid var(--crs-border); background:#fff; border-radius:var(--crs-r-sm); font-size:.62rem; font-weight:700; color:var(--crs-text-2); }
    .crs-switch input { width:16px; height:16px; accent-color:var(--crs-red); }
    .crs-empty-inline { padding:1rem; text-align:center; color:var(--crs-text-3); font-size:.62rem; }
    @@media(max-width:800px){.crs-detail-strip,.crs-switch-grid{grid-template-columns:1fr 1fr}.crs-modal-row.crs-three{grid-template-columns:1fr}}
</style>

<div class="crs-shell">

    <div class="crs-hero">
        <div class="crs-hero-icon"><i class="fa fa-graduation-cap"></i></div>
        <div class="crs-hero-copy">
            <h1>Active Courses</h1>
            <div class="crs-kicker"><i class="fa fa-layer-group"></i> Academic Management</div>
        </div>
        <div class="crs-hero-acts">
            <button type="button" class="crs-btn-ghost" id="btnRefresh" title="Refresh">
                <i class="fa fa-rotate" id="refreshIcon"></i> Refresh
            </button>
            <div class="crs-export">
                <button type="button" class="crs-btn-ghost" id="btnExportToggle">
                    <i class="fa fa-file-export"></i> Export <i class="fa fa-chevron-down" style="font-size:.4rem;margin-left:.15rem;"></i>
                </button>
                <div class="crs-export-menu" id="exportMenu">
                    <button type="button" id="btnExportCsv"><i class="fa fa-file-csv"></i> Export CSV</button>
                    <button type="button" id="btnExportJson"><i class="fa fa-code"></i> Export JSON</button>
                    <button type="button" disabled style="opacity:.4;cursor:not-allowed;"><i class="fa fa-file-pdf"></i> PDF (soon)</button>
                    <button type="button" disabled style="opacity:.4;cursor:not-allowed;"><i class="fa fa-file-excel"></i> Excel (soon)</button>
                </div>
            </div>
            <button type="button" class="crs-btn-white" data-bs-toggle="modal" data-bs-target="#addCourseModal">
                <i class="fa fa-plus"></i> Add Course
            </button>
        </div>
    </div>

    <div class="crs-stats">
        <div class="crs-stat">
            <div class="crs-stat-label">Total Courses</div>
            <div class="crs-stat-val" data-count="@total">0</div>
            <div class="crs-stat-chip"><i class="fa fa-database"></i> RECORDS</div>
        </div>
        <div class="crs-stat">
            <div class="crs-stat-label">Avg Credits</div>
            <div class="crs-stat-val" data-count="@avgCredits">0</div>
            <div class="crs-stat-chip"><i class="fa fa-star"></i> MEAN</div>
        </div>
        @foreach (var g in typeGroups)
        {
            <div class="crs-stat">
                <div class="crs-stat-label">@g.Key</div>
                <div class="crs-stat-val" data-count="@g.Count()">0</div>
                <div class="crs-stat-chip">@g.Key.ToUpperInvariant()</div>
            </div>
        }
    </div>

    <div class="crs-filter">
        <div class="crs-search-wrap">
            <i class="fa fa-search crs-si"></i>
            <input id="searchBox" type="text" placeholder="Search courses, type, added by…" autocomplete="off" />
            <span class="crs-kbd">Ctrl+K</span>
        </div>
        <div class="crs-fg">
            <label>Type</label>
            <select id="typeFilter">
                <option value="">All Types</option>
                @foreach (var g in typeGroups)
                {
                    <option value="@g.Key">@g.Key</option>
                }
            </select>
        </div>
        <div class="crs-fg">
            <label>Min Credits</label>
            <input id="minCredit" type="number" min="0" placeholder="0" style="max-width:90px;" />
        </div>
        <div class="crs-view-toggle">
            <button type="button" data-view="list" title="Table view"><i class="fa fa-list"></i></button>
            <button type="button" class="active" data-view="grid" title="Card view"><i class="fa fa-grip"></i></button>
        </div>
    </div>

    <div class="crs-table-shell crs-list-view hidden" id="listView">
        <div class="crs-table-meta">
            <span id="rowsInfo" class="crs-meta-badge">Showing @courses.Count record(s)</span>
            <span id="filterInfo" style="font-size:.5rem;letter-spacing:.1rem;font-weight:700;color:var(--crs-text-3);text-transform:uppercase;"></span>
            <span id="limitNote" class="crs-limit-note" style="display:none;"><i class="fa fa-info-circle"></i> LIMITED TO 200</span>
        </div>

        @if (!courses.Any())
        {
            <div class="crs-empty">
                <div class="crs-empty-icon"><i class="fa fa-book-open"></i></div>
                <h3>No Courses Found</h3>
                <p>Get started by adding your first course using the button above.</p>
                <button type="button" class="crs-btn-white"
                        style="background:var(--crs-red);color:#fff;"
                        data-bs-toggle="modal" data-bs-target="#addCourseModal">
                    <i class="fa fa-plus"></i> Add First Course
                </button>
            </div>
        }
        else
        {
            <div class="crs-scroll">
                <table class="crs-table" id="coursesTable">
                    <thead>
                        <tr>
                            <th class="crs-cb"><input type="checkbox" id="selectAll" title="Select All" /></th>
                            <th>Action</th>
                            <th>Course</th>
                            <th>Type</th>
                            <th>Credits</th>
                            <th>Added By</th>
                            <th>Added On</th>
                            <th>Modules</th>
                        </tr>
                    </thead>
                    <tbody id="coursesBody">
                        @foreach (var c in courses)
                        {
                            <tr data-type="@(c.Type ?? "Unknown")" data-credit="@c.Credit"
                                data-added="@c.CreatedBy" data-name="@c.CourseName">
                                <td class="crs-cb">
                                    <input type="checkbox" class="row-cb" value="@c.CourseId" />
                                </td>
                                <td>
                                    <a class="crs-pill"
                                       asp-action="OnModifyCourse" asp-controller="Course"
                                       asp-route-CourseId="@c.CourseId">
                                        <i class="fa fa-arrow-right"></i> Open
                                    </a>
                                    @if (c.HasCourseOptions)
                                    {
                                        <a class="crs-pill crs-pill-purple" asp-action="ManageCourseOptions" asp-controller="Course" asp-route-courseId="@c.CourseId"
                                           title="Configure packages, fee lines, and package duration">
                                            <i class="fa fa-layer-group"></i> Packages (@c.CourseOptions.Count)
                                        </a>
                                    }
                                    else
                                    {
                                        <a class="crs-pill crs-pill-purple" asp-action="OnModifyCourse" asp-controller="Course"
                                           asp-route-CourseId="@c.CourseId" asp-fragment="courseOptionsSettings">
                                            <i class="fa fa-layer-group"></i> Enable Packages
                                        </a>
                                    }
                                </td>
                                <td class="crs-course-name">@c.CourseName</td>
                                <td><span class="crs-badge-type">@c.Type</span></td>
                                <td>@c.Credit</td>
                                <td>@c.CreatedBy</td>
                                <td>
                                    <span class="crs-date" title="@c.CreatedOn">
                                        <span class="crs-rel" data-date="@c.CreatedOn">@c.CreatedOn</span>
                                    </span>
                                </td>
                                <td>
                                    <a class="crs-pill crs-pill-green"
                                       asp-controller="Course" asp-action="OnCourse"
                                       asp-route-CourseId="@c.CourseId">
                                        <i class="fa fa-book"></i> Modules
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="crs-bottom">
                <div>
                    <button id="btnShowAll" class="crs-btn-mini" type="button" style="display:none;">
                        <i class="fa fa-list"></i> Show All
                    </button>
                    <button id="btnLimit" class="crs-btn-mini" type="button" style="display:none;">
                        <i class="fa fa-compress"></i> Limit
                    </button>
                </div>
                <div class="crs-kbd-tip"><kbd>Ctrl</kbd>+<kbd>K</kbd> to search</div>
                <div id="perfInfo" style="font-size:.46rem;color:var(--crs-text-3);"></div>
            </div>
        }
    </div>

    <div class="crs-grid-view active" id="gridView">
        @if (!courses.Any())
        {
            <div class="crs-empty" style="grid-column:1/-1;">
                <div class="crs-empty-icon"><i class="fa fa-book-open"></i></div>
                <h3>No Courses Found</h3>
                <p>Get started by adding your first course using the button above.</p>
                <button type="button" class="crs-btn-white"
                        style="background:var(--crs-red);color:#fff;"
                        data-bs-toggle="modal" data-bs-target="#addCourseModal">
                    <i class="fa fa-plus"></i> Add First Course
                </button>
            </div>
        }
        @foreach (var c in courses)
        {
            <article class="crs-grid-card"
                     data-type="@(c.Type ?? "Unknown")" data-credit="@c.Credit"
                     data-added="@c.CreatedBy" data-name="@c.CourseName">
                <div class="cgc-head">
                    <div class="cgc-icon"><i class="fa fa-graduation-cap"></i></div>
                    <div class="cgc-heading">
                        <div class="cgc-title">@c.CourseName</div>
                        <span class="crs-badge-type">@(c.Type ?? "Unknown")</span>
                    </div>
                    <span class="cgc-credit">@(c.Credit ?? 0) credits</span>
                </div>
                <div class="cgc-meta">
                    <span><i class="fa fa-user"></i> Added by <strong>@(c.CreatedBy ?? "Unknown")</strong></span>
                    <span><i class="fa fa-calendar"></i> Added on <strong>@c.CreatedOn</strong></span>
                </div>
                <div class="crs-detail-strip">
                    <div class="crs-detail"><small>Delivery</small><strong>@ForekOnline.Application.Common.Utility.Helper.GetDisplayName(c.DeliveryMethod)</strong></div>
                    <div class="crs-detail"><small>Study mode</small><strong>@ForekOnline.Application.Common.Utility.Helper.GetDisplayName(c.StudyMode)</strong></div>
                    <div class="crs-detail"><small>Duration</small><strong>@(c.DurationValue?.ToString() ?? "—") @(c.DurationType?.ToString() ?? "")</strong></div>
                    <div class="crs-detail"><small>Tuition</small><strong>@(c.TuitionFee.HasValue ? c.TuitionFee.Value.ToString("C0", new System.Globalization.CultureInfo("en-ZA")) : "On request")</strong></div>
                    <div class="crs-detail"><small>Capacity</small><strong>@(c.MaximumStudents?.ToString() ?? "Flexible")</strong></div>
                    <div class="crs-detail"><small>Accreditation</small><strong>@(c.IsAccredited ? (c.AccreditationBody ?? "Accredited") : "Not specified")</strong></div>
                </div>
                <div class="cgc-acts">
                    <a class="crs-pill" asp-action="OnModifyCourse" asp-controller="Course" asp-route-CourseId="@c.CourseId">
                        <i class="fa fa-arrow-right"></i> Open
                    </a>
                    <a class="crs-pill crs-pill-green" asp-controller="Course" asp-action="OnCourse" asp-route-CourseId="@c.CourseId">
                        <i class="fa fa-book"></i> Modules
                    </a>
                    @if (c.HasCourseOptions)
                    {
                        <a class="crs-pill crs-pill-purple" asp-action="ManageCourseOptions" asp-controller="Course" asp-route-courseId="@c.CourseId"
                           title="Configure packages, fee lines, and package duration">
                            <i class="fa fa-layer-group"></i> Manage Packages (@c.CourseOptions.Count)
                        </a>
                    }
                    else
                    {
                        <a class="crs-pill crs-pill-purple" asp-action="OnModifyCourse" asp-controller="Course"
                           asp-route-CourseId="@c.CourseId" asp-fragment="courseOptionsSettings"
                           title="Enable package-based pricing for this course">
                            <i class="fa fa-layer-group"></i> Enable Packages
                        </a>
                    }
                </div>
            </article>
        }
    </div>

</div>

<div class="modal fade crs-modal" id="addCourseModal" tabindex="-1"
     aria-labelledby="addCourseModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title" id="addCourseModalLabel">
                        <i class="fa fa-plus-circle"></i> Add New Course
                    </h5>
                    <div class="crs-modal-sub">Course Registration</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Course" asp-controller="Course" method="post" id="addCourseForm">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="crs-modal-row">
                        <div class="crs-modal-fg">
                            <label>Course Type</label>
                            <select name="Type" class="CType" id="modalCourseType" required>
                                <option selected value="">Select Course Type</option>
                                @foreach (var val in Enum.GetValues<eCourseType>())
                                {
                                    var display = ForekOnline.Application.Common.Utility.Helper.GetDisplayName(val);
                                    <option value="@((int)val)">@display</option>
                                }
                            </select>
                        </div>
                        <div class="crs-modal-fg">
                            <label>Course Name</label>
                            <input name="Name" id="modalCourseName" required
                                   placeholder="Start typing to check duplicates…" autocomplete="off" />
                        </div>
                    </div>

                    <div class="crs-dup" id="dupPanel">
                        <div class="crs-dup-title">
                            <i class="fa fa-exclamation-triangle"></i> Potential Duplicates Found
                        </div>
                        <ul class="crs-dup-list" id="dupList"></ul>
                        <div class="crs-dup-note">
                            <i class="fa fa-info-circle"></i> This course might already exist — do you still want to proceed?
                        </div>
                    </div>

                    <div class="crs-modal-row" style="margin-top:.9rem;">
                        <div class="crs-modal-fg Level" id="modalLevelGroup">
                            <label>NQF Level</label>
                            <select name="CourseNQFLevel">
                                <option selected value="">Select NQF Level</option>
                                @foreach (var val in Enum.GetValues<eNQF>())
                                {
                                    var display = ForekOnline.Application.Common.Utility.Helper.GetDisplayName(val);
                                    <option value="@((int)val)">@display</option>
                                }
                            </select>
                        </div>
                        <div class="crs-modal-fg NType" id="modalNTypeGroup" style="display:none;">
                            <label>N Type</label>
                            <select name="NType">
                                <option selected value="">Select Option</option>
                                @foreach (var val in Enum.GetValues<eNType>())
                                {
                                    <option value="@((int)val)">@val</option>
                                }
                            </select>
                        </div>
                        <div class="crs-modal-fg">
                            <label>Course Credit</label>
                            <input name="CourseCredit" required type="number" min="0" step="1" placeholder="e.g. 120" />
                        </div>
                        <div class="crs-modal-fg">
                            <label>Minimum Requirements</label>
                            <select name="MinimumRequirement">
                                <option selected value="">Select Minimum Requirement</option>
                                @foreach (var val in Enum.GetValues<eMinimumRequirement>())
                                {
                                    var display = ForekOnline.Application.Common.Utility.Helper.GetDisplayName(val);
                                    <option value="@((int)val)">@display</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="crs-section">
                        <div class="crs-section-title"><i class="fa fa-clock"></i> Delivery &amp; Requirements</div>
                        <div class="crs-modal-row crs-three">
                            <div class="crs-modal-fg"><label>Duration Value</label><input name="DurationValue" type="number" min="1" placeholder="e.g. 12" /></div>
                            <div class="crs-modal-fg"><label>Duration Type</label><select name="DurationType"><option value="">Select duration</option>@foreach(var val in Enum.GetValues<eDurationType>()){<option value="@((int)val)">@ForekOnline.Application.Common.Utility.Helper.GetDisplayName(val)</option>}</select></div>
                            <div class="crs-modal-fg"><label>Study Mode</label><select name="StudyMode">@foreach(var val in Enum.GetValues<eStudyMode>()){<option value="@((int)val)">@ForekOnline.Application.Common.Utility.Helper.GetDisplayName(val)</option>}</select></div>
                            <div class="crs-modal-fg"><label>Delivery Method</label><select name="DeliveryMethod">@foreach(var val in Enum.GetValues<eDeliveryMethod>()){<option value="@((int)val)">@ForekOnline.Application.Common.Utility.Helper.GetDisplayName(val)</option>}</select></div>
                            <div class="crs-modal-fg" style="grid-column:span 2"><label>Minimum Requirement Notes</label><textarea name="MinimumRequirementNotes" maxlength="1000" placeholder="Describe supporting documents, subjects, grades or experience required..."></textarea></div>
                        </div>
                    </div>
                    <div class="crs-section">
                        <div class="crs-section-title"><i class="fa fa-shield-halved"></i> Accreditation &amp; Admissions</div>
                        <div class="crs-modal-row crs-three" id="accreditationFields" style="display:none">
                            <div class="crs-modal-fg"><label>Accreditation Body</label><input name="AccreditationBody" maxlength="200" placeholder="e.g. QCTO" /></div>
                            <div class="crs-modal-fg"><label>Accreditation Number</label><input name="AccreditationNumber" maxlength="100" placeholder="Registration number" /></div>
                        </div>
                        <div class="crs-switch-grid">
                            <label class="crs-switch"><input name="IsAccredited" id="modalAccredited" type="checkbox" value="true" /> Accredited course</label>
                            <label class="crs-switch"><input name="RequiresAptitudeTest" type="checkbox" value="true" /> Requires aptitude test</label>
                            <label class="crs-switch"><input name="RequiresInterview" type="checkbox" value="true" /> Requires interview</label>
                        </div>
                    </div>
                    <div class="crs-section">
                        <div class="crs-section-title"><i class="fa fa-wallet"></i> Fees &amp; Capacity</div>
                        <div class="crs-modal-row crs-three">
                            <div class="crs-modal-fg"><label>Application Fee</label><input name="ApplicationFee" type="number" min="0" step="0.01" placeholder="R 0.00" /></div>
                            <div class="crs-modal-fg"><label>Registration Fee</label><input name="RegistrationFee" type="number" min="0" step="0.01" placeholder="R 0.00" /></div>
                            <div class="crs-modal-fg"><label>Tuition Fee</label><input name="TuitionFee" type="number" min="0" step="0.01" placeholder="R 0.00" /></div>
                            <div class="crs-modal-fg"><label>Maximum Students</label><input name="MaximumStudents" type="number" min="1" placeholder="Capacity" /></div>
                        </div>
                    </div>
                    <div class="crs-switch-grid">
                        <label class="crs-switch"><input name="IsEligibleForOnlineApplications" type="checkbox" value="true" checked /> Online applications</label>
                        <label class="crs-switch"><input name="HasCourseOptions" type="checkbox" value="true" /> Has course options</label>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="crs-btn-ghost"
                            style="color:var(--crs-text-2);border-color:var(--crs-border);background:transparent;"
                            data-bs-dismiss="modal">
                        <i class="fa fa-times"></i> Cancel
                    </button>
                    <button type="submit" class="crs-btn-white"
                            style="background:var(--crs-red);color:#fff;"
                            id="btnSaveCourse">
                        <i class="fa fa-save"></i> Save Course
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>


<script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    (function () {
    const DEFAULT_LIMIT = 200;
    const body       = document.getElementById('coursesBody');
    const searchBox  = document.getElementById('searchBox');
    const typeFilter = document.getElementById('typeFilter');
    const minCredit  = document.getElementById('minCredit');
    const rowsInfo   = document.getElementById('rowsInfo');
    const filterInfo = document.getElementById('filterInfo');
    const limitNote  = document.getElementById('limitNote');
    const btnShowAll = document.getElementById('btnShowAll');
    const btnLimit   = document.getElementById('btnLimit');
    const perfInfo   = document.getElementById('perfInfo');
    let limitedMode  = true;

    function norm(v) { return (v || '').toString().toLowerCase().trim(); }

    document.querySelectorAll('.crs-stat-val[data-count]').forEach(el => {
    const target = parseInt(el.getAttribute('data-count')) || 0;
    const start  = performance.now();
    (function step(now) {
    const p = Math.min((now - start) / 800, 1);
    el.textContent = Math.round((1 - Math.pow(1 - p, 3)) * target);
    if (p < 1) requestAnimationFrame(step);
    })(start);
    });

    function applyFilters() {
    if (!body) return;
    const t0  = performance.now();
    const q   = norm(searchBox.value);
    const tp  = typeFilter.value;
    const minC = parseFloat(minCredit.value) || 0;
    const filtering = !!(q || tp || minC > 0);
    const rows      = Array.from(body.querySelectorAll('tr'));
    const gridCards = document.querySelectorAll('#gridView .crs-grid-card');
    let shown = 0, matched = 0;

    rows.forEach(r => {
    const rt = r.getAttribute('data-type');
    const rc = parseFloat(r.getAttribute('data-credit')) || 0;
    let show = true;
    if (q   && !norm(r.innerText).includes(q)) show = false;
    if (tp  && rt !== tp)                       show = false;
    if (minC > 0 && rc < minC)                  show = false;
    if (show) {
    matched++;
    if (limitedMode && !filtering && shown >= DEFAULT_LIMIT) show = false;
    }
    r.classList.toggle('crs-hidden', !show);
    if (show) shown++;
    });

    let shownCards = 0;
    gridCards.forEach(card => {
    const rt = card.getAttribute('data-type');
    const rc = parseFloat(card.getAttribute('data-credit')) || 0;
    let show = true;
    if (q   && !norm(card.innerText).includes(q)) show = false;
    if (tp  && rt !== tp)                          show = false;
    if (minC > 0 && rc < minC)                     show = false;
    if (show && limitedMode && !filtering && shownCards >= DEFAULT_LIMIT) show = false;
    card.style.display = show ? '' : 'none';
    if (show) shownCards++;
    });

    if (rowsInfo)   rowsInfo.textContent   = 'Showing ' + shown + ' record(s)' + (filtering ? ' (filtered)' : '');
    if (filterInfo) filterInfo.textContent  = filtering ? 'FILTERED' : '';
    if (limitNote)  limitNote.style.display = (!filtering && limitedMode && matched > DEFAULT_LIMIT) ? '' : 'none';
    if (btnShowAll) btnShowAll.style.display = (!filtering && limitedMode  && matched > DEFAULT_LIMIT) ? '' : 'none';
    if (btnLimit)   btnLimit.style.display   = (!filtering && !limitedMode && matched > DEFAULT_LIMIT) ? '' : 'none';
    if (perfInfo)   perfInfo.textContent     = 'Render: ' + (performance.now() - t0).toFixed(1) + 'ms';
    }

    if (searchBox)  searchBox.addEventListener('input',  () => { limitedMode = false; applyFilters(); });
    if (typeFilter) typeFilter.addEventListener('change', () => { limitedMode = false; applyFilters(); });
    if (minCredit)  minCredit.addEventListener('input',  () => { limitedMode = false; applyFilters(); });
    if (btnShowAll) btnShowAll.addEventListener('click', () => { limitedMode = false; applyFilters(); });
    if (btnLimit)   btnLimit.addEventListener('click',   () => { limitedMode = true;  applyFilters(); });

    document.addEventListener('keydown', e => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
    e.preventDefault();
    if (searchBox) searchBox.focus();
    }
    });

    const btnRefresh  = document.getElementById('btnRefresh');
    const refreshIcon = document.getElementById('refreshIcon');
    if (btnRefresh) {
    btnRefresh.addEventListener('click', () => {
    if (refreshIcon) {
    refreshIcon.style.transition = 'transform .6s ease';
    refreshIcon.style.transform  = 'rotate(360deg)';
    }
    setTimeout(() => location.reload(), 600);
    });
    }

    const selectAll = document.getElementById('selectAll');
    if (selectAll) {
    selectAll.addEventListener('change', () => {
    document.querySelectorAll('.row-cb').forEach(cb => { cb.checked = selectAll.checked; });
    });
    }

    document.querySelectorAll('.crs-view-toggle button').forEach(btn => {
    btn.addEventListener('click', () => {
    document.querySelectorAll('.crs-view-toggle button').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const listView = document.getElementById('listView');
    const gridView = document.getElementById('gridView');
    if (btn.getAttribute('data-view') === 'grid') {
    listView.classList.add('hidden');
    gridView.classList.add('active');
    } else {
    listView.classList.remove('hidden');
    gridView.classList.remove('active');
    }
    });
    });

    const exportToggle = document.getElementById('btnExportToggle');
    const exportMenu   = document.getElementById('exportMenu');
    if (exportToggle && exportMenu) {
    exportToggle.addEventListener('click', e => { e.stopPropagation(); exportMenu.classList.toggle('show'); });
    document.addEventListener('click', () => exportMenu.classList.remove('show'));
    }

    function escapeHtml(str) {
    const d = document.createElement('div');
    d.textContent = str; return d.innerHTML;
    }

    const btnExportCsv = document.getElementById('btnExportCsv');
    if (btnExportCsv && body) {
    btnExportCsv.addEventListener('click', () => {
    exportMenu.classList.remove('show');
    const visible = Array.from(body.querySelectorAll('tr:not(.crs-hidden)'));
    if (!visible.length) { Swal.fire({ icon: 'info', title: 'No Data', text: 'No visible rows to export.' }); return; }
    const lines = ['Course,Type,Credits,AddedBy,AddedOn'];
    visible.forEach(r => {
    const cells = r.querySelectorAll('td');
    lines.push([cells[2], cells[3], cells[4], cells[5], cells[6]]
    .map(td => '"' + (td?.innerText?.trim() || '').replace(/"/g, '""') + '"').join(','));
    });
    const a = Object.assign(document.createElement('a'), {
    href: URL.createObjectURL(new Blob([lines.join('\r\n')], { type: 'text/csv;charset=utf-8;' })),
    download: 'courses-' + new Date().toISOString().slice(0, 10) + '.csv'
    });
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    });
    }

    const btnExportJson = document.getElementById('btnExportJson');
    if (btnExportJson && body) {
    btnExportJson.addEventListener('click', () => {
    exportMenu.classList.remove('show');
    const visible = Array.from(body.querySelectorAll('tr:not(.crs-hidden)'));
    if (!visible.length) { Swal.fire({ icon: 'info', title: 'No Data', text: 'No visible rows to export.' }); return; }
    const data = visible.map(r => {
    const cells = r.querySelectorAll('td');
    return { course: cells[2]?.innerText?.trim() || '', type: cells[3]?.innerText?.trim() || '',
    credits: cells[4]?.innerText?.trim() || '', addedBy: cells[5]?.innerText?.trim() || '',
    addedOn: cells[6]?.innerText?.trim() || '' };
    });
    const a = Object.assign(document.createElement('a'), {
    href: URL.createObjectURL(new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' })),
    download: 'courses-' + new Date().toISOString().slice(0, 10) + '.json'
    });
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    });
    }

    const modalCourseType = document.getElementById('modalCourseType');
    const modalLevelGroup = document.getElementById('modalLevelGroup');
    const modalNTypeGroup = document.getElementById('modalNTypeGroup');
    if (modalCourseType) {
    modalCourseType.addEventListener('change', () => {
    const isNated = (modalCourseType.options[modalCourseType.selectedIndex]?.text || '').includes('Nated');
    modalNTypeGroup.style.display = isNated ? '' : 'none';
    modalLevelGroup.style.display = isNated ? 'none' : '';
    });
    }

    const modalCourseName = document.getElementById('modalCourseName');
    const dupPanel        = document.getElementById('dupPanel');
    const dupList         = document.getElementById('dupList');
    let dupTimeout        = null;

    if (modalCourseName) {
    modalCourseName.addEventListener('input', () => {
    clearTimeout(dupTimeout);
    const q = modalCourseName.value.trim();
    if (q.length < 2) { dupPanel.style.display = 'none'; return; }
    dupTimeout = setTimeout(() => {
    fetch('/Course/SearchCoursesByName?q=' + encodeURIComponent(q))
    .then(r => r.json())
    .then(results => {
    if (!results.length) { dupPanel.style.display = 'none'; return; }
    dupList.innerHTML = '';
    results.forEach(c => {
    const li = document.createElement('li');
    li.innerHTML = '<span>' + escapeHtml(c.name) + '</span>'
    + '<span class="crs-dup-tag">' + escapeHtml(c.type) + ' &bull; ' + (c.credit || 0) + ' cr</span>';
    dupList.appendChild(li);
    });
    dupPanel.style.display = 'block';
    })
    .catch(() => { dupPanel.style.display = 'none'; });
    }, 350);
    });
    }

    document.querySelectorAll('.crs-rel[data-date]').forEach(el => {
    const raw = el.getAttribute('data-date');
    if (!raw) return;
    try {
    const d = new Date(raw);
    if (isNaN(d.getTime())) return;
    const days = Math.floor((new Date() - d) / 86400000);
    let text;
    if      (days === 0) text = 'Today';
    else if (days === 1) text = 'Yesterday';
    else if (days < 7)   text = days + ' days ago';
    else if (days < 30)  text = Math.floor(days / 7) + 'w ago';
    else text = d.toLocaleDateString('en-ZA', { day: '2-digit', month: 'short', year: 'numeric' });
    el.textContent = text;
    el.closest('.crs-date').title = d.toLocaleString('en-ZA');
    } catch { }
    });

    const accredited = document.getElementById('modalAccredited');
    const accreditationFields = document.getElementById('accreditationFields');
    if (accredited && accreditationFields) accredited.addEventListener('change', () => accreditationFields.style.display = accredited.checked ? '' : 'none');

    applyFilters();
    })();
</script>
