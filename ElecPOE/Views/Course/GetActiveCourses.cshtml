    @@media (max-width: 900px) {
        .courses-table thead th:nth-child(6), .courses-table td:nth-child(6) {
            display: none;
        }

        .summary-grid {
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        }
    }

    @@media (max-width: 740px) {
        .courses-table thead th:nth-child(5), .courses-table td:nth-child(5) {
            display: none;
        }

