</style>

<div class="courses-shell">
    <div class="header-band">
        <div class="icon-pill"><i class="fa fa-graduation-cap"></i></div>
        <div>
            <h1>Active Courses</h1>
            <div class="tagline"><i class="fa fa-layer-group"></i> ACADEMIC MANAGEMENT</div>
        </div>
        <div class="toolbar">
            <button type="button" class="btn-act" id="btnRefresh" title="Refresh">
                <i class="fa fa-rotate spin-on-click"></i>
            </button>
            <div class="export-dropdown">
                <button type="button" class="btn-act" id="btnExportToggle">
                    <i class="fa fa-file-export"></i> Export <i class="fa fa-chevron-down" style="font-size:.45rem;"></i>
                </button>
                <div class="export-menu" id="exportMenu">
                    <button type="button" id="btnExportCsv"><i class="fa fa-file-csv"></i> Export CSV</button>
                    <button type="button" id="btnExportJson"><i class="fa fa-code"></i> Export JSON</button>
                    <button type="button" disabled style="opacity:.4;cursor:not-allowed;"><i class="fa fa-file-pdf"></i> Export PDF (soon)</button>
                    <button type="button" disabled style="opacity:.4;cursor:not-allowed;"><i class="fa fa-file-excel"></i> Export Excel (soon)</button>
                </div>
            </div>
            <button type="button" class="btn-primary-cta" data-bs-toggle="modal" data-bs-target="#addCourseModal">
                <i class="fa fa-plus"></i> Add Course
            </button>
        </div>
    </div>

    <div class="summary-grid">
        <div class="sum-card">
            <div class="sum-label">Total Courses</div>
            <div class="sum-value" data-count="@total">0</div>
            <div class="sum-chip"><i class="fa fa-database"></i> RECORDS</div>
        </div>
        <div class="sum-card">
            <div class="sum-label">Avg Credits</div>
            <div class="sum-value" data-count="@avgCredits">0</div>
            <div class="sum-chip"><i class="fa fa-star"></i> MEAN</div>
        </div>
        @foreach (var g in typeGroups)
        {
            <div class="sum-card">
                <div class="sum-label">@g.Key</div>
                <div class="sum-value" data-count="@g.Count()">0</div>
                <div class="sum-chip">@g.Key.ToUpperInvariant()</div>
            </div>
        }
    </div>

    <div class="filter-bar">
        <div class="search-wrap">
            <i class="fa fa-search"></i>
            <input id="searchBox" type="text" placeholder="Search courses, type, added by..." autocomplete="off" />
            <span class="kbd-hint">Ctrl+K</span>
        </div>
        <div class="filter-group">
            <label>Type</label>
            <select id="typeFilter">
                <option value="">All Types</option>
                @foreach (var g in typeGroups)
                {
                    <option value="@g.Key">@g.Key</option>
                }
            </select>
        </div>
        <div class="filter-group">
            <label>Min Credits</label>
            <input id="minCredit" type="number" min="0" placeholder="0" style="max-width:100px;" />
        </div>
        <div class="view-toggle">
            <button type="button" class="active" data-view="list" title="List View"><i class="fa fa-list"></i></button>
            <button type="button" data-view="grid" title="Grid View"><i class="fa fa-grip"></i></button>
        </div>
    </div>

    <div class="table-shell list-view" id="listView">
        <div class="table-meta">
            <span id="rowsInfo" class="badge">Showing @courses.Count record(s)</span>
            <span id="filterInfo"></span>
            <span id="limitNote" class="limit-note" style="display:none;"><i class="fa fa-info-circle"></i> LIMITED TO 200</span>
        </div>

        @if (!courses.Any())
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="fa fa-book-open"></i></div>
                <h3>No Courses Found</h3>
                <p>Get started by adding your first course. Click the "Add Course" button above to begin.</p>
                <button type="button" class="btn-primary-cta" data-bs-toggle="modal" data-bs-target="#addCourseModal">
                    <i class="fa fa-plus"></i> Add Your First Course
                </button>
            </div>
        }
        else
        {
            <div class="table-scroll">
                <table class="courses-table" id="coursesTable">
                    <thead>
                        <tr>
                            <th class="cb-cell"><input type="checkbox" id="selectAll" title="Select All" /></th>
                            <th>Action</th>
                            <th>Course</th>
                            <th>Type</th>
                            <th>Credits</th>
                            <th>Added By</th>
                            <th>Added On</th>
                            <th>Modules</th>
                        </tr>
                    </thead>
                    <tbody id="coursesBody">
                        @foreach (var c in courses)
                        {
                            var created = c.CreatedOn;
                            <tr data-type="@(c.Type ?? "Unknown")" data-credit="@c.Credit" data-added="@c.CreatedBy" data-name="@c.CourseName">
                                <td class="cb-cell"><input type="checkbox" class="row-cb" value="@c.CourseId" /></td>
                                <td>
                                    <a class="action-pill" asp-action="OnModifyCourse" asp-controller="Course" asp-route-CourseId="@c.CourseId">
                                        <i class="fa fa-arrow-right"></i> Open
                                    </a>
                                </td>
                                <td class="course-name">@c.CourseName</td>
                                <td><span class="badge-type">@c.Type</span></td>
                                <td>@c.Credit</td>
                                <td>@c.CreatedBy</td>
                                <td>
                                    <span class="date-display" title="@created">
                                        <span class="relative" data-date="@created">@created</span>
                                    </span>
                                </td>
                                <td>
                                    <a class="action-pill modules-pill" asp-controller="Course" asp-action="OnCourse" asp-route-CourseId="@c.CourseId">
                                        <i class="fa fa-book"></i> Modules
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="bottom-bar">
                <div>
                    <button id="btnShowAll" class="btn-mini" type="button" style="display:none;"><i class="fa fa-list"></i> Show All</button>
                    <button id="btnLimit" class="btn-mini" type="button" style="display:none;"><i class="fa fa-compress"></i> Limit</button>
                </div>
                <div class="kbd-bottom">
                    <kbd>Ctrl</kbd>+<kbd>K</kbd> Search
                </div>
                <div id="perfInfo"></div>
            </div>
        }
    </div>

    <div class="grid-view" id="gridView">
        @foreach (var c in courses)
        {
            <div class="course-grid-card" data-type="@(c.Type ?? "Unknown")" data-credit="@c.Credit" data-added="@c.CreatedBy" data-name="@c.CourseName">
                <div class="card-title">@c.CourseName</div>
                <span class="badge-type" style="align-self:flex-start;">@c.Type</span>
                <div class="card-meta">
                    <span><i class="fa fa-star"></i> @c.Credit credits</span>
                    <span><i class="fa fa-user"></i> @c.CreatedBy</span>
                    <span><i class="fa fa-calendar"></i> @c.CreatedOn</span>
                </div>
                <div class="card-actions">
                    <a class="action-pill" asp-action="OnModifyCourse" asp-controller="Course" asp-route-CourseId="@c.CourseId">
                        <i class="fa fa-arrow-right"></i> Open
                    </a>
                    <a class="action-pill modules-pill" asp-controller="Course" asp-action="OnCourse" asp-route-CourseId="@c.CourseId">
                        <i class="fa fa-book"></i> Modules
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade modal-add" id="addCourseModal" tabindex="-1" aria-labelledby="addCourseModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title" id="addCourseModalLabel">
                        <i class="fa fa-plus-circle"></i> Add New Course
                    </h5>
                    <div class="modal-subtitle">COURSE REGISTRATION</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Course" asp-controller="Course" method="post" id="addCourseForm">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="modal-form-row">
                        <div class="modal-form-group">
                            <label>Course Type</label>
                            <select name="Type" class="CType" id="modalCourseType" required>
                                <option selected value="">Select Course Type</option>
                                @foreach (var val in Enum.GetValues<eCourseType>())
                                {
                                    var display = ForekOnline.Application.Common.Utility.Helper.GetDisplayName(val);
                                    <option value="@((int)val)">@display</option>
                                }
                            </select>
                        </div>
                        <div class="modal-form-group">
                            <label>Course Name</label>
                            <input name="Name" id="modalCourseName" required placeholder="Start typing to check duplicates..." autocomplete="off" />
                        </div>
                    </div>

                    <div class="dup-panel" id="dupPanel">
                        <div class="dup-title">
                            <i class="fa fa-exclamation-triangle"></i> Potential Duplicates Found
                        </div>
                        <ul class="dup-list" id="dupList"></ul>
                        <div class="dup-proceed">
                            <i class="fa fa-info-circle"></i> Do you still want to proceed? This course might already exist.
                        </div>
                    </div>

                    <div class="modal-form-row" style="margin-top:1rem;">
                        <div class="modal-form-group Level" id="modalLevelGroup">
                            <label>NQF Level</label>
                            <select name="CourseNQFLevel">
                                <option selected value="">Select NQF Level</option>
                                @foreach (var val in Enum.GetValues<eNQF>())
                                {
                                    var display = ForekOnline.Application.Common.Utility.Helper.GetDisplayName(val);
                                    <option value="@((int)val)">@display</option>
                                }
                            </select>
                        </div>
                        <div class="modal-form-group NType" id="modalNTypeGroup" style="display:none;">
                            <label>N Type</label>
                            <select name="NType">
                                <option selected value="">Select Option</option>
                                @foreach (var val in Enum.GetValues<eNType>())
                                {
                                    <option value="@((int)val)">@val</option>
                                }
                            </select>
                        </div>
                        <div class="modal-form-group">
                            <label>Course Credit</label>
                            <input name="CourseCredit" required type="number" min="0" step="1" placeholder="e.g. 120" />
                        </div>
                        <div class="modal-form-group">
                            <label>Minimum Requirements</label>
                            <select name="MinimumRequirement">
                                <option selected value="">Select Minimum Requirement</option>
                                @foreach (var val in Enum.GetValues<eMinimumRequirement>())
                                {
                                    var display = ForekOnline.Application.Common.Utility.Helper.GetDisplayName(val);
                                    <option value="@((int)val)">@display</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div style="margin-top:1.2rem; display:flex; align-items:center; gap:.6rem;">
                        <input name="IsEligibleForOnlineApplications" type="checkbox" id="modalEligibility"
                               style="width:18px;height:18px;accent-color:var(--p-navy);cursor:pointer;" />
                        <label for="modalEligibility" style="font-size:.72rem;font-weight:600;color:var(--p-text);cursor:pointer;margin:0;letter-spacing:.02rem;">
                            Eligible for Online Applications
                        </label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-act" data-bs-dismiss="modal"><i class="fa fa-times"></i> Cancel</button>
                    <button type="submit" class="btn-primary-cta" id="btnSaveCourse"><i class="fa fa-save"></i> Save Course</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    (function () {
        const DEFAULT_LIMIT = 200;
        const body = document.getElementById('coursesBody');
        const searchBox = document.getElementById('searchBox');
        const typeFilter = document.getElementById('typeFilter');
        const minCredit = document.getElementById('minCredit');
        const rowsInfo = document.getElementById('rowsInfo');
        const filterInfo = document.getElementById('filterInfo');
        const limitNote = document.getElementById('limitNote');
        const btnShowAll = document.getElementById('btnShowAll');
        const btnLimit = document.getElementById('btnLimit');
        const perfInfo = document.getElementById('perfInfo');
        let limitedMode = true;

        function norm(v) { return (v || '').toString().toLowerCase().trim(); }

        document.querySelectorAll('.sum-value[data-count]').forEach(el => {
            const target = parseInt(el.getAttribute('data-count')) || 0;
            const duration = 800;
            const start = performance.now();
            function step(now) {
                const progress = Math.min((now - start) / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 3);
                el.textContent = Math.round(eased * target);
                if (progress < 1) requestAnimationFrame(step);
            }
            requestAnimationFrame(step);
        });

        function applyFilters() {
            if (!body) return;
            const t0 = performance.now();
            const q = norm(searchBox.value);
            const tp = typeFilter.value;
            const minC = parseFloat(minCredit.value) || 0;
            const filtering = !!(q || tp || minC > 0);
            const rows = Array.from(body.querySelectorAll('tr'));
            const gridCards = document.querySelectorAll('#gridView .course-grid-card');
            let shown = 0, matched = 0;

            rows.forEach(r => {
                const text = norm(r.innerText);
                const rt = r.getAttribute('data-type');
                const rc = parseFloat(r.getAttribute('data-credit')) || 0;
                let show = true;
                if (q && !text.includes(q)) show = false;
                if (tp && rt !== tp) show = false;
                if (minC > 0 && rc < minC) show = false;
                if (show) {
                    matched++;
                    if (limitedMode && !filtering && shown >= DEFAULT_LIMIT) show = false;
                }
                r.classList.toggle('hidden-row', !show);
                if (show) shown++;
            });

            gridCards.forEach(card => {
                const text = norm(card.innerText);
                const rt = card.getAttribute('data-type');
                const rc = parseFloat(card.getAttribute('data-credit')) || 0;
                let show = true;
                if (q && !text.includes(q)) show = false;
                if (tp && rt !== tp) show = false;
                if (minC > 0 && rc < minC) show = false;
                card.style.display = show ? '' : 'none';
            });

            if (rowsInfo) rowsInfo.textContent = 'Showing ' + shown + ' record(s)' + (filtering ? ' (filtered)' : '');
            if (filterInfo) filterInfo.textContent = filtering ? 'FILTERED' : (limitedMode ? '' : '');
            if (limitNote) limitNote.style.display = (!filtering && limitedMode && matched > DEFAULT_LIMIT) ? '' : 'none';
            if (btnShowAll) btnShowAll.style.display = (!filtering && limitedMode && matched > DEFAULT_LIMIT) ? '' : 'none';
            if (btnLimit) btnLimit.style.display = (!filtering && !limitedMode && matched > DEFAULT_LIMIT) ? '' : 'none';
            if (perfInfo) perfInfo.textContent = 'Render: ' + (performance.now() - t0).toFixed(1) + 'ms';
        }

        if (searchBox) searchBox.addEventListener('input', () => { limitedMode = false; applyFilters(); });
        if (typeFilter) typeFilter.addEventListener('change', () => { limitedMode = false; applyFilters(); });
        if (minCredit) minCredit.addEventListener('input', () => { limitedMode = false; applyFilters(); });
        if (btnShowAll) btnShowAll.addEventListener('click', () => { limitedMode = false; applyFilters(); });
        if (btnLimit) btnLimit.addEventListener('click', () => { limitedMode = true; applyFilters(); });

        document.addEventListener('keydown', e => {
            if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
                e.preventDefault();
                if (searchBox) searchBox.focus();
            }
        });

        const btnRefresh = document.getElementById('btnRefresh');
        if (btnRefresh) {
            btnRefresh.addEventListener('click', () => {
                const icon = btnRefresh.querySelector('i');
                icon.style.transform = 'rotate(360deg)';
                setTimeout(() => { icon.style.transform = ''; location.reload(); }, 600);
            });
        }

        const selectAll = document.getElementById('selectAll');
        if (selectAll) {
            selectAll.addEventListener('change', () => {
                document.querySelectorAll('.row-cb').forEach(cb => { cb.checked = selectAll.checked; });
            });
        }

        document.querySelectorAll('.view-toggle button').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.view-toggle button').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                const view = btn.getAttribute('data-view');
                const listView = document.getElementById('listView');
                const gridView = document.getElementById('gridView');
                if (view === 'grid') {
                    listView.classList.add('hidden');
                    gridView.classList.add('active');
                } else {
                    listView.classList.remove('hidden');
                    gridView.classList.remove('active');
                }
            });
        });

        const exportToggle = document.getElementById('btnExportToggle');
        const exportMenu = document.getElementById('exportMenu');
        if (exportToggle && exportMenu) {
            exportToggle.addEventListener('click', e => {
                e.stopPropagation();
                exportMenu.classList.toggle('show');
            });
            document.addEventListener('click', () => exportMenu.classList.remove('show'));
        }

        const btnExportCsv = document.getElementById('btnExportCsv');
        if (btnExportCsv && body) {
            btnExportCsv.addEventListener('click', () => {
                exportMenu.classList.remove('show');
                const visible = Array.from(body.querySelectorAll('tr:not(.hidden-row)'));
                if (!visible.length) { Swal.fire({ icon: 'info', title: 'No Data', text: 'No visible rows to export.' }); return; }
                const lines = ['Course,Type,Credits,AddedBy,AddedOn'];
                visible.forEach(r => {
                    const cells = r.querySelectorAll('td');
                    const row = [cells[2], cells[3], cells[4], cells[5], cells[6]]
                        .map(td => '"' + (td?.innerText?.trim() || '').replace(/"/g, '""') + '"').join(',');
                    lines.push(row);
                });
                const blob = new Blob([lines.join('\r\n')], { type: 'text/csv;charset=utf-8;' });
                const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
                a.download = 'courses-' + new Date().toISOString().slice(0, 10) + '.csv';
                document.body.appendChild(a); a.click(); document.body.removeChild(a);
            });
        }

        const btnExportJson = document.getElementById('btnExportJson');
        if (btnExportJson && body) {
            btnExportJson.addEventListener('click', () => {
                exportMenu.classList.remove('show');
                const visible = Array.from(body.querySelectorAll('tr:not(.hidden-row)'));
                if (!visible.length) { Swal.fire({ icon: 'info', title: 'No Data', text: 'No visible rows to export.' }); return; }
                const data = visible.map(r => {
                    const cells = r.querySelectorAll('td');
                    return {
                        course: cells[2]?.innerText?.trim() || '',
                        type: cells[3]?.innerText?.trim() || '',
                        credits: cells[4]?.innerText?.trim() || '',
                        addedBy: cells[5]?.innerText?.trim() || '',
                        addedOn: cells[6]?.innerText?.trim() || ''
                    };
                });
                const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
                const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
                a.download = 'courses-' + new Date().toISOString().slice(0, 10) + '.json';
                document.body.appendChild(a); a.click(); document.body.removeChild(a);
            });
        }

        const modalCourseType = document.getElementById('modalCourseType');
        const modalLevelGroup = document.getElementById('modalLevelGroup');
        const modalNTypeGroup = document.getElementById('modalNTypeGroup');
        if (modalCourseType) {
            modalCourseType.addEventListener('change', () => {
                const text = modalCourseType.options[modalCourseType.selectedIndex]?.text || '';
                if (text.includes('Nated')) {
                    modalNTypeGroup.style.display = '';
                    modalLevelGroup.style.display = 'none';
                } else {
                    modalNTypeGroup.style.display = 'none';
                    modalLevelGroup.style.display = '';
                }
            });
        }

        const modalCourseName = document.getElementById('modalCourseName');
        const dupPanel = document.getElementById('dupPanel');
        const dupList = document.getElementById('dupList');
        let dupTimeout = null;

                if (modalCourseName) {
            modalCourseName.addEventListener('input', () => {
                clearTimeout(dupTimeout);
                const q = modalCourseName.value.trim();
                if (q.length < 2) {
                    dupPanel.style.display = 'none';
                    return;
                }
                dupTimeout = setTimeout(() => {
                    fetch('/Course/SearchCoursesByName?q=' + encodeURIComponent(q))
                        .then(r => r.json())
                        .then(results => {
                            if (results.length === 0) {
                                dupPanel.style.display = 'none';
                                return;
                            }
                            dupList.innerHTML = '';
                            results.forEach(c => {
                                const li = document.createElement('li');
                                li.innerHTML = '<span>' + escapeHtml(c.name) + '</span><span class="dup-type">' + escapeHtml(c.type) + ' &bull; ' + (c.credit || 0) + ' credits</span>';
                                dupList.appendChild(li);
                            });
                            dupPanel.style.display = 'block';
                        })
                        .catch(() => { dupPanel.style.display = 'none'; });
                }, 350);
            });
        }

        function escapeHtml(str) {
            const div = document.createElement('div');
            div.textContent = str;
            return div.innerHTML;
        }

        document.querySelectorAll('.relative[data-date]').forEach(el => {
            const raw = el.getAttribute('data-date');
            if (!raw) return;
            try {
                const d = new Date(raw);
                if (isNaN(d.getTime())) return;
                const now = new Date();
                const diffMs = now - d;
                const diffDays = Math.floor(diffMs / 86400000);
                let text;
                if (diffDays === 0) text = 'Today';
                else if (diffDays === 1) text = 'Yesterday';
                else if (diffDays < 7) text = diffDays + ' days ago';
                else if (diffDays < 30) text = Math.floor(diffDays / 7) + 'w ago';
                else text = d.toLocaleDateString('en-ZA', { day: '2-digit', month: 'short', year: 'numeric' });
                el.textContent = text;
                el.closest('.date-display').title = d.toLocaleString('en-ZA');
            } catch {  }
        });

        applyFilters();
    })();
</script>