@model IEnumerable<ForekOnline.Domain.Entities.Report>
@using static ForekOnline.Domain.Enums.EnumRegistry
@using ForekOnline.Domain.Entities
@{
    Layout = null;

    var fullReports = Model?.ToList() ?? new List<Report>();

    var weekly = fullReports.Count(r => r.ReportType == ReportType.Weekly);
    var monthly = fullReports.Count(r => r.ReportType == ReportType.Monthly);
    var annual = fullReports.Count(r => r.ReportType == ReportType.Annual);
    var expired = fullReports.Count(r => r.ExpiryDate != null && r.ExpiryDate < DateTime.UtcNow);
    var lateReports = fullReports.Count(r => r.IsLateSubmission);

    int pageSize = 20;
    bool hasMore = fullReports.Count > pageSize;

    var ownerName = (string?)ViewData["UName"] ?? "User";
    var userImage = (string?)ViewData["UImage"];
    var facilitatorId = ViewData["facilitatorId"];
    var idPass = ViewData["UId"];

    string initials = string.Join("", (ownerName ?? "U")
        .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .Select(s => s[0])
        .Take(2))
        .ToUpperInvariant();

    var subReportsByReport = ViewData["SubReportsByReport"] as Dictionary<Guid, List<ReportSubReport>>
                           ?? new Dictionary<Guid, List<ReportSubReport>>();

    var compliance = ViewBag.Compliance as UserReportCompliance;
    var compStatus = compliance?.Status ?? eComplianceStatus.Compliant;
    var compPct = compliance?.CompliancePercentage ?? 100;
    var compClass = compStatus switch
    {
        eComplianceStatus.Compliant => "comp-ok",
        eComplianceStatus.PartiallyCompliant => "comp-warn",
        eComplianceStatus.NonCompliant => "comp-bad",
        _ => "comp-ok"
    };
    var compLabel = compStatus switch
    {
        eComplianceStatus.Compliant => "Fully Compliant",
        eComplianceStatus.PartiallyCompliant => "Partially Compliant",
        eComplianceStatus.NonCompliant => "Non-Compliant",
        _ => "Unknown"
    };
    var compIcon = compStatus switch
    {
        eComplianceStatus.Compliant => "fa-shield-check",
        eComplianceStatus.PartiallyCompliant => "fa-triangle-exclamation",
        eComplianceStatus.NonCompliant => "fa-circle-xmark",
        _ => "fa-question"
    };

    var weeklyComp = compliance?.ByType?.FirstOrDefault(b => b.ReportType == ReportType.Weekly);
    var monthlyComp = compliance?.ByType?.FirstOrDefault(b => b.ReportType == ReportType.Monthly);

    var missedWeekly = compliance?.MissedPeriodsByType?.GetValueOrDefault(ReportType.Weekly)
                       ?? (IReadOnlyList<MissedPeriod>)Array.Empty<MissedPeriod>();
    var missedMonthly = compliance?.MissedPeriodsByType?.GetValueOrDefault(ReportType.Monthly)
                        ?? (IReadOnlyList<MissedPeriod>)Array.Empty<MissedPeriod>();

    var totalMissedAll = missedWeekly.Count + missedMonthly.Count;
    var compYear = compliance?.ComplianceYear ?? DateTime.UtcNow.Year;
}

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <title>@ownerName — Reports</title>
    <meta name="viewport" content="width=device-width,initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <style>
        :root {
            --d-bg: #0c0e14; --d-bg-2: #12151e; --d-bg-3: #181c28;
            --d-surface: rgba(255,255,255,.04); --d-surface-2: rgba(255,255,255,.06); --d-surface-3: rgba(255,255,255,.08);
            --d-glass: rgba(24,28,40,.72); --d-glass-border: rgba(255,255,255,.08); --d-glass-border-2: rgba(255,255,255,.12);
            --d-text: #e8eaf0; --d-text-2: #9ba1b0; --d-text-3: #6b7186;
            --d-accent: #ff7a18; --d-accent-2: #ff9547; --d-red: #ef4444; --d-green: #22c55e; --d-blue: #3b82f6; --d-indigo: #818cf8;
            --d-grad: linear-gradient(135deg, #ff7a18 0%, #b31217 50%, #320606 100%);
            --d-shadow: 0 4px 24px rgba(0,0,0,.4); --d-shadow-lg: 0 12px 48px rgba(0,0,0,.5);
            --d-radius: 16px; --d-radius-sm: 10px; --d-radius-lg: 24px;
            --d-transition: .25s cubic-bezier(.4,0,.2,1);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }
        [data-theme="light"] {
            --d-bg: #f5f6fa; --d-bg-2: #eceef3; --d-bg-3: #e4e6ec;
            --d-surface: rgba(0,0,0,.03); --d-surface-2: rgba(0,0,0,.05); --d-surface-3: rgba(0,0,0,.07);
            --d-glass: rgba(255,255,255,.82); --d-glass-border: rgba(0,0,0,.08); --d-glass-border-2: rgba(0,0,0,.12);
            --d-text: #1a1a2e; --d-text-2: #555b6e; --d-text-3: #8e93a3;
            --d-shadow: 0 4px 24px rgba(0,0,0,.08); --d-shadow-lg: 0 12px 48px rgba(0,0,0,.12);
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: var(--d-bg); color: var(--d-text); -webkit-font-smoothing: antialiased; min-height: 100vh; overflow-x: hidden; }
        body::before { content: ""; position: fixed; inset: 0; background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.025'/%3E%3C/svg%3E"); pointer-events: none; z-index: 9999; }

        .sidebar { position: fixed; left: 0; top: 0; bottom: 0; width: 260px; background: var(--d-bg-2); border-right: 1px solid var(--d-glass-border); display: flex; flex-direction: column; z-index: 100; transition: transform .3s; }
        .sidebar-brand { padding: 1.4rem 1.3rem; display: flex; align-items: center; gap: .75rem; border-bottom: 1px solid var(--d-glass-border); }
        .sidebar-brand-icon { width: 40px; height: 40px; border-radius: 12px; background: var(--d-grad); display: flex; align-items: center; justify-content: center; font-size: 1.1rem; color: #fff; box-shadow: 0 4px 16px rgba(255,122,24,.3); }
        .sidebar-brand-text { font-weight: 800; font-size: .95rem; letter-spacing: -.2px; }
        .sidebar-brand-text small { display: block; font-size: .58rem; font-weight: 500; color: var(--d-text-3); letter-spacing: .3px; text-transform: uppercase; margin-top: 1px; }
        .sidebar-nav { flex: 1; padding: 1rem 0; overflow-y: auto; }
        .nav-section-label { font-size: .54rem; letter-spacing: .2rem; text-transform: uppercase; font-weight: 700; color: var(--d-text-3); padding: .6rem 1.3rem .35rem; }
        .sidebar-link { display: flex; align-items: center; gap: .65rem; padding: .6rem 1.3rem; font-size: .82rem; font-weight: 600; color: var(--d-text-2); text-decoration: none; margin: 0 .5rem; border-radius: var(--d-radius-sm); transition: all var(--d-transition); }
        .sidebar-link i { font-size: 1rem; width: 1.2rem; text-align: center; opacity: .7; }
        .sidebar-link:hover { background: var(--d-surface-2); color: var(--d-text); }
        .sidebar-link:hover i { opacity: 1; }
        .sidebar-link.active { background: var(--d-grad); color: #fff; box-shadow: 0 4px 16px rgba(255,122,24,.25); }
        .sidebar-link.active i { opacity: 1; }
        .sidebar-footer { padding: 1rem 1.3rem; border-top: 1px solid var(--d-glass-border); font-size: .65rem; color: var(--d-text-3); }
        .topbar { position: fixed; top: 0; left: 260px; right: 0; height: 64px; background: var(--d-glass); border-bottom: 1px solid var(--d-glass-border); display: flex; align-items: center; padding: 0 1.5rem; gap: 1rem; z-index: 99; }
        .topbar-live { display: flex; align-items: center; gap: .5rem; font-size: .7rem; font-weight: 600; color: var(--d-text-2); }
        .live-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--d-green); animation: pulse-dot 2s infinite; }
        @@keyframes pulse-dot { 0%, 100% { box-shadow: 0 0 0 0 rgba(34,197,94,.6); } 50% { box-shadow: 0 0 0 6px rgba(34,197,94,0); } }
        .topbar-actions { display: flex; align-items: center; gap: .6rem; margin-left: auto; }
        .topbar-btn { width: 38px; height: 38px; border-radius: var(--d-radius-sm); border: 1px solid var(--d-glass-border); background: var(--d-surface); color: var(--d-text-2); display: flex; align-items: center; justify-content: center; font-size: 1rem; transition: all var(--d-transition); cursor: pointer; }
        .topbar-btn:hover { background: var(--d-surface-3); color: var(--d-text); border-color: var(--d-glass-border-2); }
        .topbar-avatar { width: 36px; height: 36px; border-radius: var(--d-radius-sm); background: var(--d-grad); display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 900; font-size: .75rem; }
        .sidebar-toggle { display: none; width: 40px; height: 40px; border: 1px solid var(--d-glass-border); background: var(--d-surface); border-radius: var(--d-radius-sm); color: var(--d-text); font-size: 1.1rem; cursor: pointer; }
        .main-area { margin-left: 260px; padding-top: 64px; min-height: 100vh; }
        .main-content { padding: 1.5rem 1.6rem 3rem; max-width: 1280px; margin: 0 auto; }

        .report-header { display: flex; flex-wrap: wrap; gap: 1.25rem; background: var(--d-glass); border: 1px solid var(--d-glass-border); border-radius: var(--d-radius-lg); padding: 1.15rem 1.4rem 1.1rem; position: relative; overflow: hidden; box-shadow: var(--d-shadow); }
        .report-header:before { content: ""; position: absolute; inset: 0; background: radial-gradient(circle at 20% 10%, rgba(255,122,24,.20), transparent 60%), radial-gradient(circle at 85% 20%, rgba(179,18,23,.18), transparent 55%); pointer-events: none; opacity: .85; }
        .rh-accent { width: 64px; height: 64px; border-radius: 18px; background: var(--d-grad); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 1.55rem; box-shadow: 0 10px 24px rgba(255,122,24,.18); }
        .report-header h1 { margin: 0; font-size: 1.35rem; font-weight: 800; letter-spacing: -.2px; color: var(--d-text); display: flex; align-items: center; gap: .65rem; }
        .rh-tag { margin-top: .45rem; font-size: .6rem; letter-spacing: .2rem; text-transform: uppercase; font-weight: 800; background: var(--d-surface-2); color: var(--d-accent); border: 1px solid var(--d-glass-border); padding: .45rem .8rem; border-radius: 999px; display: inline-flex; gap: .45rem; align-items: center; }
        .rh-tools { margin-left: auto; display: flex; flex-wrap: wrap; gap: .55rem; align-items: center; z-index: 1; }
        .icon-btn { width: 42px; height: 42px; border-radius: 14px; border: 1px solid var(--d-glass-border); background: var(--d-surface); display: inline-flex; align-items: center; justify-content: center; font-size: .9rem; color: var(--d-text-2); transition: all var(--d-transition); cursor: pointer; }
        .icon-btn:hover { background: var(--d-surface-3); border-color: var(--d-glass-border-2); color: var(--d-text); }
        .add-report-trigger { width: auto; padding: 0 .95rem; gap: .45rem; font-weight: 800; letter-spacing: .12rem; font-size: .68rem; text-transform: uppercase; background: var(--d-grad); color: #fff; border: none; }
        .add-report-trigger:hover { filter: brightness(1.05); box-shadow: 0 10px 24px rgba(255,122,24,.18); }
        .metrics-row { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); margin: 1.25rem 0 .85rem; }
        .metric { background: var(--d-glass); border: 1px solid var(--d-glass-border); border-radius: var(--d-radius-lg); padding: 1rem 1.05rem; position: relative; overflow: hidden; transition: all var(--d-transition); box-shadow: var(--d-shadow); }
        .metric:before { content: ""; position: absolute; inset: 0 0 auto 0; height: 3px; background: var(--d-grad); }
        .metric:hover { transform: translateY(-4px); border-color: var(--d-glass-border-2); box-shadow: var(--d-shadow-lg); }
        .metric small { font-size: .58rem; letter-spacing: .16rem; text-transform: uppercase; font-weight: 900; color: var(--d-text-3); display: flex; align-items: center; gap: .45rem; }
        .metric .val { font-size: 1.75rem; font-weight: 900; letter-spacing: -.6px; line-height: 1; margin: .45rem 0 .15rem; color: var(--d-text); }
        .metric .desc { font-size: .6rem; letter-spacing: .12rem; text-transform: uppercase; color: var(--d-text-3); font-weight: 800; }
        .metric .bg-icon { position: absolute; right: .85rem; top: 50%; transform: translateY(-50%); font-size: 2.7rem; color: rgba(255,255,255,.06); }

        .comp-panel { background: var(--d-glass); border: 1px solid var(--d-glass-border); border-radius: var(--d-radius-lg); padding: 1rem 1.15rem; margin-bottom: 1.15rem; box-shadow: var(--d-shadow); position: relative; overflow: hidden; }
        .comp-panel::before { content: ""; position: absolute; inset: 0 0 auto 0; height: 3px; }
        .comp-panel.comp-ok::before { background: linear-gradient(90deg, #22c55e, #4ade80); }
        .comp-panel.comp-warn::before { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
        .comp-panel.comp-bad::before { background: linear-gradient(90deg, #ef4444, #f87171); }
        .comp-header-row { display: flex; flex-wrap: wrap; align-items: center; gap: .75rem; }
        .comp-icon { width: 42px; height: 42px; border-radius: 14px; display: grid; place-items: center; font-size: 1.1rem; }
        .comp-ok .comp-icon { background: rgba(34,197,94,.12); color: #4ade80; }
        .comp-warn .comp-icon { background: rgba(245,158,11,.12); color: #fbbf24; }
        .comp-bad .comp-icon { background: rgba(239,68,68,.12); color: #f87171; }
        .comp-title { font-size: .92rem; font-weight: 800; color: var(--d-text); }
        .comp-year-tag { font-size: .5rem; letter-spacing: .14rem; text-transform: uppercase; font-weight: 900; padding: .25rem .5rem; border-radius: 999px; background: var(--d-surface-2); border: 1px solid var(--d-glass-border); color: var(--d-text-3); margin-left: .4rem; }
        .comp-pct-text { font-size: .68rem; color: var(--d-text-2); }
        .comp-bar-lg { width: 100%; max-width: 300px; height: 8px; border-radius: 8px; background: var(--d-surface-2); overflow: hidden; margin-top: .3rem; }
        .comp-bar-lg-fill { height: 100%; border-radius: 8px; transition: width .6s ease; }
        .comp-ok .comp-bar-lg-fill { background: linear-gradient(90deg, #22c55e, #4ade80); }
        .comp-warn .comp-bar-lg-fill { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
        .comp-bad .comp-bar-lg-fill { background: linear-gradient(90deg, #ef4444, #f87171); }
        .comp-chips-row { display: flex; flex-wrap: wrap; gap: .35rem; margin-left: auto; }

        .comp-types { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: .65rem; margin-top: .85rem; }
        .comp-type-card { background: var(--d-surface); border: 1px solid var(--d-glass-border); border-radius: 14px; padding: .7rem .8rem; display: flex; flex-direction: column; gap: .35rem; }
        .comp-type-header { display: flex; align-items: center; gap: .45rem; font-size: .62rem; letter-spacing: .14rem; text-transform: uppercase; font-weight: 900; color: var(--d-text-2); }
        .comp-type-header i { font-size: .8rem; }
        .comp-type-stats { display: flex; flex-wrap: wrap; gap: .35rem; }
        .comp-type-stat { font-size: .52rem; letter-spacing: .08rem; font-weight: 900; text-transform: uppercase; padding: .25rem .45rem; border-radius: 999px; display: flex; align-items: center; gap: .2rem; border: 1px solid var(--d-glass-border); background: var(--d-surface-2); color: var(--d-text-2); }
        .comp-type-stat.ontime { background: rgba(34,197,94,.08); color: #9ff7c7; border-color: rgba(34,197,94,.18); }
        .comp-type-stat.late { background: rgba(239,68,68,.08); color: #ffd2d2; border-color: rgba(239,68,68,.18); }
        .comp-type-stat.missed { background: rgba(245,158,11,.08); color: #ffd9bf; border-color: rgba(245,158,11,.18); }

        .missed-toggle { display: flex; align-items: center; gap: .5rem; margin-top: .75rem; padding: .55rem .75rem; border-radius: 14px; background: rgba(239,68,68,.06); border: 1px solid rgba(239,68,68,.15); cursor: pointer; transition: all var(--d-transition); font-size: .65rem; font-weight: 800; color: #ffd2d2; letter-spacing: .1rem; text-transform: uppercase; }
        .missed-toggle:hover { background: rgba(239,68,68,.1); border-color: rgba(239,68,68,.25); }
        .missed-toggle .count-bubble { background: var(--d-red); color: #fff; font-size: .52rem; font-weight: 900; padding: .2rem .45rem; border-radius: 999px; min-width: 22px; text-align: center; }
        .missed-toggle .chevron { transition: transform .25s ease; }
        .missed-toggle[aria-expanded="true"] .chevron { transform: rotate(180deg); }
        .missed-body { margin-top: .55rem; }
        .missed-section-label { font-size: .52rem; letter-spacing: .16rem; text-transform: uppercase; font-weight: 900; color: var(--d-text-3); margin-bottom: .4rem; display: flex; align-items: center; gap: .4rem; }
        .missed-grid { display: flex; flex-wrap: wrap; gap: .35rem; margin-bottom: .65rem; }
        .missed-pill { display: inline-flex; align-items: center; gap: .3rem; font-size: .58rem; font-weight: 800; letter-spacing: .06rem; padding: .3rem .55rem; border-radius: 999px; border: 1px solid rgba(239,68,68,.2); background: rgba(239,68,68,.06); color: #ffd2d2; }
        .missed-pill i { font-size: .6rem; }
        .missed-pill-monthly { border-color: rgba(245,158,11,.2); background: rgba(245,158,11,.06); color: #ffd9bf; }

        .comp-chip { font-size: .52rem; letter-spacing: .08rem; font-weight: 900; text-transform: uppercase; padding: .3rem .5rem; border-radius: 999px; background: var(--d-surface-2); border: 1px solid var(--d-glass-border); color: var(--d-text-2); display: flex; align-items: center; gap: .25rem; }
        .comp-chip.late { background: rgba(239,68,68,.1); color: #ffd2d2; border-color: rgba(239,68,68,.2); }

        /* ── BOLDER late badge in table ───────────── */
        .late-badge {
            display: inline-flex; align-items: center; gap: .35rem;
            font-size: .55rem; font-weight: 900; letter-spacing: .12rem; text-transform: uppercase;
            padding: .3rem .65rem; border-radius: 999px;
            background: linear-gradient(135deg, rgba(239,68,68,.25), rgba(179,18,23,.20));
            color: #ff9494; border: 1.5px solid rgba(239,68,68,.45);
            box-shadow: 0 0 12px rgba(239,68,68,.15), inset 0 0 8px rgba(239,68,68,.08);
            animation: late-pulse 2.5s infinite;
        }
        .late-badge i { font-size: .6rem; }
        @@keyframes late-pulse {
            0%, 100% { box-shadow: 0 0 12px rgba(239,68,68,.15), inset 0 0 8px rgba(239,68,68,.08); }
            50% { box-shadow: 0 0 20px rgba(239,68,68,.3), inset 0 0 12px rgba(239,68,68,.12); }
        }

        .period-tag { display: inline-flex; align-items: center; gap: .25rem; font-size: .5rem; font-weight: 800; letter-spacing: .08rem; padding: .2rem .45rem; border-radius: 999px; background: var(--d-surface-2); border: 1px solid var(--d-glass-border); color: var(--d-text-3); margin-left: .3rem; }

        .report-surface, .side-panel { background: var(--d-glass) !important; border: 1px solid var(--d-glass-border) !important; color: var(--d-text) !important; box-shadow: var(--d-shadow) !important; border-radius: var(--d-radius-lg); padding: 1.05rem; }
        .toolbar { display: flex; flex-wrap: wrap; gap: .65rem; align-items: center; margin-bottom: .9rem; }
        .search-wrap { position: relative; flex: 1 1 240px; max-width: 360px; }
        .search-wrap i { position: absolute; top: 50%; left: .75rem; transform: translateY(-50%); font-size: .85rem; color: var(--d-text-3); }
        .search-wrap input { padding-left: 2.25rem; }
        .filter-select, .search-wrap input { border: 1px solid var(--d-glass-border) !important; background: var(--d-surface-2) !important; color: var(--d-text) !important; border-radius: 14px !important; font-size: .78rem !important; }
        .filter-select:focus, .search-wrap input:focus { border-color: var(--d-accent) !important; box-shadow: 0 0 0 3px rgba(255,122,24,.12) !important; }
        .table-modern { width: 100%; border-collapse: separate; border-spacing: 0; font-size: .78rem; overflow: hidden; border-radius: 16px; }
        .table-modern thead th { background: rgba(255,255,255,.05); color: var(--d-text-3); border-bottom: 1px solid var(--d-glass-border); font-size: .58rem; letter-spacing: .18rem; text-transform: uppercase; font-weight: 900; padding: .75rem; }
        .table-modern tbody td { padding: .7rem .75rem; border-top: 1px solid var(--d-glass-border); vertical-align: middle; color: var(--d-text-2); background: transparent; }
        .table-modern tbody tr:hover { background: rgba(255,255,255,.04); }
        .type-chip { display: inline-flex; align-items: center; justify-content: center; font-size: .58rem; font-weight: 900; letter-spacing: .12rem; text-transform: uppercase; padding: .38rem .6rem; border-radius: 999px; color: #fff; gap: .35rem; border: 1px solid rgba(255,255,255,.10); }
        .type-weekly { background: linear-gradient(135deg, #b31217, #ff7a18); }
        .type-monthly { background: linear-gradient(135deg, #ff7a18, #ff9547); }
        .type-annual { background: linear-gradient(135deg, #320606, #b31217); }
        .badge-status { display: inline-flex; align-items: center; gap: .35rem; font-size: .58rem; letter-spacing: .1rem; font-weight: 900; padding: .35rem .6rem; border-radius: 999px; border: 1px solid var(--d-glass-border); background: rgba(255,255,255,.05); color: var(--d-text-2); }
        .badge-status.expired { background: rgba(239,68,68,.12); border-color: rgba(239,68,68,.25); color: #ffd2d2; }
        .badge-status.soon { background: rgba(255,122,24,.12); border-color: rgba(255,122,24,.25); color: #ffd9bf; }
        .actions-cell a.icon-act { padding: .4rem .6rem; border-radius: 12px; border: 1px solid var(--d-glass-border); font-size: .72rem; line-height: 1; display: inline-flex; align-items: center; gap: .4rem; color: var(--d-text); background: rgba(255,255,255,.05); transition: all var(--d-transition); text-decoration: none; }
        .actions-cell a.icon-act:hover { background: var(--d-grad); color: #fff; border-color: var(--d-glass-border-2); }
        .btn-glass { background: var(--d-surface-2); border: 1px solid var(--d-glass-border); color: var(--d-text); padding: .5rem .85rem; border-radius: var(--d-radius-sm); font-size: .72rem; font-weight: 600; display: inline-flex; align-items: center; gap: .4rem; transition: all var(--d-transition); text-decoration: none; cursor: pointer; }
        .btn-glass:hover { background: var(--d-surface-3); border-color: var(--d-glass-border-2); color: var(--d-text); }
        .profile-image-wrap { width: 100%; max-width: 320px; height: 220px; margin: 0 auto; border-radius: 22px; overflow: hidden; border: 1px solid var(--d-glass-border); background: rgba(255,255,255,.03); display: flex; align-items: center; justify-content: center; }
        .profile-image-wrap img { width: 100%; height: 100%; object-fit: contain; }
        .quick-stats { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: .55rem; font-size: .7rem; }
        .quick-stats li { display: flex; justify-content: space-between; background: rgba(255,255,255,.05); border: 1px solid var(--d-glass-border); padding: .55rem .65rem; border-radius: 14px; font-weight: 800; color: var(--d-text-2); }
        .quick-stats li span.value { color: var(--d-text); }
        .profile-caption { text-align: center; font-size: .72rem; color: var(--d-text-3); letter-spacing: .2px; }
        .empty-state { text-align: center; padding: 2.2rem 1rem; color: var(--d-text-2); font-size: .85rem; }
        .empty-state i { font-size: 2.4rem; display: block; margin-bottom: .6rem; color: var(--d-accent); }
        .show-more-container { display: flex; justify-content: center; padding: .9rem 0 .35rem; }
        .show-more-btn { border: 1px solid var(--d-glass-border); background: rgba(255,255,255,.05); color: var(--d-text); border-radius: 14px; padding: .6rem .9rem; font-size: .72rem; font-weight: 900; letter-spacing: .12rem; text-transform: uppercase; transition: all var(--d-transition); cursor: pointer; }
        .show-more-btn:hover { background: var(--d-grad); border-color: var(--d-glass-border-2); color: #fff; }
        .requirements-box { border: 1px solid rgba(255,122,24,.18); background: rgba(255,122,24,.06); padding: .75rem .85rem; border-radius: 14px; font-size: .72rem; line-height: 1.2rem; color: var(--d-text-2); }
        .requirements-box strong { color: var(--d-accent); }
        .dz-wrapper { display: flex; flex-direction: column; gap: .95rem; }
        .drop-zone { position: relative; border: 2px dashed var(--d-glass-border-2); background: var(--d-surface); border-radius: 20px; padding: 1.15rem; display: flex; flex-direction: column; align-items: center; gap: .75rem; text-align: center; transition: .35s var(--d-transition); cursor: pointer; }
        .drop-zone:before { content: ""; position: absolute; inset: 0; border-radius: inherit; background: radial-gradient(circle at 78% 18%, rgba(255,122,24,.22), transparent 60%); opacity: .35; pointer-events: none; }
        .drop-zone.drag-over { background: rgba(255,122,24,.08); border-color: var(--d-accent); }
        .drop-zone.valid { border-color: rgba(34,197,94,.65); background: rgba(34,197,94,.06); }
        .drop-zone.invalid { border-color: rgba(239,68,68,.70); background: rgba(239,68,68,.06); }
        .cloud-icon { font-size: 3.1rem; background: var(--d-grad); -webkit-background-clip: text; color: transparent; }
        .dz-msg { margin: 0; font-size: .78rem; font-weight: 800; color: var(--d-text); }
        .dz-msg span { display: block; font-size: .58rem; font-weight: 900; letter-spacing: .16rem; text-transform: uppercase; margin-top: .35rem; color: var(--d-text-3); }
        .dz-btn { font-size: .6rem; font-weight: 900; letter-spacing: .14rem; text-transform: uppercase; padding: .6rem .9rem; border-radius: 14px; border: 1px solid var(--d-glass-border); background: var(--d-surface-2); color: var(--d-text); display: inline-flex; align-items: center; gap: .45rem; transition: all var(--d-transition); cursor: pointer; }
        .dz-btn:hover { background: var(--d-grad); color: #fff; }
        .dz-meta { font-size: .62rem; color: var(--d-text-3); font-weight: 700; }
        .progress-slim { height: 8px; background: rgba(255,255,255,.06); border-radius: 8px; overflow: hidden; display: none; width: 100%; border: 1px solid var(--d-glass-border); }
        .progress-slim div { height: 100%; width: 0; background: var(--d-grad); transition: width .35s; }
        .dz-success, .dz-error { display: none; font-size: .58rem; font-weight: 900; letter-spacing: .14rem; text-transform: uppercase; padding: .5rem .85rem; border-radius: 999px; border: 1px solid var(--d-glass-border); align-items: center; gap: .5rem; }
        .dz-success { color: #9ff7c7; background: rgba(34,197,94,.10); border-color: rgba(34,197,94,.22); }
        .dz-error { color: #ffd2d2; background: rgba(239,68,68,.10); border-color: rgba(239,68,68,.22); }
        .dz-file-pill { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: .75rem; background: var(--d-surface-2); border: 1px solid var(--d-glass-border); border-radius: 14px; padding: .55rem .75rem; font-size: .65rem; font-weight: 800; color: var(--d-text); }
        .dz-file-pill .name { flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .dz-remove { background: none; border: none; color: var(--d-accent); font-size: .7rem; cursor: pointer; font-weight: 900; }
        .modal-content { background: var(--d-bg-3) !important; border: 1px solid var(--d-glass-border-2) !important; border-radius: var(--d-radius-lg) !important; box-shadow: var(--d-shadow-lg); }
        .modal-header { background: var(--d-grad) !important; border: none !important; border-radius: var(--d-radius-lg) var(--d-radius-lg) 0 0 !important; padding: 1rem 1.2rem; }
        .modal-title { font-size: .75rem; letter-spacing: .18rem; text-transform: uppercase; font-weight: 900; }
        .modal-body .form-control, .modal-body select { background: var(--d-surface-2) !important; border: 1px solid var(--d-glass-border) !important; color: var(--d-text) !important; }
        .late-overlay { display: none; position: fixed; inset: 0; background: rgba(12,14,20,.78); backdrop-filter: blur(6px); z-index: 1070; place-items: center; }
        .late-overlay.show { display: grid; }
        .late-modal { background: var(--d-bg-3); border: 1px solid var(--d-glass-border-2); border-radius: var(--d-radius-lg); box-shadow: var(--d-shadow-lg); width: 95%; max-width: 520px; padding: 1.5rem; animation: lm-pop .3s ease; }
        @@keyframes lm-pop { from { opacity:0; transform:scale(.95) translateY(10px); } to { opacity:1; transform:scale(1) translateY(0); } }
        .late-modal-icon { width: 56px; height: 56px; border-radius: 18px; background: rgba(239,68,68,.12); color: var(--d-red); display: grid; place-items: center; font-size: 1.4rem; margin: 0 auto .85rem; }
        .late-modal h3 { text-align: center; font-size: 1.05rem; font-weight: 800; color: var(--d-text); margin: 0 0 .45rem; }
        .late-modal-msg { text-align: center; font-size: .78rem; color: var(--d-text-2); line-height: 1.45; margin-bottom: 1rem; padding: 0 .5rem; }
        .late-modal-period { text-align: center; font-size: .82rem; font-weight: 800; color: var(--d-accent); padding: .55rem .85rem; border-radius: 14px; background: rgba(255,122,24,.08); border: 1px solid rgba(255,122,24,.2); margin-bottom: .85rem; }
        .late-modal-warning { font-size: .68rem; color: var(--d-text-3); line-height: 1.4; padding: .7rem .8rem; border-radius: 14px; background: var(--d-surface-2); border: 1px solid var(--d-glass-border); margin-bottom: 1rem; }
        .late-modal-warning i { color: var(--d-red); margin-right: .3rem; }
        .late-modal-actions { display: flex; gap: .55rem; justify-content: center; flex-wrap: wrap; }
        .btn-grad { background: var(--d-grad); color: #fff; border: none; padding: .55rem .95rem; border-radius: 14px; font-size: .68rem; font-weight: 800; letter-spacing: .12rem; text-transform: uppercase; display: inline-flex; align-items: center; gap: .45rem; box-shadow: 0 4px 16px rgba(255,122,24,.25); transition: all var(--d-transition); cursor: pointer; }
        .btn-grad:hover { filter: brightness(1.1); box-shadow: 0 6px 24px rgba(255,122,24,.35); transform: translateY(-1px); color: #fff; }
        .period-opt { display: flex; align-items: center; gap: .6rem; padding: .55rem .7rem; border-radius: 14px; background: var(--d-surface-2); border: 1px solid var(--d-glass-border); cursor: pointer; transition: all var(--d-transition); margin-bottom: .4rem; }
        .period-opt:hover { border-color: var(--d-accent); background: rgba(255,122,24,.06); }
        .period-opt input { accent-color: var(--d-accent); width: 16px; height: 16px; cursor: pointer; }
        .period-opt-label { font-size: .78rem; font-weight: 700; color: var(--d-text); }
        .modal-type-hint { font-size: .65rem; margin-top: .35rem; min-height: 1rem; }

        @@media (max-width: 991.98px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.show { transform: translateX(0); box-shadow: var(--d-shadow-lg); }
            .topbar { left: 0; }
            .main-area { margin-left: 0; }
            .sidebar-toggle { display: flex; align-items: center; justify-content: center; }
            .comp-types { grid-template-columns: 1fr; }
        }
    </style>
</head>

<body>
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <div class="sidebar-brand-icon"><i class="bi bi-lightning-charge-fill"></i></div>
            <div class="sidebar-brand-text">Forek Online<small>Enterprise Portal</small></div>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-section-label">Main</div>
            <a href="@Url.Action("EmployeeInfo", "Employee")" class="sidebar-link"><i class="bi bi-house-fill text-danger"></i> Home</a>
            <a href="@Url.Action("Dashboard", "Applications")" class="sidebar-link"><i class="bi bi-grid-1x2-fill"></i> Dashboard</a>
            <a href="@Url.Action("AdminEmployeePortal", "Employee")" class="sidebar-link"><i class="bi bi-person-badge-fill"></i> Employees</a>
            <a href="@Url.Action("ListResources", "Resource")" class="sidebar-link"><i class="bi bi-folder-fill"></i> Resources</a>
            <div class="nav-section-label mt-3">Reports</div>
            <a href="@Url.Action("UserReports", "Report", new { idPass })" class="sidebar-link active"><i class="bi bi-collection-fill"></i> User Reports</a>
        </nav>
        <div class="sidebar-footer">&copy; @DateTime.UtcNow.Year Forek ICT Services</div>
    </aside>

    <div class="topbar">
        <button class="sidebar-toggle" id="sidebarToggle"><i class="bi bi-list"></i></button>
        <div class="topbar-live"><span class="live-dot"></span> Updated just now</div>
        <div class="topbar-actions">
            <button class="topbar-btn" id="btnRefresh" title="Refresh"><i class="bi bi-arrow-clockwise"></i></button>
            <button class="topbar-btn theme-toggle" id="themeToggle" title="Toggle theme"><i class="bi bi-moon-stars-fill"></i></button>
            <div class="topbar-avatar" title="Account">@initials</div>
        </div>
    </div>

    <div class="main-area">
        <div class="main-content">
            <div class="container-fluid py-2">

                <div class="report-header">
                    <div class="rh-accent"><i class="fa fa-folder-open"></i></div>
                    <div>
                        <h1>@ownerName'S REPORTS</h1>
                        <div class="rh-tag"><i class="fa fa-layer-group"></i> COLLECTION</div>
                    </div>
                    <div class="rh-tools">
                        <button type="button" class="icon-btn" title="Refresh" onclick="location.reload()"><i class="fa fa-rotate"></i></button>
                        <button type="button" class="icon-btn" title="Scroll to table" onclick="document.getElementById('reportTable')?.scrollIntoView({behavior:'smooth'})"><i class="fa fa-table-list"></i></button>
                        <button type="button" class="icon-btn add-report-trigger" data-bs-toggle="modal" data-bs-target="#uploadReportModal"><i class="fa fa-plus"></i> ADD</button>
                    </div>
                </div>

                <div class="metrics-row">
                    <div class="metric"><small><i class="fa fa-database text-danger"></i> Total</small><div class="val">@fullReports.Count</div><div class="desc">records</div><i class="fa fa-database bg-icon"></i></div>
                    <div class="metric"><small><i class="fa fa-calendar-week text-danger"></i> Weekly</small><div class="val">@weekly</div><div class="desc">entries</div><i class="fa fa-calendar-week bg-icon"></i></div>
                    <div class="metric"><small><i class="fa fa-calendar-days text-danger"></i> Monthly</small><div class="val">@monthly</div><div class="desc">entries</div><i class="fa fa-calendar-days bg-icon"></i></div>
                    <div class="metric"><small><i class="fa fa-calendar-check text-danger"></i> Annual</small><div class="val">@annual</div><div class="desc">entries</div><i class="fa fa-calendar-check bg-icon"></i></div>
                    <div class="metric"><small><i class="fa fa-clock-rotate-left text-danger"></i> Late</small><div class="val">@lateReports</div><div class="desc">flagged</div><i class="fa fa-clock-rotate-left bg-icon"></i></div>
                    <div class="metric"><small><i class="fa fa-triangle-exclamation text-danger"></i> Expired</small><div class="val">@expired</div><div class="desc">inactive</div><i class="fa fa-triangle-exclamation bg-icon"></i></div>
                </div>

                @if (compliance is not null)
                {
                    <div class="comp-panel @compClass">
                        <div class="comp-header-row">
                            <div class="comp-icon"><i class="fa @compIcon"></i></div>
                            <div>
                                <div class="comp-title">
                                    @compLabel
                                    <span class="comp-year-tag"><i class="fa fa-calendar"></i> @compYear</span>
                                </div>
                                <div class="comp-pct-text">
                                    @compPct% on-time rate · @(compliance.TotalSubmitted)/@(compliance.TotalExpected) expected
                                    @if (compliance.GraceWeeks > 0)
                                    {
                                        <span style="margin-left:.4rem;font-size:.55rem;color:var(--d-text-3);">
                                            (excl. first @(compliance.GraceWeeks) week(s) — starts @(compliance.ComplianceStartDate.ToString("dd MMM")))
                                        </span>
                                    }
                                </div>
                                <div class="comp-bar-lg"><div class="comp-bar-lg-fill" style="width:@(compPct)%;"></div></div>
                            </div>
                            <div class="comp-chips-row">
                                <span class="comp-chip"><i class="fa fa-check-circle"></i> @(compliance.OnTimeCount) on time</span>
                                <span class="comp-chip late"><i class="fa fa-clock-rotate-left"></i> @(compliance.LateCount) late</span>
                                <span class="comp-chip"><i class="fa fa-circle-xmark"></i> @(compliance.MissedCount) missed</span>
                            </div>
                        </div>

                        <div class="comp-types">
                            @if (weeklyComp is not null)
                            {
                                <div class="comp-type-card">
                                    <div class="comp-type-header"><i class="fa fa-calendar-week" style="color:var(--d-accent);"></i> Weekly Reports</div>
                                    <div class="comp-type-stats">
                                        <span class="comp-type-stat"><i class="fa fa-bullseye"></i> @weeklyComp.Expected expected</span>
                                        <span class="comp-type-stat ontime"><i class="fa fa-check"></i> @weeklyComp.OnTime on time</span>
                                        <span class="comp-type-stat late"><i class="fa fa-clock"></i> @weeklyComp.Late late</span>
                                        <span class="comp-type-stat missed"><i class="fa fa-xmark"></i> @weeklyComp.Missed missed</span>
                                    </div>
                                </div>
                            }
                            @if (monthlyComp is not null)
                            {
                                <div class="comp-type-card">
                                    <div class="comp-type-header"><i class="fa fa-calendar-days" style="color:var(--d-accent);"></i> Monthly Reports</div>
                                    <div class="comp-type-stats">
                                        <span class="comp-type-stat"><i class="fa fa-bullseye"></i> @monthlyComp.Expected expected</span>
                                        <span class="comp-type-stat ontime"><i class="fa fa-check"></i> @monthlyComp.OnTime on time</span>
                                        <span class="comp-type-stat late"><i class="fa fa-clock"></i> @monthlyComp.Late late</span>
                                        <span class="comp-type-stat missed"><i class="fa fa-xmark"></i> @monthlyComp.Missed missed</span>
                                    </div>
                                </div>
                            }
                        </div>

                        @if (totalMissedAll > 0)
                        {
                            <div class="missed-toggle" data-bs-toggle="collapse" data-bs-target="#missedPanel" aria-expanded="false" aria-controls="missedPanel">
                                <i class="fa fa-calendar-xmark"></i>
                                View Missed Reports
                                <span class="count-bubble">@totalMissedAll</span>
                                <i class="fa fa-chevron-down chevron" style="margin-left:auto;font-size:.6rem;"></i>
                            </div>

                            <div class="collapse missed-body" id="missedPanel">
                                @if (missedWeekly.Count > 0)
                                {
                                    <div class="missed-section-label"><i class="fa fa-calendar-week"></i> Missed Weekly Reports (@missedWeekly.Count)</div>
                                    <div class="missed-grid">
                                        @foreach (var m in missedWeekly)
                                        {
                                            <span class="missed-pill"><i class="fa fa-circle-xmark"></i> @m.Label</span>
                                        }
                                    </div>
                                }
                                @if (missedMonthly.Count > 0)
                                {
                                    <div class="missed-section-label"><i class="fa fa-calendar-days"></i> Missed Monthly Reports (@missedMonthly.Count)</div>
                                    <div class="missed-grid">
                                        @foreach (var m in missedMonthly)
                                        {
                                            <span class="missed-pill missed-pill-monthly"><i class="fa fa-circle-xmark"></i> @m.Label</span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }

                <div class="row g-3">
                    <div class="col-lg-8">
                        <div class="report-surface">
                            <div class="toolbar">
                                <div class="search-wrap">
                                    <i class="fa fa-search"></i>
                                    <input type="text" id="reportSearch" class="form-control form-control-sm" placeholder="Search reference..." autocomplete="off" />
                                </div>
                                <select id="typeFilter" class="form-select form-select-sm filter-select" style="max-width:160px;">
                                    <option value="">All Types</option>
                                    <option value="Weekly">Weekly</option>
                                    <option value="Monthly">Monthly</option>
                                    <option value="Annual">Annual</option>
                                </select>
                                <select id="statusFilter" class="form-select form-select-sm filter-select" style="max-width:160px;">
                                    <option value="">All Status</option>
                                    <option value="active">Active</option>
                                    <option value="soon">Expiring Soon</option>
                                    <option value="expired">Expired</option>
                                    <option value="late">Late Only</option>
                                </select>
                            </div>

                            <div class="table-responsive">
                                <table id="reportTable" class="table-modern">
                                    <thead>
                                        <tr>
                                            <th>Reference</th>
                                            <th>Type</th>
                                            <th>Created</th>
                                            <th>Period</th>
                                            <th>Status</th>
                                            <th style="width:8%;">Sub</th>
                                            <th style="text-align:right;">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody id="reportTableBody">
                                        @if (fullReports.Any())
                                        {
                                            var idx = 0;
                                            @foreach (var r in fullReports)
                                            {
                                                var soonThreshold = DateTime.UtcNow.AddDays(7);
                                                var isExpired = r.ExpiryDate != null && r.ExpiryDate < DateTime.UtcNow;
                                                var isSoon = !isExpired && r.ExpiryDate != null && r.ExpiryDate <= soonThreshold;
                                                string statusClass = isExpired ? "expired" : (isSoon ? "soon" : "active");
                                                bool hide = idx >= pageSize;

                                                subReportsByReport.TryGetValue(r.ReportId, out var subList);
                                                subList ??= new List<ReportSubReport>();
                                                var subCount = subList.Count;
                                                var collapseId = $"sub_{r.ReportId:N}";
                                                var canExpand = subCount > 0;

                                                <tr data-ref="@r.Reference" data-type="@r.ReportType" data-status="@statusClass" data-late="@(r.IsLateSubmission ? "true" : "false")" class="@(hide ? "hidden-row" : "")">
                                                    <td style="font-weight:600;letter-spacing:.4px;">
                                                        @r.Reference
                                                        @if (r.IsLateSubmission)
                                                        {
                                                            <span class="late-badge"><i class="fa fa-clock-rotate-left"></i> LATE</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        <span class="type-chip @(r.ReportType switch { ReportType.Weekly => "type-weekly", ReportType.Monthly => "type-monthly", ReportType.Annual => "type-annual", _ => "type-weekly" })">
                                                            <i class="fa fa-file-lines"></i>@r.ReportType.ToString()[0]
                                                        </span>
                                                    </td>
                                                    <td><i class="fa fa-calendar-alt text-danger"></i> @r.CreatedOn</td>
                                                    <td>
                                                        @if (!string.IsNullOrWhiteSpace(r.IntendedPeriodLabel))
                                                        {
                                                            <span class="period-tag"><i class="fa fa-calendar-day"></i> @r.IntendedPeriodLabel</span>
                                                        }
                                                        else
                                                        {
                                                            <span style="color:var(--d-text-3);">—</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        <span class="badge-status @statusClass">
                                                            @if (isExpired)
                                                            {
                                                                <i class="text-danger fa fa-times-circle"></i>
                                                            }
                                                            else if (isSoon)
                                                            {

                                                                <i class="text-warning fa fa-exclamation-triangle"></i>
                                                            }
                                                            else
                                                            {

                                                                <i class="text-success fa fa-check-circle"></i>
                                                            }
                                                        </span>
                                                    </td>
                                                    <td>
                                                        @if (canExpand)
                                                        {
                                                            <button type="button" class="btn-glass" style="padding:.35rem .55rem;font-weight:900;" data-bs-toggle="collapse" data-bs-target="#@collapseId"><i class="bi bi-layers-fill"></i> @subCount <span class="ms-1"><i class="bi bi-chevron-down"></i></span></button>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge-status"><i class="bi bi-dash-lg"></i> 0</span>
                                                        }
                                                    </td>
                                                    <td class="actions-cell" style="text-align:right;white-space:nowrap;">
                                                        <a class="icon-act" asp-action="ReportDetails" asp-route-ReportId="@r.ReportId" asp-route-facilitatorId="@r.FacilitatorId" title="Details"><i class="fa fa-list-ul"></i></a>
                                                    </td>
                                                </tr>
                                                <tr class="@(hide ? "hidden-row" : "")">
                                                    <td colspan="7" style="padding:0;border-top:none;">
                                                        <div id="@collapseId" class="collapse">
                                                            <div style="padding:.75rem 1rem;border-top:1px solid var(--d-glass-border);background:rgba(255,255,255,.02);">
                                                                <div style="display:flex;align-items:center;justify-content:space-between;gap:.75rem;flex-wrap:wrap;">
                                                                    <div style="font-size:.62rem;letter-spacing:.18rem;text-transform:uppercase;font-weight:900;color:var(--d-text-3);">Sub-Reports for <span style="color:var(--d-text);">@r.Reference</span></div>
                                                                    <button type="button" class="btn-glass" style="padding:.35rem .55rem;" data-bs-toggle="collapse" data-bs-target="#@collapseId"><i class="bi bi-x-lg"></i> Close</button>
                                                                </div>
                                                                @if (subCount == 0)
                                                                {
                                                                    <div class="mt-2" style="color:var(--d-text-2);font-size:.78rem;">No subreports found.</div>
                                                                }
                                                                else
                                                                {
                                                                    <div class="mt-2" style="display:grid;gap:.55rem;">
                                                                        @foreach (var s in subList)
                                                                        {
                                                                            <div style="display:flex;align-items:center;gap:.75rem;justify-content:space-between;flex-wrap:wrap;border:1px solid var(--d-glass-border);background:var(--d-surface-2);padding:.65rem .75rem;border-radius:14px;">
                                                                                <div style="min-width:240px;">
                                                                                    <div style="font-weight:900;color:var(--d-text);font-size:.82rem;"><i class="bi bi-file-earmark-pdf-fill" style="color:var(--d-accent);"></i> @s.FileName</div>
                                                                                    @if (!string.IsNullOrWhiteSpace(s.Description))
                                                                                    {
                                                                                        <div style="color:var(--d-text-3);font-size:.72rem;margin-top:.15rem;">@s.Description</div>
                                                                                    }
                                                                                </div>
                                                                                <a class="btn-glass" style="padding:.4rem .6rem;" asp-action="ReportDownload" asp-controller="Report" asp-route-fileId="@s.FileId" title="Download"><i class="bi bi-download"></i> Download</a>
                                                                            </div>
                                                                        }
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    </td>
                                                </tr>
                                                idx++;
                                            }
                                        }
                                        else
                                        {
                                            <tr><td colspan="7"><div class="empty-state"><i class="fa fa-inbox"></i> No reports found.</div></td></tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            @if (hasMore)
                            {
                                <div class="show-more-container"><button type="button" id="showMoreBtn" class="show-more-btn"><i class="fa fa-plus"></i> Show All (@fullReports.Count)</button></div>
                            }
                            <div id="filterCount" class="mt-2 small text-muted" style="font-size:.65rem;letter-spacing:.5px;"></div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="side-panel">
                            <div class="profile-image-wrap">
                                <img id="avatarPreview" src="@Url.Action("ProfileImage", "Auth", new { fileId = userImage })" alt="Profile Image" loading="lazy" />
                            </div>
                            <div style="text-align:center;font-size:.8rem;font-weight:600;letter-spacing:.5px;">@ownerName</div>
                            <div class="profile-caption">Personal report repository overview</div>
                            <ul class="quick-stats">
                                <li><span>Total</span><span class="value">@fullReports.Count</span></li>
                                <li><span>Weekly</span><span class="value">@weekly</span></li>
                                <li><span>Monthly</span><span class="value">@monthly</span></li>
                                <li><span>Annual</span><span class="value">@annual</span></li>
                                <li><span>Late</span><span class="value" style="color:#ffd2d2;">@lateReports</span></li>
                                <li><span>Expired</span><span class="value">@expired</span></li>
                            </ul>
                            <button class="btn btn-sm w-100 mt-1 text-white" style="background:var(--d-grad);border:none;border-radius:12px;font-size:.65rem;letter-spacing:.12rem;font-weight:700;" data-bs-toggle="modal" data-bs-target="#uploadReportModal">
                                <i class="fa fa-cloud-upload-alt me-1"></i> Upload Report
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal fade" id="uploadReportModal" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered modal-xl">
                    <div class="modal-content">
                        <div class="modal-header" style="background:var(--d-grad);border:none;">
                            <h5 class="modal-title text-white"><i class="fa fa-cloud-upload-alt me-1"></i> Upload Report</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <form id="uploadForm" asp-action="CreateReportWithSubReports" asp-controller="Report" enctype="multipart/form-data" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="Report.FacilitatorId" value="@facilitatorId" />
                            <input type="hidden" name="Report.IdPass" value="@idPass" />
                            <input type="hidden" name="Report.Operation" value="@eOperation.Upload" />
                            <input type="hidden" name="acknowledgeLate" id="hidAckLate" value="false" />
                            <input type="hidden" name="intendedPeriodStart" id="hidPeriodStart" value="" />
                            <div class="modal-body">
                                <div class="requirements-box mb-3"><strong>Guidelines:</strong><br />• Only PDF (max 1MB).<br />• Verify integrity before upload.<br />• Late submissions are tracked automatically.</div>
                                <div class="mb-3">
                                    <label class="form-label fw-semibold small">Report Type</label>
                                    <select name="Report.ReportType" required class="form-select form-select-sm" id="modalReportType">
                                        <option value="">Select Type</option>
                                        @foreach (var val in Enum.GetValues(typeof(ReportType)).Cast<ReportType>())
                                        {
                                            <option value="@val">@val</option>
                                        }
                                    </select>
                                    <div class="modal-type-hint" id="modalTypeHint"></div>
                                </div>
                                <div class="mb-3 dz-wrapper">
                                    <label class="form-label fw-semibold small">Attach PDF</label>
                                    <div id="dropZone" class="drop-zone" tabindex="0">
                                        <i class="fa fa-cloud-upload-alt cloud-icon"></i>
                                        <p class="dz-msg">Drag & drop PDF here <span>or click to browse</span></p>
                                        <button type="button" class="dz-btn" id="browseBtn"><i class="fa fa-folder-open"></i> Select File</button>
                                        <input name="Report.DocumentFile" id="documentFileInput" type="file" accept="application/pdf" hidden required />
                                        <div id="fileMeta" class="dz-meta">Max 1MB • PDF only</div>
                                        <div class="dz-file-pill d-none" id="filePill"><span class="name" id="fileName"></span><span id="fileSize"></span><button type="button" class="dz-remove" id="removeFileBtn">REMOVE</button></div>
                                        <div class="progress-slim" id="uploadProgress"><div></div></div>
                                        <div class="dz-success" id="uploadSuccess"><i class="fa fa-check-circle"></i> Ready</div>
                                        <div class="dz-error" id="uploadError"><i class="fa fa-exclamation-circle"></i> Invalid</div>
                                    </div>
                                    <hr style="border-color:var(--d-glass-border);" class="my-3" />
                                    <div class="d-flex align-items-center justify-content-between gap-2">
                                        <div class="fw-bold" style="font-size:.75rem;letter-spacing:.14rem;text-transform:uppercase;color:var(--d-text-2);">Sub-Reports (optional)</div>
                                        <button type="button" class="btn-glass" id="btnAddSubreport" style="padding:.4rem .65rem;"><i class="bi bi-plus-circle-fill"></i> Add</button>
                                    </div>
                                    <div class="mt-2" id="subreportsWrap" style="display:grid;gap:.65rem;"></div>
                                    <div id="subreportLimitMsg" class="mt-2 d-none" style="font-size:.72rem;color:var(--d-text-2);border:1px solid var(--d-glass-border);background:var(--d-surface-2);padding:.55rem .65rem;border-radius:14px;">Max 5 subreports reached.</div>
                                </div>
                            </div>
                            <div class="modal-footer border-0">
                                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn text-white" style="background:var(--d-grad);font-weight:700;letter-spacing:.5px;"><i class="fa fa-paper-plane me-1"></i> Upload</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="late-overlay" id="lateOverlay">
                <div class="late-modal">
                    <div class="late-modal-icon"><i class="fa fa-exclamation-triangle"></i></div>
                    <h3>Late Submission Detected</h3>
                    <p class="late-modal-msg" id="lateMsg">You have already submitted a report for the current period. By proceeding, this report will be flagged as a <strong>late submission</strong>.</p>
                    <div class="late-modal-period" id="latePeriodLabel">—</div>
                    <div id="missedPeriodsWrap" style="display:none;margin-bottom:.85rem;">
                        <div style="font-size:.6rem;letter-spacing:.14rem;text-transform:uppercase;font-weight:800;color:var(--d-text-3);margin-bottom:.45rem;"><i class="fa fa-calendar-xmark"></i> Select which missed period this report covers:</div>
                        <div id="missedPeriodsList"></div>
                    </div>
                    <div class="late-modal-warning"><i class="fa fa-shield-halved"></i> By proceeding, you acknowledge that this report will be <strong>flagged as a late submission</strong> and will be rendered <strong>non-compliant</strong> in terms of reporting on time. Your compliance score will be affected.</div>
                    <div class="late-modal-actions">
                        <button type="button" class="btn-grad" id="btnConfirmLate"><i class="fa fa-check"></i> I Acknowledge — Submit</button>
                        <button type="button" class="btn-glass" id="btnCancelLate"><i class="fa fa-xmark"></i> Cancel</button>
                    </div>
                </div>
            </div>

            <div class="d-none" id="sidebarOverlay" style="position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:99;"></div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        (function () {
            'use strict';
            var html = document.documentElement;
            var themeBtn = document.getElementById('themeToggle');
            var saved = localStorage.getItem('fo-theme') || 'dark';
            html.setAttribute('data-theme', saved);
            updateIcon();
            themeBtn?.addEventListener('click', function () {
                var next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
                html.setAttribute('data-theme', next);
                localStorage.setItem('fo-theme', next);
                updateIcon();
            });
            function updateIcon() {
                var i = themeBtn?.querySelector('i');
                if (i) i.className = html.getAttribute('data-theme') === 'dark' ? 'bi bi-moon-stars-fill' : 'bi bi-sun-fill';
            }
            var sidebar = document.getElementById('sidebar');
            var toggle = document.getElementById('sidebarToggle');
            var overlay = document.getElementById('sidebarOverlay');
            toggle?.addEventListener('click', function () { sidebar?.classList.toggle('show'); overlay?.classList.toggle('d-none'); });
            overlay?.addEventListener('click', function () { sidebar?.classList.remove('show'); overlay?.classList.add('d-none'); });
            document.getElementById('btnRefresh')?.addEventListener('click', function () { location.reload(); });
        })();
    </script>

    <script>
        (function () {
            'use strict';
            var searchInput = document.getElementById('reportSearch');
            var typeFilter = document.getElementById('typeFilter');
            var statusFilter = document.getElementById('statusFilter');
            var tbody = document.getElementById('reportTableBody');
            var filterCount = document.getElementById('filterCount');
            var showMoreBtn = document.getElementById('showMoreBtn');
            function norm(s) { return (s || '').toString().toLowerCase().trim(); }
            function applyFilters() {
                var q = norm(searchInput.value), t = typeFilter.value, st = statusFilter.value, visible = 0;
                tbody.querySelectorAll('tr[data-ref]').forEach(function (r) {
                    var ref = norm(r.getAttribute('data-ref')); var type = r.getAttribute('data-type'); var status = r.getAttribute('data-status'); var isLate = r.getAttribute('data-late') === 'true';
                    var show = (!q || ref.includes(q)) && (!t || type === t);
                    if (st === 'late') show = show && isLate; else if (st) show = show && status === st;
                    r.style.display = show ? '' : 'none';
                    var next = r.nextElementSibling;
                    if (next && next.tagName === 'TR' && !next.hasAttribute('data-ref')) next.style.display = show ? '' : 'none';
                    if (show) visible++;
                });
                if (filterCount) filterCount.textContent = visible + ' / ' + tbody.querySelectorAll('tr[data-ref]').length + ' shown';
            }
            [searchInput, typeFilter, statusFilter].forEach(function (el) { el?.addEventListener('input', applyFilters); });
            typeFilter?.addEventListener('change', applyFilters); statusFilter?.addEventListener('change', applyFilters); applyFilters();
            showMoreBtn?.addEventListener('click', function () { document.querySelectorAll('.hidden-row').forEach(function (r) { r.classList.remove('hidden-row'); }); showMoreBtn.remove(); applyFilters(); });

            var dropZone = document.getElementById('dropZone'); var browseBtn = document.getElementById('browseBtn'); var fileInput = document.getElementById('documentFileInput');
            var meta = document.getElementById('fileMeta'); var progWrap = document.getElementById('uploadProgress'); var progBar = progWrap?.querySelector('div');
            var successBadge = document.getElementById('uploadSuccess'); var errorBadge = document.getElementById('uploadError'); var filePill = document.getElementById('filePill');
            var fileNameEl = document.getElementById('fileName'); var fileSizeEl = document.getElementById('fileSize'); var removeFileBtn = document.getElementById('removeFileBtn'); var MAX = 1024 * 1024;
            function humanSize(b) { return (b / 1024).toFixed(1) + ' KB'; }
            function resetZone() { if (!progWrap) return; progWrap.style.display = 'none'; progBar.style.width = '0%'; successBadge.style.display = 'none'; errorBadge.style.display = 'none'; filePill.classList.add('d-none'); dropZone.classList.remove('valid', 'invalid', 'drag-over'); meta.textContent = 'Max 1MB • PDF only'; fileInput.value = ''; }
            function showFile(f) { fileNameEl.textContent = f.name; fileSizeEl.textContent = humanSize(f.size); filePill.classList.remove('d-none'); }
            function invalid(msg) { dropZone.classList.add('invalid'); dropZone.classList.remove('valid'); errorBadge.style.display = 'inline-flex'; successBadge.style.display = 'none'; filePill.classList.add('d-none'); meta.textContent = msg; fileInput.value = ''; progWrap.style.display = 'none'; }
            function valid(f) { dropZone.classList.add('valid'); dropZone.classList.remove('invalid'); errorBadge.style.display = 'none'; meta.textContent = 'Selected: ' + f.name + ' (' + humanSize(f.size) + ')'; showFile(f); simProg(); }
            function simProg() { progWrap.style.display = 'block'; progBar.style.width = '0%'; successBadge.style.display = 'none'; var p = 0; (function s() { p += 17; progBar.style.width = p + '%'; if (p >= 100) successBadge.style.display = 'inline-flex'; else requestAnimationFrame(s); })(); }
            browseBtn?.addEventListener('click', function () { fileInput.click(); });
            dropZone?.addEventListener('click', function (e) { if (e.target === removeFileBtn) return; fileInput.click(); });
            removeFileBtn?.addEventListener('click', function (e) { e.stopPropagation(); resetZone(); });
            fileInput?.addEventListener('change', function () { var f = fileInput.files[0]; if (!f) { resetZone(); return; } if (f.type !== 'application/pdf') { invalid('PDF only.'); return; } if (f.size > MAX) { invalid('Exceeds 1MB.'); return; } valid(f); });
            ['dragenter', 'dragover'].forEach(function (e) { dropZone?.addEventListener(e, function (ev) { ev.preventDefault(); dropZone.classList.add('drag-over'); }); });
            ['dragleave', 'dragend'].forEach(function (e) { dropZone?.addEventListener(e, function () { dropZone.classList.remove('drag-over'); }); });
            dropZone?.addEventListener('drop', function (e) { e.preventDefault(); dropZone.classList.remove('drag-over'); var f = e.dataTransfer?.files[0]; if (!f) return; if (f.type !== 'application/pdf') { invalid('PDF only.'); return; } if (f.size > MAX) { invalid('Exceeds 1MB.'); return; } fileInput.files = e.dataTransfer.files; valid(f); });
            dropZone?.addEventListener('keydown', function (e) { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fileInput.click(); } if (e.key === 'Escape') resetZone(); });
            document.getElementById('uploadReportModal')?.addEventListener('hidden.bs.modal', function () { resetZone(); document.getElementById('modalTypeHint').innerHTML = ''; document.getElementById('hidAckLate').value = 'false'; document.getElementById('hidPeriodStart').value = ''; lastCheck = null; });

            var MaxSubReports = 5; var wrap = document.getElementById('subreportsWrap'); var btnAdd = document.getElementById('btnAddSubreport'); var limitMsg = document.getElementById('subreportLimitMsg');
            if (wrap && btnAdd) {
                function count() { return wrap.querySelectorAll('.subreport-item').length; }
                function updateLimit() { var r = count() >= MaxSubReports; btnAdd.disabled = r; limitMsg?.classList.toggle('d-none', !r); }
                function rowTpl(i) { var d = document.createElement('div'); d.className = 'subreport-item'; d.style.cssText = 'border:1px solid var(--d-glass-border);background:var(--d-surface-2);border-radius:14px;padding:.75rem;'; d.innerHTML = '<div class="row g-2 align-items-end"><div class="col-md-4"><label style="font-size:.55rem;letter-spacing:.15rem;text-transform:uppercase;font-weight:800;color:var(--d-text-3);margin-bottom:.3rem;">File name</label><input name="SubReports[' + i + '].FileName" class="form-control form-control-sm" placeholder="e.g. Additional Data" /></div><div class="col-md-4"><label style="font-size:.55rem;letter-spacing:.15rem;text-transform:uppercase;font-weight:800;color:var(--d-text-3);margin-bottom:.3rem;">Description</label><input name="SubReports[' + i + '].Description" class="form-control form-control-sm" placeholder="Optional..." /></div><div class="col-md-3"><label style="font-size:.55rem;letter-spacing:.15rem;text-transform:uppercase;font-weight:800;color:var(--d-text-3);margin-bottom:.3rem;">PDF file</label><input name="SubReports[' + i + '].DocumentFile" type="file" class="form-control form-control-sm" accept=".pdf,application/pdf" /></div><div class="col-md-1 d-flex justify-content-end"><button type="button" class="btnRemoveSub btn-glass" style="padding:.35rem .55rem;"><i class="bi bi-x-lg"></i></button></div></div>'; return d; }
                function reindex() { Array.from(wrap.querySelectorAll('.subreport-item')).forEach(function (item, idx) { item.querySelectorAll('input[name]').forEach(function (inp) { inp.name = inp.name.replace(/SubReports\[\d+\]/g, 'SubReports[' + idx + ']'); }); }); }
                btnAdd.addEventListener('click', function () { if (count() >= MaxSubReports) return; wrap.appendChild(rowTpl(count())); updateLimit(); });
                wrap.addEventListener('click', function (e) { var b = e.target.closest('.btnRemoveSub'); if (b) { b.closest('.subreport-item')?.remove(); reindex(); updateLimit(); } });
                updateLimit();
            }

            var idPass = '@Html.Raw(idPass)'; var checkUrl = '@Url.Action("CheckSubmission", "Report")';
            var form = document.getElementById('uploadForm'); var selType = document.getElementById('modalReportType'); var hint = document.getElementById('modalTypeHint');
            var hidAck = document.getElementById('hidAckLate'); var hidPeriod = document.getElementById('hidPeriodStart');
            var overlay = document.getElementById('lateOverlay'); var lateMsg = document.getElementById('lateMsg'); var latePeriodLbl = document.getElementById('latePeriodLabel');
            var missedWrap = document.getElementById('missedPeriodsWrap'); var missedList = document.getElementById('missedPeriodsList');
            var btnConfirm = document.getElementById('btnConfirmLate'); var btnCancel = document.getElementById('btnCancelLate'); var lastCheck = null;

            selType.addEventListener('change', function () {
                var t = selType.value;
                if (!t) { hint.innerHTML = ''; lastCheck = null; return; }
                hint.innerHTML = '<span style="color:var(--d-text-3);">Checking…</span>';
                fetch(checkUrl + '?idPass=' + encodeURIComponent(idPass) + '&reportType=' + encodeURIComponent(t))
                    .then(function (r) { return r.json(); })
                    .then(function (d) {
                        lastCheck = d;
                        if (d.wouldBeLate) {
                            hint.innerHTML = '<span style="color:var(--d-red);font-weight:700;"><i class="fa fa-exclamation-triangle"></i> Late — ' + d.intendedPeriodLabel + '</span>';
                        } else if (d.hasMissedPeriods) {
                            hint.innerHTML = '<span style="color:var(--d-accent);font-weight:700;"><i class="fa fa-calendar-xmark"></i> On time for ' + d.intendedPeriodLabel + ' · ' + d.missedPeriods.length + ' missed period(s) available</span>';
                        } else {
                            hint.innerHTML = '<span style="color:var(--d-green);"><i class="fa fa-check-circle"></i> On time — ' + d.intendedPeriodLabel + '</span>';
                        }
                    })
                    .catch(function () { hint.innerHTML = '<span style="color:var(--d-text-3);">Unable to check.</span>'; lastCheck = null; });
            });

            form.addEventListener('submit', function (e) {
                if (hidAck.value === 'true') return;

                if (lastCheck && lastCheck.wouldBeLate) {
                    e.preventDefault();
                    showLateModal(lastCheck, false);
                    return;
                }

                if (lastCheck && !lastCheck.currentPeriodAlreadyCovered && lastCheck.hasMissedPeriods) {
                    e.preventDefault();
                    showLateModal(lastCheck, true);
                    return;
                }

            });

            function showLateModal(check, allowCurrentPeriod) {
                lateMsg.innerHTML = check.message;
                latePeriodLbl.textContent = check.intendedPeriodLabel;

                missedWrap.style.display = '';
                missedList.innerHTML = '';

                if (allowCurrentPeriod) {
                    var currentOpt = document.createElement('label');
                    currentOpt.className = 'period-opt';
                    currentOpt.style.borderColor = 'rgba(34,197,94,.3)';
                    currentOpt.style.background = 'rgba(34,197,94,.04)';
                    currentOpt.innerHTML =
                        '<input type="radio" name="missedPeriodChoice" value="current" checked />' +
                        '<div><div class="period-opt-label" style="color:var(--d-green);">' +
                        '<i class="fa fa-check-circle"></i> ' + check.intendedPeriodLabel + ' (current — on time)</div></div>';
                    missedList.appendChild(currentOpt);
                }

                check.missedPeriods.forEach(function (m, i) {
                    var lbl = document.createElement('label');
                    lbl.className = 'period-opt';
                    lbl.innerHTML =
                        '<input type="radio" name="missedPeriodChoice" value="' + m.periodStart + '"' +
                        (!allowCurrentPeriod && i === 0 ? ' checked' : '') + ' />' +
                        '<div><div class="period-opt-label"><i class="fa fa-clock-rotate-left" style="color:var(--d-red);"></i> ' +
                        m.label + ' <span style="font-size:.5rem;color:var(--d-red);font-weight:900;letter-spacing:.08rem;">LATE</span></div></div>';
                    missedList.appendChild(lbl);
                });

                hidPeriod.value = allowCurrentPeriod ? '' : (check.missedPeriods[0]?.periodStart || check.intendedPeriodStart);
                overlay.classList.add('show');
            }

            btnConfirm.addEventListener('click', function () {
                var sel = document.querySelector('input[name="missedPeriodChoice"]:checked');

                if (sel && sel.value === 'current') {
                    hidAck.value = 'false';
                    hidPeriod.value = '';
                } else {
                    hidAck.value = 'true';
                    if (sel) hidPeriod.value = sel.value;
                }

                overlay.classList.remove('show');
                form.submit();
            });

            btnCancel.addEventListener('click', function () { overlay.classList.remove('show'); });
            overlay.addEventListener('click', function (e) { if (e.target === overlay) overlay.classList.remove('show'); });
        })();
    </script>
    <partial name="_Notifications" />
</body>
</html>