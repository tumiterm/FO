@model ForekOnline.Domain.ViewModels.RoleAccessManagementViewModel
@using ForekOnline.Domain.Entities
@{ ViewData["Title"] = "Role approval centre"; }
<style>
    .approval-shell{max-width:1320px;margin:auto;padding:2rem 1.25rem 4rem;color:#172033}.approval-hero{padding:2rem;border-radius:28px;color:#fff;background:linear-gradient(125deg,#131d35,#85131b 68%,#f06b35);display:flex;justify-content:space-between;align-items:center;gap:1rem;flex-wrap:wrap}.approval-hero h1{font-weight:850;margin:.2rem 0}.approval-hero p{margin:0;opacity:.78}.back{color:#fff;border:1px solid #ffffff45;border-radius:13px;padding:.7rem 1rem;text-decoration:none}.metric{display:inline-flex;margin-top:.7rem;padding:.4rem .7rem;border-radius:99px;background:#ffffff18;font-size:.75rem}.section{margin-top:1.2rem;background:#fff;border:1px solid #e7eaf0;border-radius:22px;padding:1.25rem;box-shadow:0 10px 35px #14213d0d}.section-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem}.section h2{font-size:1.05rem;font-weight:800;margin:0}.request-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:.8rem}.request{border:1px solid #e7eaf0;border-radius:18px;padding:1rem;background:linear-gradient(145deg,#fff,#fafbfc)}.route{display:flex;align-items:center;gap:.55rem;font-weight:850}.route span{padding:.35rem .6rem;border-radius:10px;background:#f1f3f7}.meta,.reason{font-size:.75rem;color:#697386;margin-top:.65rem}.reason{padding:.7rem;border-radius:12px;background:#f6f7fa;color:#374151}.actions{display:grid;grid-template-columns:1fr 1fr auto;gap:.5rem;margin-top:.8rem}.actions input{grid-column:1/-1;border:1px solid #e1e5eb;border-radius:11px;padding:.58rem}.btn{border:0;border-radius:11px;padding:.62rem .8rem;font-size:.75rem;font-weight:800}.approve{background:#087f5b;color:#fff}.reject{background:#9d1720;color:#fff}.remind{background:#eef1f6;color:#172033}.history{width:100%;border-collapse:collapse;font-size:.78rem}.history th,.history td{text-align:left;padding:.75rem;border-bottom:1px solid #edf0f4}.status{font-weight:800}.empty{text-align:center;padding:2rem;color:#697386;background:#f7f8fa;border-radius:16px}@@media(max-width:800px){.request-grid{grid-template-columns:1fr}.actions{grid-template-columns:1fr}}
</style>
<main class="approval-shell">
    <header class="approval-hero"><div><small>SECURITY OPERATIONS</small><h1>Role approval centre</h1><p>Review elevated access with independent oversight and a complete audit trail.</p><span class="metric">@Model.Pending.Count pending decision(s)</span></div><a asp-action="RetrieveUsers" class="back"><i class="fa fa-users"></i> User directory</a></header>
    <section class="section"><div class="section-head"><h2>Awaiting review</h2><i class="fa fa-inbox"></i></div>
        @if(!Model.Pending.Any()){<div class="empty"><i class="fa fa-circle-check"></i><br/>The approval queue is clear.</div>}
        <div class="request-grid">@foreach(var item in Model.Pending){<article class="request">
            <div class="route"><span>@(item.FromRole?.ToString() ?? "None")</span><i class="fa fa-arrow-right"></i><span>@item.RequestedRole</span></div>
            <div class="meta"><strong>@item.TargetUser.Name @item.TargetUser.LastName</strong> · requested by @item.RequestedByUser.Name @item.RequestedByUser.LastName<br/>@item.RequestedUtc.ToString("dd MMM yyyy, HH:mm") UTC · @item.ReminderCount reminder(s)</div>
            <div class="reason">@item.Reason</div>
            <form class="actions" method="post"><input type="hidden" name="RequestId" value="@item.Id"/>@Html.AntiForgeryToken()<input name="ReviewNote" placeholder="Optional review note"/><button formaction="@Url.Action("ApproveRoleAccess")" class="btn approve"><i class="fa fa-check"></i> Approve</button><button formaction="@Url.Action("RejectRoleAccess")" class="btn reject"><i class="fa fa-xmark"></i> Reject</button><button formaction="@Url.Action("RemindRoleApprovers")" name="requestId" value="@item.Id" class="btn remind" title="Record reminder"><i class="fa fa-bell"></i></button></form>
        </article>}</div>
    </section>
    <section class="section"><div class="section-head"><h2>Recent decisions</h2><i class="fa fa-clock-rotate-left"></i></div><div style="overflow:auto"><table class="history"><thead><tr><th>User</th><th>Transition</th><th>Decision</th><th>Reviewed</th></tr></thead><tbody>@foreach(var item in Model.Recent){<tr><td>@item.TargetUser.Name @item.TargetUser.LastName</td><td>@item.FromRole → @item.RequestedRole</td><td class="status">@item.Status</td><td>@item.ReviewedUtc?.ToString("dd MMM yyyy, HH:mm")</td></tr>}</tbody></table></div></section>
</main>
