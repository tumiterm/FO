@model ForekOnline.Domain.ViewModels.UserDetailsViewModel
@using ForekOnline.Domain.Entities
@using static ForekOnline.Domain.Enums.EnumRegistry
@{
    ViewData["Title"] = "User access profile";
    var fullName = $"{Model.Name} {Model.LastName}".Trim();
    var initials = string.Concat((Model.Name ?? "?").Take(1), (Model.LastName ?? "").Take(1)).ToUpperInvariant();
    var roles = Enum.GetValues<eSysRole>().Where(x => x != eSysRole.None && x != Model.Role &&
        !(Model.IsViewingSelf && Model.Role == eSysRole.Admin && x == eSysRole.SuperAdmin));
    var downgradeRoles = Model.Role == eSysRole.Admin
        ? roles.Where(x => x is not eSysRole.Admin and not eSysRole.SuperAdmin)
        : roles.Where(x => x != eSysRole.SuperAdmin);
}

<style>
    :root{--ink:#172033;--muted:#697386;--line:#e7eaf0;--brand:#9d1720;--orange:#f36b35;--navy:#14213d;--soft:#f7f8fb;--green:#087f5b}
    .access-shell{max-width:1380px;margin:auto;padding:2rem 1.25rem 4rem;color:var(--ink)}
    .access-hero{position:relative;overflow:hidden;border-radius:30px;padding:2.2rem;background:linear-gradient(125deg,#111a31,#7e1019 66%,#ef6a35);color:#fff;box-shadow:0 24px 70px rgba(40,20,30,.2)}
    .access-hero:after{content:"";position:absolute;width:440px;height:440px;border:90px solid rgba(255,255,255,.06);border-radius:50%;right:-130px;top:-210px}
    .hero-grid{position:relative;z-index:1;display:flex;justify-content:space-between;align-items:center;gap:2rem;flex-wrap:wrap}
    .identity{display:flex;align-items:center;gap:1.25rem}.avatar{width:92px;height:92px;border-radius:26px;display:grid;place-items:center;background:rgba(255,255,255,.14);border:1px solid rgba(255,255,255,.26);font-size:1.8rem;font-weight:800}
    .eyebrow{text-transform:uppercase;letter-spacing:.18em;font-size:.69rem;font-weight:800;opacity:.75}.identity h1{font-size:clamp(1.65rem,4vw,2.65rem);font-weight:800;margin:.25rem 0}.hero-pills{display:flex;gap:.6rem;flex-wrap:wrap}.hero-pill{border:1px solid rgba(255,255,255,.2);background:rgba(255,255,255,.1);padding:.48rem .75rem;border-radius:99px;font-size:.76rem}
    .hero-actions{display:flex;gap:.65rem;flex-wrap:wrap}.premium-btn{border:0;border-radius:14px;padding:.78rem 1rem;font-weight:750;text-decoration:none;display:inline-flex;align-items:center;gap:.5rem;cursor:pointer}.premium-btn.light{background:#fff;color:var(--brand)}.premium-btn.ghost{background:rgba(255,255,255,.11);color:#fff;border:1px solid rgba(255,255,255,.25)}
    .summary-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin:1.2rem 0}.summary-card,.panel{background:#fff;border:1px solid var(--line);border-radius:22px;box-shadow:0 9px 35px rgba(20,33,61,.06)}.summary-card{padding:1.15rem}.summary-card span{font-size:.68rem;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);font-weight:800}.summary-card strong{display:block;font-size:1.12rem;margin-top:.35rem}
    .content-grid{display:grid;grid-template-columns:minmax(0,1.35fr) minmax(310px,.65fr);gap:1rem}.panel{padding:1.35rem}.panel-head{display:flex;justify-content:space-between;gap:1rem;align-items:start;margin-bottom:1.1rem}.panel h2{font-size:1.05rem;font-weight:800;margin:0}.panel-sub{font-size:.78rem;color:var(--muted);margin-top:.25rem}
    .field-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}.field label{font-size:.7rem;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:.4rem}.field input{width:100%;border:1px solid var(--line);background:var(--soft);border-radius:14px;padding:.78rem .85rem;outline:0}.field input:focus{border-color:var(--orange);box-shadow:0 0 0 3px rgba(243,107,53,.12)}
    .role-current{padding:1rem;border-radius:18px;background:linear-gradient(130deg,#fff5f2,#f7f8fb);border:1px solid #f2ded8;display:flex;align-items:center;justify-content:space-between;gap:1rem}.role-orb{width:48px;height:48px;border-radius:15px;display:grid;place-items:center;background:var(--navy);color:#fff}.role-name{font-weight:850}.secure-note{font-size:.74rem;color:var(--muted)}
    .role-options{display:grid;grid-template-columns:repeat(2,1fr);gap:.6rem;margin-top:.8rem}.role-choice input{position:absolute;opacity:0}.role-choice span{display:block;padding:.8rem;border:1px solid var(--line);border-radius:14px;font-size:.78rem;font-weight:750;cursor:pointer}.role-choice input:checked+span{border-color:var(--orange);background:#fff4ef;color:#9d1720;box-shadow:0 0 0 2px rgba(243,107,53,.12)}
    textarea{width:100%;border:1px solid var(--line);border-radius:14px;padding:.8rem;min-height:90px;margin-top:.8rem}.action-btn{width:100%;margin-top:.75rem;border:0;border-radius:14px;padding:.78rem;background:linear-gradient(120deg,var(--brand),var(--orange));color:#fff;font-weight:800}.action-btn.dark{background:var(--navy)}
    .timeline{position:relative;padding-left:1rem}.timeline:before{content:"";position:absolute;left:5px;top:8px;bottom:8px;width:2px;background:var(--line)}.event{position:relative;padding:0 0 1rem 1.1rem}.event:before{content:"";position:absolute;left:-.98rem;top:.3rem;width:10px;height:10px;border-radius:50%;background:var(--orange);box-shadow:0 0 0 4px #fff}.event strong{font-size:.8rem}.event p{font-size:.72rem;color:var(--muted);margin:.2rem 0}.empty{padding:1rem;text-align:center;color:var(--muted);font-size:.8rem;background:var(--soft);border-radius:14px}.warning{padding:.8rem;border-radius:14px;background:#fff8e6;color:#855d00;font-size:.75rem;margin-top:.8rem}.confirm{display:flex;gap:.6rem;align-items:flex-start;font-size:.75rem;margin-top:.8rem}
    @@media(max-width:900px){.summary-grid{grid-template-columns:1fr}.content-grid{grid-template-columns:1fr}.field-grid{grid-template-columns:1fr}}@@media(max-width:520px){.role-options{grid-template-columns:1fr}.access-hero{padding:1.4rem}.identity{align-items:flex-start}.avatar{width:65px;height:65px;border-radius:19px}}
</style>

<main class="access-shell">
    <section class="access-hero">
        <div class="hero-grid">
            <div class="identity">
                <div class="avatar">@initials</div>
                <div><div class="eyebrow">Identity & access profile</div><h1>@fullName</h1>
                    <div class="hero-pills"><span class="hero-pill"><i class="fa fa-shield"></i> @Model.Role</span><span class="hero-pill"><i class="fa fa-circle-check"></i> @(Model.IsActive ? "Active" : "Inactive")</span><span class="hero-pill">ID @Model.Id.ToString()[..8]</span></div>
                </div>
            </div>
            <div class="hero-actions"><a asp-action="RetrieveUsers" class="premium-btn ghost"><i class="fa fa-arrow-left"></i> Users</a><a asp-action="RoleAccessRequests" class="premium-btn light"><i class="fa fa-inbox"></i> Approval centre</a></div>
        </div>
    </section>

    <section class="summary-grid">
        <div class="summary-card"><span>Current access</span><strong>@Model.Role</strong></div>
        <div class="summary-card"><span>Last sign in</span><strong>@(Model.LastLoginDate?.ToString("dd MMM yyyy") ?? "Never")</strong></div>
        <div class="summary-card"><span>Access workflow</span><strong>@(Model.HasPendingRoleRequest ? "Approval pending" : "No pending request")</strong></div>
    </section>

    <div class="content-grid">
        <div>
            <section class="panel">
                <div class="panel-head"><div><h2>Profile essentials</h2><div class="panel-sub">Role is intentionally excluded from this ordinary save.</div></div><i class="fa fa-user-pen"></i></div>
                <form asp-action="OnViewUserInfo" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden"/><input asp-for="Role" type="hidden"/><input asp-for="OldPassword" type="hidden"/><input asp-for="ConfirmPassword" type="hidden"/><input asp-for="StudentNumber" type="hidden"/>
                    <div class="field-grid">
                        <div class="field"><label asp-for="Name"></label><input asp-for="Name"/></div>
                        <div class="field"><label asp-for="LastName"></label><input asp-for="LastName"/></div>
                        <div class="field"><label asp-for="Email"></label><input asp-for="Email"/></div>
                        <div class="field"><label asp-for="Cellphone"></label><input asp-for="Cellphone"/></div>
                        <div class="field"><label asp-for="IDPass">Identity / passport</label><input asp-for="IDPass"/></div>
                        <div class="field"><label>Account status</label><label class="confirm"><input asp-for="IsActive" style="width:auto"/> Active account</label></div>
                    </div>
                    <button class="action-btn dark" type="submit"><i class="fa fa-check"></i> Save profile details</button>
                </form>
            </section>

            <section class="panel" style="margin-top:1rem">
                <div class="panel-head"><div><h2>Role timeline</h2><div class="panel-sub">A durable audit trail of every applied role transition.</div></div><i class="fa fa-clock-rotate-left"></i></div>
                @if (!Model.RoleHistory.Any()){<div class="empty">No role changes have been recorded yet.</div>}
                <div class="timeline">
                    @foreach(var item in Model.RoleHistory){<div class="event"><strong>@(item.FromRole?.ToString() ?? "Unassigned") <i class="fa fa-arrow-right"></i> @(item.ToRole?.ToString() ?? "Unassigned")</strong><p>@item.ChangedUtc.ToString("dd MMM yyyy, HH:mm") UTC · @item.Reason</p></div>}
                </div>
            </section>
        </div>

        <aside>
            <section class="panel">
                <div class="panel-head"><div><h2>Access control</h2><div class="panel-sub">Deliberate, reviewed and auditable.</div></div><i class="fa fa-fingerprint"></i></div>
                <div class="role-current"><div style="display:flex;gap:.75rem;align-items:center"><span class="role-orb"><i class="fa fa-key"></i></span><div><div class="secure-note">Assigned role</div><div class="role-name">@Model.Role</div></div></div><i class="fa fa-lock"></i></div>
                <form asp-action="RequestRoleAccess" method="post">
                    @Html.AntiForgeryToken()<input type="hidden" name="TargetUserId" value="@Model.Id"/>
                    <div class="secure-note" style="margin-top:1rem">Request a different access package</div>
                    <div class="role-options">@foreach(var role in roles){<label class="role-choice"><input type="radio" name="RequestedRole" value="@role" required/><span>@role.ToString().Replace("Officer"," Officer")</span></label>}</div>
                    <textarea name="Reason" required minlength="5" placeholder="Explain the business need and responsibilities..."></textarea>
                    <button class="action-btn" type="submit" @(Model.HasPendingRoleRequest ? "disabled" : null)><i class="fa fa-paper-plane"></i> @(Model.HasPendingRoleRequest ? "Request already pending" : "Request elevated access")</button>
                </form>
            </section>

            @if(Model.CanDirectDowngrade){
            <section class="panel" style="margin-top:1rem">
                <div class="panel-head"><div><h2>Downgrade my access</h2><div class="panel-sub">Immediate action; your session will end.</div></div><i class="fa fa-triangle-exclamation"></i></div>
                <form asp-action="DowngradeOwnRole" method="post">
                    @Html.AntiForgeryToken()<input type="hidden" name="TargetUserId" value="@Model.Id"/>
                    <div class="role-options">@foreach(var role in downgradeRoles){<label class="role-choice"><input type="radio" name="NewRole" value="@role" required/><span>@role.ToString().Replace("Officer"," Officer")</span></label>}</div>
                    <textarea name="Reason" required minlength="5" placeholder="Why are you reducing your access?"></textarea>
                    <div class="warning"><i class="fa fa-shield-halved"></i> This is blocked if you are the final active Admin/SuperAdmin.</div>
                    <label class="confirm"><input type="checkbox" name="ConfirmLockoutRisk" value="true" required/> I understand that this can remove access to administration screens and will sign me out.</label>
                    <button class="action-btn dark" type="submit"><i class="fa fa-arrow-down"></i> Confirm access downgrade</button>
                </form>
            </section>}

            <section class="panel" style="margin-top:1rem">
                <div class="panel-head"><div><h2>Recent requests</h2><div class="panel-sub">The latest approval activity for this user.</div></div></div>
                @if(!Model.RoleRequests.Any()){<div class="empty">No access requests.</div>}
                @foreach(var request in Model.RoleRequests){<div class="role-current" style="margin-bottom:.55rem"><div><div class="role-name">@request.RequestedRole</div><div class="secure-note">@request.Status · @request.RequestedUtc.ToString("dd MMM yyyy")</div></div></div>}
            </section>
        </aside>
    </div>
</main>
