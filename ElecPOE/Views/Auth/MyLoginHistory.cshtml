@model ForekOnline.Domain.ViewModels.MyLoginHistoryViewModel

@using ForekOnline.Application.Common.Utility

@{
    ViewData["Title"] = "My Login History";

    var rows = Model?.Rows ?? Array.Empty<ForekOnline.Domain.ViewModels.LoginHistoryRowViewModel>();
    var avgDisplay = (Model?.AvgDuration.TotalHours >= 1)
        ? $"{(int)Model.AvgDuration.TotalHours}h {Model.AvgDuration.Minutes}m"
        : $"{(int)(Model?.AvgDuration.TotalMinutes ?? 0)}m";
}

<style>
    :root {
        --hero1: #0b5d46;
        --hero2: #0d8e66;
        --hero3: #0aa377;
        --ink: #14211b;
        --muted: #5a6b63;
        --card: #ffffff;
        --border: #e2e8e4;
        --shadow: 0 16px 40px -26px rgba(0,0,0,.35);
        --radius: 16px;
    }

    .my-hero {
        border-radius: 22px;
        background: linear-gradient(135deg, var(--hero1), var(--hero2) 60%, var(--hero3));
        color: #fff;
        padding: 1.35rem 1.25rem;
        box-shadow: var(--shadow);
        position: relative;
        overflow: hidden;
        margin-bottom: 1rem;
    }

        .my-hero:before {
            content: "";
            position: absolute;
            inset: -50% -20%;
            background: radial-gradient(circle at 30% 35%, rgba(255,255,255,.22) 0, rgba(255,255,255,0) 60%);
            pointer-events: none;
        }

        .my-hero .inner {
            position: relative;
        }

        .my-hero h1 {
            margin: 0 0 .25rem;
            font-size: 1.35rem;
            font-weight: 800;
            letter-spacing: .2px;
        }

        .my-hero p {
            margin: 0;
            color: rgba(255,255,255,.9);
            font-size: .9rem;
        }

    .my-kpis {
        display: grid;
        grid-template-columns: repeat(3, minmax(0,1fr));
        gap: .75rem;
        margin-bottom: 1rem;
    }

    @@media (max-width: 768px) {
        .my-kpis {
            grid-template-columns: 1fr;
        }
    }

    .kpi {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: 0 10px 22px -20px rgba(0,0,0,.35);
        padding: .85rem .9rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
    }

        .kpi .label {
            font-size: .72rem;
            text-transform: uppercase;
            letter-spacing: .12rem;
            color: var(--muted);
            font-weight: 800;
        }

        .kpi .value {
            font-size: 1.25rem;
            font-weight: 900;
            color: var(--ink);
            line-height: 1.1;
        }

        .kpi .icon {
            width: 38px;
            height: 38px;
            border-radius: 12px;
            display: grid;
            place-items: center;
            background: #0d8e6612;
            border: 1px solid #0d8e6630;
            color: #0b5d46;
            flex: 0 0 auto;
        }

    .my-table-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
    }

        .my-table-card .card-body {
            padding: 1rem;
        }

    .lh-badge {
        font-size: .68rem;
        text-transform: uppercase;
        letter-spacing: .12rem;
        font-weight: 900;
        border-radius: 999px;
        padding: .28rem .55rem;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        border: 1px solid transparent;
    }

        .lh-badge.active {
            background: #0d8e6612;
            border-color: #0d8e6628;
            color: #0b5d46;
        }

        .lh-badge.closed {
            background: #64748b14;
            border-color: #64748b2c;
            color: #334155;
        }

        .lh-badge.abnormal {
            background: #f59e0b12;
            border-color: #f59e0b35;
            color: #7a4b00;
        }

        .lh-badge.forced {
            background: #dc262612;
            border-color: #dc262635;
            color: #7a2525;
        }

    .duration-live {
        font-weight: 800;
        font-variant-numeric: tabular-nums;
    }

    .my-empty {
        padding: 1.1rem;
        text-align: center;
        color: var(--muted);
    }
</style>

<section class="my-hero">
    <div class="inner">
        <h1>My Login History</h1>
        <p>Welcome, <strong>@(Model?.DisplayName ?? "User")</strong>. Review your recent sessions and manage active logins.</p>
    </div>
</section>

<section class="my-kpis">
    <div class="kpi">
        <div>
            <div class="label">Your Active Sessions</div>
            <div class="value">@(Model?.ActiveSessionCount ?? 0)</div>
        </div>
        <div class="icon"><i class="fa fa-circle-play"></i></div>
    </div>

    <div class="kpi">
        <div>
            <div class="label">Total Logins (30 days)</div>
            <div class="value">@(Model?.TotalLogins30Days ?? 0)</div>
        </div>
        <div class="icon"><i class="fa fa-list"></i></div>
    </div>

    <div class="kpi">
        <div>
            <div class="label">Avg Duration</div>
            <div class="value">@avgDisplay</div>
        </div>
        <div class="icon"><i class="fa fa-clock"></i></div>
    </div>
</section>

<div class="my-table-card">
    <div class="card-body">
        @if (rows.Count == 0)
        {
            <div class="my-empty">
                <i class="fa fa-inbox fa-2x mb-2 d-block text-muted"></i>
                No sessions found in the last 90 days.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Status</th>
                            <th>Login</th>
                            <th>Last Activity</th>
                            <th>Logout</th>
                            <th>Duration</th>
                            <th>Device / Browser</th>
                            <th>IP</th>
                            <th>Reason</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in rows)
                        {
                            var s = row.Session;
                            var isActive = !s.LogoutTimeUtc.HasValue;

                            <tr>
                                <td style="white-space:nowrap;">
                                    <span class="lh-badge @row.StatusCssClass">
                                        <i class="fa @row.StatusIcon"></i> @row.Status
                                    </span>
                                </td>

                                <td style="white-space:nowrap;" title="@s.LoginTimeUtc.ToString("u")">
                                    @row.LoginRelative
                                </td>

                                <td style="white-space:nowrap;" title="@(s.LastActivityUtc?.ToString("u") ?? "-")">
                                    @row.LastActivityRelative
                                </td>

                                <td style="white-space:nowrap;" title="@(s.LogoutTimeUtc?.ToString("u") ?? "-")">
                                    @row.LogoutRelative
                                </td>

                                <td style="white-space:nowrap;">
                                    <span class="duration-live @row.DurationCssClass"
                                          data-login-utc="@s.LoginTimeUtc.ToString("o")"
                                          data-is-active="@isActive.ToString().ToLowerInvariant()">
                                        @row.DurationDisplay
                                    </span>
                                </td>

                                <td style="white-space:nowrap;">
                                    <i class="fa @row.DeviceIcon me-1" title="@(s.DeviceType ?? "Unknown")"></i>
                                    <i class="@row.BrowserIcon" title="@(s.Browser ?? "Unknown")"></i>
                                </td>

                                <td class="small">@(s.IpAddress ?? "-")</td>

                                <td class="small">@(s.LogoutReason ?? "-")</td>

                                <td class="text-end" style="white-space:nowrap;">
                                    @if (isActive)
                                    {
                                        <form asp-action="ForceLogoutOwnSession" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="sessionKey" value="@s.SessionKey" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Close this session?');">
                                                <i class="fa fa-ban me-1"></i> Close
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            function updateDurations() {
                document.querySelectorAll('.duration-live[data-is-active="true"]').forEach(el => {
                    const login = new Date(el.getAttribute('data-login-utc'));
                    const now = new Date();
                    let diff = Math.max(0, (now - login) / 1000);
                    const h = Math.floor(diff / 3600);
                    diff %= 3600;
                    const m = Math.floor(diff / 60);
                    const s = Math.floor(diff % 60);
                    let text = '';
                    if (h > 0) text += h + 'h ';
                    text += m + 'm ' + s + 's';
                    el.textContent = text;
                    const mins = (h * 60) + m;
                    el.classList.remove('text-success', 'text-warning', 'text-danger');
                    el.classList.add(mins < 30 ? 'text-success' : mins < 120 ? 'text-warning' : 'text-danger');
                });
            }
            setInterval(updateDurations, 15000);
        })();
    </script>
}