@{
    ViewData["Title"] = "Settings & Configuration";
    ViewData["MetaDescription"] = "Manage Forek Online platform modules, communication and access settings.";

    var userName = User?.Identity?.Name;
    var displayName = string.IsNullOrWhiteSpace(userName) ? "Administrator" : userName;
}

@section Styles {
<style>
    .settings-hub {
        --settings-ink: #17141b;
        --settings-muted: #77717d;
        --settings-red: #b31217;
        --settings-red-dark: #63090d;
        --settings-orange: #ff7a18;
        --settings-green: #45b97c;
        --settings-blue: #4e81dc;
        --settings-purple: #8a61cf;
        --settings-yellow: #dfa52f;
        width: min(1440px, calc(100% - 32px));
        margin: 0 auto;
        padding: 34px 0 72px;
        color: var(--settings-ink);
        font-family: Inter, system-ui, sans-serif;
    }

    .settings-hub * { box-sizing: border-box; }

    .settings-hub a:focus-visible,
    .settings-hub button:focus-visible,
    .settings-hub input:focus-visible {
        outline: 3px solid rgba(255, 122, 24, .35);
        outline-offset: 3px;
    }

    .settings-hero {
        position: relative;
        display: grid;
        grid-template-columns: minmax(0, 1.4fr) minmax(310px, .6fr);
        min-height: 360px;
        overflow: hidden;
        border-radius: 34px;
        background:
            radial-gradient(circle at 8% 110%, rgba(255, 122, 24, .35), transparent 36%),
            radial-gradient(circle at 92% 0%, rgba(179, 18, 23, .45), transparent 38%),
            linear-gradient(135deg, #22090b 0%, #560b10 48%, #171319 100%);
        box-shadow: 0 30px 80px rgba(59, 7, 10, .22);
        color: #fff;
    }

    .settings-hero::after {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        opacity: .18;
        background-image: radial-gradient(rgba(255,255,255,.75) .7px, transparent .7px);
        background-size: 18px 18px;
        mask-image: linear-gradient(90deg, #000, transparent 72%);
    }

    .settings-hero__copy {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: clamp(32px, 5vw, 66px);
    }

    .settings-eyebrow,
    .settings-section__kicker {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        font-size: .7rem;
        font-weight: 800;
        letter-spacing: .16em;
        text-transform: uppercase;
    }

    .settings-eyebrow { color: #ffbd8a; }

    .settings-eyebrow::before {
        content: "";
        width: 25px;
        height: 2px;
        border-radius: 99px;
        background: var(--settings-orange);
    }

    .settings-hero h1 {
        max-width: 760px;
        margin: 18px 0 14px;
        font-size: clamp(2.25rem, 5vw, 4.9rem);
        font-weight: 850;
        line-height: .98;
        letter-spacing: -.055em;
        color: #fff;
    }

    .settings-hero h1 span { color: #ff9b51; }

    .settings-hero p {
        max-width: 650px;
        margin: 0;
        color: rgba(255,255,255,.67);
        font-size: 1rem;
        line-height: 1.75;
    }

    .settings-search {
        position: relative;
        max-width: 610px;
        margin-top: 28px;
    }

    .settings-search i {
        position: absolute;
        top: 50%;
        left: 18px;
        transform: translateY(-50%);
        color: rgba(255,255,255,.62);
    }

    .settings-search input {
        width: 100%;
        min-height: 58px;
        padding: 0 130px 0 50px;
        border: 1px solid rgba(255,255,255,.16);
        border-radius: 17px;
        background: rgba(255,255,255,.1);
        backdrop-filter: blur(12px);
        color: #fff;
        font-size: .92rem;
        transition: border-color .2s ease, background .2s ease;
    }

    .settings-search input::placeholder { color: rgba(255,255,255,.48); }
    .settings-search input:focus { border-color: rgba(255,155,81,.75); background: rgba(255,255,255,.14); outline: 0; }

    .settings-search span {
        position: absolute;
        top: 50%;
        right: 12px;
        transform: translateY(-50%);
        padding: 8px 11px;
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 10px;
        color: rgba(255,255,255,.52);
        font-size: .66rem;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .settings-hero__side {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        margin: 18px;
        padding: 26px;
        border: 1px solid rgba(255,255,255,.11);
        border-radius: 25px;
        background: rgba(16, 13, 18, .66);
        backdrop-filter: blur(14px);
    }

    .settings-profile { display: flex; align-items: center; gap: 13px; }
    .settings-profile__icon {
        display: grid;
        place-items: center;
        width: 48px;
        height: 48px;
        border-radius: 16px;
        background: linear-gradient(135deg, var(--settings-orange), var(--settings-red));
        box-shadow: 0 12px 30px rgba(179,18,23,.35);
    }
    .settings-profile strong, .settings-profile span { display: block; }
    .settings-profile strong { color: #fff; font-size: .88rem; }
    .settings-profile span { margin-top: 3px; color: rgba(255,255,255,.46); font-size: .72rem; }

    .settings-health {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin: 30px 0;
    }
    .settings-health__item {
        padding: 15px;
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 16px;
        background: rgba(255,255,255,.045);
    }
    .settings-health__item span { display: block; color: rgba(255,255,255,.45); font-size: .66rem; text-transform: uppercase; letter-spacing: .1em; }
    .settings-health__item strong { display: block; margin-top: 8px; color: #fff; font-size: 1.25rem; }
    .settings-health__item strong em { color: #61d99a; font-size: .7rem; font-style: normal; }

    .settings-side__actions { display: flex; gap: 9px; }
    .settings-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-height: 43px;
        padding: 0 15px;
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 13px;
        background: rgba(255,255,255,.07);
        color: #fff;
        font-size: .73rem;
        font-weight: 750;
        text-decoration: none;
        transition: transform .2s ease, background .2s ease;
    }
    .settings-btn:hover { transform: translateY(-2px); background: rgba(255,255,255,.13); color: #fff; }
    .settings-btn--accent { flex: 1; border-color: transparent; background: linear-gradient(135deg, var(--settings-red), var(--settings-orange)); }

    .settings-content { padding: 44px 4px 0; }
    .settings-section + .settings-section { margin-top: 42px; }
    .settings-section__head { display: flex; align-items: end; justify-content: space-between; gap: 20px; margin-bottom: 18px; }
    .settings-section__kicker { color: var(--settings-red); }
    .settings-section h2 { margin: 6px 0 0; font-size: clamp(1.55rem, 2.6vw, 2.25rem); font-weight: 820; letter-spacing: -.035em; }
    .settings-section__head p { max-width: 480px; margin: 0; color: var(--settings-muted); font-size: .84rem; line-height: 1.65; text-align: right; }

    .settings-grid { display: grid; grid-template-columns: repeat(12, minmax(0, 1fr)); gap: 15px; }
    .settings-card {
        --module: var(--settings-red);
        grid-column: span 4;
        position: relative;
        display: flex;
        flex-direction: column;
        min-height: 245px;
        overflow: hidden;
        padding: 24px;
        border: 1px solid #ebe7eb;
        border-radius: 24px;
        background: #fff;
        color: var(--settings-ink);
        box-shadow: 0 12px 35px rgba(40, 26, 35, .055);
        text-decoration: none;
        transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
    }
    .settings-card::after {
        content: "";
        position: absolute;
        top: -38px;
        right: -38px;
        width: 130px;
        height: 130px;
        border-radius: 50%;
        background: color-mix(in srgb, var(--module) 13%, transparent);
        transition: transform .3s ease;
    }
    .settings-card:hover { transform: translateY(-6px); border-color: color-mix(in srgb, var(--module) 35%, #fff); box-shadow: 0 24px 55px rgba(40, 26, 35, .11); color: var(--settings-ink); }
    .settings-card:hover::after { transform: scale(1.25); }
    .settings-card--wide { grid-column: span 6; min-height: 220px; }
    .settings-card--green { --module: var(--settings-green); }
    .settings-card--blue { --module: var(--settings-blue); }
    .settings-card--purple { --module: var(--settings-purple); }
    .settings-card--yellow { --module: var(--settings-yellow); }
    .settings-card--orange { --module: var(--settings-orange); }
    .settings-card--muted { --module: #8c8791; }
    .settings-card.is-filtered { display: none; }

    .settings-card__top { position: relative; z-index: 1; display: flex; align-items: center; justify-content: space-between; }
    .settings-card__icon {
        display: grid;
        place-items: center;
        width: 52px;
        height: 52px;
        border-radius: 17px;
        background: color-mix(in srgb, var(--module) 12%, #fff);
        color: var(--module);
        font-size: 1.15rem;
    }
    .settings-card__tag { padding: 7px 10px; border-radius: 99px; background: #f6f3f5; color: #7f7882; font-size: .63rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
    .settings-card h3 { position: relative; z-index: 1; margin: 26px 0 8px; font-size: 1.12rem; font-weight: 800; letter-spacing: -.02em; }
    .settings-card p { position: relative; z-index: 1; margin: 0; color: var(--settings-muted); font-size: .8rem; line-height: 1.65; }
    .settings-card__foot { position: relative; z-index: 1; display: flex; align-items: center; justify-content: space-between; margin-top: auto; padding-top: 20px; color: var(--module); font-size: .72rem; font-weight: 800; }
    .settings-card__foot i { transition: transform .2s ease; }
    .settings-card:hover .settings-card__foot i { transform: translateX(4px); }
    .settings-card--locked { cursor: not-allowed; opacity: .68; }

    .settings-empty { display: none; margin-top: 18px; padding: 24px; border: 1px dashed #d9d2d8; border-radius: 18px; color: var(--settings-muted); text-align: center; }
    .settings-empty.is-visible { display: block; }

    @@media (max-width: 1050px) {
        .settings-hero { grid-template-columns: 1fr; }
        .settings-hero__side { min-height: 230px; }
        .settings-card { grid-column: span 6; }
    }

    @@media (max-width: 700px) {
        .settings-hub { width: min(100% - 20px, 1440px); padding-top: 18px; }
        .settings-hero { border-radius: 25px; }
        .settings-hero__copy { padding: 32px 24px; }
        .settings-hero__side { margin: 0 12px 12px; padding: 20px; }
        .settings-search input { padding-right: 48px; }
        .settings-search span { display: none; }
        .settings-section__head { align-items: flex-start; flex-direction: column; }
        .settings-section__head p { text-align: left; }
        .settings-card, .settings-card--wide { grid-column: 1 / -1; }
    }
</style>
}

<main class="settings-hub">
    <section class="settings-hero" aria-labelledby="settings-title">
        <div class="settings-hero__copy">
            <div class="settings-eyebrow">System control centre</div>
            <h1 id="settings-title">Shape how Forek <span>works.</span></h1>
            <p>Manage learning, placements, partners, communication and access from one focused administration workspace.</p>

            <label class="settings-search" for="settingsSearch">
                <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                <input id="settingsSearch" type="search" placeholder="Search settings and modules..." autocomplete="off" />
                <span>Quick find</span>
            </label>
        </div>

        <aside class="settings-hero__side" aria-label="Configuration overview">
            <div class="settings-profile">
                <span class="settings-profile__icon"><i class="fa-solid fa-sliders"></i></span>
                <span>
                    <strong>@displayName</strong>
                    <span>Configuration administrator</span>
                </span>
            </div>

            <div class="settings-health">
                <div class="settings-health__item"><span>Live modules</span><strong>7 <em>active</em></strong></div>
                <div class="settings-health__item"><span>Workspace</span><strong>v2 <em>ready</em></strong></div>
                <div class="settings-health__item"><span>Core areas</span><strong>5</strong></div>
                <div class="settings-health__item"><span>Status</span><strong><em><i class="fa-solid fa-circle-check"></i> Healthy</em></strong></div>
            </div>

            <div class="settings-side__actions">
                <button type="button" class="settings-btn" onclick="location.reload()"><i class="fa-solid fa-rotate"></i> Refresh</button>
                <a class="settings-btn settings-btn--accent" asp-action="Dashboard" asp-controller="Applications"><i class="fa-solid fa-chart-line"></i> View insights</a>
            </div>
        </aside>
    </section>

    <div class="settings-content">
        <section class="settings-section" aria-labelledby="core-settings-title">
            <div class="settings-section__head">
                <div>
                    <div class="settings-section__kicker"><i class="fa-solid fa-grid-2"></i> Core configuration</div>
                    <h2 id="core-settings-title">Your operational building blocks</h2>
                </div>
                <p>Open a module to manage its records, rules and day-to-day configuration.</p>
            </div>

            <div class="settings-grid" id="settingsCards">
                <a class="settings-card" data-tags="courses training catalog curriculum learning academic" asp-action="GetActiveCourses" asp-controller="Course">
                    <div class="settings-card__top"><span class="settings-card__icon"><i class="fa-solid fa-book-open"></i></span><span class="settings-card__tag">Academic</span></div>
                    <h3>Courses</h3><p>Manage active curriculum, mapped course codes and learning availability.</p>
                    <span class="settings-card__foot">Open courses <i class="fa-solid fa-arrow-right"></i></span>
                </a>
                <a class="settings-card settings-card--green" data-tags="placements learners host progress operations" asp-action="PlacedLearners" asp-controller="LearnerPlacement">
                    <div class="settings-card__top"><span class="settings-card__icon"><i class="fa-solid fa-briefcase"></i></span><span class="settings-card__tag">Operations</span></div>
                    <h3>Placement list</h3><p>Review learner placement allocations, hosts and current progress statuses.</p>
                    <span class="settings-card__foot">Open placements <i class="fa-solid fa-arrow-right"></i></span>
                </a>
                <a class="settings-card settings-card--blue" data-tags="company companies host industry partners compliance" asp-action="HostCompanies" asp-controller="Company">
                    <div class="settings-card__top"><span class="settings-card__icon"><i class="fa-solid fa-building"></i></span><span class="settings-card__tag">Compliance</span></div>
                    <h3>Host companies</h3><p>Maintain and audit experiential learning partners across the organisation.</p>
                    <span class="settings-card__foot">Open companies <i class="fa-solid fa-arrow-right"></i></span>
                </a>
                <a class="settings-card settings-card--purple" data-tags="applications admissions intake funnel analytics" asp-action="Dashboard" asp-controller="Applications">
                    <div class="settings-card__top"><span class="settings-card__icon"><i class="fa-solid fa-file-circle-check"></i></span><span class="settings-card__tag">Admissions</span></div>
                    <h3>Applications</h3><p>Monitor the application pipeline, processing activity and intake movement.</p>
                    <span class="settings-card__foot">Open applications <i class="fa-solid fa-arrow-right"></i></span>
                </a>
                <a class="settings-card settings-card--yellow" data-tags="licenses licence user access control security" asp-action="AddUserLicense" asp-controller="License">
                    <div class="settings-card__top"><span class="settings-card__icon"><i class="fa-solid fa-key"></i></span><span class="settings-card__tag">Security</span></div>
                    <h3>Licences</h3><p>Issue, revoke and review digital access entitlements for platform users.</p>
                    <span class="settings-card__foot">Manage licences <i class="fa-solid fa-arrow-right"></i></span>
                </a>
                <a class="settings-card settings-card--orange" data-tags="communication sms email guardians students broadcast messaging" asp-action="Communication" asp-controller="Auth">
                    <div class="settings-card__top"><span class="settings-card__icon"><i class="fa-solid fa-paper-plane"></i></span><span class="settings-card__tag">Messaging</span></div>
                    <h3>Communication</h3><p>Send targeted SMS and email updates to learners, guardians or course groups.</p>
                    <span class="settings-card__foot">Open communication <i class="fa-solid fa-arrow-right"></i></span>
                </a>
            </div>
        </section>

        <section class="settings-section" aria-labelledby="platform-settings-title">
            <div class="settings-section__head">
                <div>
                    <div class="settings-section__kicker"><i class="fa-solid fa-wand-magic-sparkles"></i> Platform services</div>
                    <h2 id="platform-settings-title">Communication and governance</h2>
                </div>
                <p>Keep people informed today, with deeper reporting and audit tooling planned next.</p>
            </div>

            <div class="settings-grid">
                <a class="settings-card settings-card--wide settings-card--blue" data-tags="notifications alerts messages events user messaging" asp-action="Notifications" asp-controller="Notification">
                    <div class="settings-card__top"><span class="settings-card__icon"><i class="fa-solid fa-bell"></i></span><span class="settings-card__tag">Live</span></div>
                    <h3>In-app notifications</h3><p>Configure, schedule and manage user-facing alerts and platform event messages.</p>
                    <span class="settings-card__foot">Manage notifications <i class="fa-solid fa-arrow-right"></i></span>
                </a>
                <div class="settings-card settings-card--wide settings-card--muted settings-card--locked" data-tags="reports analytics metrics audit logs history planned" aria-disabled="true">
                    <div class="settings-card__top"><span class="settings-card__icon"><i class="fa-solid fa-chart-pie"></i></span><span class="settings-card__tag">Roadmap</span></div>
                    <h3>Reporting & audit suite</h3><p>Centralised exports, forensic activity trails and anomaly monitoring are planned for a future release.</p>
                    <span class="settings-card__foot">Coming soon <i class="fa-solid fa-lock"></i></span>
                </div>
            </div>
            <div class="settings-empty" id="settingsEmpty"><i class="fa-solid fa-magnifying-glass me-2"></i>No settings match your search.</div>
        </section>
    </div>
</main>

@section Scripts {
<script>
    (() => {
        const search = document.getElementById('settingsSearch');
        const cards = Array.from(document.querySelectorAll('.settings-card'));
        const empty = document.getElementById('settingsEmpty');

        const applyFilter = () => {
            const query = (search?.value || '').trim().toLowerCase();
            let matches = 0;

            cards.forEach(card => {
                const haystack = `${card.dataset.tags || ''} ${card.textContent}`.toLowerCase();
                const visible = !query || haystack.includes(query);
                card.classList.toggle('is-filtered', !visible);
                if (visible) matches += 1;
            });

            empty?.classList.toggle('is-visible', matches === 0);
        };

        search?.addEventListener('input', applyFilter);
    })();
</script>
}
