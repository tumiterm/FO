<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Settings & Configuration</title>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet" />
    <style>
        :root {
            --clr-dr:#320606;
            --clr-red:#9d1117;
            --clr-red-strong:#b31217;
            --clr-orange:#ff7a18;
            --clr-orange-soft:#f99b4a;
            --grad-accent:linear-gradient(95deg,#320606,#b31217 55%,#ff7a18);
            --grad-soft:linear-gradient(120deg,#32060612,#b3121718,#ff7a1824);
            --border:#e4e6ea;
            --border-alt:#d4d6da;
            --bg:#ffffff;
            --bg-soft:#f7f8fa;
            --card-shadow:0 4px 14px -6px rgba(50,6,6,.15);
            --card-hover:0 10px 26px -12px rgba(50,6,6,.28);
            --radius-xl:28px;
            --radius-lg:20px;
            --radius-md:14px;
        }

        body {
            font-family:'Segoe UI',system-ui,sans-serif;
            background:var(--bg-soft);
            color:#222;
            -webkit-font-smoothing:antialiased;
        }

        .page-shell {
            max-width:1400px;
            margin:0 auto;
            padding:2.1rem 1.6rem 3.5rem;
        }

        .header-band {
            background:var(--bg);
            border:1px solid var(--border);
            border-radius:var(--radius-xl);
            padding:1.35rem 1.65rem 1.25rem;
            display:flex;
            flex-wrap:wrap;
            gap:1.35rem;
            align-items:center;
            position:relative;
            overflow:hidden;
        }
        .header-band:before {
            content:"";
            position:absolute;
            inset:0;
            background:var(--grad-soft);
            pointer-events:none;
        }
        .icon-pill {
            width:70px;height:70px;
            background:var(--grad-accent);
            border-radius:24px;
            display:flex;align-items:center;justify-content:center;
            color:#fff;font-size:1.65rem;
            box-shadow:0 10px 24px -10px rgba(179,18,23,.55);
        }
        .header-band h1 {
            margin:0;
            font-size:1.55rem;
            font-weight:600;
            letter-spacing:.5px;
            display:flex;
            align-items:center;
            gap:.7rem;
            color:#222;
        }
        .tagline {
            font-size:.60rem;
            letter-spacing:.28rem;
            font-weight:700;
            text-transform:uppercase;
            background:var(--grad-soft);
            padding:.55rem .95rem;
            border-radius:40px;
            display:inline-flex;
            align-items:center;
            gap:.5rem;
            color:var(--clr-red-strong);
            margin-top:.4rem;
        }

        .toolbar {
            margin-left:auto;
            display:flex;
            flex-wrap:wrap;
            gap:.6rem;
            align-items:center;
        }
        .btn-accent, .btn-soft {
            font-size:.62rem;
            letter-spacing:.14rem;
            font-weight:600;
            text-transform:uppercase;
            padding:.65rem 1.1rem;
            border-radius:12px;
            border:1px solid transparent;
            display:inline-flex;
            gap:.45rem;
            align-items:center;
            text-decoration:none;
            transition:.3s;
        }
        .btn-accent {
            background:var(--grad-accent); color:#fff;
        }
        .btn-accent:hover { filter:brightness(.93); box-shadow:0 6px 16px -6px rgba(179,18,23,.4); }
        .btn-soft {
            background:#fff;
            color:var(--clr-red-strong);
            border:1px solid var(--border);
        }
        .btn-soft:hover {
            background:var(--clr-red-strong);
            color:#fff;
            border-color:var(--clr-red-strong);
        }

        /* Search */
        .search-wrap {
            flex:1 1 260px;
            position:relative;
            min-width:240px;
        }
        .search-wrap input {
            width:100%;
            background:#fff;
            border:1px solid var(--border);
            padding:.65rem .85rem .65rem 2.3rem;
            border-radius:14px;
            font-size:.72rem;
            letter-spacing:.4px;
            transition:.25s;
        }
        .search-wrap input:focus {
            outline:none;
            border-color:var(--clr-red-strong);
            box-shadow:0 0 0 .15rem #b3121718;
        }
        .search-wrap i {
            position:absolute;
            top:50%;left:.8rem;
            transform:translateY(-50%);
            font-size:.75rem;
            color:#999;
        }

        /* Grid */
        .section-block {
            margin-top:2rem;
        }
        .section-block h2 {
            font-size:.68rem;
            letter-spacing:.24rem;
            font-weight:700;
            text-transform:uppercase;
            color:var(--clr-red-strong);
            margin:0 0 .85rem;
            display:flex;
            gap:.55rem;
            align-items:center;
        }
        .cards-grid {
            display:grid;
            gap:1.15rem;
            grid-template-columns:repeat(auto-fill,minmax(210px,1fr));
        }

        .card-link {
            position:relative;
            display:flex;
            flex-direction:column;
            gap:.85rem;
            background:#fff;
            border:1px solid var(--border);
            border-radius:22px;
            padding:1rem .95rem .95rem;
            text-decoration:none;
            color:#222;
            min-height:200px;
            overflow:hidden;
            transition:.4s cubic-bezier(.25,.9,.25,1);
            isolation:isolate;
        }
        .card-link:before {
            content:"";
            position:absolute;
            inset:0;
            background:radial-gradient(circle at 85% 15%,rgba(255,122,24,.15),transparent 65%);
            opacity:.55;
            transition:.4s;
        }
        .card-link:after {
            content:"";
            position:absolute;
            inset:0;
            border-radius:inherit;
            background:linear-gradient(120deg,#32060608,#b3121708,#ff7a1812);
            opacity:0;
            transition:.45s;
        }
        .card-link:hover {
            transform:translateY(-6px);
            border-color:var(--border-alt);
            box-shadow:var(--card-hover);
        }
        .card-link:hover:after { opacity:1; }

        .cl-head {
            width:60px;height:60px;
            border-radius:18px;
            background:var(--grad-accent);
            display:flex;align-items:center;justify-content:center;
            color:#fff;
            font-size:1.35rem;
            box-shadow:0 6px 18px -8px rgba(179,18,23,.55);
            position:relative;
            z-index:2;
        }
        .cl-body {
            position:relative;
            z-index:2;
            display:flex;
            flex-direction:column;
            gap:.55rem;
            flex:1;
        }
        .cl-title {
            font-size:.85rem;
            font-weight:600;
            letter-spacing:.4px;
            line-height:1.2;
        }
        .cl-desc {
            font-size:.58rem;
            letter-spacing:.06rem;
            line-height:1.1rem;
            color:#555;
            flex:1;
        }
        .cl-footer {
            display:flex;
            justify-content:space-between;
            align-items:center;
            border-top:1px solid var(--border);
            padding-top:.55rem;
            margin-top:.35rem;
        }
        .go-chip {
            font-size:.55rem;
            letter-spacing:.14rem;
            font-weight:700;
            padding:.4rem .7rem;
            border-radius:30px;
            background:#fff;
            color:var(--clr-red-strong);
            border:1px solid var(--clr-red-strong);
            display:inline-flex;
            gap:.4rem;
            align-items:center;
            transition:.3s;
        }
        .card-link:hover .go-chip {
            background:var(--grad-accent);
            color:#fff;
            border-color:var(--clr-red-strong);
        }
        .badge-mini {
            font-size:.5rem;
            letter-spacing:.12rem;
            font-weight:700;
            background:var(--clr-soft);
            color:var(--clr-red-strong);
            padding:.32rem .55rem;
            border-radius:30px;
            text-transform:uppercase;
        }

        /* Status coloring variants (optional semantic tints) */
        .var-green .cl-head { background:linear-gradient(135deg,#2f6d3f,#3f9155 60%,#53c174); }
        .var-blue .cl-head { background:linear-gradient(135deg,#1d4970,#23649c 60%,#2e86d5); }
        .var-purple .cl-head { background:linear-gradient(135deg,#4e2b74,#6c3ca4 60%,#8d51d7); }
        .var-yellow .cl-head { background:linear-gradient(135deg,#965b00,#c07a05 60%,#f2a423); }
        .var-neutral .cl-head { background:linear-gradient(135deg,#5a5a60,#787880 60%,#9a9aa1); }

        /* Filtered hide */
        .hidden-filter { display:none !important; }

        @@media (max-width:840px){
            .toolbar { width:100%; }
            .search-wrap { order:3; flex:1 1 100%; }
        }
    </style>
</head>
<body>
    <main class="page-shell">
        <div class="header-band">
            <div class="icon-pill"><i class="fa fa-gears"></i></div>
            <div>
                <h1>Settings & Global Configurations</h1>
                <div class="tagline">
                    <i class="fa fa-layer-group"></i> CONTROL PANEL
                </div>
            </div>
            <div class="toolbar">
                <div class="search-wrap">
                    <i class="fa fa-search"></i>
                    <input id="settingsSearch" placeholder="Search modules..." autocomplete="off" />
                </div>
                <button type="button" class="btn-soft" onclick="location.reload()">
                    <i class="fa fa-rotate"></i> Refresh
                </button>
                <a asp-action="Dashboard" asp-controller="Applications" class="btn-accent">
                    <i class="fa fa-chart-line"></i> Insights
                </a>
            </div>
        </div>

        <section class="section-block">
            <h2><i class="fa fa-cubes"></i> Core Modules</h2>
            <div class="cards-grid" id="settingsCards">
                <a class="card-link" data-tags="courses training catalog learn" asp-action="GetActiveCourses" asp-controller="Course">
                    <div class="cl-head"><i class="fa fa-book-open"></i></div>
                    <div class="cl-body">
                        <div class="cl-title">Courses</div>
                        <div class="cl-desc">Manage active curriculum, mapped codes & availability.</div>
                        <div class="cl-footer">
                            <span class="go-chip"><i class="fa fa-arrow-right"></i> GO</span>
                            <span class="badge-mini">Academic</span>
                        </div>
                    </div>
                </a>

                <a class="card-link var-green" data-tags="placements learners host progress" asp-action="PlacedLearners" asp-controller="LearnerPlacement">
                    <div class="cl-head"><i class="fa fa-briefcase"></i></div>
                    <div class="cl-body">
                        <div class="cl-title">Placement List</div>
                        <div class="cl-desc">Review learner placement allocations & statuses.</div>
                        <div class="cl-footer">
                            <span class="go-chip"><i class="fa fa-arrow-right"></i> GO</span>
                            <span class="badge-mini">Operational</span>
                        </div>
                    </div>
                </a>

                <a class="card-link var-blue" data-tags="company host industry partners" asp-action="HostCompanies" asp-controller="Company">
                    <div class="cl-head"><i class="fa fa-building"></i></div>
                    <div class="cl-body">
                        <div class="cl-title">Host Companies</div>
                        <div class="cl-desc">Maintain & audit registered experiential learning partners.</div>
                        <div class="cl-footer">
                            <span class="go-chip"><i class="fa fa-arrow-right"></i> GO</span>
                            <span class="badge-mini">Compliance</span>
                        </div>
                    </div>
                </a>

                <a class="card-link var-purple" data-tags="applications intake funnel analytics" asp-action="Dashboard" asp-controller="Applications">
                    <div class="cl-head"><i class="fa fa-file-alt"></i></div>
                    <div class="cl-body">
                        <div class="cl-title">Applications</div>
                        <div class="cl-desc">Monitor online application flow & processing timelines.</div>
                        <div class="cl-footer">
                            <span class="go-chip"><i class="fa fa-arrow-right"></i> GO</span>
                            <span class="badge-mini">Admissions</span>
                        </div>
                    </div>
                </a>

                <a class="card-link var-yellow" data-tags="licenses user access control" asp-action="AddUserLicense" asp-controller="License">
                    <div class="cl-head"><i class="fa fa-certificate"></i></div>
                    <div class="cl-body">
                        <div class="cl-title">Licenses</div>
                        <div class="cl-desc">Issue, revoke & review digital entitlement keys.</div>
                        <div class="cl-footer">
                            <span class="go-chip"><i class="fa fa-arrow-right"></i> GO</span>
                            <span class="badge-mini">Security</span>
                        </div>
                    </div>
                </a>

            </div>
        </section>

        <section class="section-block">
            <h2><i class="fa fa-puzzle-piece"></i> Extended</h2>
            <div class="cards-grid">
                <a class="card-link var-neutral" data-tags="notifications alerts messages events user" asp-action="Notifications" asp-controller="Notification">
                    <div class="cl-head"><i class="fa fa-bell"></i></div>
                    <div class="cl-body">
                        <div class="cl-title">In‑App Notifications</div>
                        <div class="cl-desc">Configure, schedule and manage user-facing system alerts & event messages.</div>
                        <div class="cl-footer">
                            <span class="go-chip"><i class="fa fa-arrow-right"></i> GO</span>
                            <span class="badge-mini">Messaging</span>
                        </div>
                    </div>
                </a>
                <a class="card-link var-neutral" data-tags="reports analytics metrics" href="javascript:void(0)" title="Coming Soon">
                    <div class="cl-head"><i class="fa fa-chart-pie"></i></div>
                    <div class="cl-body">
                        <div class="cl-title">Reporting Suite</div>
                        <div class="cl-desc">Centralized analytics & exports (in roadmap).</div>
                        <div class="cl-footer">
                            <span class="go-chip"><i class="fa fa-lock"></i> LOCKED</span>
                            <span class="badge-mini">Planned</span>
                        </div>
                    </div>
                </a>
                <a class="card-link var-neutral" data-tags="audit logs trace history" href="javascript:void(0)" title="Coming Soon">
                    <div class="cl-head"><i class="fa fa-shield-halved"></i></div>
                    <div class="cl-body">
                        <div class="cl-title">Audit & Logs</div>
                        <div class="cl-desc">Forensic tracking & anomaly detection (in roadmap).</div>
                        <div class="cl-footer">
                            <span class="go-chip"><i class="fa fa-lock"></i> LOCKED</span>
                            <span class="badge-mini">Planned</span>
                        </div>
                    </div>
                </a>
                <a class="card-link var-blue" data-tags="communication sms email guardians students broadcast" asp-action="Communication" asp-controller="Auth">
                    <div class="cl-head"><i class="fa fa-comment-dots"></i></div>
                    <div class="cl-body">
                        <div class="cl-title">Communication</div>
                        <div class="cl-desc">Send bulk SMS/email to students or guardians by course or selection.</div>
                        <div class="cl-footer">
                            <span class="go-chip"><i class="fa fa-arrow-right"></i> GO</span>
                            <span class="badge-mini">Messaging</span>
                        </div>
                    </div>
                </a>
            </div>
        </section>
    </main>

    <script>
        (function(){
            const search = document.getElementById('settingsSearch');
            const cards = Array.from(document.querySelectorAll('.card-link'));
            function norm(v){ return (v||'').toString().toLowerCase().trim(); }
            function apply(){
                const q = norm(search.value);
                cards.forEach(c=>{
                    const tags = (c.getAttribute('data-tags')||'') + ' ' + c.innerText;
                    const m = !q || norm(tags).includes(q);
                    c.classList.toggle('hidden-filter', !m);
                });
            }
            search?.addEventListener('input', apply);
        })();
    </script>
</body>
</html>