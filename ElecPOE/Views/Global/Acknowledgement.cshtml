@{
    Layout = null; // Keep standalone. Remove this line if you want to use the shared layout.
    string applicant = (ViewData["ApplicantName"] as string) ?? (TempData["ApplicantName"] as string) ?? "Applicant";
    string reference = (ViewData["Reference"] as string) ?? (TempData["Reference"] as string) ?? "";
    bool autoRedirect = false; // set true if you want timed redirect
    int redirectSeconds = 8;
    bool showRatingPrompt = ViewData["ShowRatingPrompt"] is true;
    Guid? ratingApplicationId = ViewData["RatingApplicationId"] is Guid applicationId ? applicationId : null;
}

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>Application Submitted</title>
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<style>
:root{
  --ack-dr:#320606;--ack-red:#b31217;--ack-orange:#ff7a18;--ack-soft:#fff5f3;
  --ack-bg:#f5f7fa;--ack-card:#ffffff;--ack-border:#e5e7ea;--ack-grad:linear-gradient(95deg,#320606,#b31217 55%,#ff7a18);
  font-family:'Segoe UI',system-ui,sans-serif;
}
*{box-sizing:border-box;}
html,body{height:100%;margin:0;background:radial-gradient(circle at 68% 22%,#ff7a1822,#32060611),var(--ack-bg);}
body{display:flex;align-items:center;justify-content:center;padding:1.8rem;}
.fade-in{animation:fade .7s ease;}
@@keyframes fade{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}
.card{
  width:100%;max-width:560px;background:var(--ack-card);border:1px solid var(--ack-border);
  border-radius:32px;padding:2.1rem 2rem 1.9rem;position:relative;overflow:hidden;
  box-shadow:0 14px 38px -18px rgba(50,6,6,.35),0 6px 20px -10px rgba(50,6,6,.18);
}
.card:before{
  content:"";position:absolute;inset:0;background:linear-gradient(120deg,#3206060d,#b312170d,#ff7a1814);
  pointer-events:none;
}
.badge-top{
  position:absolute;top:14px;right:16px;font-size:.55rem;letter-spacing:.22rem;font-weight:700;
  background:var(--ack-soft);color:var(--ack-red);padding:.45rem .8rem;border-radius:40px;
}
.icon-wrap{
  width:94px;height:94px;border-radius:30px;background:var(--ack-grad);
  display:flex;align-items:center;justify-content:center;color:#fff;
  font-size:2.3rem;margin:0 auto 1.2rem;position:relative;
  box-shadow:0 12px 32px -16px rgba(179,18,23,.65);
  animation:pop .65s cubic-bezier(.25,1.4,.45,1);
}
@@keyframes pop{0%{transform:scale(.4);opacity:0;}60%{transform:scale(1.08);}85%{transform:scale(.95);}100%{transform:scale(1);opacity:1;}}
.icon-wrap:after{
  content:"";position:absolute;inset:-4px;border-radius:inherit;
  background:conic-gradient(from 140deg at 50% 50%,#ff7a18,#b31217,#320606,#ff7a18);
  filter:blur(14px);opacity:.18;z-index:-1;
}
h1{
  margin:.2rem 0 .6rem;font-size:1.55rem;line-height:1.2;font-weight:600;text-align:center;
  background:var(--ack-grad);-webkit-background-clip:text;color:transparent;letter-spacing:.5px;
}
p.lead{
  margin:.2rem 0 1.2rem;font-size:.82rem;line-height:1.35rem;color:#444;text-align:center;
}
.ref-box{
  background:#fafbfc;border:1px dashed #d8dadd;padding:.9rem .95rem;border-radius:18px;
  font-size:.7rem;letter-spacing:.08rem;display:flex;flex-direction:column;gap:.4rem;margin:0 0 1.15rem;
}
.ref-box code{
  background:#fff;padding:.4rem .55rem;border-radius:10px;font-family:ui-monospace,monospace;font-size:.68rem;
  border:1px solid #eceef0;word-break:break-all;
}
.actions{
  display:flex;flex-wrap:wrap;gap:.6rem;justify-content:center;margin-top:.2rem;
}
.btn{
  --btn-bg:#fff;--btn-fg:var(--ack-red);--btn-bd:#dcdfe2;
  font-size:.62rem;letter-spacing:.14rem;font-weight:600;text-transform:uppercase;
  padding:.7rem 1.15rem;border-radius:14px;border:1px solid var(--btn-bd);
  background:var(--btn-bg);color:var(--btn-fg);cursor:pointer;display:inline-flex;align-items:center;gap:.5rem;
  transition:.35s;text-decoration:none;position:relative;overflow:hidden;
}
.btn:hover{
  background:var(--ack-grad);color:#fff;border-color:var(--ack-red);box-shadow:0 8px 20px -10px rgba(179,18,23,.6);
}
.btn-accent{--btn-bg:var(--ack-grad);--btn-fg:#fff;--btn-bd:var(--ack-red);}
.btn-accent:hover{filter:brightness(.95);}
.sub-note{
  margin:1.3rem 0 0;font-size:.55rem;letter-spacing:.18rem;font-weight:600;text-transform:uppercase;
  text-align:center;color:#666;
}
.timer{
  display:none;font-weight:700;color:var(--ack-red);
}
.show{display:inline;}
@@media (max-width:620px){
  .card{padding:1.85rem 1.4rem 1.6rem;border-radius:28px;}
  h1{font-size:1.35rem;}
  .icon-wrap{width:80px;height:80px;font-size:2rem;}
}

.visually-hidden{position:absolute!important;width:1px!important;height:1px!important;padding:0!important;margin:-1px!important;overflow:hidden!important;clip:rect(0,0,0,0)!important;white-space:nowrap!important;border:0!important;}
.rating-overlay{
  position:fixed;inset:0;z-index:1000;display:grid;place-items:center;padding:1.25rem;
  background:rgba(20,10,10,.56);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
  opacity:0;visibility:hidden;transition:opacity .25s ease,visibility .25s ease;
}
.rating-overlay.is-open{opacity:1;visibility:visible;}
.rating-modal{
  width:min(100%,480px);background:#fff;border:1px solid rgba(255,255,255,.72);border-radius:28px;
  padding:2rem;position:relative;box-shadow:0 28px 80px rgba(31,6,6,.32);
  transform:translateY(18px) scale(.97);transition:transform .28s cubic-bezier(.2,.8,.2,1);
}
.rating-overlay.is-open .rating-modal{transform:translateY(0) scale(1);}
.rating-close{
  position:absolute;right:1rem;top:1rem;width:38px;height:38px;border:0;border-radius:50%;
  color:#6b6161;background:#f6f2f2;cursor:pointer;font-size:1rem;transition:.2s;
}
.rating-close:hover{background:#efe4e4;color:var(--ack-red);transform:rotate(5deg);}
.rating-kicker{margin:0 0 .55rem;color:var(--ack-orange);font-size:.68rem;font-weight:800;letter-spacing:.16rem;text-transform:uppercase;}
.rating-modal h2{margin:0;color:#241a1a;font-size:1.55rem;line-height:1.2;}
.rating-copy{margin:.7rem 0 1.25rem;color:#6c6262;font-size:.85rem;line-height:1.5;}
.star-rating{display:flex;flex-direction:row-reverse;justify-content:center;gap:.35rem;margin:.2rem 0 .7rem;}
.star-rating input{position:absolute;opacity:0;pointer-events:none;}
.star-rating label{color:#ddd5c6;font-size:2.45rem;cursor:pointer;line-height:1;filter:drop-shadow(0 5px 8px rgba(115,77,0,.08));transition:color .15s,transform .15s;}
.star-rating label:hover,.star-rating label:hover~label,.star-rating input:checked~label{color:#f7bd2a;}
.star-rating label:hover{transform:translateY(-3px) scale(1.06);}
.star-rating input:focus-visible+label{outline:3px solid rgba(247,189,42,.35);outline-offset:4px;border-radius:6px;}
.rating-label{display:block;margin:.9rem 0 .45rem;color:#3e3434;font-size:.75rem;font-weight:700;}
.rating-textarea{width:100%;min-height:112px;resize:vertical;border:1px solid #ddd7d7;border-radius:16px;padding:.85rem 1rem;font:inherit;font-size:.82rem;color:#302727;background:#fcfbfb;outline:none;transition:.2s;}
.rating-textarea:focus{border-color:#e58a32;box-shadow:0 0 0 4px rgba(255,122,24,.12);background:#fff;}
.rating-meta{display:flex;justify-content:space-between;gap:1rem;margin:.4rem .15rem 1rem;color:#8a8181;font-size:.65rem;}
.rating-error{display:none;margin:0 0 .8rem;color:#a20f13;font-size:.72rem;font-weight:600;}
.rating-error.is-visible{display:block;}
.rating-submit{width:100%;justify-content:center;border:0;padding:.9rem 1rem;font-size:.7rem;}
.rating-submit:disabled{opacity:.65;cursor:wait;}
.rating-success{text-align:center;padding:1rem 0 .35rem;}
.rating-success i{display:grid;place-items:center;width:64px;height:64px;margin:0 auto 1rem;border-radius:22px;background:#fff6d9;color:#e3a511;font-size:1.7rem;}
.rating-success h2{margin-bottom:.55rem;}
.rating-success p{margin:0;color:#6c6262;font-size:.85rem;}
@media (max-width:520px){.rating-modal{padding:1.6rem 1.25rem;border-radius:24px}.star-rating label{font-size:2.15rem;}}
</style>
</head>
<body>
  <main class="card fade-in" role="status" aria-live="polite">
    <span class="badge-top">CONFIRMED</span>
    <div class="icon-wrap" aria-hidden="true"><i class="fa fa-check"></i></div>
    <h1>Application Submitted</h1>
    <p class="lead">
        Thank you @applicant, your application was received successfully            
    </br>

    @if(!string.IsNullOrWhiteSpace(reference))
    {
        <div class="ref-box">
            <strong>Reference</strong>
            <code>@reference</code>
            <span style="font-size:.6rem;color:#777;">Use this when following up with support.</span>
        </div>
    }

    <div class="actions">
        <a class="btn btn-accent" href="@Url.Action("Index","Home")"><i class="fa fa-house"></i> Home</a>
        <a class="btn" href="javascript:window.print()"><i class="fa fa-print"></i> Print</a>
        <a class="btn" href="@Url.Action("SignIn","Auth")"><i class="fa fa-right-to-bracket"></i> Sign In</a>
        @if (showRatingPrompt)
        {
            <button class="btn" id="openRatingButton" type="button"><i class="fa fa-star"></i> Rate experience</button>
        }
        <a class="btn" href="mailto:support@forek.online?subject=App%20Follow-up%20@reference"><i class="fa fa-envelope"></i> Support</a>
    </div>

    <p class="sub-note">
        All data encrypted in transit • <span id="redirectTimer" class="timer"></span>
    </p>
  </main>


  @if (showRatingPrompt)
  {
    <div class="rating-overlay" id="ratingOverlay" aria-hidden="true">
      <section class="rating-modal" role="dialog" aria-modal="true" aria-labelledby="ratingTitle" aria-describedby="ratingDescription">
        <button class="rating-close" id="ratingClose" type="button" aria-label="Close feedback form"><i class="fa fa-xmark"></i></button>
        <div id="ratingFormContent">
          <p class="rating-kicker">One last thing</p>
          <h2 id="ratingTitle">How was your application experience?</h2>
          <p class="rating-copy" id="ratingDescription">Your feedback helps us make applying simpler and better for everyone.</p>

          <form id="ratingForm" asp-controller="Global" asp-action="SubmitApplicationRating" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ApplicationId" value="@ratingApplicationId" />
            <div class="star-rating" role="radiogroup" aria-label="Choose a rating from one to five stars">
              @for (var star = 5; star >= 1; star--)
              {
                <input type="radio" id="rating-@star" name="Rating" value="@star" required />
                <label for="rating-@star" title="@star star@(star == 1 ? "" : "s")"><i class="fa-solid fa-star" aria-hidden="true"></i><span class="visually-hidden">@star star@(star == 1 ? "" : "s")</span></label>
              }
            </div>
            <label class="rating-label" for="ratingComment">Tell us more <span style="font-weight:400;color:#8a8181;">(optional)</span></label>
            <textarea class="rating-textarea" id="ratingComment" name="Comment" maxlength="1000" placeholder="What worked well, or what could we improve?"></textarea>
            <div class="rating-meta"><span>Be as brief or detailed as you like.</span><span id="ratingCount">0 / 1000</span></div>
            <p class="rating-error" id="ratingError" role="alert"></p>
            <button class="btn btn-accent rating-submit" id="ratingSubmit" type="submit"><i class="fa fa-paper-plane"></i> Send feedback</button>
          </form>
        </div>
      </section>
    </div>
  }

<script>
(function(){
  const auto = @autoRedirect.ToString().ToLower();
  const seconds = @redirectSeconds;
  if(auto){
    const span = document.getElementById('redirectTimer');
    span.classList.add('show');
    let left = seconds;
    span.textContent = 'Redirecting in ' + left + 's';
    const iv = setInterval(()=>{
       left--;
       if(left <= 0){
          clearInterval(iv);
          span.textContent = 'Redirecting...';
          window.location = '@Url.Action("Index","Home")';
       } else {
          span.textContent = 'Redirecting in ' + left + 's';
       }
    },1000);
  }

  const overlay = document.getElementById('ratingOverlay');
  if(!overlay) return;

  const modal = overlay.querySelector('.rating-modal');
  const closeButton = document.getElementById('ratingClose');
  const openButton = document.getElementById('openRatingButton');
  const form = document.getElementById('ratingForm');
  const comment = document.getElementById('ratingComment');
  const count = document.getElementById('ratingCount');
  const error = document.getElementById('ratingError');
  const submit = document.getElementById('ratingSubmit');

  const open = ()=>{
    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden','false');
    document.getElementById('rating-5')?.focus();
  };

  const close = ()=>{
    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden','true');
    openButton?.focus();
  };

  window.setTimeout(open,350);

  openButton?.addEventListener('click', open);
  closeButton.addEventListener('click', close);
  overlay.addEventListener('click', event=>{ if(event.target === overlay) close(); });
  document.addEventListener('keydown', event=>{
    if(event.key === 'Escape' && overlay.classList.contains('is-open')) close();
  });
  modal.addEventListener('click', event=>event.stopPropagation());
  comment.addEventListener('input', ()=>{ count.textContent = comment.value.length + ' / 1000'; });

  form.addEventListener('submit', async event=>{
    event.preventDefault();
    error.classList.remove('is-visible');
    const selectedRating = form.querySelector('input[name="Rating"]:checked');
    if(!selectedRating){
      error.textContent = 'Please choose a star rating before sending your feedback.';
      error.classList.add('is-visible');
      return;
    }

    submit.disabled = true;
    submit.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Sending...';

    try{
      const response = await fetch(form.action, {
        method:'POST',
        body:new FormData(form),
        headers:{'X-Requested-With':'XMLHttpRequest'}
      });
      const result = await response.json().catch(()=>({}));
      if(!response.ok) throw new Error(result.message || 'We could not save your feedback right now.');

      document.getElementById('ratingFormContent').innerHTML =
        '<div class="rating-success"><i class="fa fa-star"></i><h2>Thank you!</h2><p>' +
        (result.message || 'Your feedback has been received.') + '</p></div>';
      closeButton.focus();
      window.setTimeout(close,2200);
    }catch(exception){
      error.textContent = exception.message;
      error.classList.add('is-visible');
      submit.disabled = false;
      submit.innerHTML = '<i class="fa fa-paper-plane"></i> Send feedback';
    }
  });
})();
</script>
</body>
</html>