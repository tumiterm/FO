@model IReadOnlyList<ForekOnline.Domain.ViewModels.NotificationEventSummaryViewModel>
@{
    ViewData["Title"] = "Notifications";
}

<h2 class="mb-3">Notifications</h2>

<div class="mb-2">
    <a asp-action="Create" class="btn btn-sm btn-primary">Create Notification</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No notifications found.</div>
}
else
{
    <form asp-action="Reorder" method="post" class="mb-3">
        @Html.AntiForgeryToken()
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                <tr>
                    <th>Order</th>
                    <th>Title</th>
                    <th>Active</th>
                    <th>Window</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                @foreach (var n in Model)
                {
                    <tr>
                        <td style="width:90px">
                            <input class="form-control form-control-sm" name="orderMap[@n.Id]" value="@n.DisplayOrder" />
                        </td>
                        <td>@n.Title</td>
                        <td>
                            @if (n.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td>
                            <small>@n.StartUtc.ToShortDateString() - @n.EndUtc.ToShortDateString()</small>
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@n.Id" class="btn btn-outline-info btn-sm">View</a>
                            <a asp-action="Edit" asp-route-id="@n.Id" class="btn btn-outline-primary btn-sm">Edit</a>

                            @if (n.IsActive)
                            {
                                <form asp-action="Deactivate" asp-route-id="@n.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-warning btn-sm">Deactivate</button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="Activate" asp-route-id="@n.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-success btn-sm">Activate</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <button type="submit" class="btn btn-sm btn-secondary">Apply Reorder</button>
    </form>

    <div class="row g-3">
        @foreach (var n in Model.OrderBy(m => m.DisplayOrder))
        {
            <div class="col-md-4">
                @await Html.PartialAsync("_SummaryCard", n)
            </div>
        }
    </div>
}

@section Scripts {
    <partial name="_ScriptsBlocks" />
}